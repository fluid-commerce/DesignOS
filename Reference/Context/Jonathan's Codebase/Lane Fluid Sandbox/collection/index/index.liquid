{% assign carousel_id = section.id | append: '-carousel-' | append: collection.handle | append: '-' | append: collection.id %}
<div class="container" id="dummy-container"></div>
{%- style -%}
  .product-collection-{{ section.id }} {
    padding-top: {{ section.settings.section_padding_top_mobile | default: 40 }}px;
    padding-bottom: {{ section.settings.section_padding_bottom_mobile | default: 40 }}px;
    background-color: {{ section.settings.background_color | default: 'transparent' }};
  }

  @media (min-width: 768px) {
    .product-collection-{{ section.id }} {
      padding-top: {{ section.settings.section_padding_top_desktop | default: 50 }}px;
      padding-bottom: {{ section.settings.section_padding_bottom_desktop | default: 50 }}px;
    }
  }
{%- endstyle -%}

{% for collection in collections %}
    <section class="product-collection-section section-t-spacing product-collection-{{ section.id }}">
      
        {% if section.settings.show_collection_title %}
            <div class="header-section">
                <div class="container">
                    <div class="wrapper flex flex-wrap align-end">
                        <div class="desc">
                            <div class="{{ section.settings.title_font_size | default: 'text-5xl' }} {{ section.settings.title_font_size_desktop | default: 'xl-tab-text-5xl' }} {{ section.settings.title_font_weight | default: 'font-bold' }}"
                                style="color: {{ section.settings.title_color | default: '#000000' }};">
                                {{ collection.title | default: 'Collection' }}
                            </div>
                        </div>
                        {% if section.settings.show_view_all_button %}
                            <div class="btn-section text-right hidden sm-desktop-block">
                            <a href="{{ collection.url }}" 
                                class="btn text-center {{ section.settings.button_style | default: 'btn-border-black' }}"
                                style="
                                background-color: {{ section.settings.button_background_color | default: 'transparent' }};
                                color: {{ section.settings.button_text_color | default: '#000000' }};
                                border-color: {{ section.settings.button_border_color | default: '#000000' }};
                                border-width: {{ section.settings.button_border_width | default: 1 }}px;
                                ">
                                {{ section.settings.view_all_button_text | default: 'View All' }}
                            </a>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
            <!-- .header-section -->
        {% endif %}
    
        <div class="product-list-section carousel-container mt-12">
            <div class="container">
                <div class="product-carousel {{ carousel_id }} splide" data-carousel-id="{{ carousel_id }}">
                    <div class="splide__track">
                        <ul class="splide__list">
                            {% for product in collection.products limit: section.settings.products_limit | default: 6 %}
                                <li class="splide__slide">
                                    <div class="carousel-product">
                                        <div class="image-section">
                                            {% if product.images.size > 0 %}
                                                <img
                                                src="{{ product.images[0].src }}"
                                                alt="{{ product.title }}"
                                                class="image-cover"
                                                />
                                            {% else %}
                                                <img
                                                src="{{ product.image | image_url }}"
                                                alt="{{ product.title }}"
                                                class="image-cover"
                                                />
                                            {% endif %}
                                        </div>
                                        <div class="desc pt-4">
                                            <div class="{{ section.settings.product_title_font_size | default: 'text-base' }} {{ section.settings.product_title_font_size_desktop | default: 'xl-tab-text-lg' }} {{ section.settings.product_title_font_weight | default: 'font-semibold' }}"
                                                style="color: {{ section.settings.product_title_color | default: '#000000' }};">
                                                {{ product.title }}
                                            </div>
                                            {% if section.settings.show_product_variant %}
                                                <p class="{{ section.settings.product_variant_font_size | default: 'text-sm' }} {{ section.settings.product_variant_font_size_desktop | default: 'xl-tab-text-sm' }} {{ section.settings.product_variant_font_weight | default: 'font-normal' }} pt-1"
                                                    style="color: {{ section.settings.product_variant_color | default: '#666666' }};">
                                                    Variant
                                                </p>
                                            {% endif %}
                                            {% unless section.settings.hide_price %}
                                                <div class="{{ section.settings.product_price_font_size | default: 'text-lg' }} {{ section.settings.product_price_font_size_desktop | default: 'xl-tab-text-xl' }} {{ section.settings.product_price_font_weight | default: 'font-bold' }} pt-2"
                                                    style="color: {{ section.settings.product_price_color | default: '#000000' }};">
                                                    {{ product.price }}
                                                </div>
                                            {% endunless %}
                                        </div>
                                    </div>
                                </li>
                            {% endfor %}
                        </ul>
                    </div>
    
                    {% if section.settings.show_carousel_arrows %}
                    <div class="splide__arrows splide-arrow-section mt-12">
                        <button class="slide-arrow splide__arrow splide__arrow--prev arrow-prev-btn"
                                style="
                                color: {{ section.settings.arrow_color | default: '#000000' }};
                                width: {{ section.settings.arrow_size | default: 48 }}px; 
                                height: {{ section.settings.arrow_size | default: 48 }}px;
                                ">
                            <svg
                                width="{{ section.settings.arrow_size | default: 24 }}"
                                height="{{ section.settings.arrow_size | default: 25 }}"
                                viewBox="0 0 24 25"
                                fill="none"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <path
                                d="M20 11.4004H7.83L13.42 5.81039L12 4.40039L4 12.4004L12 20.4004L13.41 18.9904L7.83 13.4004H20V11.4004Z"
                                fill="{{ section.settings.arrow_color | default: 'black' }}"
                                />
                            </svg>
                        </button>
                        <button class="slide-arrow splide__arrow splide__arrow--next arrow-next-btn"
                                style="
                                color: {{ section.settings.arrow_color | default: '#000000' }};
                                width: {{ section.settings.arrow_size | default: 48 }}px; 
                                height: {{ section.settings.arrow_size | default: 48 }}px;
                                ">
                            <svg
                                width="{{ section.settings.arrow_size | default: 24 }}"
                                height="{{ section.settings.arrow_size | default: 25 }}"
                                viewBox="0 0 24 25"
                                fill="none"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <path
                                d="M20 11.4004H7.83L13.42 5.81039L12 4.40039L4 12.4004L12 20.4004L13.41 18.9904L7.83 13.4004H20V11.4004Z"
                                fill="{{ section.settings.arrow_color | default: 'black' }}"
                                />
                            </svg>
                        </button>
                    </div>
                    {% endif %}
                </div>
            <!-- .product-carousel -->
            </div>
        </div>
        <!-- .carousel-section -->
    </section>
{% endfor %}
<script>
    document.addEventListener("DOMContentLoaded", () => {
      // Initialize all collection carousels on the page
      function initializeAllCollectionCarousels() {
        // Find all collection carousels
        const collectionCarousels = document.querySelectorAll('.product-carousel');
        
        collectionCarousels.forEach((carousel, index) => {
          // Get the carousel ID from the data attribute
          const carouselId = carousel.getAttribute('data-carousel-id');
          
          if (carouselId) {
            // Initialize this specific carousel using the carousel element directly
            const productCarousel = new Splide(carousel, {
              perPage: 1,
              perMove: 1,
              speed: 500,
              mediaQuery: "min",
              interval: 5000,
              padding: {
                right: "64px",
              },
              gap: "24px",
              breakpoints: {
                576: {
                  perPage: 2,
                },
                768: {
                  perPage: 3,
                },
                1200: {
                  gap: "48px",
                  padding: {
                    right: "80px",
                  },
                },
              },
            });
            productCarousel.mount();
          }
        });
      }

      // Set spacing for carousel containers
      function setCarouselContainerSpacing() {
        const dummyContainer = document.getElementById('dummy-container');
        if (!dummyContainer) {
          return;
        }

        const containerRect = dummyContainer.getBoundingClientRect();
        const paddingLeft = containerRect.left;
        
        $('.carousel-container').each(function() {
          $(this).css('padding-left', paddingLeft + 'px');
        });
      }
      
      // Initialize all carousels
      initializeAllCollectionCarousels();
      setCarouselContainerSpacing();

      // Handle window resize
      $(window).resize(function() {
        setCarouselContainerSpacing();
      });
    });
</script>

