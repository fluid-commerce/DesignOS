<!DOCTYPE html>
<html lang="en">

<body>
    <div class="container">
        <div class="header">
            <h1>💳 Payment Processor Calculator</h1>
            <p>Compare processing fees and acceptance rates over 1,000 transactions</p>
        </div>

        <div class="calculator">
            <div class="input-section">
                <div class="input-group">
                    <label for="aov">Average Order Value (AOV)</label>
                    <input type="number" id="aov" value="100" min="0" step="0.01">
                </div>
            </div>

            <div class="processor-section">
                <div class="processor">
                    <h3>Processor A</h3>
                    
                    <div class="slider-group">
                        <div class="slider-label">
                            <span>Processing Fee</span>
                            <span class="slider-value" id="feeA-display">2.90%</span>
                        </div>
                        <input type="range" id="feeA" min="0" max="10" step="0.05" value="2.9">
                    </div>

                    <div class="slider-group">
                        <div class="slider-label">
                            <span>Acceptance Rate</span>
                            <span class="slider-value" id="acceptanceA-display">90.00%</span>
                        </div>
                        <input type="range" id="acceptanceA" min="50" max="100" step="0.25" value="90">
                    </div>
                </div>

                <div class="processor">
                    <h3>Processor B</h3>
                    
                    <div class="slider-group">
                        <div class="slider-label">
                            <span>Processing Fee</span>
                            <span class="slider-value" id="feeB-display">2.90%</span>
                        </div>
                        <input type="range" id="feeB" min="0" max="10" step="0.05" value="2.9">
                    </div>

                    <div class="slider-group">
                        <div class="slider-label">
                            <span>Acceptance Rate</span>
                            <span class="slider-value" id="acceptanceB-display">90.00%</span>
                        </div>
                        <input type="range" id="acceptanceB" min="50" max="100" step="0.25" value="90">
                    </div>
                </div>
            </div>

            <div class="results">
                <h2>Results Over 1,000 Transactions</h2>
                <div class="results-grid">
                    <div class="result-card">
                        <h3>Processor A</h3>
                        <div class="result-item">
                            <div class="result-label">Total Revenue</div>
                            <div class="result-value" id="totalRevenueA">$0</div>
                            <div class="result-subtext" id="successfulTransA">0 successful transactions</div>
                        </div>
                        <div class="result-item">
                            <div class="result-label">Processing Fees</div>
                            <div class="result-value" id="processingFeesA">$0</div>
                        </div>
                        <div class="result-item">
                            <div class="result-label">Net Revenue</div>
                            <div class="result-value" id="netRevenueA">$0</div>
                        </div>
                    </div>

                    <div class="result-card">
                        <h3>Processor B</h3>
                        <div class="result-item">
                            <div class="result-label">Total Revenue</div>
                            <div class="result-value" id="totalRevenueB">$0</div>
                            <div class="result-subtext" id="successfulTransB">0 successful transactions</div>
                        </div>
                        <div class="result-item">
                            <div class="result-label">Processing Fees</div>
                            <div class="result-value" id="processingFeesB">$0</div>
                        </div>
                        <div class="result-item">
                            <div class="result-label">Net Revenue</div>
                            <div class="result-value" id="netRevenueB">$0</div>
                        </div>
                    </div>
                </div>

                <div class="comparison" id="comparison">
                    <h3>Comparison</h3>
                    <p id="comparisonText">Adjust the values to see the comparison.</p>
                </div>
            </div>
        </div>
    </div>

    <script>
        function formatCurrency(value) {
            return new Intl.NumberFormat('en-US', {
                style: 'currency',
                currency: 'USD',
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            }).format(value);
        }

        function formatNumber(value) {
            return new Intl.NumberFormat('en-US', {
                minimumFractionDigits: 0,
                maximumFractionDigits: 0
            }).format(value);
        }

        function calculate() {
            const aov = parseFloat(document.getElementById('aov').value) || 0;
            const feeA = parseFloat(document.getElementById('feeA').value);
            const acceptanceA = parseFloat(document.getElementById('acceptanceA').value);
            const feeB = parseFloat(document.getElementById('feeB').value);
            const acceptanceB = parseFloat(document.getElementById('acceptanceB').value);

            const transactions = 1000;

            // Processor A calculations
            const successfulTransA = transactions * (acceptanceA / 100);
            const totalRevenueA = aov * successfulTransA;
            const processingFeesA = totalRevenueA * (feeA / 100);
            const netRevenueA = totalRevenueA - processingFeesA;

            // Processor B calculations
            const successfulTransB = transactions * (acceptanceB / 100);
            const totalRevenueB = aov * successfulTransB;
            const processingFeesB = totalRevenueB * (feeB / 100);
            const netRevenueB = totalRevenueB - processingFeesB;

            // Update displays
            document.getElementById('totalRevenueA').textContent = formatCurrency(totalRevenueA);
            document.getElementById('processingFeesA').textContent = formatCurrency(processingFeesA);
            document.getElementById('netRevenueA').textContent = formatCurrency(netRevenueA);
            document.getElementById('successfulTransA').textContent = `${formatNumber(successfulTransA)} successful transactions`;

            document.getElementById('totalRevenueB').textContent = formatCurrency(totalRevenueB);
            document.getElementById('processingFeesB').textContent = formatCurrency(processingFeesB);
            document.getElementById('netRevenueB').textContent = formatCurrency(netRevenueB);
            document.getElementById('successfulTransB').textContent = `${formatNumber(successfulTransB)} successful transactions`;

            // Comparison
            const difference = netRevenueB - netRevenueA;
            const comparisonDiv = document.getElementById('comparison');
            const comparisonText = document.getElementById('comparisonText');

            if (Math.abs(difference) < 0.01) {
                comparisonDiv.className = 'comparison';
                comparisonText.innerHTML = `Both processors deliver <span class="comparison-stat">equal net revenue</span> of ${formatCurrency(netRevenueA)}.`;
            } else if (difference > 0) {
                comparisonDiv.className = 'comparison better-b';
                const percentDiff = ((difference / netRevenueA) * 100).toFixed(2);
                comparisonText.innerHTML = `<strong>Processor B performs better!</strong><br>Net revenue is <span class="comparison-stat">${formatCurrency(difference)}</span> higher (${percentDiff}% increase) compared to Processor A.`;
            } else {
                comparisonDiv.className = 'comparison';
                const percentDiff = ((Math.abs(difference) / netRevenueB) * 100).toFixed(2);
                comparisonText.innerHTML = `<strong>Processor A performs better!</strong><br>Net revenue is <span class="comparison-stat">${formatCurrency(Math.abs(difference))}</span> higher (${percentDiff}% increase) compared to Processor B.`;
            }
        }

        // Event listeners for all inputs
        document.getElementById('aov').addEventListener('input', calculate);

        document.getElementById('feeA').addEventListener('input', function() {
            document.getElementById('feeA-display').textContent = this.value + '%';
            calculate();
        });

        document.getElementById('acceptanceA').addEventListener('input', function() {
            document.getElementById('acceptanceA-display').textContent = this.value + '%';
            calculate();
        });

        document.getElementById('feeB').addEventListener('input', function() {
            document.getElementById('feeB-display').textContent = this.value + '%';
            calculate();
        });

        document.getElementById('acceptanceB').addEventListener('input', function() {
            document.getElementById('acceptanceB-display').textContent = this.value + '%';
            calculate();
        });

        // Initial calculation
        calculate();
    </script>
</body>
</html>
