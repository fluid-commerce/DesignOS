          "id": "cmo_faq_1",
          "type": "faq_item",
          "name": "faq_item",
          "settings": {
            "question": "How do I maintain brand control when reps can customize content?",
            "answer": "Reps can add their personal story, photo, and testimonial to the top of any asset—but everything else stays locked. They can't change your messaging, modify your design, or alter your brand guidelines. They get the personalization that builds trust without the ability to break your brand. You maintain control while giving them ownership."
          }
        },
        "cmo_faq_2": {
          "id": "cmo_faq_2",
          "type": "faq_item",
          "name": "faq_item",
          "settings": {
            "question": "What if reps just keep using their own materials anyway?",
            "answer": "Reps use workarounds because corporate tools fail them—either the content doesn't convert, or they don't get credit for sharing. Fix both problems and reps naturally migrate to corporate materials. We-Commerce makes content easy to share and guarantees attribution. When your tools work better than their bootleg versions, they switch. Usually within weeks."
          }
        },
        "cmo_faq_3": {
          "id": "cmo_faq_3",
          "type": "faq_item",
          "name": "faq_item",
          "settings": {
            "question": "How granular is the content performance data?",
