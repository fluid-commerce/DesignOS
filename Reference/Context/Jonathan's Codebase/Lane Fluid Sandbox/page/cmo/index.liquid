        "cmo_faq_5": {
          "id": "cmo_faq_5",
          "type": "faq_item",
          "name": "faq_item",
          "settings": {
            "question": "How does this integrate with our existing marketing stack?",
            "answer": "We-Commerce becomes your distribution and attribution layer—connecting your content creation tools to your revenue data. Export performance data to your analytics platform. Pull conversion metrics into your reporting dashboards. The question isn't whether it integrates—it's whether your current stack can handle finally having clear attribution data."
          }
        }
