{% schema %}
{
  "sections": {
    "main_page": {
      "type": "main_page",
      "settings": {
        "heading": "You've done everything right. They trust you. They want your product. Then they hit checkout and... gone.",
        "description": "70% of ready-to-buy customers abandon their carts at checkout. Not because they changed their minds—because your checkout process killed the sale. Quick Checkout fixes that."
      }
    },
    "checkout_hero": {
      "type": "content_hero",
      "settings": {
        "show_cta_button": false,
        "cta_button_text": "Fix Your Checkout Now",
        "cta_button_new_tab": false,
        "cta_button_style": "btn-filled",
        "cta_button_color": "btn-black",
        "cta_button_size": "btn-md",
        "cta_button_border_radius": "rounded-lg",
        "cta_margin_top": "mt-2xl",
        "background_color": "bg-neutral",
        "section_padding_y_mobile": "py-xl",
        "section_padding_y_desktop": "lg:py-3xl",
        "section_border_radius": "rounded-none",
        "layout_reverse": false,
        "tag_font_family": "font-handwritten",
        "tag_text_color": "text-black",
        "tag_font_size": "text-sm",
        "tag_font_weight": "font-medium",
        "tag_margin_bottom": "mb-lg",
        "show_tag": true,
        "tag_text": "Stop Losing Sales at the Finish Line",
        "content_heading": "70% of Your Ready-to-Buy Customers Are Walking Away at Checkout",
        "content_description": "You've done everything right. Your rep educated them. They trust you. They want your product. Then they hit your checkout and... gone. Account creation, password requirements, forms that don't work on mobile. This is where good prospects become lost sales. Quick Checkout eliminates every barrier between 'I want this' and 'Purchase complete.'",
        "image_alt": "",
        "heading_font_family": "font-primary",
        "heading_font_size": "text-3xl",
        "heading_font_size_desktop": "lg:text-6xl",
        "heading_font_weight": "font-bold",
        "heading_line_height": "leading-tight",
        "heading_text_color": "",
        "heading_margin_bottom": "mb-2xl",
        "description_font_family": "font-primary",
        "description_font_size": "text-base",
        "description_font_size_desktop": "lg:text-xl",
        "description_line_height": "leading-relaxed",
        "description_text_color": "",
        "description_margin_bottom": "mb-xs",
        "hero_image": "https://ik.imagekit.io/fluid/980191006/images/L53PNR/quick-checkout-hero_TQrl7GTFO.webp"
