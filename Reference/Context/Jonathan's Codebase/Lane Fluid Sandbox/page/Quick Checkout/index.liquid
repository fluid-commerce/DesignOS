        "section_padding_y_desktop": "lg:py-3xl",
        "section_border_radius": "rounded-none",
        "layout_reverse": false,
        "section_background_color": "bg-primary",
        "section_padding": "py-2xl",
        "heading_font_family": "font-primary",
        "heading_font_size": "text-4xl",
        "heading_font_size_desktop": "lg:text-5xl",
        "heading_font_weight": "font-black",
        "heading_color": "text-white",
        "description_font_family": "font-body",
        "description_font_size": "text-base",
        "description_font_size_desktop": "lg:text-lg",
        "description_font_weight": "font-normal",
