          }
        },
        "checkout_feature_2": {
          "id": "checkout_feature_2",
          "type": "feature_item",
          "name": "feature_item",
          "settings": {
            "show_icon": true,
            "title": "No Account Required",
            "description": "Customers don't need to create accounts, remember passwords, or verify email addresses. They just buy and go. Registration can happen after purchase if they want it—not before.",
