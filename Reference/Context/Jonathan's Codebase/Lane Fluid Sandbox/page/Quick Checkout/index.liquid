        "tag_font_size": "text-sm",
        "tag_font_weight": "font-medium",
        "tag_margin_bottom": "mb-lg",
        "hero_image": "https://ik.imagekit.io/fluid/980191006/images/4R33QY/quick-pay-detail_tO53xPx70.webp"
      }
    },
    "checkout_benefit_2": {
      "type": "content_hero",
      "settings": {
        "background_color": "bg-neutral",
        "section_padding_y_mobile": "py-xl",
        "section_padding_y_desktop": "lg:py-3xl",
        "section_border_radius": "rounded-none",
        "layout_reverse": true,
        "show_tag": true,
        "tag_text": "Mobile-First Reality",
        "content_heading": "Most of Your Sales Happen on Phones—Your Checkout Better Work There",
        "content_description": "Over 80% of social media sharing happens on mobile. When your reps share content and someone clicks through, they're probably on their phone. If your checkout doesn't work perfectly on mobile—if buttons are too small, forms don't auto-fill, or pages load slowly—you've just lost a sale. Quick Checkout is mobile-first. Touch targets sized for thumbs. Auto-complete that actually works. Apple Pay and Google Pay built in. Loading times under 2 seconds. Because when someone's ready to buy on their phone, you better be ready to sell.",
        "image_alt": "",
        "container_background_color": "",
        "container_border_radius": "rounded-none",
        "container_padding_y_mobile": "py-xl",
        "container_padding_y_desktop": "lg:py-3xl",
        "container_padding_x_mobile": "px-lg",
        "container_padding_x_desktop": "lg:px-xl",
        "hero_image": "https://ik.imagekit.io/fluid/980191006/images/6NLKNZ/mobile-checkout_EKzPZ8PE1.webp"
      }
    },
    "checkout_benefit_3": {
      "type": "content_hero",
      "settings": {
        "layout_reverse": false,
        "background_color": "bg-neutral",
        "section_padding_y_mobile": "py-xl",
        "section_padding_y_desktop": "lg:py-3xl",
        "section_border_radius": "rounded-none",
        "show_tag": true,
        "tag_text": "Global Payment Intelligence",
        "content_heading": "Every Payment Method, Every Currency, Every Market",
        "content_description": "Your customers are global. Your payment system should be too. Quick Checkout automatically detects where someone is shopping from and shows them the payment methods they actually use. Credit cards in the US. SEPA transfers in Germany. PIX payments in Brazil. Alipay in China. WeChat Pay in Hong Kong. Buy Now Pay Later everywhere it makes sense. One checkout system that works for everyone, everywhere, with every payment method that matters.",
        "image_alt": "",
        "container_background_color": "",
        "container_border_radius": "rounded-none",
        "container_padding_y_mobile": "py-xl",
        "container_padding_y_desktop": "lg:py-3xl",
        "container_padding_x_mobile": "px-lg",
        "container_padding_x_desktop": "lg:px-xl",
        "hero_image": "https://ik.imagekit.io/fluid/980191006/images/92WA6Z/any-currency_E6Kv6fu4g.webp"
      }
    },
    "checkout_stats": {
      "type": "steps_process",
      "settings": {
        "background_color": "bg-black",
        "section_padding_y_mobile": "py-xl",
        "section_padding_y_desktop": "lg:py-3xl",
        "section_border_radius": "rounded-none",
        "layout_reverse": false,
        "show_header": true,
        "main_heading": "The Numbers Don't Lie About Checkout Psychology",
        "description": "Companies using Quick Checkout see immediate improvements in conversion rates, average order values, and customer satisfaction. Here's what happens when you stop losing sales at the finish line.",
        "show_cta": true,
        "cta_text": "Optimize Your Checkout",
        "cta_open_new_tab": false
      },
      "blocks": {
        "checkout_stat_1": {
          "id": "checkout_stat_1",
          "type": "step_item",
          "name": "step_item",
          "settings": {
            "step_number": "94%",
            "step_title": "Checkout Completion Rate",
            "step_description": "Quick Checkout converts 94% of people who start the purchase process, compared to 30% for traditional multi-step checkouts that require account creation."
          }
        },
        "checkout_stat_2": {
          "id": "checkout_stat_2",
          "type": "step_item",
          "name": "step_item",
          "settings": {
            "step_number": "65%",
            "step_title": "Mobile Conversion Boost",
            "step_description": "Mobile purchases increase 65% when checkout is optimized for phones instead of desktop. Touch-friendly buttons and one-tap payments eliminate mobile friction."
          }
        },
        "checkout_stat_3": {
          "id": "checkout_stat_3",
          "type": "step_item",
          "name": "step_item",
          "settings": {
            "step_number": "40%",
            "step_title": "Faster Purchase Decision",
            "step_description": "Customers complete purchases 40% faster when they can use saved payment methods, reducing the time for doubt and second-guessing to interfere with buying decisions."
          }
        }
      }
    },
    "checkout_faq": {
      "type": "faq_section",
      "settings": {
        "background_color": "bg-neutral"
      },
      "blocks": {
        "checkout_faq_1": {
          "id": "checkout_faq_1",
          "type": "faq_item",
          "name": "faq_item",
          "settings": {
            "question": "How do you handle security without account creation?",
            "answer": "We use tokenization, encryption, and PCI compliance to protect payment data without forcing customers to create accounts. Payment information is securely processed and stored, but customers can complete purchases as guests. They can create accounts after purchase if they want order tracking or repeat purchase convenience—but it's optional, not required."
          }
        },
        "checkout_faq_2": {
          "id": "checkout_faq_2",
          "type": "faq_item",
          "name": "faq_item",
          "settings": {
            "question": "What if customers want to track their orders without accounts?",
            "answer": "We provide order tracking via email and SMS without requiring account creation. Customers get a tracking link sent directly to their phone or email. They can check status, view shipping updates, and contact support—all without passwords or logins. Simple, secure, and friction-free."
          }
        },
        "checkout_faq_3": {
          "id": "checkout_faq_3",
          "type": "faq_item",
          "name": "faq_item",
          "settings": {
            "question": "Can we customize the checkout flow for our brand?",
            "answer": "Quick Checkout maintains the essential psychology while allowing brand customization. You can adjust colors, logos, and messaging, but we won't let you add friction that kills conversions. The core flow stays optimized for completion rates—that's non-negotiable. Beautiful branding, but conversion-optimized structure."
          }
        },
        "checkout_faq_4": {
          "id": "checkout_faq_4",
          "type": "faq_item",
          "name": "faq_item",
          "settings": {
            "question": "How does rep attribution work at checkout?",
            "answer": "Attribution is handled automatically through FairShare™ tracking. When someone clicks a rep's link and completes a purchase (even weeks later), the rep gets instant credit. The customer never sees attribution codes or confusing rep information—they just see a clean, fast checkout. The tracking happens behind the scenes."
          }
        },
        "checkout_faq_5": {
          "id": "checkout_faq_5",
          "type": "faq_item",
          "name": "faq_item",
          "settings": {
            "question": "What happens if our current checkout is already pretty good?",
            "answer": "If your checkout converts over 90% of people who start it and works perfectly on mobile, you might be fine. But most 'pretty good' checkouts still lose 60-70% of ready buyers to friction. The only way to know is to measure completion rates, not just how it looks. Pretty doesn't always mean functional—especially on mobile."
          }
        }
      }
    },
    "checkout_cta": {
      "type": "cta_simple",
      "settings": {
        "show_heading": true,
        "heading": "Ready to stop losing sales at checkout?",
        "heading_font_family": "font-primary",
        "heading_font_size": "text-4xl",
