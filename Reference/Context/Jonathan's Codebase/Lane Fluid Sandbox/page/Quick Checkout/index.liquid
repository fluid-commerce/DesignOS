            "show_icon": true,
            "title": "Mobile Optimized",
            "description": "Perfect on every screen size. Forms that work with auto-fill. Buttons sized for thumbs. Loading times under 2 seconds. Mobile isn't an afterthought—it's the primary experience.",
            "icon_image": "https://ik.imagekit.io/fluid/980191006/images/8TC3K4/mobile-icon_734qmjjTl.png"
          }
        },
        "checkout_feature_4": {
          "id": "checkout_feature_4",
          "type": "feature_item",
          "name": "feature_item",
          "settings": {
            "show_icon": true,
            "title": "Instant Attribution",
            "description": "The moment someone completes their purchase, the rep who guided them gets instant confirmation and credit through FairShare™. Trust builds. Sharing increases. Everyone wins.",
            "icon_image": "https://ik.imagekit.io/fluid/980191006/images/WMGFD5/attribution-icon_bMH4JsYke.png"
          }
        }
      }
    },
    "checkout_benefit_1": {
      "type": "content_hero",
      "settings": {
        "show_tag": true,
        "tag_text": "The Psychology of Purchase",
        "content_heading": "When Someone Says 'Yes,' Don't Make Them Say 'Maybe'",
        "content_description": "Here's what happens in someone's brain when they decide to buy: dopamine spikes, decision fatigue kicks in, and they want immediate gratification. Every extra step, every form field, every loading screen gives doubt time to creep in. Traditional checkouts kill that buying momentum with account creation, password requirements, and multi-step processes. Quick Checkout preserves the psychological moment by removing everything except payment. When someone's ready to buy, we let them buy.",
        "image_alt": "",
        "layout_reverse": false,
        "heading": "Stop losing sales at the finish line",
        "description": "When buying momentum peaks, friction kills sales.",
        "background_color": "bg-neutral",
        "section_padding_y_mobile": "py-xl",
        "section_padding_y_desktop": "lg:py-3xl",
        "section_border_radius": "rounded-none",
        "container_background_color": "",
        "container_border_radius": "rounded-none",
        "container_padding_y_mobile": "py-xl",
        "container_padding_y_desktop": "lg:py-3xl",
        "container_padding_x_mobile": "px-lg",
        "container_padding_x_desktop": "lg:px-xl",
