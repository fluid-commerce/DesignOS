      "blocks": {
        "fairshare_faq_1": {
          "id": "fairshare_faq_1",
          "type": "faq_item",
          "name": "faq_item",
          "settings": {
            "question": "Can we use FairShare™ with our existing website and checkout?",
            "answer": "No, and here's why that matters. FairShare™ works by tracking the entire customer journey from first click through final purchase. Break that chain anywhere—use a different checkout, send people to an external site, add steps that aren't tracked—and attribution breaks. We've seen companies try to bolt attribution onto existing systems. It always fails because the data flow gets interrupted. We'd rather say no than help you build an expensive failure."
          }
        },
        "fairshare_faq_2": {
          "id": "fairshare_faq_2",
          "type": "faq_item",
          "name": "faq_item",
          "settings": {
            "question": "What if someone clicks multiple reps' links before purchasing?",
            "answer": "You decide the rules. Want first-touch attribution? Last-touch? Time-weighted? Split credit? You set the logic that matches your compensation plan, and FairShare™ executes it perfectly every time. The key is that rules are transparent—reps understand how attribution works in complex scenarios, which builds trust even when they don't get 100% credit."
          }
        },
        "fairshare_faq_3": {
          "id": "fairshare_faq_3",
          "type": "faq_item",
          "name": "faq_item",
          "settings": {
            "question": "How long does attribution tracking last?",
            "answer": "Forever, technically. If someone clicks Sarah's link today and buys six months from now through a Google search, Sarah gets credit. We don't rely on cookies that expire or tracking that breaks. The connection between rep and prospect is permanent unless you explicitly set rules otherwise. That's what builds trust—reps know their effort today creates value indefinitely."
          }
        },
        "fairshare_faq_4": {
          "id": "fairshare_faq_4",
          "type": "faq_item",
          "name": "faq_item",
          "settings": {
            "question": "What happens with orphan signups or direct traffic?",
            "answer": "You define the rules. Some companies attribute orphans to whoever last shared with that email address. Others use geographic assignment. Some create a house account. The system is flexible—you set the logic based on your business model and compensation structure. Whatever rules you choose, FairShare™ executes them consistently and transparently."
          }
        },
        "fairshare_faq_5": {
          "id": "fairshare_faq_5",
          "type": "faq_item",
          "name": "faq_item",
          "settings": {
            "question": "How do reps know attribution is working?",
            "answer": "Instant notifications and complete transparency. Every time someone clicks their link, reps can see it. When that person purchases, they get immediate confirmation with full details. They can also view their attribution history—every click, every conversion, every credit assigned. Transparency builds trust. Trust drives sharing. Sharing creates growth."
          }
        }
