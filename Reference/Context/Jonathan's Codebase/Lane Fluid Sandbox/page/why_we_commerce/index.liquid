{% section 'fw_hero', id: 'why_hero' %}
{% section 'fw_comparison_table', id: 'comparison' %}
{% section 'fw_narrative_story', id: 'human_stakes' %}
{% section 'fw_split_content', id: 'authenticity' %}
{% section 'fw_timeline', id: 'flywheel' %}
{% section 'fw_cta_block', id: 'why_closing' %}

{% schema %}
{
  "name": "Why We-Commerce",
  "sections": {
    "main_page": {
      "type": "main_page",
      "settings": {
        "heading": "Why We-Commerce Exists",
        "description": "Most e-commerce platforms were built for ads and anonymous checkout. We-Commerce was built for people."
      }
    },
    "why_hero": {
      "type": "fw_hero",
      "settings": {
        "show_marquee": true,
        "marquee_text": "EVERY TRANSACTION MATTERS",
        "eyebrow": "Why We-Commerce Exists",
        "headline": "Most e-commerce platforms were built for ads and anonymous checkout. We-Commerce was built for people.",
        "description": "They assume customers arrive alone, click alone, and buy alone. We built something different — for sharing products you believe in, recommending them to friends, and celebrating purchases together.",
        "background_color": "bg-black"
      }
    },
    "comparison": {
      "type": "fw_comparison_table",
      "settings": {
        "headline": "The conventional wisdom is wrong.",
        "body": "<p>Everyone tells direct selling companies to use Shopify. Or Stripe. Or Square. \"That's what real e-commerce companies use,\" they say.</p><p>But here's the thing: you're not a real e-commerce company. You're something different. Something those platforms weren't built for. And pretending otherwise is costing you more than you realize.</p><p><strong>Shopify optimized for traffic. We-Commerce optimized for relationships.</strong></p>",
        "competitor_header": "Shopify",
        "fluid_header": "Fluid",
        "table_note": "Shopify is great for guest checkout. That's about 15-25% of direct selling revenue. We handle the rest.",
        "background_color": "bg-black"
      },
      "blocks": {
        "row_1": {
          "id": "row_1",
          "type": "comparison_row",
          "name": "Comparison Row",
          "settings": {
            "feature_name": "Rep attribution & credit",
            "competitor_value": "—",
            "fluid_value": "✓",
            "fluid_is_positive": true
          }
        },
        "row_2": {
          "id": "row_2",
          "type": "comparison_row",
          "name": "Comparison Row",
          "settings": {
            "feature_name": "Multi-level subscriptions",
            "competitor_value": "—",
            "fluid_value": "✓",
            "fluid_is_positive": true
          }
        },
        "row_3": {
          "id": "row_3",
          "type": "comparison_row",
          "name": "Comparison Row",
          "settings": {
            "feature_name": "Commission engine sync",
            "competitor_value": "—",
            "fluid_value": "✓",
            "fluid_is_positive": true
          }
        },
        "row_4": {
          "id": "row_4",
          "type": "comparison_row",
          "name": "Comparison Row",
          "settings": {
            "feature_name": "Logged-in rep purchasing",
            "competitor_value": "Partial",
            "fluid_value": "✓",
            "fluid_is_positive": true
          }
        },
        "row_5": {
          "id": "row_5",
          "type": "comparison_row",
          "name": "Comparison Row",
          "settings": {
            "feature_name": "Cascading payment retry",
            "competitor_value": "—",
            "fluid_value": "✓",
            "fluid_is_positive": true
          }
        },
        "row_6": {
          "id": "row_6",
          "type": "comparison_row",
          "name": "Comparison Row",
          "settings": {
            "feature_name": "Single global storefront",
            "competitor_value": "Separate stores",
            "fluid_value": "✓",
            "fluid_is_positive": true
          }
        },
        "row_7": {
          "id": "row_7",
          "type": "comparison_row",
          "name": "Comparison Row",
          "settings": {
            "feature_name": "Mobile app (no-code)",
            "competitor_value": "—",
            "fluid_value": "✓",
            "fluid_is_positive": true
          }
        }
      }
    },
    "human_stakes": {
      "type": "fw_narrative_story",
      "settings": {
        "eyebrow": "Why every transaction matters",
        "closing_statement": "Shopify doesn't think about her. Stripe doesn't know she exists. <strong>We built every feature of this platform with her in mind.</strong>",
        "background_color": "bg-black"
      },
      "blocks": {
        "story_1": {
          "id": "story_1",
          "type": "story_block",
          "name": "Story Block",
          "settings": {
            "story_heading": "We think about the mom who placed her first order at 11:47pm while nursing her baby.",
            "story_body": "<p>She's finally ready to try the products her sister won't stop talking about. If that transaction fails — if the page times out, or her card declines, or she can't figure out who to contact — she's not coming back. And her sister, your rep, just lost the person who might have become her best customer.</p><p>That's not a 2% decline rate. That's a dream that died in checkout.</p>",
            "show_divider": true
          }
        },
        "story_2": {
          "id": "story_2",
          "type": "story_block",
          "name": "Story Block",
          "settings": {
            "story_heading": "We think about the rep who's a mom of four.",
            "story_body": "<p>Her husband works long hours. She started this business for flexibility and extra income. Every commission check matters. When a transaction fails — or when she doesn't get credit for a sale she drove — that's not a rounding error.</p><p>That's groceries. That's her daughter's dance lessons. That's her belief that this business can work for her.</p>",
            "show_divider": false
          }
        }
      }
    },
    "authenticity": {
      "type": "fw_split_content",
      "settings": {
        "eyebrow": "The Authenticity Advantage",
        "headline": "The internet is drowning in AI-generated reviews, bot followers, and synthetic content.",
        "body": "<p>Consumers are exhausted. They can't tell what's real anymore. Trust in digital commerce is collapsing. But there's one thing they still trust: recommendations from people they actually know.</p><p>That's not nostalgia. That's the future of commerce.</p><p><strong>Direct sales isn't old-fashioned. It's ahead of its time.</strong> While everyone else is trying to figure out how to make AI feel human, you've already got real humans building real relationships.</p><p>We built Fluid to power that — and to give it modern infrastructure so it can scale.</p>",
        "background_color": "bg-black"
      }
    },
    "flywheel": {
      "type": "fw_timeline",
      "settings": {
        "eyebrow": "How it all works together",
        "headline": "Content fuels sharing. Sharing fuels traffic. Traffic fuels conversions. Conversions create new content.",
        "footer_note": "THE FLYWHEEL SPINS FASTER EVERY TIME.",
        "background_color": "bg-black"
      },
      "blocks": {
        "step_1": {
          "id": "step_1",
          "type": "step",
          "name": "Step",
          "settings": {
            "step_label": "01",
            "step_title": "Content",
            "step_body": "Reps share branded content, personal stories, and product experiences with their networks.",
            "step_highlight": false
          }
        },
        "step_2": {
          "id": "step_2",
          "type": "step",
          "name": "Step",
          "settings": {
            "step_label": "02",
            "step_title": "Sharing",
            "step_body": "FairShare™ tracks every touchpoint so reps always get credit for the traffic they drive.",
            "step_highlight": false
          }
        },
        "step_3": {
          "id": "step_3",
          "type": "step",
          "name": "Step",
          "settings": {
            "step_label": "03",
            "step_title": "Conversion",
            "step_body": "Visitors land on personalized storefronts built for trust — and convert at rates Shopify can't touch.",
            "step_highlight": false
          }
        },
        "step_4": {
          "id": "step_4",
          "type": "step",
          "name": "Step",
          "settings": {
            "step_label": "04",
            "step_label_color": "text-success",
            "step_title": "New Content ↩",
            "step_body": "Every purchase creates new stories, testimonials, and social proof — feeding the cycle again.",
            "step_highlight": true,
            "step_border_color": "success"
          }
        }
      }
    },
    "why_closing": {
      "type": "fw_cta_block",
      "settings": {
        "headline": "Just people, selling to people — with a system that finally reflects how commerce actually works.",
        "body": "<p>This is why We-Commerce exists. This is why we built Fluid. And this is why every transaction matters.</p>",
        "show_button_one": true,
        "button_one_text": "See the Platform",
        "button_one_style": "filled",
        "button_one_color": "white",
        "button_one_size": "btn-lg",
        "button_one_font_weight": "font-medium",
        "show_button_two": true,
        "button_two_text": "Book a Demo",
        "button_two_style": "outline",
        "button_two_color": "white",
        "button_two_size": "btn-lg",
        "button_two_font_weight": "font-medium",
        "text_alignment": "text-center",
        "background_color": "bg-black"
      }
    }
  }
}
{% endschema %}
