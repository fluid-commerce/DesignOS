<div class="flex flex-col">
{% section 'fw_hero', id: 'bw_hero' %}
{% section 'fw_timeline', id: 'bw_schedule' %}
{% section 'fw_split_content', id: 'bw_pricing' %}
</div>

{% schema %}
{
  "name": "Blitz Week",
  "sections": {
    "bw_hero": {
      "type": "fw_hero",
      "settings": {
        "eyebrow": "Blitz Week — Your Fast Track to Launch",
        "eyebrow_font_family": "font-handwritten",
        "eyebrow_font_size": "text-lg",
        "eyebrow_font_size_desktop": "lg:text-2xl",
        "eyebrow_font_weight": "font-normal",
        "eyebrow_color": "text-info",
        "headline": "Traditional platforms take 90 days. We've launched in an afternoon.",
        "headline_font_family": "font-primary",
        "headline_font_size": "text-3xl",
        "headline_font_size_desktop": "lg:text-6xl",
        "headline_font_weight": "font-bold",
        "headline_color": "text-white",
        "description": "Most platform migrations are measured in quarters. Yours will be measured in days. Blitz Week is four days, side-by-side with our best engineers and strategists, making real-time decisions and launching your platform before the week is over. No endless discovery phases. No 47-slide project plans. Just decisions, execution, and a live platform.",
        "description_font_family": "font-body",
        "description_font_size": "text-base",
        "description_font_size_desktop": "lg:text-lg",
        "description_font_weight": "font-normal",
        "description_color": "text-neutral",
        "show_button_one": true,
        "button_one_text": "Schedule Blitz Week",
        "button_one_style": "filled",
        "button_one_color": "white",
        "button_one_size": "btn-lg",
        "button_one_font_weight": "font-medium",
        "show_button_two": false,
        "show_scroll_indicator": true,
        "show_marquee": false,
        "show_ghost_text": false,
        "show_paint_stroke": false,
        "background_color": "bg-black",
        "section_padding_y_mobile": "py-xl",
        "section_padding_y_desktop": "lg:py-3xl",
        "section_border_radius": "rounded-none",
        "container_background_color": "bg-transparent",
        "container_border_radius": "rounded-none",
        "container_padding_y_mobile": "py-md",
        "container_padding_y_desktop": "lg:py-xl",
        "container_padding_x_mobile": "px-lg",
        "container_padding_x_desktop": "lg:px-3xl"
      }
    },
    "bw_schedule": {
      "type": "fw_timeline",
      "settings": {
        "eyebrow": "How It Works — Monday through Thursday",
        "eyebrow_font_family": "font-handwritten",
        "eyebrow_font_size": "text-lg",
        "eyebrow_font_size_desktop": "lg:text-xl",
        "eyebrow_font_weight": "font-normal",
        "eyebrow_color": "text-info",
        "headline": "Four days. Side-by-side with our best people. Decisions made in real time. Platform live on Thursday.",
        "headline_font_family": "font-primary",
        "headline_font_size": "text-2xl",
        "headline_font_size_desktop": "lg:text-4xl",
        "headline_font_weight": "font-bold",
        "headline_color": "text-white",
        "footer_note": "9:30 AM – 3:00 PM DAILY · LUNCH PROVIDED · LEHI, UTAH",
        "footer_note_font_family": "font-body",
        "footer_note_font_size": "text-xs",
        "footer_note_font_size_desktop": "lg:text-sm",
        "footer_note_font_weight": "font-medium",
        "footer_note_color": "text-neutral",
        "show_accent_bar": true,
        "background_color": "bg-black",
        "section_padding_y_mobile": "py-xl",
        "section_padding_y_desktop": "lg:py-3xl",
        "section_border_radius": "rounded-none",
        "container_background_color": "bg-transparent",
        "container_border_radius": "rounded-none",
        "container_padding_y_mobile": "py-md",
        "container_padding_y_desktop": "lg:py-lg",
        "container_padding_x_mobile": "px-md",
        "container_padding_x_desktop": "lg:px-xl"
      },
      "blocks": {
        "bw_step_mon": {
          "id": "bw_step_mon",
          "type": "step",
          "settings": {
            "step_label": "MON",
            "step_label_color": "text-neutral-dark",
            "step_title": "Platform Setup & Payments",
            "step_title_font_family": "font-primary",
            "step_title_font_size": "text-base",
            "step_title_font_size_desktop": "lg:text-lg",
            "step_title_font_weight": "font-bold",
            "step_title_color": "text-white",
            "step_body": "Commission engine connection, payment processor setup, Fair Share configuration, compliance review. Your foundation, built right.",
            "step_body_font_family": "font-body",
            "step_body_font_size": "text-xs",
            "step_body_font_size_desktop": "lg:text-sm",
            "step_body_font_weight": "font-normal",
            "step_body_color": "text-neutral",
            "step_highlight": false,
            "step_border_color": "neutral-dark"
          }
        },
        "bw_step_tue": {
          "id": "bw_step_tue",
          "type": "step",
          "settings": {
            "step_label": "TUE",
            "step_label_color": "text-neutral-dark",
            "step_title": "Mobile App & Rep Experience",
            "step_title_font_family": "font-primary",
            "step_title_font_size": "text-base",
            "step_title_font_size_desktop": "lg:text-lg",
            "step_title_font_weight": "font-bold",
            "step_title_color": "text-white",
            "step_body": "Branded mobile app configured, drag-and-drop widgets, rep pages, content library populated and shareable.",
            "step_body_font_family": "font-body",
            "step_body_font_size": "text-xs",
            "step_body_font_size_desktop": "lg:text-sm",
            "step_body_font_weight": "font-normal",
            "step_body_color": "text-neutral",
            "step_highlight": false,
            "step_border_color": "neutral-dark"
          }
        },
        "bw_step_wed": {
          "id": "bw_step_wed",
          "type": "step",
          "settings": {
            "step_label": "WED",
            "step_label_color": "text-neutral-dark",
            "step_title": "Website & Campaign Launch",
            "step_title_font_family": "font-primary",
            "step_title_font_size": "text-base",
            "step_title_font_size_desktop": "lg:text-lg",
            "step_title_font_weight": "font-bold",
            "step_title_color": "text-white",
            "step_body": "Live Editor pages built, campaign content ready, checkout tested and optimized, all integrations verified.",
            "step_body_font_family": "font-body",
            "step_body_font_size": "text-xs",
            "step_body_font_size_desktop": "lg:text-sm",
            "step_body_font_weight": "font-normal",
            "step_body_color": "text-neutral",
            "step_highlight": false,
            "step_border_color": "neutral-dark"
          }
        },
        "bw_step_thu": {
          "id": "bw_step_thu",
          "type": "step",
          "settings": {
            "step_label": "THU",
            "step_label_color": "text-success",
            "step_title": "You're Live.",
            "step_title_font_family": "font-primary",
            "step_title_font_size": "text-base",
            "step_title_font_size_desktop": "lg:text-lg",
            "step_title_font_weight": "font-bold",
            "step_title_color": "text-white",
            "step_body": "Full team walkthrough, go-live checklist complete, 90-day free platform period begins for 3-year partners.",
            "step_body_font_family": "font-body",
            "step_body_font_size": "text-xs",
            "step_body_font_size_desktop": "lg:text-sm",
            "step_body_font_weight": "font-normal",
            "step_body_color": "text-neutral",
            "step_highlight": true,
            "step_border_color": "success"
          }
        }
      }
    },
    "bw_pricing": {
      "type": "fw_split_content",
      "settings": {
        "headline": "The switching pain you're imagining doesn't exist here.",
        "headline_font_family": "font-primary",
        "headline_font_size": "text-3xl",
        "headline_font_size_desktop": "lg:text-4xl",
        "headline_font_weight": "font-bold",
        "headline_color": "text-white",
        "body": "<p>You've been burned before. The last platform migration took six months, cost twice the estimate, and your reps threatened mutiny halfway through. We get it.</p><p>Blitz Week exists because we've done this enough times to know exactly what needs to happen, in what order, and how to make decisions in real time instead of scheduling another call. You bring your team and your goals. We bring our best people, a proven process, and a commitment to having you live by Thursday.</p><p>No change orders. No scope creep. No surprises. Just a working platform and a team that knows how to use it.</p>",
        "body_font_family": "font-body",
        "body_font_size": "text-base",
        "body_font_size_desktop": "lg:text-lg",
        "body_font_weight": "font-normal",
        "body_color": "text-neutral",
        "show_button": true,
        "button_text": "Schedule Your Blitz Week",
        "button_style": "filled",
        "button_color": "white",
        "button_size": "btn-lg",
        "button_font_weight": "font-medium",
        "show_ghost_link": false,
        "show_accent_bar": false,
        "reverse_columns": false,
        "column_gap": "gap-xl",
        "vertical_alignment": "items-center",
        "background_color": "bg-black",
        "section_padding_y_mobile": "py-xl",
        "section_padding_y_desktop": "lg:py-3xl",
        "section_border_radius": "rounded-none",
        "container_background_color": "bg-transparent",
        "container_border_radius": "rounded-none",
        "container_padding_y_mobile": "py-md",
        "container_padding_y_desktop": "lg:py-xl",
        "container_padding_x_mobile": "px-lg",
        "container_padding_x_desktop": "lg:px-3xl"
      }
    }
  }
}
{% endschema %}
