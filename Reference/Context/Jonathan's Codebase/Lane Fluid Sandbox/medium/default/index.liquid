
<main class="flex-1 media">
  <aside class="media-sidebar flex flex-col justify-between gap-6">
    <div
      class="media-sidebar-content flex flex-col gap-6 px-6 flex-shrink-0"
    >
      <h3>{{ title }}</h3>
      <div class="media-desc flex flex-col gap-3 text-sm">
        {{ description }}
      </div>
    </div>
    <div class="register-btn flex-shrink-0 px-6">
      {% if display_shop %}
        <a href="{{ catalog_path }}" class="btn btn-bg-primary">{{ 'medium.products' | t }}</a>
      {% endif %}
      {% if lead_captureable %}
              <form autocomplete="off" class="cta-form" action="{{ learn_more_path }}" accept-charset="UTF-8" method="get">
                  <div class="field cta-field">
                  <input class="contactDetails hiddenId" name="contact[id]" type="hidden">
                  <input class="contactDetails hiddenFullName" name="contact[name]" type="hidden" value="">
                  <input class="contactDetails hiddenEmail" name="contact[email]" type="hidden">
                  <input class="contactDetails hiddenPhone" name="contact[phone]" type="hidden">
                  </div>
              </form>
              <a href="{{cta_url}}" id="ctaButton" class="btn btn-bg-primary">{{ cta_button_text }}</a>
      {% elsif visitable_on_click %}
        <a href="{{learn_more_path}}" class="btn btn-bg-primary">{{ cta_button_text }}</a>
      {% endif %}
    </div>
    <div
      class="social-icons flex align-center gap-4 justify-start flex-wrap flex-shrink-0 px-6"
    >
    {% unless social_media.facebook == blank%}
        <a href="#" class="facebook">
