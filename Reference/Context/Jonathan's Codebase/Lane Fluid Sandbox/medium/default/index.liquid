              fill="#999FB5"
            />
          </svg>
        </a>
      {% endunless %}
      {% unless social_media.twitter == blank%}
        <a href="#" class="x">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="25"
            height="25"
            viewBox="0 0 25 25"
            fill="none"
          >
            <path
              d="M14.6227 10.6491L21.1795 3.02734H19.6258L13.9325 9.64522L9.38529 3.02734H4.14062L11.0169 13.0347L4.14062 21.0273H5.69446L11.7067 14.0386L16.5089 21.0273H21.7535L14.6227 10.6491ZM12.4945 13.1229L11.7978 12.1264L6.25433 4.19705H8.64095L13.1146 10.5962L13.8113 11.5928L19.6265 19.9108H17.2399L12.4945 13.1229Z"
              fill="#999FB5"
            />
          </svg>
        </a>
      {% endunless %}
    </div>
    <div class="media-comments flex flex-col flex-1">
      <div class="flex justify-center is-shrink comments-title px-6 ">
        <h6 class="text-sm ">{{ 'medium.comments' | t }}</h6>
      </div>
      <div class="flex-1 px-6 pt-4">
        <ul class="flex flex-col text-sm comment-list">
          {% for comment in comments %}
            <li class="flex justify-start align-start gap-3">
              <span class="commentor">{{ comment.initials }}</span>
              <div class="commentetor-desc">
                <h6 class="text-sm">{{ comment.name }}</h6>
                <div class="commented-time">
                  <span>{{ 'medium.commented' | t }}</span>
                  <time datetime="">{{ comment.created_at }}</time>
                </div>
                <p class="mt-2">
                  {{ comment.body }}
                </p>
              </div>
            </li>
          {% endfor %}
        </ul>
        <template id="comment-template">
          <li class="flex justify-start align-start gap-3">
              <span class="commentor initials"></span>
              <div class="commentetor-desc">
                <h6 class="text-sm name"></h6>
                <div class="commented-time">
                  <span>{{ 'medium.commented' | t }}</span>
                  <time datetime="" class="created_at"></time>
                </div>
                <p class="mt-2 body">
                </p>
              </div>
            </li>
          </template>
      </div>
    </div>
    <div class="media-sidebar-footer px-6">
        {% render 'comment_form', comment_submit_url: comment_submit_url, relateable_id: id, relateable_type: 'Medium', contact: contact %}
    </div>
  </aside>
  
  <div class="media-content" data-bg="" >
    <fluid-media-widget media-id={{id}} responsive="true" embed-type="default" data-fluid-widget="true"></fluid-media-widget>
  </div>
  
</main>
    

<!-- Js library Import -->
<script
  src="https://code.jquery.com/jquery-3.7.1.min.js"
  integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo="
  crossorigin="anonymous"
></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.14.305/pdf.min.js"></script>

<script src="{{ 'media.js' | asset_url }}"></script>
<script src="{{ 'pdf.js' | asset_url }}"></script>

    