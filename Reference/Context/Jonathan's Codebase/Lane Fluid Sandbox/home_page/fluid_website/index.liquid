<div class="flex flex-col">
  {% section 'fw_hero', id: 'hero' %}
  {% section 'fw_logo_bar', id: 'logo_bar' %}
  {% section 'fw_pain_cards', id: 'pain_cards' %}
  {% section 'fw_split_content', id: 'solution_intro' %}
  {% section 'fw_stats_row', id: 'stats_row' %}
  {% section 'fw_split_content', id: 'fair_share_spotlight' %}
  {% section 'fw_pull_quote', id: 'payments_quote' %}
  {% section 'fw_split_content', id: 'payments_story' %}
  {% section 'fw_testimonial_billboard', id: 'customer_voice' %}
  {% section 'fw_platform_tabs', id: 'platform_tabs' %}
  {% section 'fw_cta_block', id: 'blitz_cta' %}
  {% section 'fw_dual_quotes', id: 'dual_quotes' %}
  {% section 'fw_cta_block', id: 'closing_cta' %}
</div>

{% schema %}
{
  "sections": {
    "hero": {
      "type": "fw_hero",
      "settings": {
        "show_marquee": false,
        "eyebrow": "The We-Commerce Platform",
        "headline": "The Only E-Commerce Platform Built Specifically for Direct Selling.",
        "description": "E-commerce platforms were built for selling things to strangers. You're building a network where every transaction creates ripple effects through an entire organization. That's a different game. We built the only platform that plays it.",
        "show_ghost_text": true,
        "ghost_text_content": "FLUID",
        "show_scroll_indicator": true,
        "show_button_one": true,
        "button_one_text": "Book a Demo",
        "button_one_style": "filled",
        "button_one_color": "quaternary",
        "button_one_size": "btn-lg",
        "show_button_two": true,
        "button_two_text": "Watch 2-min Overview ▶",
        "button_two_style": "outline",
        "button_two_color": "white",
        "button_two_size": "btn-lg",
        "small_text": "NO LENGTHY IMPLEMENTATION. NO I.T. TICKETS. GO LIVE IN DAYS.",
        "background_color": "bg-black",
        "section_padding_y_mobile": "py-3xl",
        "section_padding_y_desktop": "lg:py-3xl",
        "marquee_text": "EVERY TRANSACTION MATTERS",
        "marquee_font_family": "font-primary",
        "marquee_font_size": "text-4xl",
        "marquee_font_size_desktop": "lg:text-7xl",
        "marquee_font_weight": "font-bold",
        "marquee_color": "text-neutral-dark",
        "show_paint_stroke": true,
        "paint_stroke_image": "https://ik.imagekit.io/fluid/980191006/images/TN5LGA/circle_sketch_2_fHrLzJarM.webp",
        "description_font_family": "font-body",
        "description_font_size": "text-base",
        "description_font_size_desktop": "lg:text-lg",
        "description_font_weight": "font-normal",
        "description_color": "text-neutral",
        "small_text_font_family": "font-primary",
        "small_text_font_size": "text-xs",
        "small_text_font_size_desktop": "lg:text-sm",
        "small_text_font_weight": "font-medium",
        "small_text_color": "text-neutral",
        "button_one_font_weight": "font-medium",
        "decoration_image_1": "https://ik.imagekit.io/fluid/980191006/images/TCTM6S/circle_sketch_1_08erf3srd.png",
        "decoration_image_2": "https://ik.imagekit.io/fluid/980191006/images/TN5LGA/circle_sketch_2_fHrLzJarM.webp",
        "background_image": "https://ik.imagekit.io/fluid/980191006/images/UAE9LA/a_black_and_white_illustration_of_a_man_sitting_on_a_rock_pQekM_F9-.jpg",
        "section_border_radius": "rounded-none",
        "container_background_color": "bg-transparent",
        "container_background_image": "https://ik.imagekit.io/fluid/980191006/images/FFJ9F6/image_113_7ilLPjh-X.webp",
        "container_border_radius": "rounded-none",
        "container_padding_y_mobile": "py-md",
        "container_padding_y_desktop": "lg:py-xl",
        "container_padding_x_mobile": "px-lg",
        "container_padding_x_desktop": "lg:px-3xl"
      }
    },
    "logo_bar": {
      "type": "fw_logo_bar",
      "settings": {
        "eyebrow_text": "Trusted by direct selling companies in 50+ countries",
        "background_color": "bg-black"
      },
      "blocks": {
        "logo_1": {
          "type": "logo",
          "settings": {
            "logo_alt": "TEQNAVI"
          }
        },
        "logo_2": {
          "type": "logo",
          "settings": {
            "logo_alt": "iSTOCK"
          }
        },
        "logo_3": {
          "type": "logo",
          "settings": {
            "logo_alt": "PARTNER CO."
          }
        },
        "logo_4": {
          "type": "logo",
          "settings": {
            "logo_alt": "EPIC VENTURES"
          }
        },
        "logo_5": {
          "type": "logo",
          "settings": {
            "logo_alt": "Logo 5"
          }
        },
        "logo_6": {
          "type": "logo",
          "settings": {
            "logo_alt": "Logo 6"
          }
        }
      }
    },
    "pain_cards": {
      "type": "fw_pain_cards",
      "settings": {
        "show_accent_bar": true,
        "eyebrow": "Sound familiar?",
        "headline": "About half of all direct selling transactions can't even happen on Shopify.",
        "subtext": "Read that again.",
        "closing_headline": "Every one of these is a transaction that should have happened.",
        "closing_body": "We built We-Commerce around a single, uncompromising principle: Every transaction matters. Not most. Not the easy ones. Every single one.",
        "grid_columns": "3",
        "background_color": "bg-black",
        "eyebrow_font_family": "font-handwritten",
        "eyebrow_font_size": "text-xl",
        "eyebrow_font_size_desktop": "lg:text-2xl",
        "eyebrow_font_weight": "font-normal",
        "eyebrow_color": "text-info"
      },
      "blocks": {
        "pain_1": {
          "type": "pain_card",
          "settings": {
            "card_number": "01",
            "card_title": "Payments decline at higher rates",
            "card_body": "Your industry is flagged as 'higher risk.' A 3–4% failure rate becomes 6–8% for you. On a million dollars monthly, that's $50,000 in lost transactions. Every month."
          }
        },
        "pain_2": {
          "type": "pain_card",
          "settings": {
            "card_number": "02",
            "card_title": "Attribution breaks and reps stop sharing",
            "card_body": "A rep drives a prospect to your site. They come back through Google three weeks later. Who gets credit? Nobody — or the wrong person. That rep never shares again."
          }
        },
        "pain_3": {
          "type": "pain_card",
          "settings": {
            "card_number": "03",
            "card_title": "You're managing 15 vendors. Not building a business.",
            "card_body": "Payments here, commissions there, mobile app somewhere else. You spend all your time keeping the Frankenstein alive instead of growing."
          }
        },
        "pain_4": {
          "type": "pain_card",
          "settings": {
            "card_number": "04",
            "card_title": "Beautiful content sits unused",
            "card_body": "Your marketing team creates assets nobody shares. Reps don't trust they'll get credit, so they build bootleg versions — or go quiet entirely."
          }
        },
        "pain_5": {
          "type": "pain_card",
          "settings": {
            "card_number": "05",
            "card_title": "15-click checkouts kill conversions",
            "card_body": "Someone's ready to buy. The checkout wants them to create an account. They're at a red light. The moment passes. You'll never know that sale almost happened."
          }
        },
        "pain_6": {
          "type": "pain_card",
          "settings": {
            "card_number": "06",
            "card_title": "Sync failures corrupt your commissions",
            "card_body": "The order went through on the site but didn't reach the commission engine. Now you're manually fixing records while reps lose faith that anything works."
          }
        }
      }
    },
    "solution_intro": {
      "type": "fw_split_content",
      "settings": {
        "eyebrow": "One Platform. Zero Duct Tape.",
        "headline": "Everything Shopify gives you for e-commerce — plus everything direct selling actually needs.",
        "body": "<p>Enrollments, subscriptions, logged-in shopping, rep attribution, commission sync, mobile apps. All in one connected system. No middleware that breaks at 3am. No single points of failure. No IT cycles every time you want to change a landing page.</p>",
        "show_ghost_link": true,
        "link_text": "Explore the Full Platform",
        "show_button": false,
        "background_color": "bg-black"
      },
      "blocks": {
        "feature_1": {
          "type": "feature_card",
          "settings": {
            "card_tag": "Attribution",
            "card_title": "Fair Share",
            "card_body": "Full-journey tracking. Reps trust it."
          }
        },
        "feature_2": {
          "type": "feature_card",
          "settings": {
            "card_tag": "Payments",
            "card_title": "Fluid Payments",
            "card_body": "Cascading retries. Revenue recovered."
          }
        },
        "feature_3": {
          "type": "feature_card",
          "settings": {
            "card_tag": "Mobile",
            "card_title": "Mobile App",
            "card_body": "Branded iOS + Android for your reps."
          }
        },
        "feature_4": {
          "type": "feature_card",
          "settings": {
            "card_tag": "Website",
            "card_title": "Live Editor",
            "card_body": "Drag-and-drop page builder."
          }
        },
        "feature_5": {
          "type": "feature_card",
          "settings": {
            "card_tag": "Data Sync",
            "card_title": "Sync Tool",
            "card_body": "One clean connection to your back office."
          }
        },
        "feature_6": {
          "type": "feature_card",
          "settings": {
            "card_tag": "Commerce",
            "card_title": "Live Shopping",
            "card_body": "Shoppable video. Attributed to the host."
          }
        }
      }
    },
    "stats_row": {
      "type": "fw_stats_row",
      "settings": {
        "background_color": "bg-black"
      },
      "blocks": {
        "stat_1": {
          "type": "stat",
          "settings": {
            "stat_number": "~50%",
            "stat_label": "of direct selling transactions can't be processed by Shopify",
            "border_color": "secondary"
          }
        },
        "stat_2": {
          "type": "stat",
          "settings": {
            "stat_number": "6×",
            "stat_label": "payment retry attempts before we give up. Most platforms try once.",
            "border_color": "info"
          }
        },
        "stat_3": {
          "type": "stat",
          "settings": {
            "stat_number": "1 week",
            "stat_label": "average time to go live with Blitz Week. Industry standard is 90 days.",
            "border_color": "success"
          }
        },
        "stat_4": {
          "type": "stat",
          "settings": {
            "stat_number": "50+",
            "stat_label": "countries. One connected platform. No per-region rebuilds.",
            "border_color": "warning"
          }
        }
      }
    },
    "fair_share_spotlight": {
      "type": "fw_split_content",
      "settings": {
        "eyebrow": "Fair Share™ — The Unique IP",
        "headline": "Attribution isn't a technical problem. It's a trust problem.",
        "body": "<p>When a rep shares your content and drives a sale, they need to know — with certainty — that they'll get credit. Not sometimes. Not if the cookie hasn't expired. Every time.</p><p>Fair Share tracks the entire customer journey from first touch to conversion, across devices, across sessions, across weeks. Your reps see the proof. They trust the system. And when reps trust the system, they share.</p>",
        "show_ghost_link": true,
        "link_text": "Learn about Fair Share",
        "show_button": false,
        "background_color": "bg-black"
      },
      "blocks": {
        "step_1": {
          "type": "step_item",
          "settings": {
            "step_number": "1",
            "step_title": "Rep Shares Content",
            "step_body": "Every link is personalized and tracked from the first touch.",
            "step_color": "primary"
          }
        },
        "step_2": {
          "type": "step_item",
          "settings": {
            "step_number": "2",
            "step_title": "Customer Engages",
            "step_body": "Browsing, returning via Google, switching devices — all connected.",
            "step_color": "secondary"
          }
        },
        "step_3": {
          "type": "step_item",
          "settings": {
            "step_number": "3",
            "step_title": "Purchase Happens",
            "step_body": "Transaction is attributed to the rep who started the journey.",
            "step_color": "success"
          }
        },
        "step_4": {
          "type": "step_item",
          "settings": {
            "step_number": "4",
            "step_title": "Rep Gets Credit",
            "step_body": "Visible, verifiable, trusted. Rep shares again with confidence.",
            "step_color": "info"
          }
        }
      }
    },
    "payments_quote": {
      "type": "fw_pull_quote",
      "settings": {
        "quote_text": "<p>&ldquo;When a transaction fails in e-commerce, you lose a sale. When a transaction fails in direct selling, you might <strong>lose a career.</strong>&rdquo;</p>",
        "attribution_text": "— FLUID WE-COMMERCE MANIFESTO",
        "background_color": "bg-black"
      }
    },
    "payments_story": {
      "type": "fw_split_content",
      "settings": {
        "headline": "We don't give up on a transaction. We try up to six times.",
        "body": "<p>When a payment fails, most platforms show an error and move on. We built a cascading payment system that automatically routes the transaction to the next processor, adjusts parameters, and tries again — up to six times — before giving up.</p><p>On $1M monthly volume, this recovers $40,000–$60,000 in transactions that other platforms simply lose. That's not a rounding error. That's careers saved, commissions preserved, and trust maintained.</p>",
        "show_ghost_link": true,
        "link_text": "See how Fluid Payments works",
        "show_button": false,
        "reverse_columns": true,
        "background_color": "bg-black"
      }
    },
    "customer_voice": {
      "type": "fw_testimonial_billboard",
      "settings": {
        "person_name": "Dan England",
        "person_title": "VP Payments + Risk",
        "quote_text": "I get it now. You guys just had the cojones to build all the pieces direct sales needs in one system.",
        "attribution": "— DAN ENGLAND, VP PAYMENTS + RISK",
        "show_ghost_link": true,
        "ghost_link_text": "Read more customer stories",
        "background_color": "bg-black"
      }
    },
    "platform_tabs": {
      "type": "fw_platform_tabs",
      "settings": {
        "eyebrow": "Everything Your Business Needs",
        "headline": "One platform. No integration headaches. No mystery scripts.",
        "background_color": "bg-black"
      },
      "blocks": {
        "tab_fairshare": {
          "type": "tab",
          "settings": {
            "tab_label": "Fair Share™",
            "tab_title": "Your reps deserve to trust the system. Fair Share makes that possible.",
            "tab_body": "<p>Every piece of company content — videos, articles, PDFs — becomes a personalized, trackable link for each rep. They add their face and story. Customers see a human they trust. Everything is attributed automatically.</p><p>Complex scenarios handled: multiple reps sharing to one buyer, orphan sign-ups, previously sponsored customers. You set the rules. The system executes them.</p>",
            "tab_button_show": true,
            "tab_button_text": "Learn about Fair Share →",
            "tab_button_style": "ghost",
            "tab_button_color": "white"
          }
        },
        "tab_payments": {
          "type": "tab",
          "settings": {
            "tab_label": "Payments",
            "tab_title": "Cascading payment intelligence that never gives up.",
            "tab_body": "<p>When a payment fails, our system automatically routes it to the next processor, adjusts parameters, and retries — up to six times. On $1M monthly volume, this recovers $40K–$60K in revenue that other platforms simply lose.</p><p>Your finance team gets clean data. Your reps get paid on time. Every time.</p>",
            "tab_button_show": true,
            "tab_button_text": "Learn about Payments →",
            "tab_button_style": "ghost",
            "tab_button_color": "white"
          }
        },
        "tab_mobile": {
          "type": "tab",
          "settings": {
            "tab_label": "Mobile App",
            "tab_title": "A branded app your reps actually want to use.",
            "tab_body": "<p>Custom-branded mobile app with your look, your voice, your tools. Reps manage their entire business from their phone — orders, contacts, content sharing, team performance.</p><p>Push notifications keep them engaged. Offline mode keeps them selling. No app store headaches — we handle it all.</p>",
            "tab_button_show": true,
            "tab_button_text": "Learn about Mobile App →",
            "tab_button_style": "ghost",
            "tab_button_color": "white"
          }
        },
        "tab_editor": {
          "type": "tab",
          "settings": {
            "tab_label": "Live Editor",
            "tab_title": "Design your storefront. No developers required.",
            "tab_body": "<p>Drag-and-drop page builder with real-time preview. Your marketing team builds landing pages, product showcases, and campaign pages without writing a single line of code.</p><p>Full theme control, section-based layouts, and responsive design — all from the browser.</p>",
            "tab_button_show": true,
            "tab_button_text": "Learn about Live Editor →",
            "tab_button_style": "ghost",
            "tab_button_color": "white"
          }
        },
        "tab_shopping": {
          "type": "tab",
          "settings": {
            "tab_label": "Live Shopping",
            "tab_title": "Turn live events into shoppable experiences.",
            "tab_body": "<p>Broadcast live video with integrated product cards, real-time chat, and one-tap checkout. Reps host their own shows. Customers buy without leaving the stream.</p><p>Replays are automatically shoppable. Attribution follows every sale back to the host rep.</p>",
            "tab_button_show": true,
            "tab_button_text": "Learn about Live Shopping →",
            "tab_button_style": "ghost",
            "tab_button_color": "white"
          }
        },
        "tab_sync": {
          "type": "tab",
          "settings": {
            "tab_label": "Sync Tool",
            "tab_title": "Keep your systems in lockstep.",
            "tab_body": "<p>Bi-directional sync with your ERP, CRM, warehouse, and compensation engine. Real-time webhooks, batch imports, and a clean API that your developers will actually enjoy working with.</p><p>No more data silos. No more export-import-pray workflows. One source of truth.</p>",
            "tab_button_show": true,
            "tab_button_text": "Learn about Sync Tool →",
            "tab_button_style": "ghost",
            "tab_button_color": "white"
          }
        }
      }
    },
    "blitz_cta": {
      "type": "fw_cta_block",
      "settings": {
        "eyebrow": "Switching doesn't have to be scary",
        "eyebrow_color": "text-black",
        "headline": "We'll get you live in one week. Not 90 days. One week.",
        "headline_color": "text-black",
        "body": "<p>Blitz Week is an intensive 4-day launch at our headquarters in Lehi, Utah. You leave with your platform live. Fully configured. Production-ready. For partners on a 3-year agreement — it's 100% free.</p>",
        "body_color": "text-black",
        "text_alignment": "text-center",
        "show_button_one": true,
        "button_one_text": "Learn About Blitz Week",
        "button_one_style": "filled",
        "button_one_color": "white",
        "button_one_size": "btn-lg",
        "show_button_two": false,
        "background_color": "bg-quaternary"
      }
    },
    "dual_quotes": {
      "type": "fw_dual_quotes",
      "settings": {
        "background_color": "bg-black"
      },
      "blocks": {
        "quote_tingey": {
          "type": "quote",
          "settings": {
            "quote_text": "<p>&ldquo;My favorite spicy feedback from this week: &lsquo;I get it now; you guys just had the cojones to build all the pieces direct sales needs in one system.&rsquo;&rdquo;</p>",
            "attribution_text": "— MIKE TINGEY, CEO · FLUID WE-COMMERCE",
            "border_color": "secondary",
            "card_background_color": "bg-neutral-dark"
          }
        },
        "quote_mckinney": {
          "type": "quote",
          "settings": {
            "quote_text": "<p>&ldquo;Teqnavi&rsquo;s leadership return coincides with a major strategic partnership — and Fluid is how we&rsquo;re scaling everything that comes next.&rdquo;</p>",
            "attribution_text": "— HOLLY MCKINNEY, CO-FOUNDER · TEQNAVI",
            "border_color": "secondary",
            "card_background_color": "bg-neutral-dark"
          }
        }
      }
    },
    "closing_cta": {
      "type": "fw_cta_block",
      "settings": {
        "eyebrow": "Ready to stop fighting your technology?",
        "eyebrow_color": "text-info",
        "headline": "The fastest-growing direct selling companies have already figured this out.",
        "headline_color": "text-white",
        "body": "<p>The gap between leaders and laggards is widening every quarter. Your competitors are launching campaigns in hours while you're waiting 90 days for IT.</p>",
        "body_color": "text-neutral",
        "text_alignment": "text-center",
        "show_button_one": true,
        "button_one_text": "Book a Demo",
        "button_one_style": "filled",
        "button_one_color": "white",
        "button_one_size": "btn-lg",
        "show_button_two": false,
        "background_color": "bg-black"
      }
    }
  },
  "name": "Fluid Website"
}
{% endschema %}