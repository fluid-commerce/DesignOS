      "default": "h2",
      "label": "Heading Size"
    },
    {
      "type": "image_picker",
      "id": "feature_1_image",
      "label": "Feature 1 - Image"
    },
    {
      "type": "text",
      "id": "feature_1_image_alt",
      "label": "Feature 1 - Image Alt Text"
    },
    {
      "type": "text",
      "id": "feature_1_text",
      "default": "Feature benefit one",
      "label": "Feature 1 - Text"
    },
    {
      "type": "image_picker",
      "id": "feature_2_image",
      "label": "Feature 2 - Image"
    },
    {
      "type": "text",
      "id": "feature_2_image_alt",
      "label": "Feature 2 - Image Alt Text"
    },
    {
      "type": "text",
      "id": "feature_2_text",
      "default": "Feature benefit two",
      "label": "Feature 2 - Text"
    },
    {
      "type": "image_picker",
      "id": "feature_3_image",
      "label": "Feature 3 - Image"
    },
    {
      "type": "text",
      "id": "feature_3_image_alt",
      "label": "Feature 3 - Image Alt Text"
    },
    {
      "type": "text",
      "id": "feature_3_text",
      "default": "Feature benefit three",
      "label": "Feature 3 - Text"
    },
    {
      "type": "image_picker",
      "id": "feature_4_image",
      "label": "Feature 4 - Image"
    },
    {
      "type": "text",
      "id": "feature_4_image_alt",
      "label": "Feature 4 - Image Alt Text"
    },
    {
      "type": "text",
      "id": "feature_4_text",
      "default": "Feature benefit four",
      "label": "Feature 4 - Text"
    },
    {
      "type": "image_picker",
      "id": "feature_5_image",
      "label": "Feature 5 - Image"
    },
    {
      "type": "text",
      "id": "feature_5_image_alt",
      "label": "Feature 5 - Image Alt Text"
    },
    {
      "type": "text",
      "id": "feature_5_text",
      "default": "Feature benefit five",
      "label": "Feature 5 - Text"
    },
    {
      "type": "image_picker",
      "id": "feature_6_image",
      "label": "Feature 6 - Image"
    },
    {
      "type": "text",
      "id": "feature_6_image_alt",
      "label": "Feature 6 - Image Alt Text"
    },
    {
      "type": "text",
      "id": "feature_6_text",
      "default": "Feature benefit six",
      "label": "Feature 6 - Text"
    },
    {
      "type": "color_background",
      "id": "background_color",
      "default": "#ffffff",
      "label": "Background Color"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image",
      "info": "Optional background image (will override background color)"
    },
    {
      "type": "color_background",
      "id": "overlay_color",
      "default": "#000000",
      "label": "Background Overlay Color",
      "info": "Color overlay on top of background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Background Overlay Opacity",
      "default": 40,
      "info": "0% = transparent, 100% = solid color"
    },
    {
      "type": "color_background",
      "id": "tagline_color",
      "default": "#6b7280",
      "label": "Tagline Color"
