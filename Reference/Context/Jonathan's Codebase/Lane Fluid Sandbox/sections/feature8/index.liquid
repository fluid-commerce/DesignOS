    },
    {
      "type": "color_background",
      "id": "description_color",
      "default": "#6b7280",
      "label": "Description Color"
    },

    {
      "type": "color_background",
      "id": "feature_text_color",
      "default": "#1a1a1a",
      "label": "Feature Text Color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
