<!-- Testimonial section -->
{%- style -%}
  .testimonial-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile | default: 32 }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile | default: 32 }}px;
  }

  @media (min-width: 768px) {
    .testimonial-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_desktop | default: 64 }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop | default: 64 }}px;
    }
  }
{%- endstyle -%}

<section class="testimonial-section testimonial-section-{{ section.id }}">
    <div class="container">
      <div
        class="flex flex-col justify-center align-center gap-6 section-title"
      >
        <div class="{{ section.settings.title_font_size_mobile | default: 'text-h2' }} {{ section.settings.title_font_size_desktop | default: 'text-h2' }}" style="color: {{ section.settings.title_color | default: '#000000' }}; font-weight: {{ section.settings.title_font_weight | default: 600 }};">{{ section.settings.section_title | default: "Customer testimonials" }}</div>
        <p class="{{ section.settings.description_font_size_mobile | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'text-lg' }}" style="color: {{ section.settings.description_color | default: '#666666' }}; font-weight: {{ section.settings.description_font_weight | default: 400 }};">
          {{ section.settings.section_description | default: "Lorem ipsum dolor sit amet, consectetur adipiscing elit." }}
        </p>
      </div>
      <div class="grid grid-cols-3 gap-12 testimonial-grid">
        {% for block in section.blocks %}
          <div
            class="testimonial-col flex flex-col justify-center align-center gap-6 text-center"
            {{ block.fluid_attributes }}
          >
            <div class="company-logo">
              <img src="{% if block.settings.company_logo %}{{ block.settings.company_logo | image_url }}{% else %}{{ 'https://ik.imagekit.io/fluid/filestack-migration/filestack_25BaNkw7SYu5hydjLRnk_mVr58ngn6-' | asset_url }}{% endif %}" alt="{{ block.settings.company_name | default: 'logo' }}" />
            </div>
             <p class="{{ block.settings.testimonial_font_size_mobile | default: 'text-sm' }} {{ block.settings.testimonial_font_size_desktop | default: 'text-base' }} font-semibold testimonial-text" style="color: {{ block.settings.testimonial_color | default: '#333333' }}; font-weight: {{ block.settings.testimonial_font_weight | default: 600 }};">
               "{{ block.settings.testimonial_text | default: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare.' }}"
             </p>
            <div
              class="author text-center flex justify-center align-center flex-col"
            >
              <figure class="mb-4">
                <img src="{% if block.settings.author_image %}{{ block.settings.author_image | image_url }}{% else %}{{ 'avatar.png' | asset_url }}{% endif %}" alt="{{ block.settings.author_name | default: 'Author' }}" />
              </figure>
               <div class="{{ block.settings.author_name_font_size_mobile | default: 'text-sm' }} {{ block.settings.author_name_font_size_desktop | default: 'text-base' }} font-semibold author-name" style="color: {{ block.settings.author_name_color | default: '#000000' }}; font-weight: {{ block.settings.author_name_font_weight | default: 600 }};">{{ block.settings.author_name | default: "Name Surname" }}</div>
               <p class="{{ block.settings.author_position_font_size_mobile | default: 'text-xs' }} {{ block.settings.author_position_font_size_desktop | default: 'text-sm' }} author-position" style="color: {{ block.settings.author_position_color | default: '#666666' }}; font-weight: {{ block.settings.author_position_font_weight | default: 400 }};">{{ block.settings.author_position | default: "Position" }}{% if block.settings.company_name %}, {{ block.settings.company_name }}{% else %}, Company name{% endif %}</p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>

