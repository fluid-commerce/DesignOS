<!-- Product Categories Section -->
<section class="product-categories {{ section.settings.section_padding_y_mobile }} {{ section.settings.section_padding_y_desktop }} {{ section.settings.section_border_radius }} {{ section.settings.background_color }}" 
         id="{{ section.id }}"
         {% if section.settings.background_image != blank %}
         style="background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');"
         {% endif %}>
  <div class="container {{ section.settings.container_background_color }} {{ section.settings.container_border_radius }} {{ section.settings.container_padding_y_mobile }} {{ section.settings.container_padding_y_desktop }} {{ section.settings.container_padding_x_mobile }} {{ section.settings.container_padding_x_desktop }}"
       {% if section.settings.container_background_image != blank %}
       style="background-image: url('{{ section.settings.container_background_image | image_url: width: 1200 }}');"
       {% endif %}>
    
    <!-- Section Header -->
    {% if section.settings.show_section_header %}
      <div class="section-header text-center {{ section.settings.heading_margin_bottom }}">
        {% if section.settings.section_heading != blank %}
          <div class="heading-wrapper {{ section.settings.heading_margin_bottom }}">
            <h2 class="section-heading {{ section.settings.heading_font_size }} {{ section.settings.heading_font_size_desktop }} {{ section.settings.heading_font_weight }} {{ section.settings.heading_line_height }} {{ section.settings.heading_text_color | default: 'text-black' }}">
              {{ section.settings.section_heading }}
            </h2>
          </div>
        {% endif %}
        
        {% if section.settings.section_description != blank %}
          <div class="description-wrapper">
            <p class="section-description {{ section.settings.description_font_size }} {{ section.settings.description_font_size_desktop }} {{ section.settings.description_line_height }} {{ section.settings.description_text_color | default: 'text-neutral' }}">
              {{ section.settings.section_description }}
            </p>
          </div>
        {% endif %}
      </div>
    {% endif %}
    
    <!-- Categories Grid -->
    <div class="categories-grid">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'category_item' %}
            <div class="category-item {{ section.settings.item_background_color }} {{ section.settings.item_border_radius }} {{ section.settings.item_padding }}" {{ block.fluid_attributes }}>
              <div class="category-content">
                
                <!-- Icon -->
                <div class="category-icon-wrapper {{ section.settings.icon_margin_bottom }}">
                  {% if block.settings.show_icon and block.settings.icon_image != blank %}
                    <div class="category-icon {{ section.settings.icon_background_color }} {{ section.settings.icon_border_radius }} {{ section.settings.icon_size }}">
                      <img src="{{ block.settings.icon_image | image_url: width: 100 }}"
                           alt="{{ block.settings.icon_alt | default: block.settings.category_title }}"
                           class="icon-image"
                           loading="lazy">
                    </div>
                  {% elsif block.settings.show_icon %}
                    <div class="category-icon {{ section.settings.icon_background_color }} {{ section.settings.icon_border_radius }} {{ section.settings.icon_size }}">
                      <img src="{{ 'placeholder-image.png' | asset_url }}"
                           alt="Icon for {{ block.settings.category_title }}"
                           class="icon-image"
                           loading="lazy">
                    </div>
                  {% endif %}
                </div>
                
                <!-- Title -->
                {% if block.settings.category_title != blank %}
                  <div class="category-title-wrapper">
                    <h3 class="category-title {{ section.settings.title_font_size }} {{ section.settings.title_font_size_desktop }} {{ section.settings.title_font_weight }} {{ section.settings.title_line_height }} {{ block.settings.title_text_color | default: section.settings.item_text_color | default: 'text-black' }}">
                      {{ block.settings.category_title }}
                    </h3>
                  </div>
                {% endif %}
                
                <!-- Arrow -->
                {% if section.settings.show_arrows %}
                  <div class="category-arrow {{ section.settings.arrow_margin_top }}">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor" class="{{ section.settings.arrow_color | default: 'text-neutral' }}">
                      <path fill-rule="evenodd" d="M10.293 15.707a1 1 0 010-1.414L14.586 10l-4.293-4.293a1 1 0 111.414-1.414l5 5a1 1 0 010 1.414l-5 5a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                    </svg>
                  </div>
                {% endif %}
                
              </div>
              
              <!-- Optional Link Wrapper -->
              {% if block.settings.category_link != blank %}
                <a href="{{ block.settings.category_link }}" class="category-link-overlay" aria-label="Go to {{ block.settings.category_title }}"></a>
              {% endif %}
            </div>
        {% endcase %}
      {% endfor %}
    </div>
    
  </div>
</section>

