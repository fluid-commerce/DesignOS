            { "value": "font-bold", "label": "Bold" }
          ],
          "default": "font-bold"
        },
        {
          "type": "select",
          "id": "description_font_size",
          "label": "Description Font Size (Mobile)",
          "options": [
            { "value": "text-base", "label": "Base" },
            { "value": "text-lg", "label": "Large" },
            { "value": "text-xl", "label": "X-Large" },
