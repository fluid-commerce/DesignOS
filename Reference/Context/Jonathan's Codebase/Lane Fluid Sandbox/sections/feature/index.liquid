          "label": "Show Button 1",
          "default": true
        },
        {
          "type": "text",
          "id": "button_1_text",
          "label": "Button 1 Text",
          "default": "Button 1"
        },
        {
          "type": "url",
          "id": "button_1_url",
          "label": "Button 1 URL",
          "default": "#"
        },
        {
          "type": "checkbox",
          "id": "show_button_2",
          "label": "Show Button 2",
          "default": true
