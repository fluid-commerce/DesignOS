{%- style -%}
  .feature-section-wrapper-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | default: 64 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 64 }}px;
  }
{%- endstyle -%}

<!-- Feature section-->
<div class="feature-wrapper feature-section-wrapper-{{ section.id }}">
  {% for block in section.blocks %}
    {% assign feature_class = 'feature-section-' | append: forloop.index %}
    <section class="feature-section {{ feature_class }}" {{ block.fluid_attributes }}>
      <div class="container">
        <div class="grid gap-12 feature-grid">
          <div class="feature-content flex justify-center h-full flex-col gap-6 flex-1">
            <div class="{{ block.settings.headline_font_size | default: 'text-h1' }} {{ block.settings.headline_font_size_desktop | default: 'text-h1' }} {{ block.settings.headline_font_weight | default: 'font-bold' }}">
              {{ block.settings.headline | default: "Medium length hero heading goes here" }}
            </div>
            <p class="{{ block.settings.description_font_size | default: 'text-base' }} {{ block.settings.description_font_size_desktop | default: 'xl-tab-text-lg' }} {{ block.settings.description_font_weight | default: 'font-normal' }}">
              {{ block.settings.description | default: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare, eros dolor interdum nulla, ut commodo diam libero vitae erat." }}
            </p>
            <div class="flex justify-start align-center gap-4 mt-2">
              {% if block.settings.show_button_1 %}
                <a href="{{ block.settings.button_1_url | default: '#' }}" class="btn btn-bg-primary">{{ block.settings.button_1_text | default: "Button 1" }}</a>
              {% endif %}
              {% if block.settings.show_button_2 %}
                <a href="{{ block.settings.button_2_url | default: '#' }}" class="btn btn-border-primary">{{ block.settings.button_2_text | default: "Button 2" }}</a>
              {% endif %}
            </div>
          </div>
          <div class="feature-image-wrapper">
            <div class="feature-image feature-image-right">
              <img
                src="{% if block.settings.feature_image %}{{ block.settings.feature_image | image_url }}{% else %}{{ 'feature-placeholder.png' | asset_url }}{% endif %}"
                alt="{{ block.settings.image_alt | default: 'feature' }}"
              />
            </div>
          </div>
        </div>
      </div>
    </section>
  {% endfor %}
</div>

{% schema %}
{
  "name": "Feature Section",
  "tag": "section",
  "class": "feature-section",
