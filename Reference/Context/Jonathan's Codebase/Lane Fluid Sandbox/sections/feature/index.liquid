            "show_button_1": true,
            "button_1_text": "Button 1",
            "button_1_url": "#",
            "show_button_2": true,
            "button_2_text": "Button 2",
            "button_2_url": "#",
            "feature_image": "https://ik.imagekit.io/fluid/filestack-migration/filestack_ZwL4w01GQTK1F8vPLXzA_q3QY3y72qz",
            "image_alt": "feature",
            "headline_font_size": "text-h1",
            "headline_font_size_desktop": "text-h1",
            "headline_font_weight": "font-bold",
            "description_font_size": "text-base",
            "description_font_size_desktop": "xl-tab-text-lg",
            "description_font_weight": "font-normal"
          }
        },
        {
          "type": "feature_item",
          "settings": {
            "headline": "Medium length hero heading goes here",
            "description": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare, eros dolor interdum nulla, ut commodo diam libero vitae erat.",
