      "blocks": [
        {
          "type": "timeline_step",
          "settings": {
            "step_title": "Build Corporate Site",
            "step_description": "\"Start simple - just build the main ecommerce site for the company.\""
          }
        },
        {
          "type": "timeline_step",
          "settings": {
            "step_title": "Build Replicated Sites",
            "step_description": "\"Wait... every rep needs their own site? Thousands of them? All identical but unique?\""
          }
        },
        {
          "type": "timeline_step",
          "settings": {
            "step_title": "Sync Product Data",
            "step_description": "\"Product updates need to cascade to thousands of rep sites. In real-time. Without breaking.\""
          }
        },
        {
          "type": "timeline_step",
          "settings": {
            "step_title": "Enrollments & Sales",
            "step_description": "\"Support both one-off purchases AND rep enrollments. Different flows, same checkout.\""
          }
        },
        {
          "type": "timeline_step",
          "settings": {
            "step_title": "Multiple Payment Providers",
            "step_description": "\"Stripe for US, different gateway for EU, another for APAC. Set them all up.\""
          }
        },
        {
          "type": "timeline_step",
          "settings": {
            "step_title": "Integrate Payment Options",
            "step_description": "\"Now connect each gateway to every rep site. Test every combination.\""
          }
        },
        {
          "type": "timeline_step",
          "settings": {
            "step_title": "Logged-In Experiences",
            "step_description": "\"Reps see dashboards. Customers see their orders. Anonymous see marketing. Three UIs.\""
          }
        },
        {
          "type": "timeline_step",
          "settings": {
            "step_title": "Share Assets with Reps",
            "step_description": "\"Reps need images, videos, copy. Make it easy to grab and customize.\""
          }
        },
        {
          "type": "timeline_step",
          "settings": {
            "step_title": "Get Traffic",
            "step_description": "\"Reps share their unique links everywhere. Social, email, text. Traffic floods in.\""
          }
        },
        {
          "type": "timeline_step",
          "settings": {
            "step_title": "Track Attribution",
            "step_description": "\"THE NIGHTMARE: Customer clicked Rep A's link but bought on Rep B's site. Who gets credit?\""
          }
        },
        {
          "type": "timeline_step",
          "settings": {
            "step_title": "Make Sale",
            "step_description": "\"Customer completes checkout. Money received. Now the real chaos begins...\""
          }
        },
        {
          "type": "timeline_step",
          "settings": {
            "step_title": "Create New Rep Record",
            "step_description": "\"Customer wants to enroll. Create account, generate site, set permissions. Instantly.\""
          }
        },
        {
          "type": "timeline_step",
          "settings": {
            "step_title": "Place in Genealogy",
            "step_description": "\"Binary tree? Unilevel? Matrix? Place rep correctly or commissions break for everyone.\""
          }
        },
        {
          "type": "timeline_step",
          "settings": {
            "step_title": "Sync Commissions",
            "step_description": "\"Calculate commissions for upline, bonuses, overrides. Sync with Exigo, Pillars, ByDesign.\""
          }
        },
        {
          "type": "timeline_step",
          "settings": {
            "step_title": "Manage Subscriptions",
            "step_description": "\"Autoship orders renew monthly. Handle payment failures, cancellations, upgrades.\""
          }
        },
        {
          "type": "timeline_step",
          "settings": {
            "step_title": "Reconcile Payouts",
            "step_description": "\"Chargebacks, refunds, adjustments. Every rep must get paid correctly. Every month. Forever.\""
          }
        }
      ]
