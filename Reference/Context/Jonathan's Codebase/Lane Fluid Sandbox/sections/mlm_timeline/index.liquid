<!-- MLM Timeline Section -->
{%- style -%}
  .mlm-timeline {
    position: relative;
    overflow: hidden;
  }

  .mlm-timeline-container {
    position: relative;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
    padding-bottom: {{ section.blocks.size | times: 50 | plus: 200 }}px;
  }

  .timeline-hero {
    text-align: center;
    margin-bottom: 120px;
    position: relative;
    z-index: 10;
  }

  .path-svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  .dotted-path {
    fill: none;
    stroke: #000;
    stroke-width: 3;
    stroke-dasharray: 1, 15;
    stroke-linecap: round;
  }

  .path-arrow {
    fill: #000;
  }

  .timeline-item {
    position: absolute;
    opacity: 0;
    transform: scale(0.85);
    transition: all 0.7s cubic-bezier(0.4, 0, 0.2, 1);
    max-width: 90vw;
  }

  .timeline-item.visible {
    opacity: 1;
    transform: scale(1);
  }

  .item-1 { top: 250px; left: 8%; }
  .item-2 { top: 650px; right: 10%; }
  .item-3 { top: 1050px; left: 30%; }
  .item-4 { top: 1450px; right: 20%; }
  .item-5 { top: 1850px; left: 15%; }
  .item-6 { top: 2250px; right: 8%; }
  .item-7 { top: 2650px; left: 25%; }
  .item-8 { top: 3050px; right: 18%; }
  .item-9 { top: 3450px; left: 12%; }
  .item-10 { top: 3850px; right: 25%; }
  .item-11 { top: 4250px; left: 35%; }
  .item-12 { top: 4650px; right: 12%; }
  .item-13 { top: 5050px; left: 18%; }
  .item-14 { top: 5450px; right: 22%; }
  .item-15 { top: 5850px; left: 28%; }
  .item-16 { top: 6250px; right: 15%; }

  .content-wrapper {
    display: flex;
    align-items: flex-start;
    gap: 15px;
    max-width: 520px;
  }

  .item-2 .content-wrapper, .item-4 .content-wrapper,
  .item-6 .content-wrapper, .item-8 .content-wrapper,
  .item-10 .content-wrapper, .item-12 .content-wrapper,
  .item-14 .content-wrapper, .item-16 .content-wrapper {
    flex-direction: row-reverse;
    margin-left: auto;
  }

  .icon-container {
    flex-shrink: 0;
    width: clamp(60px, 8vw, 70px);
    height: clamp(60px, 8vw, 70px);
    background: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    border: 4px solid #fff;
    position: relative;
    z-index: 2;
  }

  .icon-container svg,
  .icon-container .custom-icon {
    width: clamp(28px, 5vw, 36px);
    height: clamp(28px, 5vw, 36px);
  }

  .icon-container .custom-icon {
    object-fit: contain;
  }

  .icon-1, .icon-2, .icon-3, .icon-4, 
  .icon-5, .icon-6, .icon-7, .icon-8,
  .icon-9, .icon-10, .icon-11, .icon-12,
  .icon-13, .icon-14, .icon-15, .icon-16 {
    background: #000;
    color: white;
  }

  .content-box {
    padding: clamp(18px, 3vw, 25px) clamp(20px, 4vw, 30px);
    max-width: 100%;
  }

  .item-2 .content-box, .item-4 .content-box,
  .item-6 .content-box, .item-8 .content-box,
  .item-10 .content-box, .item-12 .content-box,
  .item-14 .content-box, .item-16 .content-box {
    text-align: right;
  }

  @media (max-width: 1024px) {
    .item-1 { top: 220px; left: 10%; }
    .item-2 { top: 580px; right: 12%; }
    .item-3 { top: 940px; left: 25%; }
    .item-4 { top: 1300px; right: 15%; }
    .item-5 { top: 1660px; left: 18%; }
    .item-6 { top: 2020px; right: 10%; }
    .item-7 { top: 2380px; left: 22%; }
    .item-8 { top: 2740px; right: 18%; }
    .item-9 { top: 3100px; left: 15%; }
    .item-10 { top: 3460px; right: 20%; }
    .item-11 { top: 3820px; left: 28%; }
    .item-12 { top: 4180px; right: 12%; }
    .item-13 { top: 4540px; left: 18%; }
    .item-14 { top: 4900px; right: 18%; }
    .item-15 { top: 5260px; left: 25%; }
    .item-16 { top: 5620px; right: 15%; }
  }

  @media (max-width: 768px) {
    .mlm-timeline-container { 
      padding: 0 15px; 
    }
    
    .timeline-hero { 
      margin-bottom: 100px; 
    }
    
    .content-wrapper { 
      max-width: 400px; 
    }
  }

  @media (max-width: 480px) {
    .timeline-item {
      left: 50% !important;
      right: auto !important;
      transform: translateX(-50%) scale(0.85);
    }

    .timeline-item.visible {
      transform: translateX(-50%) scale(1) !important;
    }

    .item-1 { top: 200px; } .item-2 { top: 500px; }
    .item-3 { top: 800px; } .item-4 { top: 1100px; }
    .item-5 { top: 1400px; } .item-6 { top: 1700px; }
    .item-7 { top: 2000px; } .item-8 { top: 2300px; }
    .item-9 { top: 2600px; } .item-10 { top: 2900px; }
    .item-11 { top: 3200px; } .item-12 { top: 3500px; }
    .item-13 { top: 3800px; } .item-14 { top: 4100px; }
    .item-15 { top: 4400px; } .item-16 { top: 4700px; }

    .content-wrapper {
      max-width: 320px;
      flex-direction: row !important;
      margin-left: 0 !important;
    }

    .content-box {
      text-align: left !important;
    }
  }
{%- endstyle -%}

<section class="mlm-timeline {{ section.settings.background_color | default: 'bg-neutral-light' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" 
         id="{{ section.id }}"
         {% if section.settings.background_image %}data-bg="{{ section.settings.background_image }}"{% endif %}>
  <div class="container">
    <div class="inner-container {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_padding_y_mobile | default: 'py-xl' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-lg' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }} {{ section.settings.container_border_radius | default: 'rounded-none' }}" 
         {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image }}"{% endif %}>
      
      <div class="mlm-timeline-container">
        
        <!-- Hero Section -->
        {% if section.settings.show_hero %}
        <div class="timeline-hero text-center mb-2xl">
          {% if section.settings.hero_heading != blank %}
          <div class="hero-heading-wrapper mb-lg">
            <h1 class="{{ section.settings.hero_heading_font_family | default: 'font-primary' }} {{ section.settings.hero_heading_font_size | default: 'text-4xl' }} {{ section.settings.hero_heading_font_size_desktop | default: 'lg:text-6xl' }} {{ section.settings.hero_heading_font_weight | default: 'font-black' }} {{ section.settings.hero_heading_color | default: 'text-black' }} leading-tight">
              {{ section.settings.hero_heading | default: "The MLM Ecommerce Maze" }}
            </h1>
          </div>
          {% endif %}
          
          {% if section.settings.hero_description != blank %}
          <div class="hero-description-wrapper">
            <p class="{{ section.settings.hero_description_font_family | default: 'font-body' }} {{ section.settings.hero_description_font_size | default: 'text-lg' }} {{ section.settings.hero_description_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.hero_description_font_weight | default: 'font-normal' }} {{ section.settings.hero_description_color | default: 'text-neutral-dark' }} leading-relaxed max-w-3xl mx-auto">
              {{ section.settings.hero_description | default: "Why building ecommerce for direct sales is exponentially more complex than traditional online stores" }}
            </p>
          </div>
          {% endif %}
        </div>
        {% endif %}

        <!-- SVG Path -->
        <svg class="path-svg" id="pathSvg-{{ section.id }}">
          <defs>
            <marker id="arrowhead-{{ section.id }}" markerWidth="10" markerHeight="10" refX="9" refY="3" orient="auto">
              <polygon points="0 0, 10 3, 0 6" class="path-arrow" />
            </marker>
          </defs>
          <path class="dotted-path" id="dottedPath-{{ section.id }}" d="" marker-end="url(#arrowhead-{{ section.id }})"></path>
        </svg>

        <!-- Timeline Items (Blocks) -->
        {% if section.blocks.size > 0 %}
        <div class="timeline-items">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'timeline_step' %}
                <div class="timeline-item item-{{ forloop.index }} {{ section.settings.item_animation_class | default: '' }}" 
                     data-step="{{ forloop.index }}"
                     {{ block.fluid_attributes }}>
                  
                  <div class="content-wrapper">
                    <div class="icon-container icon-{{ forloop.index }}">
                      {% if block.settings.custom_icon != blank %}
                        <img src="{{ block.settings.custom_icon | image_url: width: 36 }}" 
                             alt="{{ block.settings.step_title | default: 'Timeline step' }}"
                             class="custom-icon">
                      {% else %}
                        <svg viewBox="0 0 24 24" fill="currentColor" class="default-icon">
                          {% case forloop.index %}
                            {% when 1 %}
                              <path d="M12 7V3H2v18h20V7H12zM6 19H4v-2h2v2zm0-4H4v-2h2v2zm0-4H4V9h2v2zm0-4H4V5h2v2zm4 12H8v-2h2v2zm0-4H8v-2h2v2zm0-4H8V9h2v2zm0-4H8V5h2v2zm10 12h-8v-2h2v-2h-2v-2h2v-2h-2V9h8v10zm-2-8h-2v2h2v-2zm0 4h-2v2h2v-2z"/>
                            {% when 2 %}
                              <path d="M4 6h16v2H4zm0 5h16v2H4zm0 5h16v2H4z"/>
                            {% when 3 %}
                              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                            {% when 4 %}
                              <path d="M19 3h-4.18C14.4 1.84 13.3 1 12 1c-1.3 0-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm2 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
                            {% when 5 %}
                              <path d="M20 4H4c-1.11 0-1.99.89-1.99 2L2 18c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z"/>
                            {% when 6 %}
                              <path d="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0l4.6-4.6-4.6-4.6L16 6l6 6-6 6-1.4-1.4z"/>
                            {% when 7 %}
                              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/>
                            {% when 8 %}
                              <path d="M21 6h-2v9H6v2c0 .55.45 1 1 1h11l4 4V7c0-.55-.45-1-1-1zm-4 6V3c0-.55-.45-1-1-1H3c-.55 0-1 .45-1 1v14l4-4h10c.55 0 1-.45 1-1z"/>
                            {% when 9 %}
                              <path d="M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6z"/>
                            {% when 10 %}
                              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                            {% when 11 %}
                              <path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/>
                            {% when 12 %}
                              <path d="M15 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm-9-2V7H4v3H1v2h3v3h2v-3h3v-2H6zm9 4c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                            {% when 13 %}
                              <path d="M12 2l-5.5 9h11L12 2zm0 3.84L13.93 9h-3.87L12 5.84zM17.5 13c-2.49 0-4.5 2.01-4.5 4.5s2.01 4.5 4.5 4.5 4.5-2.01 4.5-4.5-2.01-4.5-4.5-4.5zm0 7c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5zM3 21.5h8v-8H3v8zm2-6h4v4H5v-4z"/>
                            {% when 14 %}
                              <path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/>
                            {% when 15 %}
                              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                            {% when 16 %}
                              <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z"/>
                          {% endcase %}
                        </svg>
                      {% endif %}
                    </div>
                    
                    <div class="content-box">
                      {% if block.settings.step_title != blank %}
                      <h2 class="{{ section.settings.step_title_font_family | default: 'font-primary' }} {{ section.settings.step_title_font_size | default: 'text-xl' }} {{ section.settings.step_title_font_size_desktop | default: 'lg:text-2xl' }} {{ section.settings.step_title_font_weight | default: 'font-bold' }} {{ section.settings.step_title_color | default: 'text-black' }} leading-tight">
                        {{ block.settings.step_title | default: "Timeline Step" }}
                      </h2>
                      {% endif %}
                      
                      {% if block.settings.step_description != blank %}
                      <p class="{{ section.settings.step_description_font_family | default: 'font-body' }} {{ section.settings.step_description_font_size | default: 'text-sm' }} {{ section.settings.step_description_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.step_description_font_weight | default: 'font-normal' }} {{ section.settings.step_description_color | default: 'text-black' }} leading-relaxed">
                        {{ block.settings.step_description | default: "Add your timeline step description here." }}
                      </p>
                      {% endif %}
                    </div>
                  </div>
                </div>
            {% endcase %}
          {% endfor %}
        </div>
        {% endif %}
        
      </div>
    </div>
  </div>
</section>

<script>
// MLM Timeline Interactive Functionality
document.addEventListener('DOMContentLoaded', function() {
  // Initialize timeline for each section instance
  const timelineSections = document.querySelectorAll('.mlm-timeline');
  
  timelineSections.forEach(function(section) {
    initTimeline(section);
  });
});

function initTimeline(section) {
  const sectionId = section.id;
  const timelineItems = section.querySelectorAll('.timeline-item');
  const dottedPath = section.querySelector(`#dottedPath-${sectionId}`);
  const pathSvg = section.querySelector(`#pathSvg-${sectionId}`);
  
  if (!timelineItems.length || !dottedPath || !pathSvg) return;

  function updatePath() {
    const icons = Array.from(section.querySelectorAll('.icon-container'));
    if (icons.length === 0) return;

    const points = icons.map(icon => {
      const rect = icon.getBoundingClientRect();
      const containerRect = pathSvg.getBoundingClientRect();
      return {
        x: rect.left + rect.width / 2 - containerRect.left,
        y: rect.top + rect.height / 2 - containerRect.top
      };
    });

    const isMobile = window.innerWidth <= 480;
    const isTablet = window.innerWidth <= 1024;
    
    let pathData = `M ${points[0].x} ${points[0].y}`;
    
    const curvePatterns = [
      { wave: 1.6, offset1: 0.35, offset2: 0.65, perpMult1: 1.4, perpMult2: -0.9 },
      { wave: 1.1, offset1: 0.25, offset2: 0.75, perpMult1: -1.2, perpMult2: 0.7 },
      { wave: 1.8, offset1: 0.4, offset2: 0.6, perpMult1: 1.5, perpMult2: -1.1 },
      { wave: 1.3, offset1: 0.3, offset2: 0.7, perpMult1: -1.3, perpMult2: 1.0 },
      { wave: 1.5, offset1: 0.35, offset2: 0.65, perpMult1: 1.6, perpMult2: -0.8 },
      { wave: 1.2, offset1: 0.28, offset2: 0.72, perpMult1: -1.1, perpMult2: 0.9 },
      { wave: 1.7, offset1: 0.32, offset2: 0.68, perpMult1: 1.3, perpMult2: -1.0 },
      { wave: 1.4, offset1: 0.38, offset2: 0.62, perpMult1: -1.4, perpMult2: 0.85 }
    ];
    
    for (let i = 0; i < points.length - 1; i++) {
      const current = points[i];
      const next = points[i + 1];
      const deltaX = next.x - current.x;
      const deltaY = next.y - current.y;
      const distance = Math.sqrt(deltaX * deltaX + deltaY * deltaY);
      
      const pattern = curvePatterns[i % curvePatterns.length];
      
      let cp1x, cp1y, cp2x, cp2y;
      
      if (isMobile) {
        const waveIntensity = 35 + (i * 15 % 40);
        const direction = pattern.perpMult1 > 0 ? 1 : -1;
        
        cp1x = current.x + (waveIntensity * direction * pattern.wave);
        cp1y = current.y + deltaY * pattern.offset1;
        cp2x = next.x + (waveIntensity * -direction * Math.abs(pattern.perpMult2) * 0.8);
        cp2y = next.y - deltaY * (1 - pattern.offset2);
      } else if (isTablet) {
        const baseWave = window.innerWidth * 0.07;
        const wave = baseWave * pattern.wave;
        
        const perpX = -deltaY / distance * wave;
        const perpY = deltaX / distance * wave;
        
        cp1x = current.x + deltaX * pattern.offset1 + perpX * pattern.perpMult1;
        cp1y = current.y + deltaY * pattern.offset1 + perpY * pattern.perpMult1;
        cp2x = next.x - deltaX * (1 - pattern.offset2) + perpX * pattern.perpMult2;
        cp2y = next.y - deltaY * (1 - pattern.offset2) + perpY * pattern.perpMult2;
      } else {
        const baseWave = window.innerWidth * 0.09;
        const wave = baseWave * pattern.wave;
        
        const perpX = -deltaY / distance * wave;
        const perpY = deltaX / distance * wave;
        
        const chaos1 = Math.sin(i * 2.3) * 30;
        const chaos2 = Math.cos(i * 1.7) * 40;
        
        cp1x = current.x + deltaX * pattern.offset1 + perpX * pattern.perpMult1 + chaos1;
        cp1y = current.y + deltaY * pattern.offset1 + perpY * pattern.perpMult1;
        cp2x = next.x - deltaX * (1 - pattern.offset2) + perpX * pattern.perpMult2 + chaos2;
        cp2y = next.y - deltaY * (1 - pattern.offset2) + perpY * pattern.perpMult2;
      }
      
      pathData += ` C ${cp1x} ${cp1y}, ${cp2x} ${cp2y}, ${next.x} ${next.y}`;
    }

    dottedPath.setAttribute('d', pathData);
  }

  // Intersection Observer for animations
  const observerOptions = {
    threshold: 0.2,
    rootMargin: '-30px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, observerOptions);

  // Observe all timeline items
  timelineItems.forEach(item => {
    observer.observe(item);
  });

  // Handle resize events
  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(updatePath, 100);
  });
  
  // Initial path update
  window.addEventListener('load', () => {
    setTimeout(updatePath, 150);
  });
  
  // Multiple attempts to ensure path is drawn
  setTimeout(updatePath, 100);
  setTimeout(updatePath, 500);
  
  // Update path when images load
  const images = section.querySelectorAll('img');
  images.forEach(img => {
    img.addEventListener('load', updatePath);
  });
}
</script>

{% schema %}
{
  "name": "MLM Timeline",
  "tag": "section",
  "class": "mlm-timeline-section",
  "settings": [
    {
      "type": "header",
      "content": "Hero Settings"
    },
    {
      "type": "checkbox",
      "id": "show_hero",
      "label": "Show Hero Section",
      "default": true
    },
    {
      "type": "text",
      "id": "hero_heading",
      "label": "Hero Heading",
      "default": "The MLM Ecommerce Maze"
    },
    {
