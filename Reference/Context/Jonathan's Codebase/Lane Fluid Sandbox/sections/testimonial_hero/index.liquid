<!-- Testimonial Hero Section -->
<section class="testimonial-hero {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.section_padding_y_mobile | default: 'py-16' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-24' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image }}"{% endif %}>
  <div class="container">
    <div class="inner-container {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-8' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-12' }} {{ section.settings.container_padding_x_mobile | default: 'px-6' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-8' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image }}"{% endif %}>
      
      <!-- Testimonials Grid (Blocks) -->
      {% if section.blocks.size > 0 %}
      <div class="testimonials-wrapper mb-12">
        {% assign block_count = section.blocks.size %}
        {% assign grid_cols = 'md:grid-cols-1' %}
        {% if block_count == 2 %}
          {% assign grid_cols = 'md:grid-cols-2' %}
        {% elsif block_count == 3 %}
          {% assign grid_cols = 'md:grid-cols-3' %}
        {% elsif block_count >= 4 %}
          {% assign grid_cols = 'md:grid-cols-4' %}
        {% endif %}

        <div class="testimonials-grid grid grid-cols-1 {{ grid_cols }} gap-8">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'testimonial' %}
                <div class="testimonial-item text-center" style="gap: var(--space-4);" {{ block.fluid_attributes }}>
                  <div class="stars flex justify-center" style="gap: var(--space-1); margin-bottom: 5px;">
                    {% for i in (1..5) %}
                      <span class="star {{ section.settings.star_color | default: 'text-warning' }}" style="font-size: 1rem;">★</span>
                    {% endfor %}
                  </div>
                  <p class="{{ section.settings.testimonial_font_family | default: 'font-body' }} {{ section.settings.testimonial_font_size | default: 'text-base' }} font-normal {{ section.settings.testimonial_color | default: 'text-black' }}">
                    "{{ block.settings.text | default: 'Add your testimonial text here.' }}"
                  </p>
                </div>
            {% endcase %}
          {% endfor %}
        </div>
      </div>
      {% endif %}

      <!-- Main Content -->
      <div class="main-content text-center max-w-5xl mx-auto">
        
        <!-- Main Heading with Accent -->
        <div class="heading-wrapper mb-8">
          <h1 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-4xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-6xl' }} {{ section.settings.heading_font_weight | default: 'font-black' }} {{ section.settings.heading_color | default: 'text-black' }} leading-tight">
            {% assign heading_text = section.settings.heading | default: "The We-Volution" %}
            {% if heading_text contains "We-Volution" %}
              {% assign parts = heading_text | split: "We-Volution" %}
              {{ parts[0] }}<span class="relative inline-block">We-Volution{% if section.settings.show_heading_accent and section.settings.accent_image %}
                <img src="{{ section.settings.accent_image }}" alt="" class="accent-underline absolute bottom-0 left-0 w-full h-auto" style="transform: translateY(50%);">
              {% elsif section.settings.show_heading_accent %}
                <div class="heading-accent absolute bottom-0 left-0 w-full h-2 {{ section.settings.accent_color | default: 'bg-info' }} opacity-60" style="transform: translateY(50%);"></div>
              {% endif %}</span>{{ parts[1] }}
            {% else %}
              {{ heading_text }}
            {% endif %}
          </h1>
        </div>

        <!-- Description -->
        <div class="description-wrapper mb-8">
          <h2 class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-xl' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-2xl' }} {{ section.settings.description_font_weight | default: 'font-medium' }} {{ section.settings.description_color | default: 'text-black' }} mb-4 leading-relaxed">
            {{ section.settings.description | default: "Commerce is evolving from \"buy this now\" to \"let me help you understand\"—and it's about time." }}
          </h2>
          
          <p class="{{ section.settings.subdescription_font_family | default: 'font-body' }} {{ section.settings.subdescription_font_size | default: 'text-lg' }} {{ section.settings.subdescription_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.subdescription_font_weight | default: 'font-normal' }} {{ section.settings.subdescription_color | default: 'text-neutral-dark' }} max-w-4xl mx-auto leading-relaxed">
            {{ section.settings.subdescription | default: "People don't want to be sold to; they want to be guided. The customer journey isn't just checkout—it's awareness, education, trust, and advocacy all connected. Welcome to We-Commerce" }}
          </p>
        </div>

        <!-- Buttons -->
        <div class="buttons-wrapper flex flex-col sm:flex-row justify-center items-center gap-4">
          {% if section.settings.show_button_one %}
          <a href="{{ section.settings.button_one_url | default: '#' }}" 
             class="btn btn-{{ section.settings.button_one_style | default: 'filled' }}-{{ section.settings.button_one_color | default: 'primary' }} {{ section.settings.button_one_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded' }}">
            {{ section.settings.button_one_text | default: "Join The We-Volution" }}
          </a>
          {% endif %}
          
          {% if section.settings.show_button_two %}
          <a href="{{ section.settings.button_two_url | default: '#' }}" 
             class="btn btn-{{ section.settings.button_two_style | default: 'outline' }}-{{ section.settings.button_two_color | default: 'black' }} {{ section.settings.button_two_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded' }}">
            {{ section.settings.button_two_text | default: "Watch a demo" }}
          </a>
          {% endif %}
        </div>

      </div>
      
    </div>
  </div>
</section>

