
<!-- Features Grid Section -->
<section class="features-grid section {{ section.settings.section_background_color | default: 'bg-white' }} {{ section.settings.section_padding | default: 'py-2xl' }}">
  <div class="container py-xl lg:py-3xl px-lg lg:px-xl">
    <div class="inner-container {{ section.settings.container_background_color | default: 'bg-transparent' }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding | default: 'p-0' }}">
      
      <!-- Header Content -->
      <div class="features-header text-center">
        
        <!-- Main Heading -->
        {% if section.settings.heading != blank %}
        <div class="heading-wrapper mb-2xl">
          <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-4xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-black' }} {{ section.settings.heading_color | default: 'text-black' }} leading-tight">
            {{ section.settings.heading | default: "The complete system you've been trying to build" }}
          </h2>
        </div>
        {% endif %}
        
        <!-- Description -->
        {% if section.settings.description != blank %}
        <div class="description-wrapper mb-2xl">
          <p class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-lg' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-neutral-dark' }} leading-relaxed max-w-4xl mx-auto">
            {{ section.settings.description | default: "You've spent years trying to connect website builders to payment systems to commission engines. We built it all as one connected platform because that's the only way it actually works." }}
          </p>
        </div>
        {% endif %}
        
      </div>
      
      <!-- Features Grid -->
      <div class="features-grid-wrapper">
        <div class="features-grid-container">
          
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'feature_item' %}
                <div class="feature-item {{ section.settings.feature_background_color | default: 'bg-transparent' }} {{ section.settings.feature_border_radius | default: 'rounded-lg' }} {{ section.settings.feature_padding | default: 'p-lg' }}" {{ block.fluid_attributes }}>
                  
                  <!-- Feature Icon -->
                  {% if block.settings.show_icon %}
                  <div class="feature-icon-wrapper mb-lg">
                    <div class="feature-icon {{ section.settings.icon_background_color | default: 'bg-black' }} {{ section.settings.icon_border_radius | default: 'rounded-lg' }} w-12 h-12 flex items-center justify-center overflow-hidden">
                      {% if block.settings.icon_image %}
                        <img src="{{ block.settings.icon_image | image_url: width: 48 }}"
                             alt="{{ block.settings.icon_alt | default: 'Feature icon' }}"
                             class="w-full h-full object-cover">
                      {% else %}
                        <img src="{{ 'placeholder-image.png' | asset_url }}"
                             alt="{{ block.settings.icon_alt | default: 'Feature icon placeholder' }}"
                             class="w-full h-full object-cover">
                      {% endif %}
                    </div>
                  </div>
                  {% endif %}
                  
                  <!-- Feature Title -->
                  {% if block.settings.title != blank %}
                  <div class="feature-title-wrapper mb-md">
                    <h3 class="{{ section.settings.feature_title_font_family | default: 'font-primary' }} {{ section.settings.feature_title_font_size | default: 'text-xl' }} {{ section.settings.feature_title_font_size_desktop | default: 'lg:text-2xl' }} {{ section.settings.feature_title_font_weight | default: 'font-bold' }} {{ section.settings.feature_title_color | default: 'text-black' }} leading-tight">
                      {{ block.settings.title | default: "Feature Title" }}
                    </h3>
                  </div>
                  {% endif %}
                  
                  <!-- Feature Description -->
                  {% if block.settings.description != blank %}
                  <div class="feature-description-wrapper">
                    <p class="{{ section.settings.feature_description_font_family | default: 'font-body' }} {{ section.settings.feature_description_font_size | default: 'text-base' }} {{ section.settings.feature_description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.feature_description_font_weight | default: 'font-normal' }} {{ section.settings.feature_description_color | default: 'text-neutral-dark' }} leading-relaxed">
                      {{ block.settings.description | default: "Add a description for this feature that explains its benefits and value to your customers." }}
                    </p>
                  </div>
                  {% endif %}
                  
                </div>
            {% endcase %}
          {% endfor %}
          
        </div>
      </div>
      
    </div>
  </div>
</section>

<style>
  {% render 'section-css', section_id: 'features_grid' %}
</style>

