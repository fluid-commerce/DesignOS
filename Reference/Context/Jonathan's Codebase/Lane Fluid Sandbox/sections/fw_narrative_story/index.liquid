<link rel="stylesheet" href="{{ 'fw_narrative_story/styles.css' | asset_url }}">

<section class="fw-narrative-story {{ section.settings.background_color }} {{ section.settings.section_padding_y_mobile }} {{ section.settings.section_padding_y_desktop }} {{ section.settings.section_border_radius }}"
  {% if section.settings.background_image != blank %}data-bg style="background-image: url('{{ section.settings.background_image | image_url }}'); background-size: cover; background-position: center;"{% endif %}>

  <div class="fw-narrative-story__container {{ section.settings.container_background_color }} {{ section.settings.container_border_radius }} {{ section.settings.container_padding_y_mobile }} {{ section.settings.container_padding_y_desktop }} {{ section.settings.container_padding_x_mobile }} {{ section.settings.container_padding_x_desktop }}"
    {% if section.settings.container_background_image != blank %}data-bg style="background-image: url('{{ section.settings.container_background_image | image_url }}'); background-size: cover; background-position: center;"{% endif %}>

    {% if section.settings.show_accent_bar and section.settings.accent_bar_image != blank %}
    <div class="fw-narrative-story__accent">
      <img src="{{ section.settings.accent_bar_image | image_url }}" alt="" aria-hidden="true" class="fw-narrative-story__accent-img">
    </div>
    {% endif %}

    {% if section.settings.eyebrow != blank %}
    <p class="fw-narrative-story__eyebrow {{ section.settings.eyebrow_font_family }} {{ section.settings.eyebrow_font_size }} {{ section.settings.eyebrow_font_size_desktop }} {{ section.settings.eyebrow_font_weight }} {{ section.settings.eyebrow_color }}">
      {{ section.settings.eyebrow }}
    </p>
    {% endif %}

    <div class="fw-narrative-story__content {{ section.settings.content_max_width }}"
      {% if section.settings.emphasize_color != blank %}style="--emphasize-color: var(--clr-{{ section.settings.emphasize_color }});"{% endif %}>

      {% for block in section.blocks %}
        {% if block.type == 'story_block' %}
        <div class="fw-story-block" {{ block.fluid_attributes }}>

          {% if block.settings.story_heading != blank %}
          <h3 class="fw-story-block__heading {{ block.settings.story_heading_font_family }} {{ block.settings.story_heading_font_size }} {{ block.settings.story_heading_font_size_desktop }} {{ block.settings.story_heading_font_weight }} {{ block.settings.story_heading_color }}">
            {{ block.settings.story_heading }}
          </h3>
          {% endif %}

          {% if block.settings.story_body != blank %}
          <div class="fw-story-block__body {{ block.settings.story_body_font_family }} {{ block.settings.story_body_font_size }} {{ block.settings.story_body_font_size_desktop }} {{ block.settings.story_body_font_weight }} {{ block.settings.story_body_color }}">
            {{ block.settings.story_body }}
          </div>
          {% endif %}

          {% if block.settings.show_divider and forloop.last == false %}
          <hr class="fw-story-block__divider">
          {% endif %}

        </div>
        {% endif %}
      {% endfor %}

    </div>

    {% if section.settings.closing_statement != blank %}
    <div class="fw-narrative-closing {{ section.settings.content_max_width }}"
      {% if section.settings.emphasize_color != blank %}style="--emphasize-color: var(--clr-{{ section.settings.emphasize_color }});"{% endif %}>
      <p class="fw-narrative-closing__text {{ section.settings.closing_font_family }} {{ section.settings.closing_font_size }} {{ section.settings.closing_font_size_desktop }} {{ section.settings.closing_font_weight }} {{ section.settings.closing_color }}">
        {{ section.settings.closing_statement }}
      </p>
    </div>
    {% endif %}

  </div>
</section>

