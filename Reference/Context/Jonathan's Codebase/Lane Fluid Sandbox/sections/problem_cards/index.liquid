<!-- Problem Cards Section -->
<link rel="stylesheet" href="{{ 'problem_cards/styles.css' | asset_url }}">

<section class="problem-cards-section {{ section.settings.background_color }} {{ section.settings.section_padding_y_mobile }} {{ section.settings.section_padding_y_desktop }}">
  <div class="container">
    
    <!-- Section Header -->
    {% if section.settings.show_header %}
    <div class="problem-cards-header {{ section.settings.header_alignment }} mb-3xl">
      {% if section.settings.show_tagline and section.settings.tagline != blank %}
      <span class="problem-cards-tagline {{ section.settings.tagline_font_family }} {{ section.settings.tagline_font_size }} {{ section.settings.tagline_font_size_desktop }} {{ section.settings.tagline_font_weight }} {{ section.settings.tagline_color }} mb-md block">
        {{ section.settings.tagline }}
      </span>
      {% endif %}
      
      {% if section.settings.heading != blank %}
      <h2 class="problem-cards-heading {{ section.settings.heading_font_family }} {{ section.settings.heading_font_size }} {{ section.settings.heading_font_size_desktop }} {{ section.settings.heading_font_weight }} {{ section.settings.heading_color }} mb-lg">
        {{ section.settings.heading }}
      </h2>
      {% endif %}
      
      {% if section.settings.description != blank %}
      <p class="problem-cards-description {{ section.settings.description_font_family }} {{ section.settings.description_font_size }} {{ section.settings.description_font_size_desktop }} {{ section.settings.description_font_weight }} {{ section.settings.description_color }} max-w-3xl {% if section.settings.header_alignment == 'text-center' %}mx-auto{% endif %}">
        {{ section.settings.description }}
      </p>
      {% endif %}
    </div>
    {% endif %}
    
    <!-- Cards Grid -->
    <div class="problem-cards-grid grid grid-cols-1 md:grid-cols-2 {{ section.settings.gap }}">
      {% for block in section.blocks %}
        {% if block.type == 'problem_card' %}
        <div class="problem-card {{ block.settings.card_background_color }} {{ section.settings.card_border_radius }} {{ section.settings.card_padding }}" {{ block.fluid_attributes }}>
          
          <!-- Card Icon/Number -->
          {% if block.settings.show_icon %}
          <div class="problem-card-icon mb-md">
            {% if block.settings.icon_image != blank %}
            <img src="{{ block.settings.icon_image | image_url }}" alt="" class="problem-icon-img">
            {% elsif block.settings.icon_text != blank %}
            <span class="problem-icon-text {{ section.settings.icon_font_family }} {{ section.settings.icon_font_size }} {{ block.settings.icon_color }}">
              {{ block.settings.icon_text }}
            </span>
            {% endif %}
          </div>
          {% endif %}
          
          <!-- Card Title -->
          {% if block.settings.title != blank %}
          <h3 class="problem-card-title {{ section.settings.card_title_font_family }} {{ section.settings.card_title_font_size }} {{ section.settings.card_title_font_size_desktop }} {{ section.settings.card_title_font_weight }} {{ block.settings.title_color }} mb-md">
            {{ block.settings.title }}
          </h3>
          {% endif %}
          
          <!-- Card Description -->
          {% if block.settings.description != blank %}
          <p class="problem-card-description {{ section.settings.card_description_font_family }} {{ section.settings.card_description_font_size }} {{ section.settings.card_description_font_size_desktop }} {{ section.settings.card_description_font_weight }} {{ block.settings.description_color }}">
            {{ block.settings.description }}
          </p>
          {% endif %}
          
          <!-- Optional Paint Mark -->
          {% if block.settings.show_paint_mark and block.settings.paint_mark_image != blank %}
          <img src="{{ block.settings.paint_mark_image | image_url }}" alt="" class="problem-card-paint-mark" aria-hidden="true">
          {% endif %}
        </div>
        {% endif %}
      {% endfor %}
    </div>
    
  </div>
</section>

