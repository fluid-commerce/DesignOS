      >
        <span class="copyright">© 2024 Relume. {{ 'footer.all_rights_reserved' | t }}.</span>
        <div
          class="terms-policy flex justify-center align-center gap-6 md-tab-flex-row flex-col gap-6"
        >
          <a href="" class="underline">{{ 'footer.privacy_policy' | t }}</a>
          <a href="" class="underline">{{ 'footer.terms_of_service' | t }}</a>
          <a href="" class="underline">{{ 'footer.cookies_settings' | t }}</a>
        </div>
      </div>
    </div>
  </footer>
