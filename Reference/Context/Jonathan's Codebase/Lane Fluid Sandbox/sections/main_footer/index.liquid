{% schema %}
{
  "name": "main_footer",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "default": "footer",
      "label": "Menu"
    },
    {
      "type": "checkbox",
      "id": "reset_footer_bg_color",
      "label": "Reset footer background to default",
      "default": false
    },
    {
      "type": "color_background",
      "id": "footer_bg_color",
      "label": "Footer Background Color",
      "default": ""
    },
    {
      "type": "range",
      "id": "footer_text_size",
      "min": 10,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Footer Font Size",
      "default": 14
    },
    {
      "type": "select",
      "id": "footer_menu_font_weight",
      "options": [
        { "value": "font-light", "label": "Light" },
        { "value": "font-normal", "label": "Regular" },
        { "value": "font-medium", "label": "Medium" },
        { "value": "font-semibold", "label": "Semi Bold" },
        { "value": "font-bold", "label": "Bold" },
        { "value": "font-extrabold", "label": "Extra Bold" },
        { "value": "font-semibold", "label": "Default" }
      ],
      "default": "font-semibold",
      "label": "Footer Menu Font Weight"
    },
    {
      "type": "select",
      "id": "footer_copy_right_font_weight",
      "options": [
        { "value": "font-light", "label": "Light" },
        { "value": "font-normal", "label": "Regular" },
        { "value": "font-medium", "label": "Medium" },
        { "value": "font-semibold", "label": "Semi Bold" },
        { "value": "font-bold", "label": "Bold" },
        { "value": "font-extrabold", "label": "Extra Bold" },
        { "value": "font-normal", "label": "Default" }
      ],
      "default": "font-normal",
      "label": "Footer Copy Right Section Font Weight"
    },
    {
      "type": "checkbox",
      "id": "reset_footer_text_color",
      "label": "Reset Footer Text Color to default",
      "default": false
    },
    {
      "type": "color_background",
      "id": "footer_text_color",
      "default": "#000",
      "label": "Footer Text Color"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Footer Main Section Padding Top(Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Footer Main Section Padding Bottom(Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Footer Main Section Padding Top(Mobile)",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Footer Main Section Padding Bottom(Mobile)",
      "default": 48
    }
  ]
}
{% endschema %}