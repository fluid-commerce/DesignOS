{%- style -%}
  {%- if section.settings.reset_footer_bg_color != true and section.settings.footer_bg_color != blank -%}
  footer.site-footer{
      background-color: {{ section.settings.footer_bg_color }};
    }
  {%- endif -%}

  {%- if section.settings.reset_footer_text_color != true and section.settings.footer_text_color != blank -%}
    footer.site-footer{
      color: {{ section.settings.footer_text_color }};
    }
    footer.site-footer svg path{
      fill: {{ section.settings.footer_text_color }};
    }
    footer.site-footer a {
      color: {{ section.settings.footer_text_color }};
    }
  {%- endif -%}

  footer.site-footer {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    font-size: {{ section.settings.footer_text_size }}px;
  }

  @media screen and (min-width: 768px) {
    footer.site-footer {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
  }
  
{%- endstyle -%}
{% unless request.page_type == 'medium' or request.page_type == 'library' %}   
