    },
    {
      "type": "color_background",
      "id": "secondary_button_text",
      "default": "#000000",
      "label": "Secondary Button Text"
    },
    {
      "type": "color_background",
      "id": "secondary_button_border",
      "default": "#000000",
      "label": "Secondary Button Border"
    },
    {
      "type": "image_picker",
      "id": "logo_1",
      "label": "Logo 1"
    },
    {
      "type": "text",
      "id": "logo_1_alt",
      "label": "Logo 1 Alt Text",
      "info": "Describe the logo for accessibility"
    },
    {
      "type": "url",
