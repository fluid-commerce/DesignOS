        </div>
      </div>
      
    </div>
  </div>
</section>

<style>
.cta-banner3-section {
  padding: 64px 0;
  position: relative;
}

.cta-banner3-section .cta-banner3-content {
  max-width: 768px;
  margin: 0 auto;
}

.cta-banner3-section .cta-banner3-content h2 {
  margin-bottom: 24px;
}

.cta-banner3-section .cta-banner3-content p {
  margin-bottom: 32px;
  line-height: 1.6;
}

.cta-banner3-section .cta-banner3-buttons {
  display: flex;
  justify-content: center;
  gap: 16px;
  flex-wrap: wrap;
  margin-bottom: 48px;
}

.cta-banner3-section .cta-banner3-buttons .btn {
  padding: 12px 24px;
  text-decoration: none;
  border-radius: 4px;
  font-weight: 500;
  transition: all 0.3s ease;
}

.cta-banner3-section .cta-banner3-buttons .btn:hover {
  opacity: 0.8;
}

.cta-banner3-section .cta-banner3-logos {
  margin-top: 48px;
  padding-top: 32px;
}

.cta-banner3-section .logos-container {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 32px;
  flex-wrap: wrap;
}

.cta-banner3-section .logo-item {
  display: flex;
  align-items: center;
  justify-content: center;
}

.cta-banner3-section .logo-image {
  height: 40px;
  width: auto;
  object-fit: contain;
  opacity: 0.7;
  transition: opacity 0.3s ease;
}

.cta-banner3-section .logo-image:hover {
  opacity: 1;
}

@media (max-width: 767px) {
  .cta-banner3-section .cta-banner3-buttons {
    flex-direction: column;
    align-items: center;
  }
  
  .cta-banner3-section .cta-banner3-buttons .btn {
    text-align: center;
    min-width: 200px;
  }
  
  .cta-banner3-section .logos-container {
    gap: 24px;
  }
}
</style>

{% schema %}
{
  "name": "CTA Banner 3",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Medium length heading goes here",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "intro_text",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique.",
      "label": "Intro Text"
    },
    {
      "type": "checkbox",
      "id": "show_primary_button",
      "default": true,
      "label": "Show Primary Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "default": "Button",
      "label": "Primary Button Text"
    },
    {
      "type": "url",
      "id": "button_link",
      "default": "#",
      "label": "Primary Button Link"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_button",
      "default": true,
      "label": "Show Secondary Button"
    },
    {
      "type": "text",
      "id": "button_text_secondary",
      "default": "Button",
      "label": "Secondary Button Text"
    },
    {
      "type": "url",
      "id": "button_link_secondary",
      "default": "#",
      "label": "Secondary Button Link"
    },
    {
      "type": "color_background",
      "id": "background_color",
      "default": "#f8f8f8",
      "label": "Background Color"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image",
      "info": "Optional background image (will override background color)"
    },
    {
      "type": "color_background",
      "id": "overlay_color",
      "default": "#000000",
      "label": "Background Overlay Color",
      "info": "Color overlay on top of background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Background Overlay Opacity",
      "default": 40,
      "info": "0% = transparent, 100% = solid color"
    },
    {
      "type": "color_background",
      "id": "heading_color",
      "default": "#000000",
      "label": "Heading Color"
    },
    {
      "type": "color_background",
