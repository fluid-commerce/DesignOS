            {% else %}
              <div class="logo-placeholder" style="background-color: #e5e5e5; border-radius: 6px; height: 40px; width: 100px; display: flex; align-items: center; justify-content: center; border: 1px dashed #ccc;">
                <div class="placeholder-content text-center" style="color: #999;">
                  <svg width="20" height="20" fill="currentColor" viewBox="0 0 20 20" style="margin: 0 auto;">
                    <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd"></path>
                  </svg>
                </div>
              </div>
            {% endif %}
          </div>

          <!-- Logo 6 -->
          <div class="logo-item">
            {% if section.settings.logo_6 != blank %}
              {% if section.settings.logo_6_link != blank %}
