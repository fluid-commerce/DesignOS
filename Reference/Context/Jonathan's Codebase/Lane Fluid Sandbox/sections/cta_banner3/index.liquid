<section class="cta-banner3-section" 
         style="background-color: {{ section.settings.background_color | default: '#f8f8f8' }};
                {% if section.settings.background_image != blank %}
                background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;
                {% endif %}">
  
  {% if section.settings.background_image != blank %}
    <div class="cta-banner3-overlay" 
         style="background-color: {{ section.settings.overlay_color | default: '#000000' }}; 
                opacity: {{ section.settings.overlay_opacity | default: 40 | divided_by: 100.0 }}; 
                position: absolute; 
                top: 0; 
                left: 0; 
                width: 100%; 
                height: 100%; 
                z-index: 1;"></div>
  {% endif %}
  
  <div class="container" style="position: relative; z-index: 2;">
    <div class="cta-banner3-wrapper text-center py-16">
      
      <!-- Centered Content -->
      <div class="cta-banner3-content max-w-4xl mx-auto">
        <h2 class="text-h2 mb-6" style="color: {{ section.settings.heading_color | default: '#000000' }};">
          {{ section.settings.heading }}
        </h2>
        
        <p class="text-lg mb-8 max-w-3xl mx-auto" style="color: {{ section.settings.text_color | default: '#666666' }};">
          {{ section.settings.intro_text }}
        </p>
        
        {% if section.settings.show_primary_button or section.settings.show_secondary_button %}
          <div class="cta-banner3-buttons flex justify-center gap-4 flex-wrap mb-12">
            {% if section.settings.show_primary_button and section.settings.button_text != blank %}
              <a href="{{ section.settings.button_link }}" 
                 class="btn"
                 style="background-color: {{ section.settings.primary_button_bg | default: '#000000' }}; color: {{ section.settings.primary_button_text | default: '#ffffff' }}; border: 1px solid {{ section.settings.primary_button_bg | default: '#000000' }};">
                {{ section.settings.button_text }}
              </a>
            {% endif %}
            
            {% if section.settings.show_secondary_button and section.settings.button_text_secondary != blank %}
              <a href="{{ section.settings.button_link_secondary }}" 
                 class="btn"
                 style="background-color: transparent; color: {{ section.settings.secondary_button_text | default: '#000000' }}; border: 1px solid {{ section.settings.secondary_button_border | default: '#000000' }};">
                {{ section.settings.button_text_secondary }}
              </a>
            {% endif %}
          </div>
        {% endif %}
      </div>
      
      <!-- Logos Section -->
      <div class="cta-banner3-logos">
        <div class="logos-container flex justify-center align-center gap-8 flex-wrap">
          
          <!-- Logo 1 -->
          <div class="logo-item">
            {% if section.settings.logo_1 != blank %}
              {% if section.settings.logo_1_link != blank %}
                <a href="{{ section.settings.logo_1_link }}" target="_blank" rel="noopener">
              {% endif %}
              <img src="{{ section.settings.logo_1 | image_url: width: 120 }}" 
                   alt="{{ section.settings.logo_1_alt | default: 'Partner logo' }}"
                   class="logo-image"
                   style="height: 40px; width: auto; object-fit: contain; opacity: 0.7;">
              {% if section.settings.logo_1_link != blank %}
                </a>
              {% endif %}
            {% else %}
              <!-- Logo placeholder -->
              <div class="logo-placeholder" style="background-color: #e5e5e5; border-radius: 6px; height: 40px; width: 100px; display: flex; align-items: center; justify-content: center; border: 1px dashed #ccc;">
                <div class="placeholder-content text-center" style="color: #999;">
                  <svg width="20" height="20" fill="currentColor" viewBox="0 0 20 20" style="margin: 0 auto;">
                    <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd"></path>
                  </svg>
                </div>
              </div>
            {% endif %}
          </div>

          <!-- Logo 2 -->
