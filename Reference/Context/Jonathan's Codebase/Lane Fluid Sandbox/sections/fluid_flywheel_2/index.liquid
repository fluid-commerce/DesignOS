<!-- Fluid Flywheel 2 - SVG wheel with segment buttons, content on right -->
<link rel="stylesheet" href="{{ 'fluid_flywheel_2/styles.css' | asset_url }}">

<section class="fluid-flywheel2-section {{ section.settings.section_padding_y_mobile }} {{ section.settings.section_padding_y_desktop }}"
         style="background-color: {{ section.settings.background_color }};{% if section.settings.background_image != blank %} background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}'); background-size: cover; background-position: center;{% endif %}--flywheel2-offset-left: {{ section.settings.wheel_offset_left | default: 0 }}px;"
         id="flywheel2-{{ section.id }}"
         data-inactive-opacity="{{ section.settings.inactive_segment_opacity | divided_by: 100.0 }}"
         data-rotation-duration="{{ section.settings.rotation_duration }}"
         data-content-duration="{{ section.settings.content_animation_duration }}">

