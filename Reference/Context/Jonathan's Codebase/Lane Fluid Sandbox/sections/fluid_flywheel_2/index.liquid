<script>
(function() {
  const sectionId = '{{ section.id }}';
  const sectionEl = document.getElementById('flywheel2-' + sectionId);
  if (!sectionEl) return;

  const ROTATION_ANGLES = [0, 51, 102, 154, 205, 257, 308];
  const wheelGroup = sectionEl.querySelector('.flywheel2-wheel-group');
  const segments = sectionEl.querySelectorAll('.flywheel2-segment');
  const defaultPanel = sectionEl.querySelector('.flywheel2-default-content');
  const contentPanels = sectionEl.querySelectorAll('.flywheel2-content-panel[data-index]');

  const inactiveOpacity = parseFloat(sectionEl.dataset.inactiveOpacity) || 0.4;
  const rotationDuration = parseFloat(sectionEl.dataset.rotationDuration) || 0.6;
  const contentDuration = parseFloat(sectionEl.dataset.contentDuration) || 0.45;

  let activeIndex = -1;
  let currentRotation = 0;

  function setRotation(deg) {
    currentRotation = deg;
    wheelGroup.style.transition = 'transform ' + rotationDuration + 's cubic-bezier(0.4, 0, 0.2, 1)';
    wheelGroup.style.transform = 'rotate(' + deg + 'deg)';
  }

  function shortestRotationTo(targetDeg) {
    var delta = targetDeg - currentRotation;
    while (delta > 180) delta -= 360;
    while (delta < -180) delta += 360;
    return currentRotation + delta;
  }

  function updateSegmentOpacity() {
    segments.forEach(function(seg) {
      var segIndex = parseInt(seg.getAttribute('data-index'), 10);
      if (activeIndex === -1) {
        seg.style.opacity = '1';
        seg.classList.remove('active');
      } else {
        seg.style.opacity = (segIndex === activeIndex) ? '1' : String(inactiveOpacity);
        seg.classList.toggle('active', segIndex === activeIndex);
      }
    });
  }

  function showDefaultContent(show) {
    if (!defaultPanel) return;
    if (show) {
      defaultPanel.style.display = 'block';
      defaultPanel.dataset.active = 'true';
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          defaultPanel.classList.add('visible');
        });
      });
    } else {
      defaultPanel.classList.remove('visible');
      defaultPanel.dataset.active = 'false';
      setTimeout(function() {
        if (defaultPanel.dataset.active === 'false') defaultPanel.style.display = 'none';
      }, Math.round(contentDuration * 1000) + 50);
    }
  }

  function showContentPanel(index) {
    if (index === -1) {
      showDefaultContent(true);
      contentPanels.forEach(function(panel) {
        panel.classList.remove('visible');
        panel.dataset.active = 'false';
        panel.style.display = 'none';
      });
      return;
    }
    showDefaultContent(false);
    contentPanels.forEach(function(panel) {
      var panelIndex = parseInt(panel.getAttribute('data-index'), 10);
      if (panelIndex === index) {
        panel.dataset.active = 'true';
        panel.style.display = 'block';
        requestAnimationFrame(function() {
          requestAnimationFrame(function() {
            panel.classList.add('visible');
          });
        });
      } else {
        panel.classList.remove('visible');
        panel.dataset.active = 'false';
        setTimeout(function() {
          if (panel.dataset.active === 'false') panel.style.display = 'none';
        }, Math.round(contentDuration * 1000) + 50);
      }
    });
  }

  function selectSegment(index) {
    if (index === activeIndex) {
      activeIndex = -1;
      updateSegmentOpacity();
      showContentPanel(-1);
      showDefaultContent(true);
      return;
    }
    activeIndex = index;
    setRotation(shortestRotationTo(ROTATION_ANGLES[index]));
    updateSegmentOpacity();
    showContentPanel(index);
    showDefaultContent(false);
  }

  segments.forEach(function(seg) {
    var idx = parseInt(seg.getAttribute('data-index'), 10);
    seg.style.cursor = 'pointer';
    seg.addEventListener('click', function() { selectSegment(idx); });
    seg.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); selectSegment(idx); }
    });
  });

  updateSegmentOpacity();
  showContentPanel(-1);
  setRotation(0);
})();
</script>

