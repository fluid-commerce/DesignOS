    <!-- Right: Content (no visible container) - default content + segment panels -->
    <div class="flywheel2-content-wrap" id="flywheel2-content-{{ section.id }}">
      <div class="flywheel2-default-content flywheel2-content-panel visible" id="flywheel2-default-{{ section.id }}" data-default="true" style="display: block;">
        <div class="flywheel2-content-inner">
          {% if section.settings.default_header_text != blank %}
            <h3 class="flywheel2-content-title {{ section.settings.default_header_font_family }} {{ section.settings.default_header_font_size }} {{ section.settings.default_header_font_weight }}"
                style="color: {{ section.settings.default_header_color }};">
              {{ section.settings.default_header_text }}
            </h3>
          {% endif %}
          {% if section.settings.default_body1_text != blank %}
            <div class="flywheel2-content-description">
              <p class="{{ section.settings.default_body1_font_family }} {{ section.settings.default_body1_font_size }} {{ section.settings.default_body1_font_weight }}"
                 style="color: {{ section.settings.default_body1_color }};">
                {{ section.settings.default_body1_text }}
              </p>
            </div>
          {% endif %}
          {% if section.settings.default_body2_text != blank %}
            <div class="flywheel2-content-description">
              <p class="{{ section.settings.default_body2_font_family }} {{ section.settings.default_body2_font_size }} {{ section.settings.default_body2_font_weight }}"
                 style="color: {{ section.settings.default_body2_color }};">
                {{ section.settings.default_body2_text }}
              </p>
            </div>
          {% endif %}
          {% if section.settings.default_media != blank %}
            <div class="flywheel2-content-media">
              <div class="flywheel2-media-image">
                <img src="{{ section.settings.default_media | image_url: width: 800 }}" alt="" loading="lazy">
              </div>
            </div>
          {% endif %}
        </div>
      </div>
      {% for block in section.blocks %}{% if block.type == 'payments_green' %}
        <div class="flywheel2-content-panel" data-index="0" {{ block.fluid_attributes }}>
          <div class="flywheel2-content-inner {% if block.settings.media_above_text %}flywheel2-media-on-top{% endif %}">
            <h3 class="flywheel2-content-title {{ section.settings.content_title_font_family }} {{ section.settings.content_title_font_size }} {{ section.settings.content_title_font_weight }}"
                style="color: {{ block.settings.content_title_color | default: section.settings.content_title_color }};">
              {{ block.settings.segment_title }}
            </h3>
            {% if block.settings.segment_description != blank %}
              <div class="flywheel2-content-description">
                <p class="{{ block.settings.description_font_family | default: section.settings.content_text_font_family }} {{ section.settings.content_text_font_size }} {{ section.settings.content_text_font_weight }}"
                   style="color: {{ section.settings.content_text_color }};">
                  {{ block.settings.segment_description }}
                </p>
              </div>
            {% endif %}
            {% if block.settings.content_media != blank or block.settings.content_video_url != blank %}
              <div class="flywheel2-content-media">
                {% if block.settings.content_video_url != blank %}
                  <div class="flywheel2-media-video">
                    <iframe src="{{ block.settings.content_video_url }}" frameborder="0" allowfullscreen loading="lazy"></iframe>
                  </div>
                {% elsif block.settings.content_media != blank %}
                  <div class="flywheel2-media-image">
                    <img src="{{ block.settings.content_media | image_url: width: 800 }}" alt="{{ block.settings.segment_title }}" loading="lazy">
                  </div>
                {% endif %}
              </div>
            {% endif %}
          </div>
        </div>
      {% endif %}{% endfor %}
      {% for block in section.blocks %}{% if block.type == 'checkout_teal' %}
        <div class="flywheel2-content-panel" data-index="1" {{ block.fluid_attributes }}>
          <div class="flywheel2-content-inner {% if block.settings.media_above_text %}flywheel2-media-on-top{% endif %}">
            <h3 class="flywheel2-content-title {{ section.settings.content_title_font_family }} {{ section.settings.content_title_font_size }} {{ section.settings.content_title_font_weight }}"
                style="color: {{ block.settings.content_title_color | default: section.settings.content_title_color }};">
              {{ block.settings.segment_title }}
            </h3>
            {% if block.settings.segment_description != blank %}
              <div class="flywheel2-content-description">
                <p class="{{ block.settings.description_font_family | default: section.settings.content_text_font_family }} {{ section.settings.content_text_font_size }} {{ section.settings.content_text_font_weight }}"
                   style="color: {{ section.settings.content_text_color }};">
                  {{ block.settings.segment_description }}
                </p>
              </div>
            {% endif %}
            {% if block.settings.content_media != blank or block.settings.content_video_url != blank %}
              <div class="flywheel2-content-media">
                {% if block.settings.content_video_url != blank %}
                  <div class="flywheel2-media-video">
                    <iframe src="{{ block.settings.content_video_url }}" frameborder="0" allowfullscreen loading="lazy"></iframe>
                  </div>
                {% elsif block.settings.content_media != blank %}
                  <div class="flywheel2-media-image">
                    <img src="{{ block.settings.content_media | image_url: width: 800 }}" alt="{{ block.settings.segment_title }}" loading="lazy">
                  </div>
                {% endif %}
              </div>
            {% endif %}
          </div>
        </div>
      {% endif %}{% endfor %}
      {% for block in section.blocks %}{% if block.type == 'droplets_blue' %}
        <div class="flywheel2-content-panel" data-index="2" {{ block.fluid_attributes }}>
          <div class="flywheel2-content-inner {% if block.settings.media_above_text %}flywheel2-media-on-top{% endif %}">
            <h3 class="flywheel2-content-title {{ section.settings.content_title_font_family }} {{ section.settings.content_title_font_size }} {{ section.settings.content_title_font_weight }}"
                style="color: {{ block.settings.content_title_color | default: section.settings.content_title_color }};">
              {{ block.settings.segment_title }}
            </h3>
            {% if block.settings.segment_description != blank %}
              <div class="flywheel2-content-description">
                <p class="{{ block.settings.description_font_family | default: section.settings.content_text_font_family }} {{ section.settings.content_text_font_size }} {{ section.settings.content_text_font_weight }}"
                   style="color: {{ section.settings.content_text_color }};">
                  {{ block.settings.segment_description }}
                </p>
              </div>
            {% endif %}
            {% if block.settings.content_media != blank or block.settings.content_video_url != blank %}
              <div class="flywheel2-content-media">
                {% if block.settings.content_video_url != blank %}
                  <div class="flywheel2-media-video">
                    <iframe src="{{ block.settings.content_video_url }}" frameborder="0" allowfullscreen loading="lazy"></iframe>
                  </div>
                {% elsif block.settings.content_media != blank %}
                  <div class="flywheel2-media-image">
                    <img src="{{ block.settings.content_media | image_url: width: 800 }}" alt="{{ block.settings.segment_title }}" loading="lazy">
                  </div>
                {% endif %}
              </div>
            {% endif %}
          </div>
        </div>
      {% endif %}{% endfor %}
      {% for block in section.blocks %}{% if block.type == 'builder_purple' %}
        <div class="flywheel2-content-panel" data-index="3" {{ block.fluid_attributes }}>
          <div class="flywheel2-content-inner {% if block.settings.media_above_text %}flywheel2-media-on-top{% endif %}">
            <h3 class="flywheel2-content-title {{ section.settings.content_title_font_family }} {{ section.settings.content_title_font_size }} {{ section.settings.content_title_font_weight }}"
                style="color: {{ block.settings.content_title_color | default: section.settings.content_title_color }};">
