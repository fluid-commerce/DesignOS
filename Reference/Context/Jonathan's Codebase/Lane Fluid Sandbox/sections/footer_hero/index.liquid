<!-- Footer Hero Section -->
<section class="footer-hero section {{ section.settings.background_color | default: 'bg-black' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  <div class="container">
    <div class="inner-container {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_padding_y_mobile | default: 'py-xl' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-lg' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }} {{ section.settings.container_border_radius | default: 'rounded-none' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Main Footer Content -->
      <div class="footer-main-content grid grid-cols-1 lg:grid-cols-2 {{ section.settings.main_content_gap | default: 'gap-xl' }} {{ section.settings.main_content_alignment | default: 'items-start' }} {{ section.settings.main_content_margin_bottom | default: 'mb-3xl' }}">
        
        <!-- Left Side - Hero Content -->
        <div class="footer-hero-content">
          
          {% if section.settings.main_heading != blank %}
          <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-bold' }} {{ section.settings.heading_color | default: 'text-white' }} {{ section.settings.heading_line_height | default: 'leading-tight' }} {{ section.settings.heading_margin_bottom | default: 'mb-lg' }}">
            {{ section.settings.main_heading }}
          </h2>
          {% endif %}
          
          {% if section.settings.description != blank %}
          <p class="{{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_line_height | default: 'leading-relaxed' }} {{ section.settings.description_color | default: 'text-gray-300' }} {{ section.settings.description_margin_bottom | default: 'mb-lg' }}">
            {{ section.settings.description }}
          </p>
          {% endif %}
          
          {% if section.settings.show_cta and section.settings.cta_text != blank %}
          <div class="footer-cta">
            <a href="{{ section.settings.cta_url | default: '#' }}" 
               class="inline-flex items-center {{ section.settings.cta_text_color | default: 'text-white' }} {{ section.settings.cta_font_size | default: 'text-lg' }} {{ section.settings.cta_font_weight | default: 'font-semibold' }} hover:opacity-75 transition-opacity duration-200"
               {% if section.settings.cta_open_new_tab %}target="_blank" rel="noopener"{% endif %}>
              {{ section.settings.cta_text }}
              <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
          </div>
          {% endif %}
          
        </div>
        

<!-- Right Side - Navigation Links -->
{% if section.settings.navigation_menu and section.settings.navigation_menu.menu_items.size > 0 %}
<div class="footer-navigation">
  <div class="nav-columns grid grid-cols-1 lg:grid-cols-{{ section.settings.nav_columns }} gap-8 lg:gap-12">
    {% assign nav_items = section.settings.navigation_menu.menu_items %}
    {% assign items_per_column = nav_items.size | divided_by: section.settings.nav_columns | ceil %}
    
    {% for i in (1..section.settings.nav_columns) %}
      <div class="nav-column flex flex-col gap-3">
        {% assign column_start = forloop.index0 | times: items_per_column %}
        {% assign column_end = column_start | plus: items_per_column %}
        
        {% for link in nav_items %}
          {% assign current_index = forloop.index0 %}
          {% if current_index >= column_start and current_index < column_end %}
            <div class="nav-link-item">
              <a href="{{ link.url }}" 
                 class="nav-link inline-block hover:opacity-75 transition-opacity duration-200 {{ section.settings.nav_link_font_family | default: 'font-primary' }} {{ section.settings.nav_link_font_size | default: 'text-sm' }} {{ section.settings.nav_link_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.nav_link_font_weight | default: 'font-medium' }} {{ section.settings.nav_link_color | default: 'text-gray-300' }}">
                {{ link.title }}
              </a>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endfor %}
  </div>
</div>
{% endif %}
      </div>
      
      <!-- Divider Line -->
      {% if section.settings.show_divider %}
      <div class="footer-divider {{ section.settings.divider_margin_bottom | default: 'mb-xl' }}">
        <hr class="{{ section.settings.divider_color | default: 'border-gray-700' }}">
      </div>
      {% endif %}
      
      <!-- Bottom Footer -->
      <div class="footer-bottom flex flex-col lg:flex-row {{ section.settings.bottom_alignment | default: 'justify-between items-center' }} {{ section.settings.bottom_gap | default: 'gap-lg' }}">
        
        <!-- Left Side - Logo & Copyright -->
        <div class="footer-bottom-left flex flex-col lg:flex-row {{ section.settings.bottom_left_alignment | default: 'items-center' }} {{ section.settings.bottom_left_gap | default: 'gap-lg' }}">
          
          {% if section.settings.show_logo %}
          <div class="footer-logo">
            {% if section.settings.logo_image != blank %}
              <img src="{{ section.settings.logo_image | image_url: width: 200 }}" 
                   alt="{{ section.settings.logo_alt | default: 'Company Logo' }}"
                   class="footer-logo-img {{ section.settings.logo_max_height | default: 'max-h-12' }} w-auto object-contain">
            {% else %}
              <img src="{{ 'footer-logo.png' | asset_url }}" 
                   alt="Company Logo"
                   class="footer-logo-img {{ section.settings.logo_max_height | default: 'max-h-12' }} w-auto object-contain">
            {% endif %}
          </div>
          {% endif %}
          
          {% if section.settings.copyright_text != blank %}
          <div class="footer-copyright">
            <p class="{{ section.settings.copyright_font_size | default: 'text-sm' }} {{ section.settings.copyright_color | default: 'text-gray-400' }}">
              {{ section.settings.copyright_text }}
            </p>
          </div>
          {% endif %}
          
        </div>
        
        <!-- Right Side - Social Icons -->
        {% if section.settings.show_social_icons %}
        <div class="footer-social">
          <div class="social-icons flex {{ section.settings.social_gap | default: 'gap-md' }} {{ section.settings.social_alignment | default: 'items-center' }}">
            
            {% if section.settings.facebook_url != blank %}
            <a href="{{ section.settings.facebook_url }}" 
               class="social-icon {{ section.settings.social_icon_size | default: 'w-8 h-8' }} {{ section.settings.social_icon_color | default: 'text-gray-400' }} hover:opacity-75 transition-opacity duration-200"
               target="_blank" rel="noopener" aria-label="Facebook">
              <svg fill="currentColor" viewBox="0 0 24 24" class="w-full h-full">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
            {% endif %}
            
            {% if section.settings.instagram_url != blank %}
            <a href="{{ section.settings.instagram_url }}" 
               class="social-icon {{ section.settings.social_icon_size | default: 'w-8 h-8' }} {{ section.settings.social_icon_color | default: 'text-gray-400' }} hover:opacity-75 transition-opacity duration-200"
               target="_blank" rel="noopener" aria-label="Instagram">
              <svg fill="currentColor" viewBox="0 0 24 24" class="w-full h-full">
                <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 6.621 5.367 11.988 11.988 11.988s11.987-5.367 11.987-11.988C24.004 5.367 18.637.001 12.017.001zM8.449 16.988c-2.508 0-4.541-2.033-4.541-4.541s2.033-4.541 4.541-4.541 4.541 2.033 4.541 4.541-2.033 4.541-4.541 4.541zm7.058 0c-2.508 0-4.541-2.033-4.541-4.541s2.033-4.541 4.541-4.541 4.541 2.033 4.541 4.541-2.033 4.541-4.541 4.541z"/>
              </svg>
            </a>
            {% endif %}
            
            {% if section.settings.twitter_url != blank %}
            <a href="{{ section.settings.twitter_url }}" 
               class="social-icon {{ section.settings.social_icon_size | default: 'w-8 h-8' }} {{ section.settings.social_icon_color | default: 'text-gray-400' }} hover:opacity-75 transition-opacity duration-200"
               target="_blank" rel="noopener" aria-label="X (Twitter)">
              <svg fill="currentColor" viewBox="0 0 24 24" class="w-full h-full">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
            {% endif %}
            
            {% if section.settings.linkedin_url != blank %}
            <a href="{{ section.settings.linkedin_url }}" 
               class="social-icon {{ section.settings.social_icon_size | default: 'w-8 h-8' }} {{ section.settings.social_icon_color | default: 'text-gray-400' }} hover:opacity-75 transition-opacity duration-200"
               target="_blank" rel="noopener" aria-label="LinkedIn">
              <svg fill="currentColor" viewBox="0 0 24 24" class="w-full h-full">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
            {% endif %}
            
            {% if section.settings.youtube_url != blank %}
            <a href="{{ section.settings.youtube_url }}" 
               class="social-icon {{ section.settings.social_icon_size | default: 'w-8 h-8' }} {{ section.settings.social_icon_color | default: 'text-gray-400' }} hover:opacity-75 transition-opacity duration-200"
               target="_blank" rel="noopener" aria-label="YouTube">
              <svg fill="currentColor" viewBox="0 0 24 24" class="w-full h-full">
                <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
            </a>
            {% endif %}
            
          </div>
        </div>
        {% endif %}
        
      </div>
      
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Footer Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Navigation Settings"
    },
    {
      "type": "link_list",
      "id": "navigation_menu",
      "label": "Navigation Menu",
      "default": "footer-menu",
      "info": "Select a navigation menu to display in the footer"
    },
    {
      "type": "range",
      "id": "nav_columns",
      "label": "Number of Navigation Columns",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2,
      "info": "Choose how many columns to display navigation links in"
    },
    {
      "type": "header",
      "content": "Content Elements"
    },
    {
      "type": "text",
      "id": "main_heading",
      "label": "Main Heading",
      "default": "Where commerce meets human nature"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Connecting every moment from curiosity to commission in one seamless, trusted platform"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show CTA Link",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Start Building"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    },
    {
      "type": "checkbox",
      "id": "cta_open_new_tab",
      "label": "Open CTA in New Tab",
      "default": false
    },
    {
      "type": "header",
      "content": "Logo & Copyright"
    },
    {
      "type": "checkbox",
      "id": "show_logo",
      "label": "Show Logo",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo Image"
    },
    {
      "type": "text",
      "id": "logo_alt",
      "label": "Logo Alt Text",
      "default": "Company Logo"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "© 2025 Fluid Commerce Inc. All rights reserved."
