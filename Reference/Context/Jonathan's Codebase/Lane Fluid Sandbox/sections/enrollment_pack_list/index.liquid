{%- style -%}
  .enrollment-product-{{ section.id }} {
    padding-top: {{ section.settings.section_padding_top_mobile | default: 64 }}px;
    padding-bottom: {{ section.settings.section_padding_bottom_mobile | default: 64 }}px;
    background-color: {{ section.settings.background_color | default: 'transparent' }};
  }

  @media (min-width: 1280px) {
    .enrollment-product-{{ section.id }} {
      padding-top: {{ section.settings.section_padding_top_desktop | default: 100 }}px;
      padding-bottom: {{ section.settings.section_padding_bottom_desktop | default: 100 }}px;
    }
  }

  .enrollment-product-{{ section.id }} .section-tagline {
    color: {{ section.settings.tagline_color | default: '#666666' }};
  }

  .enrollment-product-{{ section.id }} .section-heading {
    color: {{ section.settings.heading_color | default: '#000000' }};
  }

  .enrollment-product-{{ section.id }} .section-description {
    color: {{ section.settings.description_color | default: '#666666' }};
  }

  .enrollment-product-{{ section.id }} .view-all-button {
    background-color: {{ section.settings.button_background_color | default: 'transparent' }};
    color: {{ section.settings.button_text_color | default: '#000000' }};
    border: {{ section.settings.button_border_width | default: 1 }}px solid {{ section.settings.button_border_color | default: '#000000' }};
  }

  .enrollment-product-{{ section.id }} .product-title {
    color: {{ section.settings.product_title_color | default: '#000000' }};
  }

  .enrollment-product-{{ section.id }} .product-variant {
    color: {{ section.settings.product_variant_color | default: '#666666' }};
  }

  .enrollment-product-{{ section.id }} .product-price {
    color: {{ section.settings.product_price_color | default: '#000000' }};
  }
{%- endstyle -%}

<section class="product-collection-section section-y-spacing enrollment-product-{{ section.id }}">
  <div class="container">
    <div class="header-section">
      <div class="wrapper sm-desktop-flex flex-wrap align-end">
        <div class="desc">
          {% if section.settings.show_tagline %}
            <h6 class="section-tagline {{ section.settings.tagline_font_size | default: 'text-base' }} {{ section.settings.tagline_font_size_desktop | default: 'sm-desktop-text-base' }} {{ section.settings.tagline_font_weight | default: 'font-normal' }}">
              {% if section.settings.tagline contains 'shop_page.' or section.settings.tagline contains 'shared.' %}
                {{ section.settings.tagline | t }}
              {% else %}
                {{ section.settings.tagline }}
              {% endif %}
            </h6>
          {% endif %}

          <div class="section-heading {{ section.settings.heading_font_size | default: 'text-5xl' }} {{ section.settings.heading_font_size_desktop | default: 'sm-desktop-text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-bold' }} py-3 sm-desktop-py-4">
            {% if section.settings.heading contains 'shop_page.' or section.settings.heading contains 'shared.' %}
              {{ section.settings.heading | t }}
            {% else %}
              {{ section.settings.heading }}
            {% endif %}
          </div>

          {% if section.settings.show_description %}
            <p class="section-description {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'sm-desktop-text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }}">
              {% if section.settings.description contains 'shop_page.' or section.settings.description contains 'shared.' %}
                {{ section.settings.description | t }}
              {% else %}
                {{ section.settings.description }}
              {% endif %}
            </p>
          {% endif %}
        </div>
      </div>
    </div>
    {%- paginate collection.enrollment_packs by 10 -%}
      <div class="product-list-section mt-12">
        <ul class="grid grid-cols-1 xl-phone-grid-cols-2 lg-tab-grid-cols-3 gap-x-8 sm-desktop-gap-x-12 gap-y-12 sm-desktop-gap-y-16">
          {% assign enrollment_packs_array = collection.enrollment_packs | parse_json %}
          {% for enrollment_pack in enrollment_packs_array %}
            {% if enrollment_pack.images_array.size > 0 %}
              {% assign image_url = enrollment_pack.images_array[0] %}
            {% elsif enrollment_pack.subscription_products and enrollment_pack.subscription_products[0].image %}
              {% assign image_url = enrollment_pack.subscription_products[0].image %}
            {% else %}
              {% assign image_url = '' %}
            {% endif %}

            <li>
              <a href="{{ enrollment_pack.url }}" class="product">
                <div class="image-section product-image-height image-hover-effect">
                  <img
                    src="{{ image_url }}"
                    alt="{{ enrollment_pack.title }}"
                    class="image-cover"
                  />
                </div>
                <div class="desc pt-4">
                  <div class="product-title text-hover-effect {{ section.settings.product_title_font_size | default: 'text-base' }} {{ section.settings.product_title_font_size_desktop | default: 'sm-desktop-text-lg' }} {{ section.settings.product_title_font_weight | default: 'font-semibold' }}">
                    {{ enrollment_pack.title }}
                  </div>
                  <div class="product-price {{ section.settings.product_price_font_size | default: 'text-base' }} {{ section.settings.product_price_font_size_desktop | default: 'sm-desktop-text-xl' }} {{ section.settings.product_price_font_weight | default: 'font-bold' }} pt-2">
                    {{ enrollment_pack.price }}
                  </div>
                </div>
              </a>
            </li>
          {% endfor %}
        </ul>
      </div>
      {%- if paginate.pages > 1 -%}
        {% render 'pagination', paginate: paginate, anchor: '' %}
      {%- endif -%}
    {% endpaginate %}
  </div>
</section>

