<link rel="stylesheet" href="{{ 'fw_cta_block/styles.css' | asset_url }}">

<section class="fw-cta-block {{ section.settings.background_color }} {{ section.settings.section_padding_y_mobile }} {{ section.settings.section_padding_y_desktop }} {{ section.settings.section_border_radius }}"
  {% if section.settings.background_image != blank %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>

  {% if section.settings.show_decorations %}
  <div class="fw-cta-block__decorations" aria-hidden="true">
    {% if section.settings.decoration_image_1 != blank %}
    <img src="{{ section.settings.decoration_image_1 | image_url }}" alt="" class="fw-cta-block__decoration fw-cta-block__decoration--1">
    {% endif %}
    {% if section.settings.decoration_image_2 != blank %}
    <img src="{{ section.settings.decoration_image_2 | image_url }}" alt="" class="fw-cta-block__decoration fw-cta-block__decoration--2">
    {% endif %}
  </div>
  {% endif %}

  {% if section.settings.bg_decoration_image != blank %}
  <img src="{{ section.settings.bg_decoration_image | image_url }}" alt="" class="fw-cta-block__bg-decoration" aria-hidden="true">
  {% endif %}

  <div class="fw-cta-block__container {{ section.settings.container_background_color }} {{ section.settings.container_border_radius }} {{ section.settings.container_padding_y_mobile }} {{ section.settings.container_padding_y_desktop }} {{ section.settings.container_padding_x_mobile }} {{ section.settings.container_padding_x_desktop }}"
    {% if section.settings.container_background_image != blank %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>

    <div class="fw-cta-block__content {{ section.settings.text_alignment }} {{ section.settings.content_max_width }}">

      {% if section.settings.eyebrow != blank %}
      <p class="fw-cta-block__eyebrow {{ section.settings.eyebrow_font_family }} {{ section.settings.eyebrow_font_size }} {{ section.settings.eyebrow_font_size_desktop }} {{ section.settings.eyebrow_font_weight }} {{ section.settings.eyebrow_color }}">
        {{ section.settings.eyebrow }}
      </p>
      {% endif %}

      {% if section.settings.headline != blank %}
      <h2 class="fw-cta-block__headline {{ section.settings.headline_font_family }} {{ section.settings.headline_font_size }} {{ section.settings.headline_font_size_desktop }} {{ section.settings.headline_font_weight }} {{ section.settings.headline_color }}">
        {{ section.settings.headline }}
      </h2>
      {% endif %}

      {% if section.settings.body != blank %}
      <div class="fw-cta-block__body {{ section.settings.body_font_family }} {{ section.settings.body_font_size }} {{ section.settings.body_font_size_desktop }} {{ section.settings.body_font_weight }} {{ section.settings.body_color }}">
        {{ section.settings.body }}
      </div>
      {% endif %}

      <div class="fw-cta-block__buttons {% if section.settings.text_alignment == 'text-center' %}fw-cta-block__buttons--center{% endif %}">
        {% if section.settings.show_button_one %}
        <a href="{{ section.settings.button_one_url | default: '#' }}"
           class="btn btn-{{ section.settings.button_one_style | default: 'filled' }}-{{ section.settings.button_one_color | default: 'primary' }} {{ section.settings.button_one_size | default: 'btn-md' }} {{ section.settings.button_one_font_weight | default: 'font-medium' }}">
          {{ section.settings.button_one_text | default: 'Learn More' }}
        </a>
        {% endif %}

        {% if section.settings.show_button_two %}
        <a href="{{ section.settings.button_two_url | default: '#' }}"
           class="btn btn-{{ section.settings.button_two_style | default: 'ghost' }}-{{ section.settings.button_two_color | default: 'white' }} {{ section.settings.button_two_size | default: 'btn-md' }} {{ section.settings.button_two_font_weight | default: 'font-medium' }}">
          {{ section.settings.button_two_text | default: 'Book a Demo' }}
        </a>
        {% endif %}
      </div>

    </div>
  </div>

</section>

