{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.section_padding_top_mobile | default: 40 }}px;
    padding-bottom: {{ section.settings.section_padding_bottom_mobile | default: 40 }}px;
  }

  @media screen and (min-width: 1280px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.section_padding_top_desktop | default: 80 }}px;
      padding-bottom: {{ section.settings.section_padding_bottom_desktop | default: 80 }}px;
    }
  }
{%- endstyle -%}

<section class="product-collection-section section-{{ section.id }}-padding" style="
  background-color: {{ section.settings.background_color | default: '#ffffff' }}; 
  color: {{ section.settings.text_color | default: '#000000' }};
">
  <div class="container">
    <div class="text-center">
      <span class="{{ section.settings.tagline_font_size | default: 'text-base' }} {{ section.settings.tagline_font_size_desktop | default: 'xl-tab-text-base' }} {{ section.settings.tagline_font_weight | default: 'font-semibold' }}" style="color: {{ section.settings.tagline_color | default: '#000000' }};">{{ section.settings.tagline | default: "Tagline" }}</span>
      <div class="py-3 sm-desktop-py-4 {{ section.settings.heading_font_size | default: 'text-h2' }} {{ section.settings.heading_font_size_desktop | default: 'text-h1' }} {{ section.settings.heading_font_weight | default: 'font-bold' }}" style="color: {{ section.settings.heading_color | default: '#000000' }};">{{ section.settings.heading | default: "Related Products" }}</div>
      <p class="{{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'xl-tab-text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }}" style="color: {{ section.settings.description_color | default: '#000000' }};">
        {{ section.settings.description | default: "Lorem ipsum dolor sit amet, consectetur adipiscing elit." }}
      </p>
    </div>
    
    <div class="product-list-section mt-12">
      <ul class="grid grid-cols-1 xl-phone-grid-cols-2 md-tab-grid-cols-3 gap-x-8 sm-desktop-gap-x-12 gap-y-12 sm-desktop-gap-y-16">
        {% for recommendation in product.recommendations limit: section.settings.products_to_show %}
          <li>
            <a href="{{ recommendation.url }}" class="product block">
              <div class="image-section product-image-height">
                <img
                  src="{{ recommendation.image_url }}"
                  alt="{{ recommendation.title }}"
                  class="image-cover"
                />
              </div>
              <div class="desc pt-4 text-center">
                <div class="{{ section.settings.product_title_font_size | default: 'text-base' }} {{ section.settings.product_title_font_size_desktop | default: 'xl-tab-text-base' }} {{ section.settings.product_title_font_weight | default: 'font-medium' }}" style="color: {{ section.settings.product_title_color | default: '#000000' }};">{{ recommendation.title}}</div>
                <p class="{{ section.settings.product_variant_font_size | default: 'text-sm' }} {{ section.settings.product_variant_font_size_desktop | default: 'xl-tab-text-sm' }} {{ section.settings.product_variant_font_weight | default: 'font-normal' }} pt-1" style="color: {{ section.settings.product_variant_color | default: '#666666' }};">{{ 'product.variant' | t }}</p>
                <div class="pt-2 {{ section.settings.product_price_font_size | default: 'text-lg' }} {{ section.settings.product_price_font_size_desktop | default: 'xl-tab-text-lg' }} {{ section.settings.product_price_font_weight | default: 'font-semibold' }}" style="color: {{ section.settings.product_price_color | default: '#000000' }};">{{ recommendation.price }}</div>
              </div>
            </a>
          </li>
        {%  endfor %}
       
      </ul>
    </div>

    {% if section.settings.show_view_all_button %}
    <div class="btn-section mt-12 sm-desktop-mt-20 flex justify-center">
      <a href="{{ section.settings.view_all_url | default: '#' }}" class="btn btn-border-primary">{{ section.settings.view_all_text | default: 'View All' }}</a>
    </div>
    {% endif %}
    <!-- .product-list -->
  </div>
</section>
