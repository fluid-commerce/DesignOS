<link rel="stylesheet" href="{{ 'fw_split_content/styles.css' | asset_url }}">

<section class="fw-split-section {{ section.settings.background_color }} {{ section.settings.section_padding_y_mobile }} {{ section.settings.section_padding_y_desktop }} {{ section.settings.section_border_radius }}"
  {% if section.settings.background_image != blank %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>

  <div class="fw-split-container {{ section.settings.container_background_color }} {{ section.settings.container_border_radius }} {{ section.settings.container_padding_y_mobile }} {{ section.settings.container_padding_y_desktop }} {{ section.settings.container_padding_x_mobile }} {{ section.settings.container_padding_x_desktop }}"
    {% if section.settings.container_background_image != blank %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>

    <div class="fw-split-content {{ section.settings.column_gap }} {{ section.settings.vertical_alignment }}{% if section.settings.reverse_columns %} fw-split-content--reversed{% endif %}">

      <!-- Left Column: Text Content -->
      <div class="fw-split-left">

        {% if section.settings.show_accent_bar and section.settings.accent_bar_image != blank %}
        <div class="fw-split-accent-bar">
          <img src="{{ section.settings.accent_bar_image | image_url }}" alt="" class="fw-split-accent-bar-img" aria-hidden="true">
        </div>
        {% endif %}

        {% if section.settings.eyebrow != blank %}
        <p class="fw-split-eyebrow {{ section.settings.eyebrow_font_family }} {{ section.settings.eyebrow_font_size }} {{ section.settings.eyebrow_font_size_desktop }} {{ section.settings.eyebrow_font_weight }} {{ section.settings.eyebrow_color }}">
          {{ section.settings.eyebrow }}
        </p>
        {% endif %}

        {% if section.settings.headline != blank %}
        <h2 class="fw-split-headline {{ section.settings.headline_font_family }} {{ section.settings.headline_font_size }} {{ section.settings.headline_font_size_desktop }} {{ section.settings.headline_font_weight }} {{ section.settings.headline_color }}">
          {{ section.settings.headline }}
        </h2>
        {% endif %}

        {% if section.settings.body != blank %}
        <div class="fw-split-body {{ section.settings.body_font_family }} {{ section.settings.body_font_size }} {{ section.settings.body_font_size_desktop }} {{ section.settings.body_font_weight }} {{ section.settings.body_color }}">
          {{ section.settings.body }}
        </div>
        {% endif %}

        {% if section.settings.show_ghost_link and section.settings.link_text != blank %}
        <a href="{{ section.settings.link_url | default: '#' }}"
           class="fw-split-ghost-link {{ section.settings.link_font_family }} {{ section.settings.link_font_size }} {{ section.settings.link_font_size_desktop }} {{ section.settings.link_font_weight }} {{ section.settings.link_color }}">
          {{ section.settings.link_text }}
        </a>
        {% endif %}

        {% if section.settings.show_button %}
        <a href="{{ section.settings.button_url | default: '#' }}"
           class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ section.settings.button_font_weight | default: 'font-medium' }}">
          {{ section.settings.button_text | default: 'Learn More' }}
        </a>
        {% endif %}

      </div>

      <!-- Right Column: Image or Block Content -->
      <div class="fw-split-right">

        {% if section.settings.right_image != blank %}
        <img src="{{ section.settings.right_image | image_url }}"
             alt="{{ section.settings.right_image_alt | default: '' }}"
             class="fw-split-right-image"
             loading="lazy">
        {% endif %}

        {% assign feature_cards = section.blocks | where: "type", "feature_card" %}
        {% if feature_cards.size > 0 %}
        <div class="fw-split-feature-grid">
          {% for block in feature_cards %}
          <div class="fw-split-feature-card" {{ block.fluid_attributes }}>
            {% if block.settings.card_tag != blank %}
            <span class="fw-split-card-tag {{ block.settings.card_tag_color }}">{{ block.settings.card_tag }}</span>
            {% endif %}
            {% if block.settings.card_title != blank %}
            <h3 class="fw-split-card-title {{ block.settings.card_title_color }}">{{ block.settings.card_title }}</h3>
            {% endif %}
            {% if block.settings.card_body != blank %}
            <p class="fw-split-card-body">{{ block.settings.card_body }}</p>
            {% endif %}
          </div>
          {% endfor %}
        </div>
        {% endif %}

        {% assign step_items = section.blocks | where: "type", "step_item" %}
        {% if step_items.size > 0 %}
        <div class="fw-split-steps">
          {% for block in step_items %}
          <div class="fw-split-step fw-split-step--{{ block.settings.step_color | default: 'primary' }}" {{ block.fluid_attributes }}>
            <div class="fw-split-step-indicator">
              <span class="fw-split-step-dot">
                {% if block.settings.step_icon != blank %}{{ block.settings.step_icon }}{% else %}{{ block.settings.step_number | default: forloop.index }}{% endif %}
              </span>
              {% unless forloop.last %}
              <span class="fw-split-step-line"></span>
              {% endunless %}
            </div>
            <div class="fw-split-step-content">
              {% if block.settings.step_title != blank %}
              <h4 class="fw-split-step-title">{{ block.settings.step_title }}</h4>
              {% endif %}
              {% if block.settings.step_body != blank %}
              <p class="fw-split-step-body">{{ block.settings.step_body }}</p>
              {% endif %}
            </div>
          </div>
          {% endfor %}
        </div>
        {% endif %}

      </div>

    </div>
  </div>
</section>

