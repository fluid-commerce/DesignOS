<!-- Bold CTA Section -->
<link rel="stylesheet" href="{{ 'bold_cta/styles.css' | asset_url }}">

<section class="bold-cta-section {{ section.settings.background_color }} {{ section.settings.section_padding_y_mobile }} {{ section.settings.section_padding_y_desktop }}">
  <div class="container">
    <div class="bold-cta-content max-w-3xl mx-auto {{ section.settings.text_alignment }}">
      
      <!-- Tagline -->
      {% if section.settings.show_tagline and section.settings.tagline != blank %}
      <span class="bold-cta-tagline {{ section.settings.tagline_font_family }} {{ section.settings.tagline_font_size }} {{ section.settings.tagline_font_size_desktop }} {{ section.settings.tagline_font_weight }} {{ section.settings.tagline_color }} mb-md block">
        {{ section.settings.tagline }}
      </span>
      {% endif %}
      
      <!-- Main Headline -->
      {% if section.settings.headline != blank %}
      <h2 class="bold-cta-headline {{ section.settings.headline_font_family }} {{ section.settings.headline_font_size }} {{ section.settings.headline_font_size_desktop }} {{ section.settings.headline_font_weight }} {{ section.settings.headline_color }} mb-lg">
        {{ section.settings.headline }}
      </h2>
      {% endif %}
      
      <!-- Subheadline with optional underline -->
      {% if section.settings.subheadline != blank %}
      <div class="bold-cta-subheadline-wrapper mb-xl relative inline-block">
        <p class="bold-cta-subheadline {{ section.settings.subheadline_font_family }} {{ section.settings.subheadline_font_size }} {{ section.settings.subheadline_font_size_desktop }} {{ section.settings.subheadline_font_weight }} {{ section.settings.subheadline_color }}">
          {{ section.settings.subheadline }}
        </p>
        {% if section.settings.show_underline and section.settings.underline_image != blank %}
        <img src="{{ section.settings.underline_image | image_url }}" alt="" class="cta-underline-accent" aria-hidden="true">
        {% endif %}
      </div>
      {% endif %}
      
      <!-- CTA Buttons -->
      <div class="bold-cta-buttons flex flex-wrap gap-md {% if section.settings.text_alignment == 'text-center' %}justify-center{% elsif section.settings.text_alignment == 'text-right' %}justify-end{% else %}justify-start{% endif %}">
        {% if section.settings.show_button_one %}
        <a href="{{ section.settings.button_one_url }}" 
           class="btn {{ section.settings.button_one_style }} {{ section.settings.button_one_size }}"
           {% if section.settings.button_one_new_tab %}target="_blank" rel="noopener"{% endif %}>
          {{ section.settings.button_one_text }}
        </a>
        {% endif %}
        
        {% if section.settings.show_button_two %}
        <a href="{{ section.settings.button_two_url }}" 
           class="btn {{ section.settings.button_two_style }} {{ section.settings.button_two_size }}"
           {% if section.settings.button_two_new_tab %}target="_blank" rel="noopener"{% endif %}>
          {{ section.settings.button_two_text }}
        </a>
        {% endif %}
      </div>
      
    </div>
  </div>
  
  <!-- Optional Decorative Elements -->
  {% if section.settings.show_decorations %}
  <div class="bold-cta-decorations" aria-hidden="true">
    {% if section.settings.decoration_image_1 != blank %}
    <img src="{{ section.settings.decoration_image_1 | image_url }}" alt="" class="decoration decoration-1">
    {% endif %}
    {% if section.settings.decoration_image_2 != blank %}
    <img src="{{ section.settings.decoration_image_2 | image_url }}" alt="" class="decoration decoration-2">
    {% endif %}
  </div>
  {% endif %}
</section>

