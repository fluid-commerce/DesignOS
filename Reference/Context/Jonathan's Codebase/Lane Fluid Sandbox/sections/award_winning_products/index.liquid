<!-- Award Winning Products Section -->
<section class="award-winning-products {{ section.settings.section_padding_y_mobile }} {{ section.settings.section_padding_y_desktop }} {{ section.settings.section_border_radius }} {{ section.settings.background_color }}" 
         id="{{ section.id }}"
         {% if section.settings.background_image != blank %}
         style="background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');"
         {% endif %}>
  <div class="container {{ section.settings.container_background_color }} {{ section.settings.container_border_radius }} {{ section.settings.container_padding_y_mobile }} {{ section.settings.container_padding_y_desktop }} {{ section.settings.container_padding_x_mobile }} {{ section.settings.container_padding_x_desktop }}"
       {% if section.settings.container_background_image != blank %}
       style="background-image: url('{{ section.settings.container_background_image | image_url: width: 1200 }}');"
       {% endif %}>
    
    <!-- Section Header -->
    {% if section.settings.show_section_header %}
      <div class="section-header {{ section.settings.header_text_align }} {{ section.settings.heading_margin_bottom }}">
        {% if section.settings.section_heading != blank %}
          <div class="heading-wrapper {{ section.settings.heading_margin_bottom }}">
            <h2 class="section-heading {{ section.settings.heading_font_size }} {{ section.settings.heading_font_size_desktop }} {{ section.settings.heading_font_weight }} {{ section.settings.heading_line_height }} {{ section.settings.heading_text_color | default: 'text-black' }}">
              {{ section.settings.section_heading }}
            </h2>
          </div>
        {% endif %}
        
        {% if section.settings.section_description != blank %}
          <div class="description-wrapper">
            <p class="section-description {{ section.settings.description_font_size }} {{ section.settings.description_font_size_desktop }} {{ section.settings.description_line_height }} {{ section.settings.description_text_color | default: 'text-neutral' }}">
              {{ section.settings.section_description }}
            </p>
          </div>
        {% endif %}
      </div>
    {% endif %}
    
    <!-- Filter Navigation -->
    {% if section.settings.show_filter_navigation %}
      <div class="filter-navigation {{ section.settings.filter_margin_top }}">
        <div class="filter-tabs {{ section.settings.filter_text_align }}">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'product_filter' %}
                <button class="filter-tab {{ section.settings.filter_font_size }} {{ section.settings.filter_font_weight }} {{ section.settings.filter_text_color }}" 
                        data-filter="{{ block.settings.filter_category | handle }}" 
                        onclick="filterProducts(this, '{{ block.settings.filter_category | handle }}')"
                        aria-label="Filter by {{ block.settings.filter_category }}">
                  {{ block.settings.filter_category | upcase }}
                </button>
            {% endcase %}
          {% endfor %}
          
          <button class="filter-tab active {{ section.settings.filter_font_size }} {{ section.settings.filter_font_weight }} {{ section.settings.filter_text_color }}" 
                  data-filter="all" 
                  onclick="filterProducts(this, 'all')"
                  aria-label="Show all products">
            {{ section.settings.all_filter_text | default: 'ALL PRODUCTS' }}
          </button>
        </div>
      </div>
    {% endif %}
    
    <!-- Products Grid -->
    <div class="products-wrapper {{ section.settings.products_margin_top }}">
      <div class="products-grid">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'product_card' %}
              <div class="product-card {{ section.settings.card_background_color }} {{ section.settings.card_border_radius }}" 
                   data-category="{{ block.settings.product_category | handle }}"
                   {{ block.fluid_attributes }}>
                
                <!-- Product Rating & Reviews -->
                <div class="product-rating {{ section.settings.rating_margin_bottom }}">
                  {% if block.settings.show_rating %}
                    <div class="star-rating" 
                         aria-label="Rated {{ block.settings.product_rating }} out of 5 stars"
                         data-rating="{{ block.settings.product_rating }}">
                      {% assign rating = block.settings.product_rating | plus: 0.0 %}
                      {% assign full_stars = rating | floor %}
                      {% assign has_half_star = rating | minus: full_stars | at_least: 0.5 %}
                      
                      {% for i in (1..5) %}
                        {% if i <= full_stars %}
                          <span class="star filled {{ section.settings.star_color }}">★</span>
                        {% elsif i == full_stars | plus: 1 and has_half_star %}
                          <span class="star half {{ section.settings.star_color }}">★</span>
                        {% else %}
                          <span class="star empty {{ section.settings.star_color }}">☆</span>
                        {% endif %}
                      {% endfor %}
                    </div>
                  {% endif %}
                  
                  {% if block.settings.review_count != blank %}
                    <div class="review-count {{ section.settings.review_font_size }} {{ section.settings.review_text_color }}">
                      {{ block.settings.review_count }} reviews
                    </div>
                  {% endif %}
                </div>
                
                <!-- Product Image -->
                <div class="product-image-wrapper {{ section.settings.image_margin_bottom }}">
                  {% if block.settings.product_image != blank %}
                    <img src="{{ block.settings.product_image | image_url: width: 400 }}"
                         alt="{{ block.settings.image_alt | default: block.settings.product_title }}"
                         class="product-image {{ section.settings.image_border_radius }}"
                         loading="lazy">
                  {% else %}
                    <img src="{{ 'placeholder-image.png' | asset_url }}"
                         alt="Product image for {{ block.settings.product_title }}"
                         class="product-image {{ section.settings.image_border_radius }}"
                         loading="lazy">
                  {% endif %}
                  
                  <!-- Award Badges -->
                  {% if block.settings.show_badges %}
                    <div class="award-badges">
                      {% if block.settings.badge_1_image != blank %}
                        <div class="badge badge-1 {{ section.settings.badge_size }}">
                          <img src="{{ block.settings.badge_1_image | image_url: width: 100 }}"
                               alt="{{ block.settings.badge_1_alt | default: 'Award badge' }}"
                               loading="lazy">
                        </div>
                      {% endif %}
                      
                      {% if block.settings.badge_2_image != blank %}
                        <div class="badge badge-2 {{ section.settings.badge_size }}">
                          <img src="{{ block.settings.badge_2_image | image_url: width: 100 }}"
                               alt="{{ block.settings.badge_2_alt | default: 'Award badge' }}"
                               loading="lazy">
                        </div>
                      {% endif %}
                      
                      {% if block.settings.badge_3_image != blank %}
                        <div class="badge badge-3 {{ section.settings.badge_size }}">
                          <img src="{{ block.settings.badge_3_image | image_url: width: 100 }}"
                               alt="{{ block.settings.badge_3_alt | default: 'Award badge' }}"
                               loading="lazy">
                        </div>
                      {% endif %}
                    </div>
                  {% endif %}
                </div>
                
                <!-- Product Info -->
                <div class="product-info">
                  {% if block.settings.product_title != blank %}
                    <h3 class="product-title {{ section.settings.title_font_size }} {{ section.settings.title_font_size_desktop }} {{ section.settings.title_font_weight }} {{ section.settings.title_line_height }} {{ block.settings.title_text_color | default: section.settings.card_text_color | default: 'text-black' }} {{ section.settings.title_margin_bottom }}">
                      {{ block.settings.product_title }}
                    </h3>
                  {% endif %}
                  
                  {% if block.settings.product_tagline != blank %}
                    <p class="product-tagline {{ section.settings.tagline_font_size }} {{ section.settings.tagline_font_size_desktop }} {{ section.settings.tagline_font_style }} {{ section.settings.tagline_line_height }} {{ block.settings.tagline_text_color | default: section.settings.card_text_color | default: 'text-neutral' }} {{ section.settings.tagline_margin_bottom }}">
                      {{ block.settings.product_tagline }}
                    </p>
                  {% endif %}
                  
                  <!-- CTA Button -->
                  {% if section.settings.show_cta_buttons %}
                    <div class="product-cta {{ section.settings.cta_margin_top }}">
                      {% if block.settings.cta_link != blank %}
                        <a href="{{ block.settings.cta_link }}" 
                           class="cta-button {{ section.settings.cta_style }} {{ section.settings.cta_size }} {{ section.settings.cta_border_radius }} {{ section.settings.cta_background_color }} {{ section.settings.cta_text_color }}"
                           aria-label="Learn more about {{ block.settings.product_title }}">
                          {{ block.settings.cta_text | default: section.settings.default_cta_text | default: 'Learn More' }}
                        </a>
                      {% else %}
                        <button class="cta-button {{ section.settings.cta_style }} {{ section.settings.cta_size }} {{ section.settings.cta_border_radius }} {{ section.settings.cta_background_color }} {{ section.settings.cta_text_color }}"
                                aria-label="Learn more about {{ block.settings.product_title }}">
                          {{ block.settings.cta_text | default: section.settings.default_cta_text | default: 'Learn More' }}
                        </button>
                      {% endif %}
                    </div>
                  {% endif %}
                </div>
              </div>
          {% endcase %}
        {% endfor %}
      </div>
    </div>
    
  </div>
</section>

<!-- Filter JavaScript -->
<script>
  // Filter products by category
  function filterProducts(button, category) {
    const section = button.closest('.award-winning-products');
    const productCards = section.querySelectorAll('.product-card');
    const filterTabs = section.querySelectorAll('.filter-tab');
    const productsGrid = section.querySelector('.products-grid');
    
    // Update active tab
    filterTabs.forEach(tab => tab.classList.remove('active'));
    button.classList.add('active');
    
    // Count visible cards and filter products
    let visibleCount = 0;
    productCards.forEach(card => {
      const cardCategory = card.getAttribute('data-category');
      
      if (category === 'all' || cardCategory === category) {
        card.style.display = 'block';
        card.classList.remove('hidden');
        visibleCount++;
      } else {
        card.style.display = 'none';
        card.classList.add('hidden');
      }
    });
    
    // Update grid layout based on visible cards
    productsGrid.classList.remove('grid-1', 'grid-2', 'grid-3', 'grid-4', 'grid-5', 'grid-6');
    
    if (visibleCount <= 6) {
      productsGrid.classList.add(`grid-${visibleCount}`);
    } else {
      productsGrid.classList.add('grid-6');
    }
    
    // Log filter action for analytics
    console.log('Products filtered by:', category, 'Visible cards:', visibleCount);
  }
  
  // Initialize on page load
  document.addEventListener('DOMContentLoaded', function() {
    const sections = document.querySelectorAll('.award-winning-products');
    
    sections.forEach(section => {
      // Initialize star ratings
      const starRatings = section.querySelectorAll('.star-rating');
      starRatings.forEach(rating => {
        const ratingValue = parseFloat(rating.getAttribute('data-rating'));
        const stars = rating.querySelectorAll('.star');
        
        stars.forEach((star, index) => {
          const starValue = index + 1;
          
          if (starValue <= Math.floor(ratingValue)) {
            star.classList.add('filled');
            star.classList.remove('half', 'empty');
          } else if (starValue === Math.floor(ratingValue) + 1 && ratingValue % 1 >= 0.5) {
            star.classList.add('half');
            star.classList.remove('filled', 'empty');
          } else {
            star.classList.add('empty');
            star.classList.remove('filled', 'half');
          }
        });
      });
    });
    
    console.log('Award winning products section initialized');
  });
</script>

