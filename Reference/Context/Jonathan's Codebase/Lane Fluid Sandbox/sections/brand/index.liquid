<!-- Brand -->
<section class="brands" style="
  padding-top: {{ section.settings.section_padding_top_mobile | default: 40 }}px; 
  padding-bottom: {{ section.settings.section_padding_bottom_mobile | default: 40 }}px; 
  background-color: {{ section.settings.background_color | default: '#ffffff' }}; 
  <style>
    @media (min-width: 1280px) {
      .brands {
        padding-top: {{ section.settings.section_padding_top_desktop | default: 80 }}px !important;
        padding-bottom: {{ section.settings.section_padding_bottom_desktop | default: 80 }}px !important;
      }
    }
  </style>
    <div class="container">
      {% if section.settings.heading != blank %}
      <div class="flex justify-center align-center mb-12">
        <div class="{{ section.settings.heading_font_size | default: 'text-lg' }} {{ section.settings.heading_font_size_desktop | default: 'sm-desktop-text-lg' }} {{ section.settings.heading_font_weight | default: 'font-bold' }}" style="color: {{ section.settings.heading_color | default: '#000000' }};">
          {{ section.settings.heading }}
        </div>
      </div>
      {% endif %}
    </div>
    {% if section.blocks.size > 0 %}
    <div class="brand-slider splide" id="brand-slider-{{ section.id }}">
      <div class="splide__track">
        <ul class="splide__list">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'brand_item' %}
                <li class="splide__slide" {{ block.fluid_attributes }}>
                  <figure>
                    {% if block.settings.brand_link != blank %}
                      <a href="{{ block.settings.brand_link }}" target="{{ block.settings.link_target }}">
                    {% endif %}
                    {% if block.settings.brand_image != blank %}
                      <img src="{{ block.settings.brand_image | image_url: width: 200 }}" alt="{{ block.settings.brand_alt | default: 'Brand logo' }}" loading="lazy" />
                    {% else %}
                      <div class="placeholder-brand" style="width: 120px; height: 60px; background-color: #f0f0f0; display: flex; align-items: center; justify-content: center; border: 1px solid #ddd;">
                        <span style="font-size: 12px; color: #999;">Brand Logo</span>
                      </div>
                    {% endif %}
                    {% if block.settings.brand_link != blank %}
                      </a>
                    {% endif %}
                  </figure>
                </li>
            {% endcase %}
          {% endfor %}
        </ul>
      </div>
    </div>
    {% endif %}
</section>

<script>
document.addEventListener("DOMContentLoaded", () => {
  // Initialize brand slider
  const brandSlider = new Splide('#brand-slider-{{ section.id }}', {
    type: "loop",
    perPage: 8,
    perMove: 1,
    autoplay: true,
    interval: 2000,
    speed: 6000,
    pauseOnHover: true,
    pauseOnFocus: true,
    gap: "32px",
    pagination: false,
    arrows: false,
    breakpoints: {
      480: {
        perPage: 3,
      },
      768: {
        perPage: 5,
      },
      1024: {
        perPage: 8,
      },
    },
  });
  
  brandSlider.mount();
});
</script>

