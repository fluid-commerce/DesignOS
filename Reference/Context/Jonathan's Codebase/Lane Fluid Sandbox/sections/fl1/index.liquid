                      <div class="icon-embed-xxsmall w-embed">
                        <svg width="100%" height="100%" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M0.201432 8.35425C0.0324796 8.23123 -0.0397528 8.01452 0.021606 7.81473L0.101529 7.56496C0.159961 7.36756 0.335635 7.22781 0.541103 7.21527L6.92493 6.70573L9.37256 0.821007C9.45466 0.614853 9.66074 0.485543 9.88206 0.501294H10.1418C10.3505 0.496866 10.539 0.62523 10.6114 0.821007L13.069 6.70573L19.4528 7.21527C19.6583 7.22781 19.8339 7.36756 19.8924 7.56496L19.9723 7.81473C20.0403 8.00821 19.9805 8.22355 19.8224 8.35425L15.0071 12.4905L16.4857 18.695C16.5344 18.8936 16.4596 19.1021 16.2959 19.2245L16.0061 19.3843C15.8371 19.4986 15.6157 19.4986 15.4467 19.3843L10.0119 16.0873L4.54723 19.4143C4.37823 19.5286 4.15676 19.5286 3.98777 19.4143L3.76798 19.2645C3.60419 19.142 3.52945 18.9335 3.57816 18.7349L5.01677 12.4905L0.201432 8.35425Z" fill="CurrentColor"></path>
                        </svg>
                      </div>
                    </div>
                    <div class="product-header1_rating-icon">
                      <div class="icon-embed-xxsmall w-embed">
                        <svg width="100%" height="100%" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path fill-rule="evenodd" clip-rule="evenodd" d="M19.8928 7.56999L19.9725 7.81999C20.0381 8.00868 19.9829 8.21839 19.8329 8.34999L14.9863 12.5L16.4223 18.72C16.4709 18.9188 16.3963 19.1275 16.2328 19.25L16.0134 19.4C15.9282 19.467 15.8225 19.5023 15.7143 19.5C15.6229 19.5019 15.533 19.4776 15.455 19.43L9.99999 16.1L4.57492 19.43C4.49692 19.4776 4.40695 19.5019 4.31563 19.5C4.20738 19.5023 4.10167 19.467 4.01646 19.4L3.76714 19.25C3.60364 19.1275 3.52904 18.9188 3.57766 18.72L5.01371 12.5L0.177024 8.35999C0.0192942 8.22917 -0.0404113 8.01364 0.027436 7.81999L0.137134 7.56999C0.195462 7.37241 0.370823 7.23254 0.575926 7.21999L6.94839 6.70999L9.39166 0.819989C9.46995 0.624384 9.66017 0.497222 9.87035 0.499989H10.1296C10.3379 0.495557 10.5261 0.624037 10.5983 0.819989L13.0815 6.70999L19.454 7.21999C19.6591 7.23254 19.8344 7.37241 19.8928 7.56999ZM14.1087 16.56L12.9918 11.88L16.6517 8.74999L11.8549 8.36999L9.99999 3.90999V14.05L14.1087 16.56Z" fill="CurrentColor"></path>
                        </svg>
                      </div>
                    </div>
                  </div>
                  <div class="text-size-small">{{ section.settings.rating_text | default: "Join the millions of people feeling their best." }}</div>
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<!-- This will include the original CSS from your webflow CSS file -->
<style>
/* Using exact CSS from your original webflow file - DO NOT MODIFY */

/* Core Webflow styles that we need to include */
.w-layout-grid {
  display: -ms-grid;
  display: grid;
  grid-auto-columns: 1fr;
  -ms-grid-columns: 1fr 1fr;
  grid-template-columns: 1fr 1fr;
  -ms-grid-rows: auto auto;
  grid-template-rows: auto auto;
  grid-row-gap: 16px;
  grid-column-gap: 16px;
}

.w-background-video {
  position: relative;
  overflow: hidden;
}

.w-background-video > video {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* Original Webflow CSS Variables - Exact Colors */
:root {
  --text-alternate: #ffffff;
  --text-color--text-primary: #231f20;
  --background-color--background-primary: #ffffff;
  --background-color--background-secondary: #f8fafc;
  --base-color-neutral--white: #ffffff;
  --base-color-neutral--neutral-lightest: #f9fafb;
  --brand-color--brand-primary: #0066cc;
  --brand-color--brand-secondary: #004499;
  --star-color: #fbbf24;
}

/* Your original Webflow utility classes */
.padding-global {
  padding-left: 2rem;
  padding-right: 2rem;
}

.container-large {
  width: 100%;
  max-width: 80rem;
  margin-left: auto;
  margin-right: auto;
}

.padding-section-small {
  padding-top: 4rem;
  padding-bottom: 4rem;
}

.margin-bottom {
  margin-bottom: 1rem;
}

.margin-bottom.margin-xsmall {
  margin-bottom: 0.5rem;
}

.margin-bottom.margin-small {
  margin-bottom: 1rem;
}

.margin-top {
  margin-top: 1rem;
}

.margin-top.margin-medium {
  margin-top: 2rem;
}

.margin-top.margin-small {
  margin-top: 1rem;
}

/* Your original header styles */
.section_header1 {
  position: relative;
  overflow: hidden;
  min-height: 80vh;
  display: flex;
  align-items: center;
}

.header1_component {
  position: relative;
  z-index: 2;
}

.header1_content {
  grid-template-areas: ". .";
  -ms-grid-columns: 1fr 1fr;
  grid-template-columns: 1fr 1fr;
  -ms-grid-rows: auto;
  grid-template-rows: auto;
  grid-column-gap: 4rem;
  grid-row-gap: 4rem;
  align-items: center;
  position: relative;
  z-index: 2;
}

.header1_image-wrapper {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
}

.header1_image {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header1_content-left {
  max-width: 36rem;
  color: var(--text-alternate);
}

/* Typography from your original styles */
.text-style-tagline {
  color: var(--text-alternate);
  font-size: 0.875rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.heading-style-h1-2 {
  color: var(--text-alternate);
  font-size: 4rem;
  font-weight: 800;
  line-height: 1.1;
  text-transform: uppercase;
}

.text-span {
  color: var(--text-color--text-primary);
}

.text-size-medium-4 {
  color: var(--text-alternate);
  font-size: 1.125rem;
  line-height: 1.6;
}

/* Button styles from original */
.button-group {
  display: flex;
  align-items: center;
  grid-column-gap: 1rem;
  grid-row-gap: 1rem;
}

.button-4 {
  background-color: var(--background-color--background-primary);
  color: var(--text-color--text-primary);
  border-radius: 0.5rem;
  padding: 1rem 2rem;
  font-size: 1rem;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.2s ease;
  display: inline-block;
  border: none;
  cursor: pointer;
}

.button-4:hover {
  background-color: var(--background-color--background-secondary);
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
}

.headerbutton {
  background-color: var(--background-color--background-primary);
  color: var(--text-color--text-primary);
}

.w-button {
  display: inline-block;
  line-height: inherit;
  text-decoration: none;
  cursor: pointer;
  border: 0;
}

/* Rating styles from original */
.product-header1_reviews-wrapper {
  display: flex;
  align-items: center;
  grid-column-gap: 1rem;
  grid-row-gap: 1rem;
}

.product-header1_rating-wrapper {
  display: flex;
  align-items: center;
  grid-column-gap: 0.125rem;
  grid-row-gap: 0.125rem;
}

.product-header1_rating-icon {
  width: 1rem;
  height: 1rem;
  color: var(--star-color);
}

.icon-embed-xxsmall {
  width: 1rem;
  height: 1rem;
  flex: none;
}

.w-embed {
  position: relative;
}

.text-size-small {
  color: var(--text-alternate);
  font-size: 0.875rem;
  line-height: 1.5;
}

/* Responsive styles matching your original breakpoints */
@media screen and (max-width: 991px) {
  .padding-global {
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }
  
  .header1_content {
    -ms-grid-columns: 1fr;
    grid-template-columns: 1fr;
    grid-column-gap: 2rem;
    grid-row-gap: 2rem;
    text-align: center;
  }
  
  .header1_content-left {
    max-width: none;
  }
  
  .heading-style-h1-2 {
    font-size: 3rem;
  }
}

@media screen and (max-width: 767px) {
  .padding-global {
    padding-left: 1rem;
    padding-right: 1rem;
  }
  
  .padding-section-small {
    padding-top: 3rem;
    padding-bottom: 3rem;
  }
  
  .section_header1 {
    min-height: 70vh;
  }
  
  .heading-style-h1-2 {
    font-size: 2.5rem;
  }
  
  .header1_content {
    grid-column-gap: 1.5rem;
    grid-row-gap: 1.5rem;
  }
}

@media screen and (max-width: 479px) {
  .heading-style-h1-2 {
    font-size: 2rem;
  }
  
  .button-4 {
    padding: 0.875rem 1.5rem;
    font-size: 0.875rem;
  }
  
  .text-size-medium-4 {
    font-size: 1rem;
  }
}
</style>

{% schema %}
{
  "name": "Hero Homepage",
  "settings": [
    {
      "type": "header",
      "content": "Hero Content"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline/Eyebrow Text",
      "default": "ASEA REDOX - A Breakthrough in Cellular Science"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero Title",
      "default": "Look move and feel <span class=\"text-span\">younger</span>"
    },
    {
      "type": "textarea",
      "id": "hero_description",
      "label": "Hero Description",
      "default": "Feeling like your best self starts at the cellular level. That's why we pioneered redox technology that works with your body's natural processes to help you combat inflammation, improve cardiovascular health, and tighten saggy skin."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "Feel Like Yourself Again"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Button Link"
    },
    {
      "type": "header",
      "content": "Background Media"
    },
    {
      "type": "video",
      "id": "background_video",
      "label": "Background Video"
    },
    {
      "type": "video",
      "id": "background_video_webm",
      "label": "Background Video (WebM)"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image (fallback)"
    },
    {
      "type": "header",
      "content": "Social Proof"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show Rating Stars",
      "default": true
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Rating Text",
      "default": "Join the millions of people feeling their best."
    }
  ],
  "presets": [
    {
      "name": "Hero Homepage"
    }
  ]
}
{% endschema %}
