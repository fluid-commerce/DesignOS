{% comment %}
  Homepage Hero Section (section_header1)
  Using exact original Webflow structure and CSS classes
{% endcomment %}

<header class="section_header1">
  <div class="padding-global">
    <div class="container-large">
      <div class="padding-section-small">
        <div class="header1_component">
          <div class="w-layout-grid header1_content">
            <!-- Background Video/Image -->
            <div class="header1_image-wrapper">
              {% if section.settings.background_video %}
                <div class="header1_image w-background-video w-background-video-atom">
                  <video autoplay loop muted playsinline data-object-fit="cover">
                    <source src="{{ section.settings.background_video }}" type="video/mp4">
                    {% if section.settings.background_video_webm %}
                      <source src="{{ section.settings.background_video_webm }}" type="video/webm">
                    {% endif %}
                  </video>
                </div>
              {% elsif section.settings.background_image %}
                <div class="header1_image">
                  <img 
                    src="{{ section.settings.background_image | img_url: '1920x1080' }}" 
                    alt="{{ section.settings.hero_title }}" 
                    loading="eager"
                    style="object-fit: cover; width: 100%; height: 100%;"
                  >
                </div>
              {% endif %}
            </div>
            
            <!-- Hero Content -->
            <div class="header1_content-left">
              {% if section.settings.tagline %}
                <div class="margin-bottom margin-xsmall">
                  <div class="text-style-tagline">{{ section.settings.tagline }}</div>
                </div>
              {% endif %}
              
              <div class="margin-bottom margin-small">
                <h1 class="heading-style-h1-2">
                  {{ section.settings.hero_title | default: 'Look move and feel <span class="text-span">younger</span>' }}
                </h1>
              </div>
              
              {% if section.settings.hero_description %}
                <p class="text-size-medium-4">{{ section.settings.hero_description }}</p>
              {% endif %}
              
              {% if section.settings.cta_text %}
                <div class="margin-top margin-medium">
                  <div class="button-group">
                    <a href="{{ section.settings.cta_link | default: '#' }}" class="button-4 headerbutton w-button">
                      <strong>{{ section.settings.cta_text }}</strong>
                    </a>
                  </div>
                </div>
              {% endif %}
              
              {% if section.settings.show_rating %}
                <div class="product-header1_reviews-wrapper margin-top margin-small">
                  <div class="product-header1_rating-wrapper">
                    <div class="product-header1_rating-icon">
                      <div class="icon-embed-xxsmall w-embed">
