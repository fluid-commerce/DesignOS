 <!-- Heading section -->
<section class="heading-section {{ section.settings.background_color | default: 'bg-black' }} {{ section.settings.section_padding_y_mobile | default: 'py-10' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-20' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image }}"{% endif %}>
  <div class="container">
    <div class="inner-container {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-8' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-12' }} {{ section.settings.container_padding_x_mobile | default: 'px-6' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-8' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image }}"{% endif %}>
      <div class="grid gap-8 heading-grid {% if section.settings.flip_layout %}flip-layout{% endif %}">
       <div class="heading flex flex-col justify-start lg-tab-justify-end" style="gap: var(--space-4);"
       >
         <h6 class="{{ section.settings.tagline_font_family | default: 'font-body' }} {{ section.settings.tagline_font_size | default: 'text-base' }} {{ section.settings.tagline_font_weight | default: 'font-normal' }} {{ section.settings.tagline_color | default: 'text-white' }}">
           {{ section.settings.tagline | default: "Tagline" }}
         </h6>
         <h1 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_weight | default: 'font-bold' }} {{ section.settings.heading_color | default: 'text-white' }}">
           {{ section.settings.heading | default: "Medium length section heading goes here" }}
         </h1>
       </div>
       <div class="heading-item flex flex-col" style="gap: var(--space-8);">
         <p class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-white' }}">
           {{ section.settings.description | default: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare, eros dolor interdum nulla, ut commodo diam libero vitae erat." }}
         </p>
         <div class="grid sub-heading-grid" style="gap: var(--space-8);">
           <div class="flex flex-col" style="gap: var(--space-4);">
             <h3 class="{{ section.settings.subheading_one_font_family | default: 'font-primary' }} {{ section.settings.subheading_one_font_size | default: 'text-xl' }} {{ section.settings.subheading_one_font_weight | default: 'font-medium' }} {{ section.settings.subheading_one_color | default: 'text-white' }}">
               {{ section.settings.subheading_one_title | default: "Subheading one" }}
             </h3>
             <p class="{{ section.settings.subheading_one_description_font_family | default: 'font-body' }} {{ section.settings.subheading_one_description_font_size | default: 'text-base' }} {{ section.settings.subheading_one_description_font_weight | default: 'font-normal' }} {{ section.settings.subheading_one_description_color | default: 'text-white' }}">
               {{ section.settings.subheading_one_description | default: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros." }}
             </p>
           </div>
           <div class="flex flex-col" style="gap: var(--space-4);">
             <h3 class="{{ section.settings.subheading_two_font_family | default: 'font-primary' }} {{ section.settings.subheading_two_font_size | default: 'text-xl' }} {{ section.settings.subheading_two_font_weight | default: 'font-medium' }} {{ section.settings.subheading_two_color | default: 'text-white' }}">
               {{ section.settings.subheading_two_title | default: "Subheading two" }}
             </h3>
             <p class="{{ section.settings.subheading_two_description_font_family | default: 'font-body' }} {{ section.settings.subheading_two_description_font_size | default: 'text-base' }} {{ section.settings.subheading_two_description_font_weight | default: 'font-normal' }} {{ section.settings.subheading_two_description_color | default: 'text-white' }}">
               {{ section.settings.subheading_two_description | default: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros." }}
             </p>
           </div>
         </div>
         <div class="flex justify-start items-center" style="gap: var(--space-4);">
           {% if section.settings.show_button_one %}
           <a href="{{ section.settings.button_one_url | default: '#' }}" 
              class="btn btn-{{ section.settings.button_one_style | default: 'filled' }}-{{ section.settings.button_one_color | default: 'white' }} {{ section.settings.button_one_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded' }}">
             {{ section.settings.button_one_text | default: "Button 1" }}
           </a>
           {% endif %}
           {% if section.settings.show_button_two %}
           <a href="{{ section.settings.button_two_url | default: '#' }}" 
              class="btn btn-{{ section.settings.button_two_style | default: 'outline' }}-{{ section.settings.button_two_color | default: 'white' }} {{ section.settings.button_two_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded' }}">
             {{ section.settings.button_two_text | default: "Button 2" }}
           </a>
           {% endif %}
         </div>
       </div>
     </div>
   </div>
 </div>
</section>

