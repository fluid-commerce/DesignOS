<!-- Articles List Section -->
<section class="articles-list {{ section.settings.background_color | default: 'bg-neutral-light' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image }}"{% endif %}>
  <div class="container">
    <div class="inner-container {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_padding_y_mobile | default: 'py-xl' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-lg' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }} {{ section.settings.container_border_radius | default: 'rounded-none' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image }}"{% endif %}>
      
      <div class="max-w-7xl mx-auto">
        
        <!-- Section Header -->
        <div class="section-header flex flex-col lg:flex-row lg:items-center lg:justify-between mb-3xl gap-lg">
          
          <!-- Section Title -->
          {% if section.settings.show_heading %}
          <div class="section-title">
            <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-4xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-bold' }} {{ section.settings.heading_color | default: 'text-black' }} leading-tight">
              {{ section.settings.heading | default: "Discover the latest science and news from Therabody" }}
            </h2>
          </div>
          {% endif %}
          
          <!-- Explore All Button -->
          {% if section.settings.show_explore_button %}
          <div class="explore-button-wrapper flex-shrink-0">
            <a href="{{ section.settings.explore_button_url | default: '#' }}" 
               class="btn btn-{{ section.settings.explore_button_style | default: 'outline' }}-{{ section.settings.explore_button_color | default: 'black' }} {{ section.settings.explore_button_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded' }}">
              {{ section.settings.explore_button_text | default: "Explore all articles" }}
            </a>
          </div>
          {% endif %}
          
        </div>
        
        <!-- Articles Grid -->
        {% if section.blocks.size > 0 %}
        <div class="articles-wrapper">
          {% assign block_count = section.blocks.size %}
          {% assign grid_cols = 'md:grid-cols-1' %}
          {% if block_count == 2 %}
            {% assign grid_cols = 'md:grid-cols-2' %}
          {% elsif block_count == 3 %}
            {% assign grid_cols = 'md:grid-cols-3' %}
          {% elsif block_count >= 4 %}
            {% assign grid_cols = 'md:grid-cols-4' %}
          {% endif %}

          <div class="articles-grid grid grid-cols-1 {{ grid_cols }} gap-lg lg:gap-xl">
            {% for block in section.blocks %}
              {% case block.type %}
                {% when 'article_item' %}
                  <article class="article-item" {{ block.fluid_attributes }}>
                    
                    <!-- Article Image -->
                    <div class="article-image-wrapper {{ section.settings.image_border_radius | default: 'rounded-lg' }} overflow-hidden bg-neutral-light mb-lg">
                      {% if block.settings.article_image %}
                        <img src="{{ block.settings.article_image | image_url }}"
                             alt="{{ block.settings.image_alt | default: block.settings.article_title }}"
                             class="article-image w-full h-64 lg:h-72 object-cover transition-transform duration-300 ease-in-out hover:scale-105">
                      {% else %}
                        <img src="{{ 'placeholder-image.png' | asset_url }}"
                             alt="{{ block.settings.image_alt | default: 'Article image placeholder' }}"
                             class="article-image w-full h-64 lg:h-72 object-cover transition-transform duration-300 ease-in-out hover:scale-105">
                      {% endif %}
                    </div>
                    
                    <!-- Article Content -->
                    <div class="article-content space-y-sm">
                      
                      <!-- Article Date -->
                      {% if block.settings.article_date != blank %}
                      <div class="article-date">
                        <time class="{{ section.settings.date_font_family | default: 'font-body' }} {{ section.settings.date_font_size | default: 'text-sm' }} {{ section.settings.date_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.date_font_weight | default: 'font-normal' }} {{ section.settings.date_color | default: 'text-neutral' }} uppercase tracking-wide">
                          {{ block.settings.article_date }}
                        </time>
                      </div>
                      {% endif %}
                      
                      <!-- Article Title -->
                      {% if block.settings.article_title != blank %}
                      <h3 class="{{ section.settings.title_font_family | default: 'font-primary' }} {{ section.settings.title_font_size | default: 'text-xl' }} {{ section.settings.title_font_size_desktop | default: 'lg:text-2xl' }} {{ section.settings.title_font_weight | default: 'font-bold' }} {{ section.settings.title_color | default: 'text-black' }} leading-tight">
                        {% if block.settings.article_url != blank %}
                          <a href="{{ block.settings.article_url }}" class="hover:opacity-70 transition-opacity duration-200">
                            {{ block.settings.article_title }}
                          </a>
                        {% else %}
                          {{ block.settings.article_title }}
                        {% endif %}
                      </h3>
                      {% endif %}
                      
                      <!-- Article Excerpt -->
                      {% if block.settings.show_excerpt and block.settings.article_excerpt != blank %}
                      <p class="{{ section.settings.excerpt_font_family | default: 'font-body' }} {{ section.settings.excerpt_font_size | default: 'text-base' }} {{ section.settings.excerpt_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.excerpt_font_weight | default: 'font-normal' }} {{ section.settings.excerpt_color | default: 'text-neutral-dark' }} leading-relaxed">
                        {{ block.settings.article_excerpt }}
                      </p>
                      {% endif %}
                      
                    </div>
                    
                  </article>
              {% endcase %}
            {% endfor %}
          </div>
        </div>
        {% endif %}
        
      </div>
      
    </div>
  </div>
</section>

