<link rel="stylesheet" href="{{ 'fw_stats_row/styles.css' | asset_url }}">

<section class="fw-stats-row-section {{ section.settings.background_color }} {{ section.settings.section_padding_y_mobile }} {{ section.settings.section_padding_y_desktop }} {{ section.settings.section_border_radius }}"
  {% if section.settings.background_image != blank %}data-bg style="background-image: url('{{ section.settings.background_image | image_url }}'); background-size: cover; background-position: center;"{% endif %}>

  <div class="fw-stats-row-container {{ section.settings.container_background_color }} {{ section.settings.container_border_radius }} {{ section.settings.container_padding_y_mobile }} {{ section.settings.container_padding_y_desktop }} {{ section.settings.container_padding_x_mobile }} {{ section.settings.container_padding_x_desktop }}"
    {% if section.settings.container_background_image != blank %}data-bg style="background-image: url('{{ section.settings.container_background_image | image_url }}'); background-size: cover; background-position: center;"{% endif %}>

    <div class="fw-stats-row">
      {% for block in section.blocks %}
        {% if block.type == 'stat' %}
        <div class="fw-stat-cell" {{ block.fluid_attributes }}>
          <div class="fw-stat-border {% if block.settings.border_image == blank %}border-color-{{ block.settings.border_color }}{% endif %}">
            {% if block.settings.border_image != blank %}
            <img src="{{ block.settings.border_image | image_url }}" alt="" class="fw-stat-border-image" aria-hidden="true">
            {% endif %}
          </div>
          <div class="fw-stat-content">
            {% if block.settings.stat_number != blank %}
            <div class="fw-stat-number {{ block.settings.stat_number_font_family }} {{ block.settings.stat_number_font_size }} {{ block.settings.stat_number_font_size_desktop }} {{ block.settings.stat_number_font_weight }} {{ block.settings.stat_number_color }}">
              {{ block.settings.stat_number }}
            </div>
            {% endif %}
            {% if block.settings.stat_label != blank %}
            <div class="fw-stat-label {{ block.settings.stat_label_font_family }} {{ block.settings.stat_label_font_size }} {{ block.settings.stat_label_font_size_desktop }} {{ block.settings.stat_label_font_weight }} {{ block.settings.stat_label_color }}">
              {{ block.settings.stat_label }}
            </div>
            {% endif %}
          </div>
        </div>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</section>

