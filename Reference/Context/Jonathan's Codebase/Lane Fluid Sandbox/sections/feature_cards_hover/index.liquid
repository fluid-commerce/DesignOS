<!-- Feature Cards with Hover Section -->
<section class="feature-cards-hover {{ section.settings.background_color | default: 'bg-primary' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image }}"{% endif %}>
  <div class="container">
    <div class="inner-container {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_padding_y_mobile | default: 'py-xl' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-lg' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }} {{ section.settings.container_border_radius | default: 'rounded-none' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image }}"{% endif %}>
      
      <div class="max-w-7xl mx-auto">
        
        <!-- Section Header -->
        <div class="section-header text-center mb-3xl">
          
          <!-- Small Tagline -->
          {% if section.settings.show_tagline and section.settings.tagline != blank %}
          <div class="tagline-wrapper mb-lg">
            <p class="{{ section.settings.tagline_font_family | default: 'font-body' }} {{ section.settings.tagline_font_size | default: 'text-sm' }} {{ section.settings.tagline_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.tagline_font_weight | default: 'font-medium' }} {{ section.settings.tagline_color | default: 'text-white' }} tracking-wider uppercase">
              {{ section.settings.tagline | default: "Made to Flex" }}
            </p>
          </div>
          {% endif %}
          
          <!-- Main Heading -->
          {% if section.settings.show_heading and section.settings.heading != blank %}
          <div class="heading-wrapper">
            <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-bold' }} {{ section.settings.heading_color | default: 'text-white' }} leading-tight">
              {{ section.settings.heading | default: "Lorem ipsum dolor sit amet consectetur. Adipiscing elit sed do <em>eiusmod tempor incididunt.</em>" }}
            </h2>
          </div>
          {% endif %}
          
        </div>
        
        <!-- Feature Cards Grid -->
        <div class="cards-wrapper">
          <div class="cards-grid grid grid-cols-1 md:grid-cols-3 gap-lg lg:gap-xl">
            
            <!-- Card 1 -->
            {% if section.settings.card_1_link != blank %}
              <a href="{{ section.settings.card_1_link }}" class="feature-card-item group cursor-pointer block">
            {% else %}
              <div class="feature-card-item group cursor-pointer">
            {% endif %}
              <div class="card-container {{ section.settings.card_border_radius | default: 'rounded-xl' }} overflow-hidden transition-all duration-500 ease-in-out">
                <div class="card-image-wrapper {{ section.settings.image_aspect_ratio | default: 'aspect-square' }} overflow-hidden">
                  {% if section.settings.card_1_image %}
                    <img src="{{ section.settings.card_1_image | image_url: width: 600 }}"
                         alt="{{ section.settings.card_1_image.alt | default: section.settings.card_1_title }}"
                         class="card-image w-full h-full object-cover transition-transform duration-700 ease-in-out group-hover:scale-110">
                  {% else %}
                    <img src="{{ 'placeholder-image.png' | asset_url }}"
                         alt="{{ section.settings.card_1_title | default: 'Top global creative talent' }}"
                         class="card-image w-full h-full object-cover transition-transform duration-700 ease-in-out group-hover:scale-110">
                  {% endif %}
                </div>
                <div class="card-content-overlay {{ section.settings.card_1_background_color | default: 'bg-black' }} {{ section.settings.card_padding | default: 'p-lg' }}">
                  <h3 class="{{ section.settings.card_title_font_family | default: 'font-primary' }} {{ section.settings.card_title_font_size | default: 'text-xl' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-2xl' }} {{ section.settings.card_title_font_weight | default: 'font-bold' }} {{ section.settings.card_1_title_color | default: 'text-white' }} leading-tight">
                    {{ section.settings.card_1_title | default: "Lorem Ipsum Dolor" }}
                  </h3>
                  <div class="card-description mt-md overflow-hidden transition-all duration-500 ease-in-out max-h-0 opacity-0 group-hover:max-h-40 group-hover:opacity-100">
                    <p class="{{ section.settings.card_description_font_family | default: 'font-body' }} {{ section.settings.card_description_font_size | default: 'text-base' }} {{ section.settings.card_description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.card_description_font_weight | default: 'font-normal' }} {{ section.settings.card_1_description_color | default: 'text-white' }} leading-relaxed">
                      {{ section.settings.card_1_description | default: "Lorem ipsum dolor sit amet consectetur adipiscing elit sed do eiusmod tempor incididunt ut labore et dolore magna aliqua." }}
                    </p>
                  </div>
                </div>
              </div>
            {% if section.settings.card_1_link != blank %}
              </a>
            {% else %}
              </div>
            {% endif %}
            
            <!-- Card 2 -->
            {% if section.settings.card_2_link != blank %}
              <a href="{{ section.settings.card_2_link }}" class="feature-card-item group cursor-pointer block">
            {% else %}
              <div class="feature-card-item group cursor-pointer">
            {% endif %}
              <div class="card-container {{ section.settings.card_border_radius | default: 'rounded-xl' }} overflow-hidden transition-all duration-500 ease-in-out">
                <div class="card-image-wrapper {{ section.settings.image_aspect_ratio | default: 'aspect-square' }} overflow-hidden">
                  {% if section.settings.card_2_image %}
                    <img src="{{ section.settings.card_2_image | image_url: width: 600 }}"
                         alt="{{ section.settings.card_2_image.alt | default: section.settings.card_2_title }}"
                         class="card-image w-full h-full object-cover transition-transform duration-700 ease-in-out group-hover:scale-110">
                  {% else %}
                    <img src="{{ 'placeholder-image.png' | asset_url }}"
                         alt="{{ section.settings.card_2_title | default: 'Ultra-fast turnaround times' }}"
                         class="card-image w-full h-full object-cover transition-transform duration-700 ease-in-out group-hover:scale-110">
                  {% endif %}
                </div>
                <div class="card-content-overlay {{ section.settings.card_2_background_color | default: 'bg-black' }} {{ section.settings.card_padding | default: 'p-lg' }}">
                  <h3 class="{{ section.settings.card_title_font_family | default: 'font-primary' }} {{ section.settings.card_title_font_size | default: 'text-xl' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-2xl' }} {{ section.settings.card_title_font_weight | default: 'font-bold' }} {{ section.settings.card_2_title_color | default: 'text-white' }} leading-tight">
                    {{ section.settings.card_2_title | default: "Consectetur Adipiscing" }}
                  </h3>
                  <div class="card-description mt-md overflow-hidden transition-all duration-500 ease-in-out max-h-0 opacity-0 group-hover:max-h-40 group-hover:opacity-100">
                    <p class="{{ section.settings.card_description_font_family | default: 'font-body' }} {{ section.settings.card_description_font_size | default: 'text-base' }} {{ section.settings.card_description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.card_description_font_weight | default: 'font-normal' }} {{ section.settings.card_2_description_color | default: 'text-white' }} leading-relaxed">
                      {{ section.settings.card_2_description | default: "Ut enim ad minim veniam quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat duis aute irure." }}
                    </p>
                  </div>
                </div>
              </div>
            {% if section.settings.card_2_link != blank %}
              </a>
            {% else %}
              </div>
            {% endif %}
            
            <!-- Card 3 -->
            {% if section.settings.card_3_link != blank %}
              <a href="{{ section.settings.card_3_link }}" class="feature-card-item group cursor-pointer block">
            {% else %}
              <div class="feature-card-item group cursor-pointer">
            {% endif %}
              <div class="card-container {{ section.settings.card_border_radius | default: 'rounded-xl' }} overflow-hidden transition-all duration-500 ease-in-out">
                <div class="card-image-wrapper {{ section.settings.image_aspect_ratio | default: 'aspect-square' }} overflow-hidden">
                  {% if section.settings.card_3_image %}
                    <img src="{{ section.settings.card_3_image | image_url: width: 600 }}"
                         alt="{{ section.settings.card_3_image.alt | default: section.settings.card_3_title }}"
                         class="card-image w-full h-full object-cover transition-transform duration-700 ease-in-out group-hover:scale-110">
                  {% else %}
                    <img src="{{ 'placeholder-image.png' | asset_url }}"
                         alt="{{ section.settings.card_3_title | default: 'Flexible subscription model' }}"
                         class="card-image w-full h-full object-cover transition-transform duration-700 ease-in-out group-hover:scale-110">
                  {% endif %}
                </div>
                <div class="card-content-overlay {{ section.settings.card_3_background_color | default: 'bg-black' }} {{ section.settings.card_padding | default: 'p-lg' }}">
                  <h3 class="{{ section.settings.card_title_font_family | default: 'font-primary' }} {{ section.settings.card_title_font_size | default: 'text-xl' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-2xl' }} {{ section.settings.card_title_font_weight | default: 'font-bold' }} {{ section.settings.card_3_title_color | default: 'text-white' }} leading-tight">
                    {{ section.settings.card_3_title | default: "Eiusmod Tempor Incididunt" }}
                  </h3>
                  <div class="card-description mt-md overflow-hidden transition-all duration-500 ease-in-out max-h-0 opacity-0 group-hover:max-h-40 group-hover:opacity-100">
                    <p class="{{ section.settings.card_description_font_family | default: 'font-body' }} {{ section.settings.card_description_font_size | default: 'text-base' }} {{ section.settings.card_description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.card_description_font_weight | default: 'font-normal' }} {{ section.settings.card_3_description_color | default: 'text-white' }} leading-relaxed">
                      {{ section.settings.card_3_description | default: "Excepteur sint occaecat cupidatat non proident sunt in culpa qui officia deserunt mollit anim id est laborum sed ut perspiciatis." }}
                    </p>
                  </div>
                </div>
              </div>
            {% if section.settings.card_3_link != blank %}
              </a>
            {% else %}
              </div>
            {% endif %}
            
          </div>
        </div>
        
      </div>
      
    </div>
  </div>
</section>

