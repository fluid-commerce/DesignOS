
<!-- Content Hero Section -->
<section class="content-hero {{ section.settings.section_padding_y_mobile }} {{ section.settings.section_padding_y_desktop }} {{ section.settings.section_border_radius }} {{ section.settings.background_color }}" 
         id="{{ section.id }}"
         {% if section.settings.background_image != blank %}
         style="background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');"
         {% endif %}>
  <div class="container {{ section.settings.container_background_color }} {{ section.settings.container_border_radius }} {{ section.settings.container_padding_y_mobile }} {{ section.settings.container_padding_y_desktop }} {{ section.settings.container_padding_x_mobile }} {{ section.settings.container_padding_x_desktop }}"
       {% if section.settings.container_background_image != blank %}
       style="background-image: url('{{ section.settings.container_background_image | image_url: width: 1200 }}');"
       {% endif %}>
    
    <!-- Content Grid -->
    <div class="content-grid {{ section.settings.layout_reverse | default: false }}">
      
      <!-- Content Column -->
      <div class="content-column">
        
        <!-- Tagline -->
        {% if section.settings.show_tag and section.settings.tag_text != blank %}
          <div class="tagline-wrapper {{ section.settings.tag_margin_bottom }}">
            <div class="tagline {{ section.settings.tag_font_family | default: 'font-handwritten' }} {{ section.settings.tag_text_color }} {{ section.settings.tag_font_size }} {{ section.settings.tag_font_weight }}">
              {{ section.settings.tag_text }}
            </div>
          </div>
        {% endif %}
        
        <!-- Heading -->
        {% if section.settings.content_heading != blank %}
          <div class="heading-wrapper {{ section.settings.heading_margin_bottom }}">
            <h2 class="content-heading {{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size }} {{ section.settings.heading_font_size_desktop }} {{ section.settings.heading_font_weight }} {{ section.settings.heading_line_height }} {{ section.settings.heading_text_color | default: 'text-black' }}">
              {{ section.settings.content_heading }}
            </h2>
          </div>
        {% endif %}
        
        <!-- Description -->
        {% if section.settings.content_description != blank %}
          <div class="description-wrapper {{ section.settings.description_margin_bottom }}">
            <div class="content-description {{ section.settings.description_font_family | default: 'font-primary' }} {{ section.settings.description_font_size }} {{ section.settings.description_font_size_desktop }} {{ section.settings.description_line_height }} {{ section.settings.description_text_color | default: 'text-neutral-dark' }}">
              {{ section.settings.content_description }}
            </div>
          </div>
        {% endif %}
        
        <!-- CTA Button -->
        {% if section.settings.show_cta_button and section.settings.cta_button_text != blank %}
          <div class="cta-wrapper {{ section.settings.cta_margin_top }}">
            {% if section.settings.cta_button_link != blank %}
              <a href="{{ section.settings.cta_button_link }}" 
                 class="cta-button {{ section.settings.cta_button_style }} {{ section.settings.cta_button_size }} {{ section.settings.cta_button_color }} {{ section.settings.cta_button_border_radius }}"
                 {% if section.settings.cta_button_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
                {{ section.settings.cta_button_text }}
              </a>
            {% else %}
              <button class="cta-button {{ section.settings.cta_button_style }} {{ section.settings.cta_button_size }} {{ section.settings.cta_button_color }} {{ section.settings.cta_button_border_radius }}">
                {{ section.settings.cta_button_text }}
              </button>
            {% endif %}
          </div>
        {% endif %}
        
      </div>
      
      <!-- Image Column -->
      <div class="image-column">
        <div class="image-wrapper {{ section.settings.image_border_radius }}">
          {% if section.settings.hero_image != blank %}
            <img src="{{ section.settings.hero_image | image_url: width: 800 }}"
                 alt="{{ section.settings.image_alt | default: section.settings.content_heading }}"
                 class="hero-image"
                 loading="lazy">
          {% else %}
            <img src="{{ 'placeholder-image.png' | asset_url }}"
                 alt="Placeholder image for {{ section.settings.content_heading }}"
                 class="hero-image"
                 loading="lazy">
          {% endif %}
        </div>
      </div>
      
    </div>
  </div>
</section>

