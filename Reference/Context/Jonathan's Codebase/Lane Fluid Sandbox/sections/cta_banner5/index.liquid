{%- style -%}
  .cta-banner5-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | default: 64 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 64 }}px;
    background-color: {{ section.settings.background_color | default: '#444444' }} !important;
  }
  
  .cta-banner5-section-{{ section.id }} .cta-heading {
    color: {{ section.settings.heading_color | default: '#ffffff' }} !important;
  }
  
  .cta-banner5-section-{{ section.id }} .cta-description {
    color: {{ section.settings.description_color | default: '#ffffff' }} !important;
  }
  
  .cta-banner5-section-{{ section.id }} .cta-terms {
    color: {{ section.settings.terms_color | default: '#ffffff' }} !important;
  }
  
  .cta-banner5-section-{{ section.id }} .cta-terms a {
    color: {{ section.settings.terms_link_color | default: '#ffffff' }} !important;
  }
  
  .cta-banner5-section-{{ section.id }} .cta-terms a:hover {
    color: {{ section.settings.terms_link_color | default: '#ffffff' }} !important;
    opacity: 0.8;
  }
{%- endstyle -%}

<!-- Cta section -->
<section class="cta-section cta-banner5-section-{{ section.id }} py-16 xl-tab-py-20">
    <div class="container">
      <div class="grid grid-cols-1 md-tab-grid-cols-2 gap-12 md-tab-grid-20">
        <h2 class="cta-heading {{ section.settings.heading_font_size | default: 'text-h2' }} {{ section.settings.heading_font_size_desktop | default: 'text-h2' }} {{ section.settings.heading_font_weight | default: 'font-bold' }}">
          {{ section.settings.heading | default: "Medium length heading goes here" }}
        </h2>
        <div class="cta-content">
          <p class="cta-description {{ section.settings.description_font_size | default: 'text-lg' }} {{ section.settings.description_font_size_desktop | default: 'xl-tab-text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }}">
            {{ section.settings.description | default: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare, eros dolor interdum nulla, ut commodo diam libero vitae erat." }}
          </p>
          {% if section.settings.show_form %}
          <form class="cta-signup mt-6 flex-col xl-phone-flex-row flex gap-4" action="{{ section.settings.form_action | default: '#' }}" method="POST">
            <div class="flex-1">
              <input
                type="email"
                name="email"
                placeholder="{{ section.settings.input_placeholder | default: 'Enter your email' }}"
                class="input-border-white"
                required
              />
            </div>
            <button class="btn btn-bg-white {{ section.settings.button_font_size | default: 'text-base' }} {{ section.settings.button_font_size_desktop | default: 'xl-tab-text-base' }} {{ section.settings.button_font_weight | default: 'font-medium' }}" type="submit">
              {{ section.settings.button_text | default: "sign up" }}
            </button>
          </form>
          {% endif %}
          {% if section.settings.show_terms %}
          <div class="cta-terms {{ section.settings.terms_font_size | default: 'text-xs' }} {{ section.settings.terms_font_size_desktop | default: 'xl-tab-text-xs' }} {{ section.settings.terms_font_weight | default: 'font-normal' }} mt-4">
            {{ section.settings.terms_text | default: "By clicking Sign Up you're confirming that you agree with our" }}
            {% if section.settings.terms_link_url != blank %}
            <a href="{{ section.settings.terms_link_url }}" class="underline">{{ section.settings.terms_link_text | default: "Terms and Conditions" }}</a>.
            {% endif %}
          </div>
          {% endif %}
        </div>
      </div>
    </div>
</section>

