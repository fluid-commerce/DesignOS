<!-- Quote Testimonial Section -->
<section class="quote-testimonial section {{ section.settings.section_background_color | default: 'bg-neutral-light' }} {{ section.settings.section_padding | default: 'py-2xl' }}">
  <div class="container">
    <div class="inner-container {{ section.settings.container_background_color | default: 'bg-transparent' }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding | default: 'p-0' }}">
      
      <!-- Quote Content Grid -->
      <div class="quote-grid grid grid-cols-1 lg:grid-cols-2 gap-xl lg:gap-2xl items-center {{ section.settings.flip_layout == true ? 'flip-layout' : '' }}">
        
        <!-- Left Side - Image -->
        <div class="quote-image-wrapper">
          {% if section.settings.testimonial_image %}
            <div class="quote-image-container {{ section.settings.image_border_radius | default: 'rounded-xl' }} overflow-hidden">
              <img src="{{ section.settings.testimonial_image | image_url }}"
                   alt="{{ section.settings.testimonial_image_alt | default: 'Testimonial image' }}"
                   class="quote-image w-full h-full object-cover">
            </div>
          {% else %}
            <div class="quote-image-container {{ section.settings.image_border_radius | default: 'rounded-xl' }} overflow-hidden">
              <img src="{{ 'placeholder-image.png' | asset_url }}"
                   alt="{{ section.settings.testimonial_image_alt | default: 'Testimonial placeholder image' }}"
                   class="quote-image w-full h-full object-cover">
            </div>
          {% endif %}
        </div>
        
        <!-- Right Side - Quote Content -->
        <div class="quote-content-wrapper">
          <div class="quote-content space-y-lg">
            
            <!-- Star Rating -->
            {% if section.settings.show_rating %}
            <div class="rating-wrapper">
              <div class="stars-container flex items-center gap-xs">
                {% for i in (1..5) %}
                  <svg class="star w-6 h-6 {{ section.settings.star_color | default: 'text-yellow-500' }}" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                {% endfor %}
              </div>
            </div>
            {% endif %}
            
            <!-- Quote Text -->
            {% if section.settings.testimonial_text != blank %}
            <div class="quote-text-wrapper">
              <blockquote class="{{ section.settings.quote_font_family | default: 'font-body' }} {{ section.settings.quote_font_size | default: 'text-lg' }} {{ section.settings.quote_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.quote_font_weight | default: 'font-normal' }} {{ section.settings.quote_color | default: 'text-black' }} leading-relaxed">
                <span class="quote-mark {{ section.settings.quote_mark_color | default: 'text-primary' }}">"</span>{{ section.settings.testimonial_text | default: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare, eros dolor interdum nulla, ut commodo diam libero vitae erat." }}<span class="quote-mark {{ section.settings.quote_mark_color | default: 'text-primary' }}">"</span>
              </blockquote>
            </div>
            {% endif %}
            
            <!-- Author Info -->
            <div class="author-info-wrapper">
              <div class="author-info">
                
                <!-- Author Name -->
                {% if section.settings.author_name != blank %}
                <div class="author-name-wrapper">
                  <p class="{{ section.settings.author_name_font_family | default: 'font-primary' }} {{ section.settings.author_name_font_size | default: 'text-lg' }} {{ section.settings.author_name_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.author_name_font_weight | default: 'font-bold' }} {{ section.settings.author_name_color | default: 'text-black' }}">
                    {{ section.settings.author_name | default: "Lorem Ipsum" }}
                  </p>
                </div>
                {% endif %}
                
                <!-- Author Title & Company -->
                <div class="author-details flex items-center gap-md">
                  {% if section.settings.author_title != blank %}
                  <p class="{{ section.settings.author_title_font_family | default: 'font-body' }} {{ section.settings.author_title_font_size | default: 'text-base' }} {{ section.settings.author_title_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.author_title_font_weight | default: 'font-normal' }} {{ section.settings.author_title_color | default: 'text-neutral-dark' }}">
                    {{ section.settings.author_title | default: "Lorem Ipsum" }}
                  </p>
                  {% endif %}
                  
                  {% if section.settings.author_title != blank and section.settings.company_name != blank %}
                  <span class="divider {{ section.settings.author_title_color | default: 'text-neutral-dark' }}">|</span>
                  {% endif %}
                  
                  {% if section.settings.company_name != blank %}
                  <div class="company-info flex items-center gap-sm">
                    {% if section.settings.company_logo %}
                      <img src="{{ section.settings.company_logo | image_url: width: 80 }}"
                           alt="{{ section.settings.company_name }}"
                           class="company-logo h-6 w-auto">
                    {% endif %}
                    <p class="{{ section.settings.company_name_font_family | default: 'font-body' }} {{ section.settings.company_name_font_size | default: 'text-base' }} {{ section.settings.company_name_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.company_name_font_weight | default: 'font-medium' }} {{ section.settings.company_name_color | default: 'text-black' }}">
                      {{ section.settings.company_name | default: "Lorem Corp" }}
                    </p>
                  </div>
                  {% endif %}
                </div>
                
              </div>
            </div>
            
          </div>
        </div>
        
      </div>
      
    </div>
  </div>
</section>

<style>
  {% render 'section-css', section_id: 'quote_testimonial' %}
</style>

