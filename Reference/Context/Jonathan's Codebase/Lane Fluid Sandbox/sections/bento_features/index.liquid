<!-- Bento Features Section -->
<section class="bento-features {{ section.settings.background_color | default: 'bg-neutral-light' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image }}"{% endif %}>
  <div class="container">
    <div class="inner-container {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_padding_y_mobile | default: 'py-xl' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-lg' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }} {{ section.settings.container_border_radius | default: 'rounded-none' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image }}"{% endif %}>
      
      <div class="max-w-7xl mx-auto">
        
        <!-- Main Content -->
        <div class="bento-content space-y-4xl">
          
          <!-- Header Section -->
          <div class="bento-header text-center lg:text-left space-y-xl">
            
            <!-- Tagline -->
            {% if section.settings.show_tagline %}
            <div class="tagline-wrapper">
              <p class="{{ section.settings.tagline_font_family | default: 'font-body' }} {{ section.settings.tagline_font_size | default: 'text-sm' }} {{ section.settings.tagline_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.tagline_font_weight | default: 'font-medium' }} {{ section.settings.tagline_color | default: 'text-neutral-dark' }} uppercase tracking-wider">
                {{ section.settings.tagline | default: "EASY & HASSLE-FREE" }}
              </p>
            </div>
            {% endif %}
            
            <!-- Main Heading -->
            {% if section.settings.show_heading %}
            <div class="heading-wrapper">
              <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-4xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-6xl' }} {{ section.settings.heading_font_weight | default: 'font-black' }} {{ section.settings.heading_color | default: 'text-black' }} leading-tight">
                {{ section.settings.heading | default: "Tech enabled and made to <em>work for you</em>." }}
              </h2>
            </div>
            {% endif %}
            
            <!-- Description -->
            {% if section.settings.show_description %}
            <div class="description-wrapper lg:max-w-md lg:ml-auto">
              <p class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-neutral-dark' }} leading-relaxed">
                {{ section.settings.description | default: "No matter your creative need, submitting and managing a project is effortless." }}
              </p>
            </div>
            {% endif %}
            
          </div>
          
          <!-- Bento Grid -->
          <div class="bento-grid-wrapper">
            <div class="bento-grid">
              
              <!-- Card 1 -->
              <div class="bento-card card-1 {{ section.settings.card_border_radius | default: 'rounded-2xl' }} overflow-hidden relative" {% if section.settings.card_1_background_image %}data-bg="{{ section.settings.card_1_background_image }}"{% endif %}>
                <div class="card-content {{ section.settings.card_padding | default: 'p-xl lg:p-2xl' }} relative z-10 h-full flex flex-col justify-start">
                  <div class="card-top space-y-lg">
                    <!-- Icon -->
                    {% if section.settings.card_1_icon %}
                    <div class="icon-wrapper">
                      <div class="icon {{ section.settings.icon_size | default: 'w-12 h-12' }} {{ section.settings.icon_color | default: 'text-black' }}">
                        {{ section.settings.card_1_icon }}
                      </div>
                    </div>
                    {% endif %}
                    
                    <!-- Title -->
                    <div class="card-title">
                      <h3 class="{{ section.settings.card_title_font_family | default: 'font-primary' }} {{ section.settings.card_title_font_size | default: 'text-2xl' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.card_title_font_weight | default: 'font-bold' }} {{ section.settings.card_title_color | default: 'text-black' }} leading-tight">
                        {{ section.settings.card_1_title | default: "From brief to review and sign off" }}
                      </h3>
                    </div>
                    
                    <!-- Description -->
                    <div class="card-description">
                      <p class="{{ section.settings.card_description_font_family | default: 'font-body' }} {{ section.settings.card_description_font_size | default: 'text-base' }} {{ section.settings.card_description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.card_description_font_weight | default: 'font-normal' }} {{ section.settings.card_description_color | default: 'text-neutral-dark' }} leading-relaxed">
                        {{ section.settings.card_1_description | default: "Welcome to Superspace. Quickly submit a brief, review in platform, keep track of usage and more in one easy place." }}
                      </p>
                    </div>
                  </div>
                </div>
              </div>
              
              <!-- Card 2 -->
              <div class="bento-card card-2 {{ section.settings.card_border_radius | default: 'rounded-2xl' }} overflow-hidden relative" {% if section.settings.card_2_background_image %}data-bg="{{ section.settings.card_2_background_image }}"{% endif %}>
                <div class="card-content {{ section.settings.card_padding | default: 'p-xl lg:p-2xl' }} relative z-10 h-full flex flex-col justify-start">
                  <div class="card-top space-y-lg">
                    <!-- Icon -->
                    {% if section.settings.card_2_icon %}
                    <div class="icon-wrapper">
                      <div class="icon {{ section.settings.icon_size | default: 'w-12 h-12' }} {{ section.settings.icon_color | default: 'text-black' }}">
                        {{ section.settings.card_2_icon }}
                      </div>
                    </div>
                    {% endif %}
                    
                    <!-- Title -->
                    <div class="card-title">
                      <h3 class="{{ section.settings.card_title_font_family | default: 'font-primary' }} {{ section.settings.card_title_font_size | default: 'text-2xl' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.card_title_font_weight | default: 'font-bold' }} {{ section.settings.card_title_color | default: 'text-black' }} leading-tight">
                        {{ section.settings.card_2_title | default: "Integrate with your favorite platforms" }}
                      </h3>
                    </div>
                    
                    <!-- Description -->
                    <div class="card-description">
                      <p class="{{ section.settings.card_description_font_family | default: 'font-body' }} {{ section.settings.card_description_font_size | default: 'text-base' }} {{ section.settings.card_description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.card_description_font_weight | default: 'font-normal' }} {{ section.settings.card_description_color | default: 'text-neutral-dark' }} leading-relaxed">
                        {{ section.settings.card_2_description | default: "Already using platforms like Asana/Jira/Slack? They integrate too." }}
                      </p>
                    </div>
                  </div>
                </div>
              </div>
              
              <!-- Card 3 -->
              <div class="bento-card card-3 {{ section.settings.card_border_radius | default: 'rounded-2xl' }} overflow-hidden relative" {% if section.settings.card_3_background_image %}data-bg="{{ section.settings.card_3_background_image }}"{% endif %}>
                <div class="card-content {{ section.settings.card_padding | default: 'p-xl lg:p-2xl' }} relative z-10 h-full flex flex-col justify-start">
                  <div class="card-top space-y-lg">
                    <!-- Icon -->
                    {% if section.settings.card_3_icon %}
                    <div class="icon-wrapper">
                      <div class="icon {{ section.settings.icon_size | default: 'w-12 h-12' }} {{ section.settings.icon_color | default: 'text-white' }}">
                        {{ section.settings.card_3_icon }}
                      </div>
                    </div>
                    {% endif %}
                    
                    <!-- Title -->
                    <div class="card-title">
                      <h3 class="{{ section.settings.card_title_font_family | default: 'font-primary' }} {{ section.settings.card_title_font_size | default: 'text-2xl' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.card_title_font_weight | default: 'font-bold' }} text-white leading-tight">
                        {{ section.settings.card_3_title | default: "Learn from our customers' successful projects" }}
                      </h3>
                    </div>
                    
                    <!-- Description -->
                    <div class="card-description">
                      <p class="{{ section.settings.card_description_font_family | default: 'font-body' }} {{ section.settings.card_description_font_size | default: 'text-base' }} {{ section.settings.card_description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.card_description_font_weight | default: 'font-normal' }} text-neutral-light leading-relaxed">
                        {{ section.settings.card_3_description | default: "Reference work from the world's best brands on our platform." }}
                      </p>
                    </div>
                  </div>
                </div>
              </div>
              
              <!-- Card 4 -->
              <div class="bento-card card-4 {{ section.settings.card_border_radius | default: 'rounded-2xl' }} overflow-hidden relative" {% if section.settings.card_4_background_image %}data-bg="{{ section.settings.card_4_background_image }}"{% endif %}>
                <div class="card-content {{ section.settings.card_padding | default: 'p-xl lg:p-2xl' }} relative z-10 h-full flex flex-col justify-start">
                  <div class="card-top space-y-lg">
                    <!-- Icon -->
                    {% if section.settings.card_4_icon %}
                    <div class="icon-wrapper">
                      <div class="icon {{ section.settings.icon_size | default: 'w-12 h-12' }} {{ section.settings.icon_color | default: 'text-white' }}">
                        {{ section.settings.card_4_icon }}
                      </div>
                    </div>
                    {% endif %}
                    
                    <!-- Title -->
                    <div class="card-title">
                      <h3 class="{{ section.settings.card_title_font_family | default: 'font-primary' }} {{ section.settings.card_title_font_size | default: 'text-2xl' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.card_title_font_weight | default: 'font-bold' }} text-white leading-tight">
                        {{ section.settings.card_4_title | default: "Organize and share all your brand assets" }}
                      </h3>
                    </div>
                    
                    <!-- Description -->
                    <div class="card-description">
                      <p class="{{ section.settings.card_description_font_family | default: 'font-body' }} {{ section.settings.card_description_font_size | default: 'text-base' }} {{ section.settings.card_description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.card_description_font_weight | default: 'font-normal' }} text-neutral-light leading-relaxed">
                        {{ section.settings.card_4_description | default: "Stop searching—store and organize everything on our platform." }}
                      </p>
                    </div>
                  </div>
                </div>
              </div>
              
            </div>
          </div>
          
        </div>
        
      </div>
      
    </div>
  </div>
</section>

