<!-- You May Also Like Section -->
<section class="you-may-also-like {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image }}"{% endif %}>
  <div class="container">
    <div class="inner-container {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_padding_y_mobile | default: 'py-xl' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-lg' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }} {{ section.settings.container_border_radius | default: 'rounded-none' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image }}"{% endif %}>
      
      <div class="max-w-7xl mx-auto">
        
        <!-- Section Header -->
        {% if section.settings.show_heading %}
        <div class="section-header text-center mb-3xl">
          <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-4xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-bold' }} {{ section.settings.heading_color | default: 'text-black' }} leading-tight">
            {{ section.settings.heading | default: "You May Also Like" }}
          </h2>
        </div>
        {% endif %}
        
        <!-- Products Grid -->
        {% if section.blocks.size > 0 %}
        <div class="products-wrapper">
          {% assign block_count = section.blocks.size %}
          {% assign grid_cols = 'md:grid-cols-1' %}
          {% if block_count == 2 %}
            {% assign grid_cols = 'md:grid-cols-2' %}
          {% elsif block_count == 3 %}
            {% assign grid_cols = 'md:grid-cols-3' %}
          {% elsif block_count >= 4 %}
            {% assign grid_cols = 'md:grid-cols-4' %}
          {% endif %}

          <div class="products-grid grid grid-cols-1 {{ grid_cols }} gap-lg lg:gap-xl">
            {% for block in section.blocks %}
              {% case block.type %}
                {% when 'product_item' %}
                  <div class="product-item" {{ block.fluid_attributes }}>
                    
                    {% comment %} Get product data from block settings {% endcomment %}
                    {% if block.settings.product != blank %}
                      {% assign selected_product = block.settings.product %}
                      {% assign product_name = selected_product.title %}
                      {% assign product_description = block.settings.custom_description | default: selected_product.description | truncate: 200 %}
                      {% assign product_price = selected_product.price | money %}
                      {% assign product_url = selected_product.url %}
                      {% assign primary_image = block.settings.custom_primary_image | default: selected_product.featured_media %}
                      {% assign hover_image = block.settings.custom_hover_image %}
                      {% if selected_product.images.size > 1 and hover_image == blank %}
                        {% assign hover_image = selected_product.images[1] %}
                      {% endif %}
                    {% else %}
                      {% comment %} Fallback to manual entry {% endcomment %}
                      {% assign product_name = block.settings.product_name %}
                      {% assign product_description = block.settings.product_description %}
                      {% assign product_price = block.settings.product_price %}
                      {% assign product_url = block.settings.product_url %}
                      {% assign primary_image = block.settings.primary_image %}
                      {% assign hover_image = block.settings.hover_image %}
                    {% endif %}
                    
                    <!-- Debug Info (remove in production) -->
                    {% if section.settings.show_debug_info %}
                    <div class="debug-info p-2 bg-yellow-100 text-xs mb-2">
                      <strong>Debug:</strong><br>
                      Product Selected: {{ block.settings.product.title | default: 'None' }}<br>
                      Product ID: {{ selected_product.id }}<br>
                      Product Name: {{ product_name }}<br>
                      Product URL: {{ product_url }}<br>
                      Primary Image: {{ primary_image }}<br>
                      Price: {{ product_price }}
                    </div>
                    {% endif %}
                    
                    <!-- Product Image with Hover Effect -->
                    <div class="product-image-wrapper {{ section.settings.image_border_radius | default: 'rounded-lg' }} overflow-hidden bg-neutral-light mb-lg">
                      <div class="product-image-container relative">
                        
                        <!-- Primary Image -->
                        {% if primary_image %}
                          <img src="{{ primary_image | image_url: width: 400 }}"
                               alt="{{ primary_image.alt | default: product_name }}"
                               class="product-image-primary w-full h-64 lg:h-80 object-cover transition-all duration-500 ease-in-out">
                        {% else %}
                          <img src="{{ 'placeholder-image.png' | asset_url }}"
                               alt="{{ product_name | default: 'Product image placeholder' }}"
                               class="product-image-primary w-full h-64 lg:h-80 object-cover transition-all duration-500 ease-in-out">
                        {% endif %}
                        
                        <!-- Hover Image (if provided) -->
                        {% if hover_image %}
                          <img src="{{ hover_image | image_url: width: 400 }}"
                               alt="{{ hover_image.alt | default: product_name }}"
                               class="product-image-hover absolute inset-0 w-full h-64 lg:h-80 object-cover transition-all duration-500 ease-in-out opacity-0">
                        {% endif %}
                        
                      </div>
                    </div>
                    
                    <!-- Product Info -->
                    <div class="product-info space-y-sm">
                      
                      <!-- Product Name -->
                      {% if product_name != blank %}
                      <h3 class="{{ section.settings.product_name_font_family | default: 'font-primary' }} {{ section.settings.product_name_font_size | default: 'text-xl' }} {{ section.settings.product_name_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.product_name_font_weight | default: 'font-bold' }} {{ section.settings.product_name_color | default: 'text-black' }}">
                        {% if product_url != blank %}
                          <a href="{{ product_url }}" class="hover:opacity-70 transition-opacity duration-200">
                            {{ product_name }}
                          </a>
                        {% else %}
                          {{ product_name }}
                        {% endif %}
                      </h3>
                      {% endif %}
                      
                      <!-- Product Description -->
                      {% if section.settings.show_description and product_description != blank %}
                      <p class="{{ section.settings.product_description_font_family | default: 'font-body' }} {{ section.settings.product_description_font_size | default: 'text-sm' }} {{ section.settings.product_description_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.product_description_font_weight | default: 'font-normal' }} {{ section.settings.product_description_color | default: 'text-neutral-dark' }} leading-relaxed">
                        {{ product_description }}
                      </p>
                      {% endif %}
                      
                      <!-- Product Price -->
                      {% if section.settings.show_price and product_price != blank %}
                      <div class="product-price">
                        <span class="{{ section.settings.product_price_font_family | default: 'font-body' }} {{ section.settings.product_price_font_size | default: 'text-lg' }} {{ section.settings.product_price_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.product_price_font_weight | default: 'font-bold' }} {{ section.settings.product_price_color | default: 'text-black' }}">
                          {{ product_price }}
                        </span>
                      </div>
                      {% endif %}
                      
                    </div>
                    
                  </div>
              {% endcase %}
            {% endfor %}
          </div>
        </div>
        {% else %}
          <!-- No products message -->
          {% if section.settings.show_no_products_message %}
          <div class="no-products-message text-center py-xl">
            <p class="{{ section.settings.no_products_font_size | default: 'text-base' }} {{ section.settings.no_products_color | default: 'text-neutral-dark' }}">
              {{ section.settings.no_products_message | default: "No products found. Add some product blocks to display related products." }}
            </p>
          </div>
          {% endif %}
        {% endif %}
        
      </div>
      
    </div>
  </div>
</section>

