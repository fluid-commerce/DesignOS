<!-- Therapy Showcase Section -->
<section class="therapy-showcase {{ section.settings.section_padding_y_mobile }} {{ section.settings.section_padding_y_desktop }} {{ section.settings.section_border_radius }} {{ section.settings.background_color }}" 
         id="{{ section.id }}"
         {% if section.settings.background_image != blank %}
         style="background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');"
         {% endif %}>
  <div class="container {{ section.settings.container_background_color }} {{ section.settings.container_border_radius }} {{ section.settings.container_padding_y_mobile }} {{ section.settings.container_padding_y_desktop }} {{ section.settings.container_padding_x_mobile }} {{ section.settings.container_padding_x_desktop }}"
       {% if section.settings.container_background_image != blank %}
       style="background-image: url('{{ section.settings.container_background_image | image_url: width: 1200 }}');"
       {% endif %}>
    
    <!-- Section Header -->
    {% if section.settings.show_section_header %}
      <div class="section-header {{ section.settings.header_text_align }} {{ section.settings.heading_margin_bottom }}">
        {% if section.settings.section_heading != blank %}
          <div class="heading-wrapper {{ section.settings.heading_margin_bottom }}">
            <h2 class="section-heading {{ section.settings.heading_font_size }} {{ section.settings.heading_font_size_desktop }} {{ section.settings.heading_font_weight }} {{ section.settings.heading_line_height }} {{ section.settings.heading_text_color | default: 'text-white' }}">
              {{ section.settings.section_heading }}
            </h2>
          </div>
        {% endif %}
        
        {% if section.settings.section_description != blank %}
          <div class="description-wrapper">
            <p class="section-description {{ section.settings.description_font_size }} {{ section.settings.description_font_size_desktop }} {{ section.settings.description_line_height }} {{ section.settings.description_text_color | default: 'text-neutral-light' }}">
              {{ section.settings.section_description }}
            </p>
          </div>
        {% endif %}
      </div>
    {% endif %}
    
    <!-- Therapy Cards Container -->
    <div class="therapy-cards-wrapper {{ section.settings.cards_margin_top }}">
      
      <!-- Therapy Cards Grid/Slider -->
      <div class="therapy-cards-container" data-slider="{{ section.settings.enable_slider }}">
        <div class="therapy-cards-grid">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'therapy_card' %}
                <div class="therapy-card {{ section.settings.card_background_color }} {{ section.settings.card_border_radius }}" {{ block.fluid_attributes }}>
                  
                  <!-- Card Image -->
                  <div class="therapy-card-image {{ section.settings.image_border_radius }}">
                    {% if block.settings.therapy_image != blank %}
                      <img src="{{ block.settings.therapy_image | image_url: width: 400 }}"
                           alt="{{ block.settings.image_alt | default: block.settings.therapy_title }}"
                           class="card-image"
                           loading="lazy">
                    {% else %}
                      <img src="{{ 'placeholder-image.png' | asset_url }}"
                           alt="Image for {{ block.settings.therapy_title }}"
                           class="card-image"
                           loading="lazy">
                    {% endif %}
                    
                    <!-- Image Overlay -->
                    <div class="image-overlay"></div>
                  </div>
                  
                  <!-- Card Content -->
                  <div class="therapy-card-content {{ section.settings.card_content_padding }}">
                    
                    <!-- Icon and Title Row -->
                    <div class="card-header">
                      
                      <!-- Icon -->
                      {% if block.settings.show_icon %}
                        <div class="therapy-icon {{ section.settings.icon_background_color }} {{ section.settings.icon_border_radius }} {{ section.settings.icon_size }}">
                          {% if block.settings.icon_image != blank %}
                            <img src="{{ block.settings.icon_image | image_url: width: 100 }}"
                                 alt="{{ block.settings.icon_alt | default: block.settings.therapy_title }}"
                                 class="icon-image"
                                 loading="lazy">
                          {% else %}
                            <img src="{{ 'placeholder-image.png' | asset_url }}"
                                 alt="Icon for {{ block.settings.therapy_title }}"
                                 class="icon-image"
                                 loading="lazy">
                          {% endif %}
                        </div>
                      {% endif %}
                      
                      <!-- Title -->
                      {% if block.settings.therapy_title != blank %}
                        <div class="therapy-title-wrapper">
                          <h3 class="therapy-title {{ section.settings.title_font_size }} {{ section.settings.title_font_size_desktop }} {{ section.settings.title_font_weight }} {{ section.settings.title_line_height }} {{ block.settings.title_text_color | default: section.settings.card_text_color | default: 'text-black' }}">
                            {{ block.settings.therapy_title }}
                          </h3>
                        </div>
                      {% endif %}
                      
                      <!-- Toggle Button -->
                      {% if section.settings.show_action_buttons %}
                        <div class="therapy-action">
                          <button class="toggle-button {{ section.settings.button_background_color }} {{ section.settings.button_text_color }} {{ section.settings.button_border_radius }}"
                                  data-therapy="{{ block.settings.therapy_title | handle }}"
                                  data-active="{{ block.settings.default_active | default: false }}"
                                  aria-label="Toggle {{ block.settings.therapy_title }}"
                                  onclick="toggleTherapy(this)">
                            <!-- Plus Icon (inactive state) -->
                            <svg class="plus-icon" width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                              <path d="M8 2a.5.5 0 01.5.5v5h5a.5.5 0 010 1h-5v5a.5.5 0 01-1 0v-5h-5a.5.5 0 010-1h5v-5A.5.5 0 018 2z"/>
                            </svg>
                            <!-- Check Icon (active state) -->
                            <svg class="check-icon" width="16" height="16" viewBox="0 0 16 16" fill="currentColor" style="display: none;">
                              <path d="M13.854 3.646a.5.5 0 0 1 0 .708l-7 7a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L6.5 10.293l6.646-6.647a.5.5 0 0 1 .708 0z"/>
                            </svg>
                          </button>
                        </div>
                      {% endif %}
                      
                    </div>
                    
                    <!-- Description (Optional) -->
                    {% if block.settings.therapy_description != blank %}
                      <div class="therapy-description-wrapper {{ section.settings.description_margin_top }}">
                        <p class="therapy-description {{ section.settings.card_description_font_size }} {{ section.settings.card_description_font_size_desktop }} {{ section.settings.card_description_line_height }} {{ block.settings.description_text_color | default: section.settings.card_text_color | default: 'text-neutral' }}">
                          {{ block.settings.therapy_description }}
                        </p>
                      </div>
                    {% endif %}
                    
                  </div>
                </div>
            {% endcase %}
          {% endfor %}
        </div>
      </div>
      
      <!-- Navigation (for slider mode) -->
      {% if section.settings.enable_slider and section.settings.show_navigation %}
        <div class="slider-navigation {{ section.settings.navigation_margin_top }}">
          <button class="nav-button nav-prev {{ section.settings.nav_button_background_color }} {{ section.settings.nav_button_text_color }} {{ section.settings.nav_button_border_radius }}" 
                  aria-label="Previous therapy">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
          </button>
          <button class="nav-button nav-next {{ section.settings.nav_button_background_color }} {{ section.settings.nav_button_text_color }} {{ section.settings.nav_button_border_radius }}" 
                  aria-label="Next therapy">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
            </svg>
          </button>
        </div>
      {% endif %}
      
      <!-- Bottom CTA Link (Optional) -->
      {% if section.settings.show_bottom_cta and section.settings.bottom_cta_text != blank %}
        <div class="bottom-cta {{ section.settings.bottom_cta_margin_top }}">
          {% if section.settings.bottom_cta_link != blank %}
            <a href="{{ section.settings.bottom_cta_link }}" 
               class="bottom-cta-link {{ section.settings.bottom_cta_font_size }} {{ section.settings.bottom_cta_text_color | default: 'text-white' }}">
              {{ section.settings.bottom_cta_text }}
            </a>
          {% else %}
            <span class="bottom-cta-text {{ section.settings.bottom_cta_font_size }} {{ section.settings.bottom_cta_text_color | default: 'text-white' }}">
              {{ section.settings.bottom_cta_text }}
            </span>
          {% endif %}
        </div>
      {% endif %}
      
    </div>
  </div>
</section>

<!-- Embedded JavaScript for Slider Functionality -->
{% if section.settings.enable_slider %}
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const sliderContainer = document.querySelector('.therapy-showcase .therapy-cards-container[data-slider="true"]');
    if (!sliderContainer) return;
    
    const cardsGrid = sliderContainer.querySelector('.therapy-cards-grid');
    const cards = cardsGrid.querySelectorAll('.therapy-card');
    const prevButton = document.querySelector('.therapy-showcase .nav-prev');
    const nextButton = document.querySelector('.therapy-showcase .nav-next');
    
    if (!cards.length || !prevButton || !nextButton) return;
    
    let currentIndex = 0;
    let cardsPerView = 1;
    
    // Calculate cards per view based on screen size
    function updateCardsPerView() {
      const containerWidth = sliderContainer.offsetWidth;
      if (containerWidth >= 1200) {
        cardsPerView = Math.min(4, cards.length); // Show 4 cards on large screens
      } else if (containerWidth >= 900) {
        cardsPerView = Math.min(3, cards.length); // Show 3 cards on medium screens
      } else if (containerWidth >= 600) {
        cardsPerView = Math.min(2, cards.length); // Show 2 cards on small screens
      } else {
        cardsPerView = 1; // Show 1 card on mobile
      }
    }
    
    // Update slider position
    function updateSlider() {
      const cardWidth = 100 / cardsPerView;
      const maxIndex = Math.max(0, cards.length - cardsPerView);
      currentIndex = Math.min(currentIndex, maxIndex);
      
      const translateX = -(currentIndex * cardWidth);
      cardsGrid.style.transform = `translateX(${translateX}%)`;
      
      // Update button states
      prevButton.disabled = currentIndex === 0;
      nextButton.disabled = currentIndex >= maxIndex;
      
      prevButton.style.opacity = currentIndex === 0 ? '0.5' : '1';
      nextButton.style.opacity = currentIndex >= maxIndex ? '0.5' : '1';
    }
    
    // Navigation event listeners
    prevButton.addEventListener('click', function() {
      if (currentIndex > 0) {
        currentIndex--;
        updateSlider();
      }
    });
    
    nextButton.addEventListener('click', function() {
      const maxIndex = Math.max(0, cards.length - cardsPerView);
      if (currentIndex < maxIndex) {
        currentIndex++;
        updateSlider();
      }
    });
    
    // Handle window resize
    window.addEventListener('resize', function() {
      updateCardsPerView();
      updateSlider();
    });
    
    // Initialize
    updateCardsPerView();
    updateSlider();
    
    console.log('Therapy showcase slider initialized with', cards.length, 'cards');
  });
</script>
{% endif %}

<!-- Toggle Button JavaScript -->
<script>
  // Toggle therapy selection
  function toggleTherapy(button) {
    const isActive = button.getAttribute('data-active') === 'true';
    const plusIcon = button.querySelector('.plus-icon');
    const checkIcon = button.querySelector('.check-icon');
    
    if (isActive) {
      // Deactivate
      button.setAttribute('data-active', 'false');
      button.classList.remove('active');
      plusIcon.style.display = 'block';
      checkIcon.style.display = 'none';
    } else {
      // Activate
      button.setAttribute('data-active', 'true');
      button.classList.add('active');
      plusIcon.style.display = 'none';
      checkIcon.style.display = 'block';
    }
    
    // Optional: Log selection for analytics or further processing
    const therapyName = button.getAttribute('data-therapy');
    console.log('Therapy toggled:', therapyName, isActive ? 'deselected' : 'selected');
  }
  
  // Initialize button states on page load
  document.addEventListener('DOMContentLoaded', function() {
    const toggleButtons = document.querySelectorAll('.therapy-showcase .toggle-button');
    
    toggleButtons.forEach(function(button) {
      const isActive = button.getAttribute('data-active') === 'true';
      const plusIcon = button.querySelector('.plus-icon');
      const checkIcon = button.querySelector('.check-icon');
      
      if (isActive) {
        button.classList.add('active');
        plusIcon.style.display = 'none';
        checkIcon.style.display = 'block';
      } else {
        button.classList.remove('active');
        plusIcon.style.display = 'block';
        checkIcon.style.display = 'none';
      }
    });
  });
</script>

