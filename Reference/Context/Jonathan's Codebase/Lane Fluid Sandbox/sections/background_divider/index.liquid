<!-- Background Divider Section -->
<section class="background-divider {{ section.settings.background_color | default: 'bg-transparent' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" 
         style="
           {% if section.settings.divider_image %}
             background: url('{{ section.settings.divider_image | image_url }}') 0 0 / 100% 100% no-repeat;
           {% endif %}
           {% if section.settings.divider_height_mobile %}
             height: {{ section.settings.divider_height_mobile }};
           {% endif %}
           {% if section.settings.divider_height_desktop %}
             --desktop-height: {{ section.settings.divider_height_desktop }};
           {% endif %}
         ">
  
  <!-- Optional overlay for better content readability -->
  {% if section.settings.show_overlay %}
  <div class="divider-overlay" style="
    background: {{ section.settings.overlay_color | default: 'rgba(0, 0, 0, 0.4)' }};
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  "></div>
  {% endif %}

  <!-- Optional content container -->
  {% if section.settings.show_content %}
  <div class="container relative z-10 h-full flex items-center justify-center">
    <div class="divider-content text-center">
      
      <!-- Optional heading -->
      {% if section.settings.show_heading and section.settings.heading != blank %}
      <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-4xl' }} {{ section.settings.heading_font_weight | default: 'font-bold' }} {{ section.settings.heading_color | default: 'text-white' }} mb-md">
        {{ section.settings.heading }}
      </h2>
      {% endif %}
      
      <!-- Optional subheading -->
      {% if section.settings.show_subheading and section.settings.subheading != blank %}
      <p class="{{ section.settings.subheading_font_family | default: 'font-body' }} {{ section.settings.subheading_font_size | default: 'text-lg' }} {{ section.settings.subheading_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.subheading_font_weight | default: 'font-normal' }} {{ section.settings.subheading_color | default: 'text-white' }}">
        {{ section.settings.subheading }}
      </p>
      {% endif %}
      
    </div>
  </div>
  {% endif %}

</section>

