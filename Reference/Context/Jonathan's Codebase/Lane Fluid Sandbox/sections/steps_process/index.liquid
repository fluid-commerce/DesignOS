<!-- Steps Process Section -->
<section class="steps-process section {{ section.settings.background_color | default: 'bg-black' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  <div class="container">
    <div class="inner-container {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_padding_y_mobile | default: 'py-xl' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-lg' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }} {{ section.settings.container_border_radius | default: 'rounded-none' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <div class="max-w-7xl mx-auto text-center">
        
        <!-- Header Content -->
        {% if section.settings.show_header %}
        <div class="steps-header {{ section.settings.header_margin_bottom | default: 'mb-3xl' }}">
          
          {% if section.settings.main_heading != blank %}
          <h1 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-4xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-6xl' }} {{ section.settings.heading_font_weight | default: 'font-bold' }} {{ section.settings.heading_color | default: 'text-white' }} {{ section.settings.heading_line_height | default: 'leading-tight' }} {{ section.settings.heading_margin_bottom | default: 'mb-lg' }}">
            {{ section.settings.main_heading }}
          </h1>
          {% endif %}
          
          {% if section.settings.description != blank %}
          <div class="{{ section.settings.description_font_size | default: 'text-lg' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.description_line_height | default: 'leading-relaxed' }} {{ section.settings.description_color | default: 'text-gray-300' }} max-w-4xl mx-auto">
            {{ section.settings.description }}
          </div>
          {% endif %}
          
        </div>
        {% endif %}
        
        <!-- Steps Grid -->
        {% if section.blocks.size > 0 %}
        <div class="steps-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 {{ section.settings.steps_gap | default: 'gap-xl' }} {{ section.settings.steps_margin_bottom | default: 'mb-3xl' }}">
          
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'step_item' %}
                <div class="step-card text-center" {{ block.fluid_attributes }}>
                  
                  <!-- Step Number -->
                  {% if block.settings.step_number != blank %}
                  <div class="step-number {{ section.settings.step_number_margin_bottom | default: 'mb-lg' }}">
                    <span class="{{ section.settings.step_number_font_family | default: 'font-handwritten' }} {{ section.settings.step_number_font_size | default: 'text-4xl' }} {{ section.settings.step_number_font_size_desktop | default: 'lg:text-6xl' }} {{ section.settings.step_number_font_weight | default: 'font-bold' }} {{ section.settings.step_number_color | default: 'text-secondary' }} {{ section.settings.step_number_line_height | default: 'leading-none' }} italic">
                      {{ block.settings.step_number }}
                    </span>
                  </div>
                  {% endif %}
                  
                  <!-- Step Title -->
                  {% if block.settings.step_title != blank %}
                  <h3 class="{{ section.settings.step_title_font_family | default: 'font-primary' }} {{ section.settings.step_title_font_size | default: 'text-xl' }} {{ section.settings.step_title_font_size_desktop | default: 'lg:text-2xl' }} {{ section.settings.step_title_font_weight | default: 'font-bold' }} {{ section.settings.step_title_color | default: 'text-white' }} {{ section.settings.step_title_line_height | default: 'leading-tight' }} {{ section.settings.step_title_margin_bottom | default: 'mb-md' }}">
                    {{ block.settings.step_title }}
                  </h3>
                  {% endif %}
                  
                  <!-- Step Description -->
                  {% if block.settings.step_description != blank %}
                  <div class="{{ section.settings.step_description_font_family | default: 'font-primary' }} {{ section.settings.step_description_font_size | default: 'text-base' }} {{ section.settings.step_description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.step_description_font_weight | default: 'font-normal' }} {{ section.settings.step_description_color | default: 'text-white' }} {{ section.settings.step_description_line_height | default: 'leading-relaxed' }}">
                    {{ block.settings.step_description }}
                  </div>
                  {% endif %}
                  
                </div>
            {% endcase %}
          {% endfor %}
          
        </div>
        {% endif %}
        
        <!-- CTA Button -->
        {% if section.settings.show_cta and section.settings.cta_text != blank %}
        <div class="steps-cta">
          <a href="{{ section.settings.cta_url | default: '#' }}" 
             class="inline-block {{ section.settings.cta_background_color | default: 'bg-blue-500' }} {{ section.settings.cta_text_color | default: 'text-white' }} {{ section.settings.cta_font_size | default: 'text-lg' }} {{ section.settings.cta_font_weight | default: 'font-semibold' }} {{ section.settings.cta_padding | default: 'px-xl py-md' }} {{ section.settings.cta_border_radius | default: 'rounded-full' }} hover:opacity-90 transition-opacity duration-200"
             {% if section.settings.cta_open_new_tab %}target="_blank" rel="noopener"{% endif %}>
            {{ section.settings.cta_text }}
          </a>
        </div>
        {% endif %}
        
      </div>
      
    </div>
  </div>
</section>

