<link rel="stylesheet" href="{{ 'fw_card_grid/styles.css' | asset_url }}">

<section class="fw-card-grid-section {{ section.settings.background_color }} {{ section.settings.section_padding_y_mobile }} {{ section.settings.section_padding_y_desktop }} {{ section.settings.section_border_radius }}"
  {% if section.settings.background_image != blank %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  <div class="fw-card-grid-container {{ section.settings.container_background_color }} {{ section.settings.container_border_radius }} {{ section.settings.container_padding_y_mobile }} {{ section.settings.container_padding_y_desktop }} {{ section.settings.container_padding_x_mobile }} {{ section.settings.container_padding_x_desktop }}"
    {% if section.settings.container_background_image != blank %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>

    {% if section.settings.eyebrow != blank or section.settings.headline != blank or section.settings.body != blank %}
    <div class="fw-card-grid-header">

      {% if section.settings.eyebrow != blank %}
      <p class="fw-card-grid__eyebrow {{ section.settings.eyebrow_font_family }} {{ section.settings.eyebrow_font_size }} {{ section.settings.eyebrow_font_size_desktop }} {{ section.settings.eyebrow_font_weight }} {{ section.settings.eyebrow_color }}">
        {{ section.settings.eyebrow }}
      </p>
      {% endif %}

      {% if section.settings.headline != blank %}
      <h2 class="fw-card-grid__headline {{ section.settings.headline_font_family }} {{ section.settings.headline_font_size }} {{ section.settings.headline_font_size_desktop }} {{ section.settings.headline_font_weight }} {{ section.settings.headline_color }}">
        {{ section.settings.headline }}
      </h2>
      {% endif %}

      {% if section.settings.body != blank %}
      <div class="fw-card-grid__body {{ section.settings.body_font_family }} {{ section.settings.body_font_size }} {{ section.settings.body_font_size_desktop }} {{ section.settings.body_font_weight }} {{ section.settings.body_color }}">
        {{ section.settings.body }}
      </div>
      {% endif %}

    </div>
    {% endif %}

    {% if section.blocks.size > 0 %}
    <div class="fw-card-grid fw-card-grid--{{ section.settings.grid_style }} fw-card-grid--cols-{{ section.settings.grid_columns_desktop }} fw-card-grid--mobile-{{ section.settings.grid_columns_mobile }}">
      {% for block in section.blocks %}
        {% if block.type == 'card' %}
        <div class="fw-card {{ block.settings.card_background_color }}" {{ block.fluid_attributes }}>

          {% if block.settings.card_tag != blank %}
          <span class="fw-card__tag {{ block.settings.card_tag_color }}">
            {{ block.settings.card_tag }}
          </span>
          {% endif %}

          {% if block.settings.card_icon != blank %}
          <div class="fw-card__icon {{ block.settings.card_icon_background }}">
            {{ block.settings.card_icon }}
          </div>
          {% endif %}

          {% if block.settings.card_title != blank %}
          <h3 class="fw-card__title {{ block.settings.card_title_font_family }} {{ block.settings.card_title_font_size }} {{ block.settings.card_title_font_size_desktop }} {{ block.settings.card_title_font_weight }} {{ block.settings.card_title_color }}">
            {{ block.settings.card_title }}
          </h3>
          {% endif %}

          {% if block.settings.card_body != blank %}
          <p class="fw-card__body {{ block.settings.card_body_font_family }} {{ block.settings.card_body_font_size }} {{ block.settings.card_body_font_size_desktop }} {{ block.settings.card_body_font_weight }} {{ block.settings.card_body_color }}">
            {{ block.settings.card_body }}
          </p>
          {% endif %}

          {% if block.settings.card_link_show and block.settings.card_link_text != blank %}
          <a href="{{ block.settings.card_link_url | default: '#' }}" class="fw-card__link {{ block.settings.card_link_color }}">
            {{ block.settings.card_link_text }}
          </a>
          {% endif %}

        </div>
        {% endif %}
      {% endfor %}
    </div>
    {% endif %}

  </div>
</section>

