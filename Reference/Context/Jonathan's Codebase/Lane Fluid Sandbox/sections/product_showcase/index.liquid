<!-- Product Showcase Section -->
<section class="product-showcase {{ section.settings.background_color | default: 'bg-neutral-light' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image }}"{% endif %}>
  <div class="container">
    <div class="inner-container {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_padding_y_mobile | default: 'py-xl' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-lg' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }} {{ section.settings.container_border_radius | default: 'rounded-none' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image }}"{% endif %}>
      
      <div class="max-w-7xl mx-auto">
        
        <!-- Main Content -->
        <div class="product-showcase-content space-y-3xl">
          
          <!-- Main Heading -->
          {% if section.settings.show_heading %}
          <div class="heading-wrapper text-center mb-2xl">
            <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-black' }} {{ section.settings.heading_color | default: 'text-black' }} leading-tight max-w-4xl mx-auto">
              {{ section.settings.heading | default: "Relief that supports recovery and fits your lifestyle" }}
            </h2>
          </div>
          {% endif %}
          
          <!-- Description -->
          {% if section.settings.show_description %}
          <div class="description-wrapper text-center mb-2xl">
            <p class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-lg' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-neutral-dark' }} leading-relaxed max-w-3xl mx-auto">
              {{ section.settings.description | default: "Whether you're looking to soothe sore muscles with therapeutic massage or relieve lower back pain with powerful infrared LED, our solutions help you relax, recover and keep moving — every day." }}
            </p>
          </div>
          {% endif %}
          
          <!-- Product Cards -->
          <div class="products-wrapper">
            <div class="products-grid">
              
              <!-- Product Card 1 -->
              {% if section.settings.show_product_one %}
              <div class="product-card {{ section.settings.product_card_border_radius | default: 'rounded-xl' }} overflow-hidden relative">
                
                <!-- Product Image (Background) -->
                <div class="product-hero-wrapper aspect-video relative">
                  {% if section.settings.product_one_image %}
                    <img src="{{ section.settings.product_one_image | image_url }}"
                         alt="{{ section.settings.product_one_image_alt | default: section.settings.product_one_title }}"
                         class="product-hero-image w-full h-full object-cover">
                  {% else %}
                    <img src="{{ 'placeholder-image.png' | asset_url }}"
                         alt="{{ section.settings.product_one_title | default: 'Product 1 placeholder image' }}"
                         class="product-hero-image w-full h-full object-cover">
                  {% endif %}
                  
                  <!-- Dark Overlay for Text Readability -->
                  <div class="product-overlay absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"></div>
                  
                  <!-- Product Badge -->
                  {% if section.settings.show_product_one_badge and section.settings.product_one_badge_text != blank %}
                  <div class="product-badge absolute top-lg left-lg z-20">
                    <span class="badge {{ section.settings.badge_background_color | default: 'bg-white' }} {{ section.settings.badge_text_color | default: 'text-black' }} {{ section.settings.badge_font_family | default: 'font-body' }} {{ section.settings.badge_font_size | default: 'text-sm' }} {{ section.settings.badge_font_weight | default: 'font-medium' }} px-md py-xs {{ section.settings.badge_border_radius | default: 'rounded' }}">
                      {{ section.settings.product_one_badge_text }}
                    </span>
                  </div>
                  {% endif %}
                  
                  <!-- Product Content Overlay -->
                  <div class="product-content-overlay absolute inset-0 p-lg lg:p-xl flex flex-col justify-end z-10">
                    <div class="product-text-content space-y-md">
                      
                      <!-- Product Title -->
                      {% if section.settings.product_one_title != blank %}
                      <h3 class="{{ section.settings.product_title_font_family | default: 'font-primary' }} {{ section.settings.product_title_font_size | default: 'text-2xl' }} {{ section.settings.product_title_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.product_title_font_weight | default: 'font-bold' }} text-white leading-tight">
                        {{ section.settings.product_one_title | default: "Lorem Ipsum Product" }}
                      </h3>
                      {% endif %}
                      
                      <!-- Product Description -->
                      {% if section.settings.product_one_description != blank %}
                      <p class="{{ section.settings.product_description_font_family | default: 'font-body' }} {{ section.settings.product_description_font_size | default: 'text-sm' }} {{ section.settings.product_description_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.product_description_font_weight | default: 'font-normal' }} text-white/90 leading-relaxed">
                        {{ section.settings.product_one_description | default: "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua." }}
                      </p>
                      {% endif %}
                      
                      <!-- Product Button -->
                      {% if section.settings.show_product_one_button and section.settings.product_one_button_text != blank %}
                      <div class="product-button-wrapper mt-lg">
                        <a href="{{ section.settings.product_one_button_url | default: '#' }}"
                           class="btn btn-{{ section.settings.product_button_style | default: 'filled' }}-{{ section.settings.product_button_color | default: 'white' }} {{ section.settings.product_button_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded' }}">
                          {{ section.settings.product_one_button_text | default: "Shop Product" }}
                        </a>
                      </div>
                      {% endif %}
                      
                    </div>
                  </div>
                  
                </div>
                
              </div>
              {% endif %}
              
              <!-- Product Card 2 -->
              {% if section.settings.show_product_two %}
              <div class="product-card {{ section.settings.product_card_border_radius | default: 'rounded-xl' }} overflow-hidden relative">
                
                <!-- Product Image (Background) -->
                <div class="product-hero-wrapper aspect-video relative">
                  {% if section.settings.product_two_image %}
                    <img src="{{ section.settings.product_two_image | image_url }}"
                         alt="{{ section.settings.product_two_image_alt | default: section.settings.product_two_title }}"
                         class="product-hero-image w-full h-full object-cover">
                  {% else %}
                    <img src="{{ 'placeholder-image.png' | asset_url }}"
                         alt="{{ section.settings.product_two_title | default: 'Product 2 placeholder image' }}"
                         class="product-hero-image w-full h-full object-cover">
                  {% endif %}
                  
                  <!-- Dark Overlay for Text Readability -->
                  <div class="product-overlay absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"></div>
                  
                  <!-- Product Badge -->
                  {% if section.settings.show_product_two_badge and section.settings.product_two_badge_text != blank %}
                  <div class="product-badge absolute top-lg left-lg z-20">
                    <span class="badge {{ section.settings.badge_background_color | default: 'bg-white' }} {{ section.settings.badge_text_color | default: 'text-black' }} {{ section.settings.badge_font_family | default: 'font-body' }} {{ section.settings.badge_font_size | default: 'text-sm' }} {{ section.settings.badge_font_weight | default: 'font-medium' }} px-md py-xs {{ section.settings.badge_border_radius | default: 'rounded' }}">
                      {{ section.settings.product_two_badge_text }}
                    </span>
                  </div>
                  {% endif %}
                  
                  <!-- Product Content Overlay -->
                  <div class="product-content-overlay absolute inset-0 p-lg lg:p-xl flex flex-col justify-end z-10">
                    <div class="product-text-content space-y-md">
                      
                      <!-- Product Title -->
                      {% if section.settings.product_two_title != blank %}
                      <h3 class="{{ section.settings.product_title_font_family | default: 'font-primary' }} {{ section.settings.product_title_font_size | default: 'text-2xl' }} {{ section.settings.product_title_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.product_title_font_weight | default: 'font-bold' }} text-white leading-tight">
                        {{ section.settings.product_two_title | default: "Dolor Sit Product" }}
                      </h3>
                      {% endif %}
                      
                      <!-- Product Description -->
                      {% if section.settings.product_two_description != blank %}
                      <p class="{{ section.settings.product_description_font_family | default: 'font-body' }} {{ section.settings.product_description_font_size | default: 'text-sm' }} {{ section.settings.product_description_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.product_description_font_weight | default: 'font-normal' }} text-white/90 leading-relaxed">
                        {{ section.settings.product_two_description | default: "Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat." }}
                      </p>
                      {% endif %}
                      
                      <!-- Product Button -->
                      {% if section.settings.show_product_two_button and section.settings.product_two_button_text != blank %}
                      <div class="product-button-wrapper mt-lg">
                        <a href="{{ section.settings.product_two_button_url | default: '#' }}"
                           class="btn btn-{{ section.settings.product_button_style | default: 'filled' }}-{{ section.settings.product_button_color | default: 'white' }} {{ section.settings.product_button_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded' }}">
                          {{ section.settings.product_two_button_text | default: "Shop Product" }}
                        </a>
                      </div>
                      {% endif %}
                      
                    </div>
                  </div>
                  
                </div>
                
              </div>
              {% endif %}
              
            </div>
          </div>
          
        </div>
        
      </div>
      
    </div>
  </div>
</section>

