<link rel="stylesheet" href="{{ 'fw_timeline/styles.css' | asset_url }}">

<section class="fw-timeline-section {{ section.settings.background_color }} {{ section.settings.section_padding_y_mobile }} {{ section.settings.section_padding_y_desktop }} {{ section.settings.section_border_radius }}"
  {% if section.settings.background_image != blank %}data-bg style="background-image: url('{{ section.settings.background_image | image_url }}'); background-size: cover; background-position: center;"{% endif %}>

  <div class="fw-timeline-container {{ section.settings.container_background_color }} {{ section.settings.container_border_radius }} {{ section.settings.container_padding_y_mobile }} {{ section.settings.container_padding_y_desktop }} {{ section.settings.container_padding_x_mobile }} {{ section.settings.container_padding_x_desktop }}"
    {% if section.settings.container_background_image != blank %}data-bg style="background-image: url('{{ section.settings.container_background_image | image_url }}'); background-size: cover; background-position: center;"{% endif %}>

    {% if section.settings.eyebrow != blank or section.settings.headline != blank %}
    <div class="fw-timeline-header text-center">

      {% if section.settings.show_accent_bar %}
      <div class="fw-timeline-accent-bar mb-lg">
        {% if section.settings.accent_bar_image != blank %}
        <img src="{{ section.settings.accent_bar_image | image_url }}" alt="" class="fw-accent-bar-img" aria-hidden="true">
        {% else %}
        <div class="fw-accent-bar-fallback"></div>
        {% endif %}
      </div>
      {% endif %}

      {% if section.settings.eyebrow != blank %}
      <p class="fw-timeline-eyebrow {{ section.settings.eyebrow_font_family }} {{ section.settings.eyebrow_font_size }} {{ section.settings.eyebrow_font_size_desktop }} {{ section.settings.eyebrow_font_weight }} {{ section.settings.eyebrow_color }} mb-md">
        {{ section.settings.eyebrow }}
      </p>
      {% endif %}

      {% if section.settings.headline != blank %}
      <h2 class="fw-timeline-headline {{ section.settings.headline_font_family }} {{ section.settings.headline_font_size }} {{ section.settings.headline_font_size_desktop }} {{ section.settings.headline_font_weight }} {{ section.settings.headline_color }} mb-2xl">
        {{ section.settings.headline }}
      </h2>
      {% endif %}

    </div>
    {% endif %}

    {% if section.blocks.size > 0 %}
    <div class="fw-timeline-row" data-step-count="{{ section.blocks.size }}">
      {% for block in section.blocks %}
        {% if block.type == 'step' %}
        <div class="fw-step-item {% if block.settings.step_highlight %}fw-step-highlighted{% endif %} {% if forloop.last %}fw-step-last{% endif %}" {{ block.fluid_attributes }}
          {% if block.settings.step_highlight %}style="--step-border-color: var(--clr-{{ block.settings.step_border_color }});"{% endif %}>

          {% if block.settings.step_label != blank %}
          <div class="fw-step-label {{ block.settings.step_label_color }}">
            {{ block.settings.step_label }}
          </div>
          {% endif %}

          {% if block.settings.step_title != blank %}
          <h3 class="fw-step-title {{ block.settings.step_title_font_family }} {{ block.settings.step_title_font_size }} {{ block.settings.step_title_font_size_desktop }} {{ block.settings.step_title_font_weight }} {{ block.settings.step_title_color }}">
            {{ block.settings.step_title }}
          </h3>
          {% endif %}

          {% if block.settings.step_body != blank %}
          <p class="fw-step-body {{ block.settings.step_body_font_family }} {{ block.settings.step_body_font_size }} {{ block.settings.step_body_font_size_desktop }} {{ block.settings.step_body_font_weight }} {{ block.settings.step_body_color }}">
            {{ block.settings.step_body }}
          </p>
          {% endif %}

        </div>
        {% endif %}
      {% endfor %}
    </div>
    {% endif %}

    {% if section.settings.footer_note != blank %}
    <div class="fw-timeline-footer text-center">
      <p class="fw-timeline-footer-note {{ section.settings.footer_note_font_family }} {{ section.settings.footer_note_font_size }} {{ section.settings.footer_note_font_size_desktop }} {{ section.settings.footer_note_font_weight }} {{ section.settings.footer_note_color }}">
        {{ section.settings.footer_note }}
      </p>
    </div>
    {% endif %}

  </div>
</section>

