{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="feature4-section section-t-spacing section-{{ section.id }}-padding" 
         style="background-color: {{ section.settings.background_color | default: '#ffffff' }};
                {% if section.settings.background_image != blank %}
                background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;
                {% endif %}
                position: relative;">
  
  {% if section.settings.background_image != blank %}
    <div class="feature4-overlay" 
         style="background-color: {{ section.settings.overlay_color | default: '#000000' }}; 
                opacity: {{ section.settings.overlay_opacity | default: 40 | divided_by: 100.0 }}; 
                position: absolute; 
                top: 0; 
                left: 0; 
                width: 100%; 
                height: 100%; 
                z-index: 1;"></div>
  {% endif %}
  
  <div class="container" style="position: relative; z-index: 2;">
    
    <!-- Header Section -->
    <div class="feature4-header text-center mb-16">
      {% if section.settings.tagline != blank %}
        <p class="feature4-tagline text-sm mb-4" 
           style="color: {{ section.settings.tagline_color | default: '#6b7280' }};">
          {{ section.settings.tagline }}
        </p>
      {% endif %}
      
      <h2 class="feature4__heading {{ section.settings.heading_size }} mb-6" 
          style="color: {{ section.settings.heading_color | default: '#1a1a1a' }};">
        {{ section.settings.heading }}
      </h2>
      
      {% if section.settings.description != blank %}
        <p class="feature4-description text-lg max-w-3xl mx-auto" 
           style="color: {{ section.settings.description_color | default: '#6b7280' }};">
          {{ section.settings.description }}
        </p>
      {% endif %}
    </div>

    <!-- Main Content Section -->
    <div class="feature4-main-content grid grid-cols-1 sm-desktop-grid-cols-3 gap-12 align-center mb-16">
      
      <!-- Left Feature Points (Column 1) -->
      <div class="feature4-left-points">
        <!-- Feature Point 1 -->
        <div class="feature4-point text-center mb-12">
          <div class="feature4-icon mb-4 flex justify-center">
            {% if section.settings.point_1_image != blank %}
              <img src="{{ section.settings.point_1_image | image_url: width: 96 }}" 
                   alt="{{ section.settings.point_1_image_alt | default: section.settings.point_1_heading }}"
                   class="feature4-point-image">
            {% else %}
              <div class="feature4-icon-placeholder">
                <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                </svg>
              </div>
            {% endif %}
          </div>
          <h3 class="text-lg font-semibold mb-3" 
              style="color: {{ section.settings.point_heading_color | default: '#1a1a1a' }};">
            {{ section.settings.point_1_heading | default: 'Short heading goes here' }}
          </h3>
          <p class="text-md" 
             style="color: {{ section.settings.point_text_color | default: '#6b7280' }};">
            {{ section.settings.point_1_description | default: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique.' }}
          </p>
        </div>

        <!-- Feature Point 2 -->
        <div class="feature4-point text-center">
          <div class="feature4-icon mb-4 flex justify-center">
            {% if section.settings.point_2_image != blank %}
              <img src="{{ section.settings.point_2_image | image_url: width: 96 }}" 
                   alt="{{ section.settings.point_2_image_alt | default: section.settings.point_2_heading }}"
                   class="feature4-point-image">
            {% else %}
              <div class="feature4-icon-placeholder">
                <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                </svg>
              </div>
            {% endif %}
          </div>
          <h3 class="text-lg font-semibold mb-3" 
              style="color: {{ section.settings.point_heading_color | default: '#1a1a1a' }};">
            {{ section.settings.point_2_heading | default: 'Short heading goes here' }}
          </h3>
          <p class="text-md" 
             style="color: {{ section.settings.point_text_color | default: '#6b7280' }};">
            {{ section.settings.point_2_description | default: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique.' }}
          </p>
        </div>
      </div>

      <!-- Central Image (Column 2) -->
      <div class="feature4-image-wrapper flex justify-center">
        {% if section.settings.feature_image != blank %}
          <img src="{{ section.settings.feature_image | image_url: width: 500 }}" 
               alt="{{ section.settings.image_alt | default: section.settings.heading }}"
               class="feature4-image image-cover">
        {% else %}
          <div class="feature4-image-placeholder">
            <svg width="80" height="80" fill="currentColor" viewBox="0 0 24 24">
              <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
            </svg>
            <p class="text-sm" style="margin-top: 12px; color: #9ca3af;">Upload feature image</p>
          </div>
        {% endif %}
      </div>

      <!-- Right Feature Points (Column 3) -->
      <div class="feature4-right-points">
        <!-- Feature Point 3 -->
        <div class="feature4-point text-center mb-12">
          <div class="feature4-icon mb-4 flex justify-center">
            {% if section.settings.point_3_image != blank %}
              <img src="{{ section.settings.point_3_image | image_url: width: 96 }}" 
                   alt="{{ section.settings.point_3_image_alt | default: section.settings.point_3_heading }}"
                   class="feature4-point-image">
            {% else %}
              <div class="feature4-icon-placeholder">
                <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                </svg>
              </div>
            {% endif %}
          </div>
          <h3 class="text-lg font-semibold mb-3" 
              style="color: {{ section.settings.point_heading_color | default: '#1a1a1a' }};">
            {{ section.settings.point_3_heading | default: 'Short heading goes here' }}
          </h3>
          <p class="text-md" 
             style="color: {{ section.settings.point_text_color | default: '#6b7280' }};">
            {{ section.settings.point_3_description | default: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique.' }}
          </p>
        </div>

        <!-- Feature Point 4 -->
        <div class="feature4-point text-center">
          <div class="feature4-icon mb-4 flex justify-center">
            {% if section.settings.point_4_image != blank %}
              <img src="{{ section.settings.point_4_image | image_url: width: 96 }}" 
                   alt="{{ section.settings.point_4_image_alt | default: section.settings.point_4_heading }}"
                   class="feature4-point-image">
            {% else %}
              <div class="feature4-icon-placeholder">
                <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                </svg>
              </div>
            {% endif %}
          </div>
          <h3 class="text-lg font-semibold mb-3" 
              style="color: {{ section.settings.point_heading_color | default: '#1a1a1a' }};">
            {{ section.settings.point_4_heading | default: 'Short heading goes here' }}
          </h3>
          <p class="text-md" 
             style="color: {{ section.settings.point_text_color | default: '#6b7280' }};">
            {{ section.settings.point_4_description | default: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique.' }}
          </p>
        </div>
      </div>
    </div>

    <!-- Buttons Section -->
    <div class="feature4-buttons flex flex-wrap gap-4 justify-center">
      {% if section.settings.show_primary_button and section.settings.primary_button_text != blank %}
        <a href="{{ section.settings.primary_button_link | default: '#' }}" 
           class="btn btn-bg-primary btn-border-primary"
           style="background-color: {{ section.settings.primary_button_bg | default: 'var(--clr-primary)' }};
                  color: {{ section.settings.primary_button_text_color | default: '#ffffff' }};
                  border-color: {{ section.settings.primary_button_bg | default: 'var(--clr-primary)' }};">
          {{ section.settings.primary_button_text }}
        </a>
      {% endif %}
      
      {% if section.settings.show_secondary_button and section.settings.secondary_button_text != blank %}
        <a href="{{ section.settings.secondary_button_link | default: '#' }}" 
           class="btn btn-border-black"
           style="color: {{ section.settings.secondary_button_text_color | default: '#000000' }};
                  border-color: {{ section.settings.secondary_button_border_color | default: '#000000' }};">
          {{ section.settings.secondary_button_text }}
          {% if section.settings.secondary_button_arrow %}
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24" style="margin-left: 8px;">
              <path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/>
            </svg>
          {% endif %}
        </a>
      {% endif %}
    </div>
  </div>
</section>

<style>
.feature4-section .feature4-image {
  width: 100%;
  max-width: 400px;
  height: 400px;
  border-radius: 8px;
  object-fit: cover;
}

.feature4-section .feature4-image-placeholder {
  width: 100%;
  max-width: 400px;
  height: 400px;
  background-color: #f3f4f6;
  border: 2px dashed #d1d5db;
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
}

.feature4-section .feature4-point-image {
  width: 48px;
  height: 48px;
  object-fit: cover;
  border-radius: 4px;
}

.feature4-section .feature4-icon-placeholder {
  width: 48px;
  height: 48px;
  background-color: #f3f4f6;
  border: 2px dashed #d1d5db;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
}

.feature4-section .feature4-main-content {
  min-height: 500px;
}

@media (max-width: 767px) {
  .feature4-section .feature4-main-content {
    grid-template-columns: 1fr !important;
    gap: 32px;
  }
  
  .feature4-section .feature4-left-points,
  .feature4-section .feature4-right-points {
    display: block;
  }
  
  .feature4-section .feature4-point {
    margin-bottom: 48px;
  }

  .feature4-section .feature4-image,
  .feature4-section .feature4-image-placeholder {
    height: 300px;
  }
  
  .feature4-section .feature4-header {
    margin-bottom: 48px;
  }
  
  .feature4-section .feature4-main-content {
    margin-bottom: 48px;
  }
}
</style>

