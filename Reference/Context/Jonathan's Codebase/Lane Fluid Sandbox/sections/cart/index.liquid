                                            fill="#999FB5"
                                            />
                                        </svg>
                                        </div>
                                    </div>
                                    <div class="price {{ section.settings.summary_price_font_size | default: 'text-xl' }} {{ section.settings.summary_price_font_weight | default: 'font-medium' }} tax">{{cart.tax_total_in_currency}}</div>
                                </li>

                                <li
                                class="order-item flex flex-wrap justify-between align-center mt-6"
                                >
                                    <div class="heading {{ section.settings.total_heading_font_size | default: 'text-xl' }} {{ section.settings.total_heading_font_weight | default: 'font-semibold' }}">
                                        {{ 'cart_page.total' | t }}
                                    </div>
                                    <div class="price {{ section.settings.total_price_font_size | default: 'text-xl' }} {{ section.settings.total_price_font_weight | default: 'font-semibold' }} total">{{cart.amount_total_in_currency}}</div>
                                </li>
                            </ul>

                            <div class="btn-section mt-8">
                                <a href="{{cart.checkout_url}}" class="btn {{ section.settings.button_style | default: 'btn-bg-primary' }} w-full checkout-btn {{ section.settings.button_font_size | default: 'text-base' }} {{ section.settings.button_font_size_desktop | default: 'xl-tab-text-lg' }} {{ section.settings.button_font_weight | default: 'font-medium' }}">
                                    {% if section.settings.checkout_button_text %}{{ section.settings.checkout_button_text }}{% else %}{{ 'cart_page.checkout' | t }}{% endif %}
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>  
    </section>
</main>
{% render 'cart_template' %}
<script src="{{ 'cart_page.js' | asset_url }}"></script>

{% schema %}
{
  "name": "Shopping Cart",
  "tag": "section",
  "class": "cart-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "page_title",
      "label": "Page Title",
      "default": "Shopping Cart"
    },
    {
      "type": "select",
      "id": "title_font_size",
      "label": "Title Font Size (Mobile)",
      "options": [
        { "value": "text-xl", "label": "Extra Large" },
        { "value": "text-2xl", "label": "2X Large" },
        { "value": "text-3xl", "label": "3X Large" },
        { "value": "text-4xl", "label": "4X Large" },
        { "value": "text-5xl", "label": "5X Large" },
        { "value": "text-h3", "label": "H3" }
      ],
      "default": "text-h3"
    },
    {
      "type": "select",
      "id": "title_font_size_desktop",
      "label": "Title Font Size (Desktop)",
      "options": [
        { "value": "xl-tab-text-xl", "label": "Extra Large" },
        { "value": "xl-tab-text-2xl", "label": "2X Large" },
        { "value": "xl-tab-text-3xl", "label": "3X Large" },
        { "value": "xl-tab-text-5xl", "label": "5X Large" },
        { "value": "text-h3", "label": "H3" }
      ],
      "default": "text-h3"
    },
    {
      "type": "select",
      "id": "title_font_weight",
      "label": "Title Font Weight",
      "options": [
        { "value": "font-light", "label": "Light" },
        { "value": "font-normal", "label": "Normal" },
        { "value": "font-medium", "label": "Medium" },
        { "value": "font-semibold", "label": "Semi Bold" },
        { "value": "font-bold", "label": "Bold" },
        { "value": "font-extrabold", "label": "Extra Bold" }
      ],
      "default": "font-bold"
    },
    {
      "type": "color_background",
      "id": "title_color",
      "label": "Title Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Product Display"
    },
    {
      "type": "checkbox",
      "id": "show_product_variant",
      "label": "Show Product Variant",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_product_price",
      "label": "Hide Product Price",
      "default": false
    },
    {
      "type": "select",
      "id": "product_title_font_size",
      "label": "Product Title Font Size (Mobile)",
