<!-- Timeline Progress Section -->
<section class="timeline-progress {{ section.settings.background_color | default: 'bg-black' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image }}"{% endif %}>
  <div class="container">
    <div class="inner-container {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_padding_y_mobile | default: 'py-xl' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-lg' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }} {{ section.settings.container_border_radius | default: 'rounded-none' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image }}"{% endif %}>
      
      <div class="max-w-6xl mx-auto">
        
        <!-- Main Content -->
        <div class="timeline-content">
          
          <!-- Main Heading -->
          {% if section.settings.show_heading %}
          <div class="heading-wrapper text-center mb-3xl">
            <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-4xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-6xl' }} {{ section.settings.heading_font_weight | default: 'font-black' }} {{ section.settings.heading_color | default: 'text-white' }} leading-tight">
              {{ section.settings.heading | default: "The Complete Customer Journey" }}
            </h2>
          </div>
          {% endif %}
          
          <!-- Description -->
          {% if section.settings.show_description %}
          <div class="description-wrapper text-center mb-4xl">
            <p class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-lg' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-white' }} leading-relaxed max-w-4xl mx-auto">
              {{ section.settings.description | default: "Follow the customer journey from initial awareness to becoming a loyal advocate, with each stage carefully designed to build trust and deliver value." }}
            </p>
          </div>
          {% endif %}
          
          <!-- Timeline Container -->
          {% if section.blocks.size > 0 %}
          <div class="timeline-wrapper" id="timeline-{{ section.id }}">
            
            <!-- Timeline Line (Progress Bar) -->
            <div class="timeline-line">
              <div class="timeline-progress-bar" id="timeline-progress-{{ section.id }}"></div>
            </div>
            
            <!-- Timeline Items -->
            <div class="timeline-items">
              {% for block in section.blocks %}
                {% case block.type %}
                  {% when 'timeline_item' %}
                    <div class="timeline-item" data-timeline-item="{{ forloop.index0 }}" {{ block.fluid_attributes }}>
                      
                      <!-- Timeline Dot -->
                      <div class="timeline-dot" data-dot="{{ forloop.index0 }}">
                        <div class="dot-inner"></div>
                      </div>
                      
                      <!-- Timeline Content -->
                      <div class="timeline-content-box">
                        
                        <!-- Timeline Title -->
                        {% if block.settings.title != blank %}
                        <div class="timeline-title-wrapper mb-md">
                          <h3 class="{{ section.settings.item_title_font_family | default: 'font-primary' }} {{ section.settings.item_title_font_size | default: 'text-2xl' }} {{ section.settings.item_title_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.item_title_font_weight | default: 'font-bold' }} {{ section.settings.item_title_color | default: 'text-black' }} leading-tight">
                            {{ block.settings.title | default: "Timeline Stage" }}
                          </h3>
                        </div>
                        {% endif %}
                        
                        <!-- Timeline Description -->
                        {% if block.settings.description != blank %}
                        <div class="timeline-description-wrapper">
                          <div class="{{ section.settings.item_description_font_family | default: 'font-body' }} {{ section.settings.item_description_font_size | default: 'text-base' }} {{ section.settings.item_description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.item_description_font_weight | default: 'font-normal' }} {{ section.settings.item_description_color | default: 'text-neutral-dark' }} leading-relaxed">
                            {{ block.settings.description | default: "Add a description for this timeline stage that explains what happens during this phase of the customer journey." }}
                          </div>
                        </div>
                        {% endif %}
                        
                      </div>
                      
                    </div>
                {% endcase %}
              {% endfor %}
            </div>
            
          </div>
          {% endif %}
          
        </div>
        
      </div>
      
    </div>
  </div>
</section>

<script>
// Timeline Progress Animation
function initTimelineProgress() {
  const timelines = document.querySelectorAll('[id^="timeline-"]');
  
  timelines.forEach(timeline => {
    const timelineId = timeline.id.split('-').pop();
    const progressBar = document.getElementById(`timeline-progress-${timelineId}`);
    const timelineItems = timeline.querySelectorAll('.timeline-item');
    const timelineDots = timeline.querySelectorAll('.timeline-dot');
    
    if (!progressBar || timelineItems.length === 0) return;
    
    function updateProgress() {
      const timelineRect = timeline.getBoundingClientRect();
      const windowHeight = window.innerHeight;
      const timelineTop = timelineRect.top;
      const timelineHeight = timelineRect.height;
      
      // Calculate when timeline enters and exits viewport
      const timelineEntersViewport = timelineTop + timelineHeight;
      const timelineExitsViewport = timelineTop;
      
      // Start animation when timeline enters bottom of viewport
      // Complete animation when timeline exits top of viewport
      const totalScrollDistance = timelineHeight + windowHeight;
      const currentScrollProgress = windowHeight - timelineTop;
      
      let progress = 0;
      if (currentScrollProgress > 0 && currentScrollProgress < totalScrollDistance) {
        progress = Math.max(0, Math.min(1, currentScrollProgress / totalScrollDistance));
      } else if (currentScrollProgress >= totalScrollDistance) {
        progress = 1;
      }
      
      // Update progress bar
      progressBar.style.height = `${progress * 100}%`;
      
      // Update dots and items based on progress
      const totalItems = timelineItems.length;
      
      timelineDots.forEach((dot, index) => {
        const itemThreshold = (index + 1) / totalItems;
        const isActive = progress >= itemThreshold * 0.3; // Start becoming active early
        const isCompleted = progress >= itemThreshold * 0.7; // Complete later
        
        // Update dot states
        dot.classList.toggle('active', isActive);
        dot.classList.toggle('completed', isCompleted);
        
        // Update corresponding timeline item
        const item = timelineItems[index];
        if (item) {
          item.classList.toggle('active', isActive);
          item.classList.toggle('completed', isCompleted);
        }
      });
      
      // Debug logging (remove in production)
      console.log('Progress:', progress, 'TimelineTop:', timelineTop, 'Current Scroll:', currentScrollProgress);
    }
    
    // Throttle function for better performance
    let ticking = false;
    function requestTick() {
      if (!ticking) {
        requestAnimationFrame(updateProgress);
        ticking = true;
        setTimeout(() => { ticking = false; }, 16); // ~60fps
      }
    }
    
    // Initial call
    updateProgress();
    
    // Update on scroll with throttling
    window.addEventListener('scroll', requestTick, { passive: true });
    window.addEventListener('resize', updateProgress);
  });
}

// Initialize when page loads
document.addEventListener('DOMContentLoaded', initTimelineProgress);

// Reinitialize when page changes (for SPA compatibility)
document.addEventListener('page:loaded', initTimelineProgress);
document.addEventListener('turbo:load', initTimelineProgress);
</script>

