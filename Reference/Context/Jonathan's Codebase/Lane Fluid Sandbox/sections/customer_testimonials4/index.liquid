{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="testimonial4-section section-t-spacing section-{{ section.id }}-padding" 
         style="background-color: {{ section.settings.background_color | default: '#f8f9fa' }};
                {% if section.settings.background_image != blank %}
                background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;
                {% endif %}
                position: relative;
                padding-bottom: {{ section.settings.padding_top }}px;">
  
  {% if section.settings.background_image != blank %}
    <div class="testimonials4-overlay" 
         style="background-color: {{ section.settings.overlay_color | default: '#000000' }}; 
                opacity: {{ section.settings.overlay_opacity | default: 40 | divided_by: 100.0 }}; 
                position: absolute; 
                top: 0; 
                left: 0; 
                width: 100%; 
                height: 100%; 
                z-index: 1;"></div>
  {% endif %}
  
  <div class="container" style="position: relative; z-index: 2;">
    <div class="testimonials4-card" 
         style="background-color: {{ section.settings.card_background_color | default: '#ffffff' }};">
      
      <div class="testimonials4-wrapper grid grid-cols-1 sm-desktop-grid-cols-2 gap-12 align-center">
        
        <!-- Column 1: CTA Content -->
        <div class="testimonials4-content">
          <h2 class="customer_testimonials4__heading {{ section.settings.heading_size }} mb-6" 
              style="color: {{ section.settings.heading_color | default: '#1a1a1a' }};">
            {{ section.settings.heading }}
          </h2>
          
          {% if section.settings.description != blank %}
            <p class="text-lg mb-8" 
               style="color: {{ section.settings.description_color | default: '#6b7280' }};">
              {{ section.settings.description }}
            </p>
          {% endif %}

          <div class="testimonials4-buttons flex flex-wrap gap-4">
            {% if section.settings.show_primary_button and section.settings.primary_button_text != blank %}
              <a href="{{ section.settings.primary_button_link | default: '#' }}" 
                 class="btn btn-bg-primary btn-border-primary"
                 style="background-color: {{ section.settings.primary_button_bg | default: 'var(--clr-primary)' }};
                        color: {{ section.settings.primary_button_text_color | default: '#ffffff' }};
                        border-color: {{ section.settings.primary_button_bg | default: 'var(--clr-primary)' }};">
                {{ section.settings.primary_button_text }}
              </a>
            {% endif %}
            
            {% if section.settings.show_secondary_button and section.settings.secondary_button_text != blank %}
              <a href="{{ section.settings.secondary_button_link | default: '#' }}" 
                 class="btn btn-border-black"
                 style="color: {{ section.settings.secondary_button_text_color | default: '#000000' }};
                        border-color: {{ section.settings.secondary_button_border_color | default: '#000000' }};">
                {{ section.settings.secondary_button_text }}
              </a>
            {% endif %}
          </div>
        </div>

                 <!-- Column 2: Vertical Scrolling Testimonials -->
         <div class="testimonials4-testimonials-column">
           <div class="testimonials4-scroll-container">
             <div class="testimonials4-scroll-track">
               <div class="testimonials4-grid">
                 <!-- Column 1 -->
                 <div class="testimonials4-column">
                   {% assign column_1_testimonials = '1,3,5' | split: ',' %}
                   {% for testimonial_num in column_1_testimonials %}
                     {% assign testimonial_text = 'testimonial_' | append: testimonial_num | append: '_text' %}
                     {% assign testimonial_name = 'testimonial_' | append: testimonial_num | append: '_name' %}
                     {% assign testimonial_position = 'testimonial_' | append: testimonial_num | append: '_position' %}
                     {% assign testimonial_image = 'testimonial_' | append: testimonial_num | append: '_image' %}
                     
                     <div class="testimonial4-testimonial-card" 
                          style="background-color: {{ section.settings.testimonial_card_background | default: 'transparent' }};">
                       
                       <!-- Testimonial Text -->
                       <div class="testimonial-content mb-4">
                         <p class="text-sm" 
                            style="color: {{ section.settings.testimonial_text_color | default: '#374151' }};">
                           {% if section.settings[testimonial_text] != blank %}
                             "{{ section.settings[testimonial_text] }}"
                           {% else %}
                             "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique."
                           {% endif %}
                         </p>
                       </div>

                       <!-- Author Info -->
                       <div class="author-info flex align-center gap-3">
                         <div class="author-avatar">
                           {% if section.settings[testimonial_image] != blank %}
                             <img src="{{ section.settings[testimonial_image] | image_url: width: 64 }}" 
                                  alt="{{ section.settings[testimonial_name] | default: 'Customer' }}"
                                  class="avatar-image">
                           {% else %}
                             <div class="avatar-placeholder">
                               <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
                                 <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                               </svg>
                             </div>
                           {% endif %}
                         </div>
                         <div class="author-details">
                           {% if section.settings.show_name %}
                             <p class="text-sm font-semibold mb-1" style="color: {{ section.settings.author_name_color | default: '#111827' }};">
                               {% if section.settings[testimonial_name] != blank %}
