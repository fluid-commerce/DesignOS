<style>
.testimonial4-section .testimonials4-card {
  border: 2px solid #e5e7eb;
  border-radius: 12px;
  padding: 0 40px 0 0;
  background-color: #ffffff;
}

.testimonial4-section .testimonials4-wrapper {
  min-height: 500px;
}

.testimonial4-section .testimonials4-content {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 48px 0 48px 40px;
}

.testimonial4-section .testimonials4-testimonials-column {
  position: relative;
  height: 500px;
}

.testimonial4-section .testimonials4-scroll-container {
  height: 100%;
  overflow: hidden;
  position: relative;
  border-radius: 0 8px 8px 0;
  padding: 20px;
}

.testimonial4-section .testimonials4-scroll-track {
  animation: testimonials4-vertical-scroll 30s linear infinite;
}

.testimonial4-section .testimonials4-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.testimonial4-section .testimonials4-column {
  display: flex;
  flex-direction: column;
}

.testimonial4-section .testimonials4-card:hover .testimonials4-scroll-track {
  animation-play-state: paused;
}

@keyframes testimonials4-vertical-scroll {
  0% {
    transform: translateY(0);
  }
  100% {
    transform: translateY(-50%);
  }
}

.testimonial4-section .testimonial4-testimonial-card {
  padding: 20px 16px;
  border: 1px solid #e5e7eb;
  border-radius: 8px;
  margin-bottom: 16px;
  min-height: 120px;
  display: flex;
  flex-direction: column;
}

.testimonial4-section .testimonial-content {
  flex: 1;
}

.testimonial4-section .author-info {
  margin-top: auto;
}

.testimonial4-section .avatar-image {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  object-fit: cover;
}

.testimonial4-section .avatar-placeholder {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background-color: #e5e5e5;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
}

@media (max-width: 959px) {
  .testimonial4-section .testimonials4-card {
    padding: 0 24px 0 0;
  }

  .testimonial4-section .testimonials4-content {
    padding: 32px 0 32px 24px;
  }
  
  .testimonial4-section .testimonials4-wrapper {
    min-height: auto;
    gap: 32px;
  }
  
  .testimonial4-section .testimonials4-testimonials-column {
    height: 300px;
  }
  
  .testimonial4-section .testimonials4-scroll-track {
    animation-duration: 25s;
  }

  .testimonial4-section .testimonials4-grid {
    gap: 12px;
  }

  .testimonial4-section .testimonials4-scroll-container {
    padding: 16px;
  }
}

@media (max-width: 767px) {
  .testimonial4-section .testimonials4-card {
    padding: 0 20px 0 0;
  }

  .testimonial4-section .testimonials4-content {
    padding: 24px 0 24px 20px;
  }
  
  .testimonial4-section .testimonials4-wrapper {
    gap: 24px;
  }
  
  .testimonial4-section .testimonials4-testimonials-column {
    height: 250px;
  }
  
  .testimonial4-section .testimonials4-scroll-track {
    animation-duration: 20s;
  }
  
  .testimonial4-section .testimonial4-testimonial-card {
    padding: 16px 12px;
    margin-bottom: 12px;
    min-height: 100px;
  }

  .testimonial4-section .testimonials4-grid {
    grid-template-columns: 1fr;
    gap: 8px;
  }

  .testimonial4-section .testimonials4-scroll-container {
    padding: 12px;
  }
}
</style>

{% schema %}
{
  "name": "Customer Testimonials 4",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "What Our Customers Say",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "description",
      "default": "Don't just take our word for it. See what our customers have to say about their experience.",
      "label": "Description"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "Heading 2"
        },
        {
          "value": "h1",
          "label": "Heading 1"
        },
        {
          "value": "h3",
          "label": "Heading 3"
        },
        {
          "value": "h4",
          "label": "Heading 4"
        },
        {
          "value": "h5",
          "label": "Heading 5"
        }
      ],
      "default": "h1",
      "label": "Heading Size"
    },
    {
      "type": "text",
      "id": "primary_button_text",
      "default": "Get Started",
      "label": "Primary Button Text"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "default": "#",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "default": "Learn More",
      "label": "Secondary Button Text"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "default": "#",
      "label": "Secondary Button Link"
    },
    {
      "type": "checkbox",
      "id": "show_primary_button",
      "default": true,
      "label": "Show Primary Button"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_button",
      "default": true,
      "label": "Show Secondary Button"
    },
    {
      "type": "range",
