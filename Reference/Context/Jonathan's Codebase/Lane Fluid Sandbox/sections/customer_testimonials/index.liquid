{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="testimonial-section section-t-spacing section-{{ section.id }}-padding" 
         style="background-color: {{ section.settings.background_color | default: '#ffffff' }};
                {% if section.settings.background_image != blank %}
                background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;
                {% endif %}
                position: relative;">
  
  {% if section.settings.background_image != blank %}
    <div class="testimonials-overlay" 
         style="background-color: {{ section.settings.overlay_color | default: '#000000' }}; 
                opacity: {{ section.settings.overlay_opacity | default: 40 | divided_by: 100.0 }}; 
                position: absolute; 
                top: 0; 
                left: 0; 
                width: 100%; 
                height: 100%; 
                z-index: 1;"></div>
  {% endif %}
  
  <div class="container" style="position: relative; z-index: 2;">
    <div class="header text-center">
      <h2 class="customer_testimonials__heading {{ section.settings.heading_size }}" 
          style="color: {{ section.settings.heading_color | default: '#000000' }};">
        {{ section.settings.heading }}
      </h2>
      <p class="sm-desktop-text-lg pt-5" 
         style="color: {{ section.settings.intro_text_color | default: '#666666' }};">
        {{ section.settings.intro_text }}
      </p>
    </div>

    <div class="carousel-section pt-12 sm-desktop-pt-20">
      <div class="testimonial-carousel splide">
        <div class="splide__track">
          <ul class="splide__list">
            {% for i in (1..10) limit: section.settings.testimonials_to_show %}
              <li class="splide__slide">
                <div class="testimonial-post px-6 px-6 xl-phone-px-8 xl-phone-py-8 border border-solid flex flex-col gap-y-5 xl-phone-gap-y-6"
                     style="border-color: {{ section.settings.card_border_color | default: '#000000' }}; 
                            background-color: {{ section.settings.card_background_color | default: '#ffffff' }};">
                  <div class="rating">
                    <svg width="116" height="19" viewBox="0 0 116 19" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <g clip-path="url(#clip0_506_132070)">
                      <path d="M9.07088 0.612343C9.41462 -0.204115 10.5854 -0.204114 10.9291 0.612346L12.9579 5.43123C13.1029 5.77543 13.4306 6.01061 13.8067 6.0404L19.0727 6.45748C19.9649 6.52814 20.3267 7.62813 19.6469 8.2034L15.6348 11.5987C15.3482 11.8412 15.223 12.2218 15.3106 12.5843L16.5363 17.661C16.744 18.5211 15.7969 19.201 15.033 18.7401L10.5245 16.0196C10.2025 15.8252 9.7975 15.8252 9.47548 16.0196L4.96699 18.7401C4.20311 19.201 3.25596 18.5211 3.46363 17.661L4.68942 12.5843C4.77698 12.2218 4.65182 11.8412 4.36526 11.5987L0.353062 8.2034C-0.326718 7.62813 0.0350679 6.52814 0.927291 6.45748L6.19336 6.0404C6.5695 6.01061 6.89716 5.77543 7.04207 5.43123L9.07088 0.612343Z" fill="{{ section.settings.star_rating_color | default: '#000000' }}"/>
                      <path d="M33.0709 0.612343C33.4146 -0.204115 34.5854 -0.204114 34.9291 0.612346L36.9579 5.43123C37.1029 5.77543 37.4306 6.01061 37.8067 6.0404L43.0727 6.45748C43.9649 6.52814 44.3267 7.62813 43.6469 8.2034L39.6348 11.5987C39.3482 11.8412 39.223 12.2218 39.3106 12.5843L40.5363 17.661C40.744 18.5211 39.7969 19.201 39.033 18.7401L34.5245 16.0196C34.2025 15.8252 33.7975 15.8252 33.4755 16.0196L28.967 18.7401C28.2031 19.201 27.256 18.5211 27.4636 17.661L28.6894 12.5843C28.777 12.2218 28.6518 11.8412 28.3653 11.5987L24.3531 8.2034C23.6733 7.62813 24.0351 6.52814 24.9273 6.45748L30.1934 6.0404C30.5695 6.01061 30.8972 5.77543 31.0421 5.43123L33.0709 0.612343Z" fill="{{ section.settings.star_rating_color | default: '#000000' }}"/>
                      <path d="M57.0709 0.612343C57.4146 -0.204115 58.5854 -0.204114 58.9291 0.612346L60.9579 5.43123C61.1029 5.77543 61.4306 6.01061 61.8067 6.0404L67.0727 6.45748C67.9649 6.52814 68.3267 7.62813 67.6469 8.2034L63.6348 11.5987C63.3482 11.8412 63.223 12.2218 63.3106 12.5843L64.5363 17.661C64.744 18.5211 63.7969 19.201 63.033 18.7401L58.5245 16.0196C58.2025 15.8252 57.7975 15.8252 57.4755 16.0196L52.967 18.7401C52.2031 19.201 51.256 18.5211 51.4636 17.661L52.6894 12.5843C52.777 12.2218 52.6518 11.8412 52.3653 11.5987L48.3531 8.2034C47.6733 7.62813 48.0351 6.52814 48.9273 6.45748L54.1934 6.0404C54.5695 6.01061 54.8972 5.77543 55.0421 5.43123L57.0709 0.612343Z" fill="{{ section.settings.star_rating_color | default: '#000000' }}"/>
                      <path d="M81.0709 0.612343C81.4146 -0.204115 82.5854 -0.204114 82.9291 0.612346L84.9579 5.43123C85.1029 5.77543 85.4306 6.01061 85.8067 6.0404L91.0727 6.45748C91.9649 6.52814 92.3267 7.62813 91.6469 8.2034L87.6348 11.5987C87.3482 11.8412 87.223 12.2218 87.3106 12.5843L88.5363 17.661C88.744 18.5211 87.7969 19.201 87.033 18.7401L82.5245 16.0196C82.2025 15.8252 81.7975 15.8252 81.4755 16.0196L76.967 18.7401C76.2031 19.201 75.256 18.5211 75.4636 17.661L76.6894 12.5843C76.777 12.2218 76.6518 11.8412 76.3653 11.5987L72.3531 8.2034C71.6733 7.62813 72.0351 6.52814 72.9273 6.45748L78.1934 6.0404C78.5695 6.01061 78.8972 5.77543 79.0421 5.43123L81.0709 0.612343Z" fill="{{ section.settings.star_rating_color | default: '#000000' }}"/>
                      <path d="M105.071 0.612343C105.415 -0.204115 106.585 -0.204114 106.929 0.612346L108.958 5.43123C109.103 5.77543 109.431 6.01061 109.807 6.0404L115.073 6.45748C115.965 6.52814 116.327 7.62813 115.647 8.2034L111.635 11.5987C111.348 11.8412 111.223 12.2218 111.311 12.5843L112.536 17.661C112.744 18.5211 111.797 19.201 111.033 18.7401L106.525 16.0196C106.203 15.8252 105.797 15.8252 105.475 16.0196L100.967 18.7401C100.203 19.201 99.256 18.5211 99.4636 17.661L100.689 12.5843C100.777 12.2218 100.652 11.8412 100.365 11.5987L96.3531 8.2034C95.6733 7.62813 96.0351 6.52814 96.9273 6.45748L102.193 6.0404C102.569 6.01061 102.897 5.77543 103.042 5.43123L105.071 0.612343Z" fill="{{ section.settings.star_rating_color | default: '#000000' }}"/>
                      </g>
                      <defs>
                      <clipPath id="clip0_506_132070">
                      <rect width="116" height="18.8889" fill="white"/>
                      </clipPath>
                      </defs>
                    </svg>
                  </div>
                  <p style="color: {{ section.settings.testimonial_text_color | default: '#000000' }};">
                    "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare."
                  </p>

                  <div class="review-author-post flex flex-wrap align-center gap-y-4">
                    <div class="image-section">
                      <img src="{{ 'placeholder-image.png' | asset_url }}" alt="reviewer" class="image-cover rounded-full">
                    </div>
                    <div class="desc col-12 xl-phone-pl-4">
                      {% if section.settings.show_name %}
                        <p class="font-semibold" style="color: {{ section.settings.author_name_color | default: '#000000' }};">
                          Name Surname
                        </p>
                      {% endif %}
                       {% if section.settings.show_position %}
                        <p style="color: {{ section.settings.author_position_color | default: '#666666' }};">
                          Position, Company name
                        </p>
                      {% endif %}
                    </div>
                  </div>
                </div>
              </li>
            {% endfor %}
          </ul>

          <div class="splide__arrows splide-arrow-section">
            <button class="slide-arrow splide__arrow splide__arrow--prev arrow-prev-btn"
                    style="color: {{ section.settings.arrow_color | default: '#000000' }};">
              <svg width="24" height="25" viewBox="0 0 24 25" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M20 11.4004H7.83L13.42 5.81039L12 4.40039L4 12.4004L12 20.4004L13.41 18.9904L7.83 13.4004H20V11.4004Z" fill="currentColor"/>
              </svg>
            </button>
            <button class="slide-arrow splide__arrow splide__arrow--next arrow-next-btn"
                    style="color: {{ section.settings.arrow_color | default: '#000000' }};">
              <svg width="24" height="25" viewBox="0 0 24 25" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M20 11.4004H7.83L13.42 5.81039L12 4.40039L4 12.4004L12 20.4004L13.41 18.9904L7.83 13.4004H20V11.4004Z" fill="currentColor"/>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div><!-- .carousel-section -->
  </div>
</section>

{% schema %}
{
  "name": "Customer Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Customer Testimonials",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "intro_text",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit.",
      "label": "Intro Text"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "Heading 2"
        },
        {
          "value": "h1",
          "label": "Heading 1"
        },
        {
          "value": "h3",
          "label": "Heading 3"
        },
        {
          "value": "h4",
          "label": "Heading 4"
        },
        {
          "value": "h5",
          "label": "Heading 5"
        }
      ],
      "default": "h1",
      "label": "Heading Size"
    },
    {
      "type": "range",
      "id": "testimonials_to_show",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 6,
      "label": "Testimonials to Show"
    },
    {
      "type": "color_background",
      "id": "background_color",
      "default": "#ffffff",
      "label": "Background Color"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image",
      "info": "Optional background image (will override background color)"
    },
    {
      "type": "color_background",
      "id": "overlay_color",
      "default": "#000000",
      "label": "Background Overlay Color",
      "info": "Color overlay on top of background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Background Overlay Opacity",
      "default": 40,
      "info": "0% = transparent, 100% = solid color"
    },
    {
      "type": "color_background",
      "id": "heading_color",
      "default": "#000000",
      "label": "Heading Color"
    },
    {
      "type": "color_background",
      "id": "intro_text_color",
      "default": "#666666",
      "label": "Intro Text Color"
    },
    {
      "type": "color_background",
      "id": "card_background_color",
      "default": "#ffffff",
      "label": "Testimonial Card Background"
    },
    {
      "type": "color_background",
      "id": "card_border_color",
      "default": "#000000",
      "label": "Testimonial Card Border"
    },
    {
      "type": "color_background",
      "id": "star_rating_color",
      "default": "#000000",
      "label": "Star Rating Color"
    },
    {
      "type": "color_background",
      "id": "testimonial_text_color",
      "default": "#000000",
      "label": "Testimonial Text Color"
    },
    {
      "type": "color_background",
      "id": "author_name_color",
      "default": "#000000",
      "label": "Author Name Color"
    },
    {
      "type": "color_background",
      "id": "author_position_color",
      "default": "#666666",
      "label": "Author Position Color"
    },
    {
      "type": "color_background",
      "id": "arrow_color",
      "default": "#000000",
      "label": "Carousel Arrow Color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "show_name",
      "default": true,
      "label": "Show author name"
    },
    {
      "type": "checkbox",
      "id": "show_position",
      "default": true,
      "label": "Show author position"
    }
  ]
}
{% endschema %}