<link rel="stylesheet" href="{{ 'fw_testimonial_billboard/styles.css' | asset_url }}">

<section class="fw-testimonial-billboard {% if section.settings.reverse_layout %}fw-testimonial-billboard--reversed{% endif %} {{ section.settings.background_color }} {{ section.settings.section_padding_y_mobile }} {{ section.settings.section_padding_y_desktop }} {{ section.settings.section_border_radius }}"
  {% if section.settings.background_image != blank %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>

  <div class="fw-testimonial-billboard-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius }} {{ section.settings.container_padding_y_mobile }} {{ section.settings.container_padding_y_desktop }} {{ section.settings.container_padding_x_mobile }} {{ section.settings.container_padding_x_desktop }}"
    {% if section.settings.container_background_image != blank %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>

    <!-- Photo Column -->
    <div class="fw-testimonial-photo-col">
      <div class="fw-testimonial-photo">
        {% if section.settings.person_image != blank %}
          <img src="{{ section.settings.person_image | image_url }}" alt="{{ section.settings.person_name | default: 'Testimonial photo' }}" loading="lazy">
        {% else %}
          <div class="fw-testimonial-photo-placeholder">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>
          </div>
        {% endif %}

        <div class="fw-testimonial-photo-overlay">
          {% if section.settings.person_name != blank %}
            <p class="fw-testimonial-person-name {{ section.settings.person_name_font_family }} {{ section.settings.person_name_font_size }} {{ section.settings.person_name_font_size_desktop }} {{ section.settings.person_name_font_weight }} {{ section.settings.person_name_color }}">
              {{ section.settings.person_name }}
            </p>
          {% endif %}

          {% if section.settings.person_title != blank %}
            <p class="fw-testimonial-person-title {{ section.settings.person_title_font_family }} {{ section.settings.person_title_font_size }} {{ section.settings.person_title_font_size_desktop }} {{ section.settings.person_title_font_weight }} {{ section.settings.person_title_color }}">
              {{ section.settings.person_title }}
            </p>
          {% endif %}
        </div>
      </div>

      {% if section.settings.brush_stroke_image != blank %}
        <img src="{{ section.settings.brush_stroke_image | image_url }}" alt="" class="fw-testimonial-brush-stroke" aria-hidden="true">
      {% endif %}
    </div>

    <!-- Content Column -->
    <div class="fw-testimonial-content-col">
      {% if section.settings.quote_text != blank %}
        <blockquote class="fw-testimonial-quote {{ section.settings.quote_font_family }} {{ section.settings.quote_font_size }} {{ section.settings.quote_font_size_desktop }} {{ section.settings.quote_font_weight }} {{ section.settings.quote_color }}">
          &ldquo;{{ section.settings.quote_text }}&rdquo;
        </blockquote>
      {% endif %}

      {% if section.settings.attribution != blank %}
        <p class="fw-testimonial-attribution {{ section.settings.attribution_font_family }} {{ section.settings.attribution_font_size }} {{ section.settings.attribution_font_size_desktop }} {{ section.settings.attribution_font_weight }} {{ section.settings.attribution_color }}">
          {{ section.settings.attribution }}
        </p>
      {% endif %}

      {% if section.settings.show_ghost_link and section.settings.ghost_link_text != blank %}
        <a href="{{ section.settings.ghost_link_url | default: '#' }}"
           class="fw-testimonial-ghost-link {{ section.settings.ghost_link_font_family }} {{ section.settings.ghost_link_font_size }} {{ section.settings.ghost_link_font_size_desktop }} {{ section.settings.ghost_link_font_weight }} {{ section.settings.ghost_link_color }}">
          {{ section.settings.ghost_link_text }}
          <span class="fw-testimonial-ghost-arrow" aria-hidden="true">&rarr;</span>
        </a>
      {% endif %}
    </div>

  </div>

</section>

