<link rel="stylesheet" href="{{ 'fw_comparison_table/styles.css' | asset_url }}">

<section class="fw-compare-section {{ section.settings.background_color }} {{ section.settings.section_padding_y_mobile }} {{ section.settings.section_padding_y_desktop }} {{ section.settings.section_border_radius }}"
  {% if section.settings.background_image != blank %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>

  <div class="fw-compare-container {{ section.settings.container_background_color }} {{ section.settings.container_border_radius }} {{ section.settings.container_padding_y_mobile }} {{ section.settings.container_padding_y_desktop }} {{ section.settings.container_padding_x_mobile }} {{ section.settings.container_padding_x_desktop }}"
    {% if section.settings.container_background_image != blank %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>

    <div class="fw-compare-grid">

      <div class="fw-compare-narrative">

        {% if section.settings.show_accent_bar and section.settings.accent_bar_image != blank %}
        <div class="fw-compare-accent-bar">
          <img src="{{ section.settings.accent_bar_image | image_url }}" alt="" class="fw-compare-accent-bar-img" aria-hidden="true">
        </div>
        {% endif %}

        {% if section.settings.headline != blank %}
        <h2 class="fw-compare-headline {{ section.settings.headline_font_family }} {{ section.settings.headline_font_size }} {{ section.settings.headline_font_size_desktop }} {{ section.settings.headline_font_weight }} {{ section.settings.headline_color }}">
          {{ section.settings.headline }}
        </h2>
        {% endif %}

        {% if section.settings.body != blank %}
        <div class="fw-compare-body {{ section.settings.body_font_family }} {{ section.settings.body_font_size }} {{ section.settings.body_font_size_desktop }} {{ section.settings.body_font_weight }} {{ section.settings.body_color }}">
          {{ section.settings.body }}
        </div>
        {% endif %}

      </div>

      <div class="fw-compare-table-wrap">
        {% if section.blocks.size > 0 %}
        <div class="fw-compare-table-scroll">
          <table class="fw-compare-table">
            <thead>
              <tr>
                <th class="feature-col">Feature</th>
                <th class="competitor-col">{{ section.settings.competitor_header | default: 'Shopify' }}</th>
                <th class="fluid-col">{{ section.settings.fluid_header | default: 'Fluid' }}</th>
              </tr>
            </thead>
            <tbody>
              {% for block in section.blocks %}
                {% if block.type == 'comparison_row' %}
                <tr {{ block.fluid_attributes }}>
                  <td class="feature-col">{{ block.settings.feature_name }}</td>
                  <td class="competitor-col check-no">{{ block.settings.competitor_value }}</td>
                  <td class="fluid-col {% if block.settings.fluid_is_positive %}check-yes{% else %}check-no{% endif %}">{{ block.settings.fluid_value }}</td>
                </tr>
                {% endif %}
              {% endfor %}
            </tbody>
          </table>
        </div>
        {% endif %}

        {% if section.settings.table_note != blank %}
        <p class="fw-compare-note {{ section.settings.table_note_font_family }} {{ section.settings.table_note_font_size }} {{ section.settings.table_note_font_size_desktop }} {{ section.settings.table_note_font_weight }} {{ section.settings.table_note_color }}">
          {{ section.settings.table_note }}
        </p>
        {% endif %}
      </div>

    </div>

  </div>
</section>

