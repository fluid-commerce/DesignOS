 <!-- Multiple slider -->
 <div class="container" id="dummy-container"></div>
{% assign carousel_id = section.id | append: '-carousel' %}

{%- style -%}
  .product-collection-section-{{ section.id }} {
    padding-top: {{ section.settings.section_padding_top_mobile | default: 40 }}px;
    padding-bottom: {{ section.settings.section_padding_bottom_mobile | default: 40 }}px;
    background-color: {{ section.settings.background_color | default: '#ffffff' }};
    color: {{ section.settings.text_color | default: '#000000' }};
  }

  @media (min-width: 1280px) {
    .product-collection-section-{{ section.id }} {
      padding-top: {{ section.settings.section_padding_top_desktop | default: 80 }}px;
      padding-bottom: {{ section.settings.section_padding_bottom_desktop | default: 80 }}px;
    }
  }
{%- endstyle -%}

<section class="product-collection-section product-collection-section-{{ section.id }}">
   <div class="header-section">
     <div class="container">
       <div class="wrapper flex flex-wrap items-center justify-between">
         <div class="desc">
           <span class="{{ section.settings.tagline_font_size | default: 'text-base' }} {{ section.settings.tagline_font_size_desktop | default: 'xl-tab-text-base' }} {{ section.settings.tagline_font_weight | default: 'font-semibold' }}" style="color: {{ section.settings.tagline_color | default: '#000000' }};">{{ section.settings.tagline | default: "Tagline" }}</span>
           <div class="py-3 sm-desktop-py-4 {{ section.settings.heading_font_size | default: 'text-h3' }} {{ section.settings.heading_font_size_desktop | default: 'text-h2' }} {{ section.settings.heading_font_weight | default: 'font-bold' }}" style="color: {{ section.settings.heading_color | default: '#000000' }};">{{ section.settings.heading | default: "Products" }}</div>
           <p class="{{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'xl-tab-text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }}" style="color: {{ section.settings.description_color | default: '#000000' }};">
             {{ section.settings.description | default: "Lorem ipsum dolor sit amet, consectetur adipiscing elit." }}
           </p>
         </div>
         {% if section.settings.show_view_all_button %}
         <div class="btn-section hidden sm-desktop-block">
           <a href="{{ section.settings.view_all_url | default: '#' }}" class="btn btn-border-primary" style="
             background-color: {{ section.settings.view_all_button_background_color | default: '#ffffff' }};
             color: {{ section.settings.view_all_button_text_color | default: '#000000' }};
             border-color: {{ section.settings.view_all_button_border_color | default: '#000000' }};
           ">{{ section.settings.view_all_text | default: "View All" }}</a>
         </div>
         {% endif %}
       </div>
     </div>
   </div>
    <!-- .header-section -->

    <div class="product-list-section carousel-container mt-12">
      <div class="container">
        <div class="product-carousel {{ carousel_id }} splide">
          <div class="splide__track">
            <ul class="splide__list">
              {% for product in all_products limit: 10 %}
                <li class="splide__slide">
                  <a href="{{ product.url }}" class="carousel-product">
                    <div class="image-section product-image-height">
                      <img
                        src="{{ product.image }}"
                        alt="{{ product.title }}"
                        class="image-cover"
                      />
                    </div>
                    <div class="desc pt-4">
                      <h6 class="{{ section.settings.product_title_font_size | default: 'text-base' }} {{ section.settings.product_title_font_size_desktop | default: 'xl-tab-text-base' }} {{ section.settings.product_title_font_weight | default: 'font-medium' }}" style="color: {{ section.settings.product_title_color | default: '#000000' }};">{{ product.title }}</h6>
                      {% comment %}<p class="text-sm pt-1">Variant</p> {% endcomment %}
                      {% unless product.price == 0 %}<h5 class="pt-2 {{ section.settings.product_price_font_size | default: 'text-lg' }} {{ section.settings.product_price_font_size_desktop | default: 'xl-tab-text-lg' }} {{ section.settings.product_price_font_weight | default: 'font-semibold' }}" style="color: {{ section.settings.product_price_color | default: '#000000' }};">{{ product.price }}</h5>{% endunless %}
                    </div>
                  </a>
                </li>
              {% endfor %}
            </ul>
          </div>

          <div class="splide__arrows splide-arrow-section mt-12">
            <button
              class="slide-arrow splide__arrow splide__arrow--prev arrow-prev-btn"
              style="
                background-color: {{ section.settings.arrow_background_color | default: '#ffffff' }};
                border: {{ section.settings.arrow_border_width | default: 1 }}px solid {{ section.settings.arrow_border_color | default: '#e5e5e5' }};
                width: {{ section.settings.arrow_width | default: 48 }}px;
                height: {{ section.settings.arrow_height | default: 48 }}px;
                color: {{ section.settings.arrow_icon_color | default: '#000000' }};
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
              "
            >
              <svg
                width="24"
                height="25"
                viewBox="0 0 24 25"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M20 11.4004H7.83L13.42 5.81039L12 4.40039L4 12.4004L12 20.4004L13.41 18.9904L7.83 13.4004H20V11.4004Z"
                  fill="currentColor"
                />
              </svg>
            </button>
            <button
              class="slide-arrow splide__arrow splide__arrow--next arrow-next-btn"
              style="
                background-color: {{ section.settings.arrow_background_color | default: '#ffffff' }};
                border: {{ section.settings.arrow_border_width | default: 1 }}px solid {{ section.settings.arrow_border_color | default: '#e5e5e5' }};
                width: {{ section.settings.arrow_width | default: 48 }}px;
                height: {{ section.settings.arrow_height | default: 48 }}px;
                color: {{ section.settings.arrow_icon_color | default: '#000000' }};
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
              "
            >
              <svg
                width="24"
                height="25"
                viewBox="0 0 24 25"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M20 11.4004H7.83L13.42 5.81039L12 4.40039L4 12.4004L12 20.4004L13.41 18.9904L7.83 13.4004H20V11.4004Z"
                  fill="currentColor"
                />
              </svg>
            </button>
          </div>
        </div>
        <!-- .product-carousel -->
      </div>
    </div>
    <!-- .carousel-section -->
  </section>
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      // Initialize this specific carousel
      const productCarousel = new Splide('.{{ carousel_id }}', {
        perPage: 1,
        perMove: 1,
        speed: 500,
        mediaQuery: "min",
        interval: 5000,
        padding: {
          right: "64px",
        },
        gap: "24px",
        breakpoints: {
          576: {
            perPage: 2,
          },
          768: {
            perPage: 3,
          },
          1200: {
            gap: "48px",
            padding: {
              right: "80px",
            },
          },
        },
      });
      productCarousel.mount();

      // Set spacing for carousel containers
      function setCarsouselContainerSpacing() {
        let paddingLeft = $("#dummy-container").offset().left;
        $(".carousel-container").each(function () {
          $(this).css("padding-left", paddingLeft + "px");
        });
      }
      setCarsouselContainerSpacing();

      $(window).resize(function () {
        setCarsouselContainerSpacing();
      });
    });
</script>

