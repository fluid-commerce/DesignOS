<!-- Blog section  -->
<section class="blog-section" style="
  padding-top: {{ section.settings.section_padding_top_mobile | default: 40 }}px; 
  padding-bottom: {{ section.settings.section_padding_bottom_mobile | default: 40 }}px; 
  background-color: {{ section.settings.background_color | default: '#ffffff' }}; 
">
  <style>
    @media (min-width: 1280px) {
      .blog-section {
        padding-top: {{ section.settings.section_padding_top_desktop | default: 100 }}px !important;
        padding-bottom: {{ section.settings.section_padding_bottom_desktop | default: 80 }}px !important;
      }
    }
  </style>
  <div class="container">
    <div class="header text-center">
      <div class="{{ section.settings.heading_font_size | default: 'text-h1' }} {{ section.settings.heading_font_size_desktop | default: 'xl-tab-text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-bold' }}" style="color: {{ section.settings.heading_color | default: '#000000' }};">{{ section.settings.heading | default: "Short heading goes here" }}</div>
      {% if section.settings.intro_text != blank %}
      <p class="{{ section.settings.intro_font_size | default: 'text-base' }} {{ section.settings.intro_font_size_desktop | default: 'xl-tab-text-lg' }} {{ section.settings.intro_font_weight | default: 'font-normal' }} pt-5" style="color: {{ section.settings.intro_color | default: '#000000' }};">{{ section.settings.intro_text }}</p>
      {% endif %}
    </div>

    <div class="blog-grid-section pt-12 sm-desktop-pt-20">
      <div class="grid grid-cols-1 {{ section.settings.grid_columns_tablet | default: 'lg-tab-grid-cols-2' }} {{ section.settings.grid_columns_desktop | default: 'xl-desktop-grid-cols-3' }} gap-{{ section.settings.grid_gap | default: 12 }} blog-grid">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'blog_post' %}
              <div class="blog-col flex flex-col gap-6" {{ block.fluid_attributes }}>
                <figure class="blog-image relative overflow-hidden" style="
                  border-radius: {{ block.settings.image_border_radius | default: 0 }}px;
                  height: {{ block.settings.image_height | default: 'auto' }};
                ">
                  {% if block.settings.blog_image != blank %}
                    <img src="{{ block.settings.blog_image | image_url: width: 600 }}" alt="{{ block.settings.blog_title | default: 'Blog post' }}" class="image-cover" loading="lazy"/>
                  {% else %}
                    <img src="{{ 'blog-placeholder.png' | asset_url }}" alt="blog" class="image-cover"/>
                  {% endif %}
                </figure>
                <div class="blog-content">
                  {% if block.settings.show_category and block.settings.blog_category != blank %}
                  <div class="blog-category mb-2">
                    <span class="{{ block.settings.category_font_size | default: 'text-sm' }} {{ block.settings.category_font_weight | default: 'font-medium' }}" style="color: {{ block.settings.category_color | default: '#666666' }};">{{ block.settings.blog_category }}</span>
                  </div>
                  {% endif %}
                  <h4 class="mb-2 {{ block.settings.title_font_size | default: 'text-h4' }} {{ block.settings.title_font_size_desktop | default: 'xl-tab-text-h4' }} {{ block.settings.title_font_weight | default: 'font-semibold' }}" style="color: {{ block.settings.title_color | default: '#000000' }};">{{ block.settings.blog_title | default: "Blog title heading will go here" }}</h4>
                  <p class="{{ block.settings.content_font_size | default: 'text-base' }} {{ block.settings.content_font_size_desktop | default: 'xl-tab-text-base' }} {{ block.settings.content_font_weight | default: 'font-normal' }}" style="color: {{ block.settings.content_color | default: '#000000' }};">
                    {{ block.settings.blog_excerpt | default: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare." }}
                  </p>
                  {% if block.settings.show_author and block.settings.author_name != blank %}
                  <div class="blog-author mt-4 flex items-center gap-3">
                    {% if block.settings.author_image != blank %}
                      <img src="{{ block.settings.author_image | image_url: width: 40 }}" alt="{{ block.settings.author_name }}" class="rounded-full w-10 h-10 object-cover">
                    {% endif %}
                    <div>
                      <p class="{{ block.settings.author_font_size | default: 'text-sm' }} {{ block.settings.author_font_weight | default: 'font-medium' }}" style="color: {{ block.settings.author_color | default: '#000000' }};">{{ block.settings.author_name }}</p>
                      {% if block.settings.publish_date != blank %}
                      <p class="text-xs" style="color: {{ block.settings.date_color | default: '#666666' }};">{{ block.settings.publish_date }}</p>
                      {% endif %}
                    </div>
                  </div>
                  {% endif %}
                  {% if block.settings.show_read_more %}
                  <div class="blog-btn mt-{{ block.settings.button_margin_top | default: 3 }}">
                    <a href="{{ block.settings.blog_url | default: '#' }}" class="btn btn-link {{ block.settings.button_style | default: 'btn-link' }}" style="color: {{ block.settings.button_color | default: '#000000' }};">
                      <span>{{ block.settings.button_text | default: "Read more" }}</span>
                      {% if block.settings.show_button_icon %}
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="25"
                        viewBox="0 0 24 25"
                        fill="none"
                        class="mt-1"
                      >
                        <path
                          d="M9.70697 17.3491L15.414 11.6421L9.70697 5.93506L8.29297 7.34906L12.586 11.6421L8.29297 15.9351L9.70697 17.3491Z"
                          fill="currentColor"
                        />
                      </svg>
                      {% endif %}
                    </a>
                  </div>
                  {% endif %}
                </div>
              </div>
          {% endcase %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

