<link rel="stylesheet" href="{{ 'fw_logo_bar/styles.css' | asset_url }}">

<section class="fw-logo-bar-section {{ section.settings.background_color }} {{ section.settings.section_padding_y_mobile }} {{ section.settings.section_padding_y_desktop }} {{ section.settings.section_border_radius }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  <div class="container">
    <div class="inner-container {{ section.settings.container_background_color }} {{ section.settings.container_padding_y_mobile }} {{ section.settings.container_padding_y_desktop }} {{ section.settings.container_padding_x_mobile }} {{ section.settings.container_padding_x_desktop }} {{ section.settings.container_border_radius }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>

      {% if section.settings.eyebrow_text != blank %}
      <p class="fw-logo-bar__eyebrow {{ section.settings.eyebrow_font_family }} {{ section.settings.eyebrow_font_size }} {{ section.settings.eyebrow_font_size_desktop }} {{ section.settings.eyebrow_font_weight }} {{ section.settings.eyebrow_color }}">
        {{ section.settings.eyebrow_text }}
      </p>
      {% endif %}

      <div class="fw-logo-bar__logos">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'logo' %}
              <div class="fw-logo-bar__item" {{ block.fluid_attributes }}>
                {% if block.settings.logo_url != blank %}
                  <a href="{{ block.settings.logo_url }}" class="fw-logo-bar__link" target="_blank" rel="noopener">
                {% endif %}

                {% if block.settings.logo_image != blank %}
                  <img
                    src="{{ block.settings.logo_image | image_url }}"
                    alt="{{ block.settings.logo_alt | default: 'Partner logo' }}"
                    class="fw-logo-bar__logo"
                    style="max-height: {{ section.settings.logo_max_height }};"
                    loading="lazy"
                  >
                {% else %}
                  <div class="fw-logo-bar__placeholder" style="height: {{ section.settings.logo_max_height }};">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 40" fill="none" style="height: 100%; width: auto; opacity: 0.3;">
                      <rect width="120" height="40" rx="4" fill="currentColor" fill-opacity="0.15"/>
                      <text x="60" y="24" text-anchor="middle" fill="currentColor" fill-opacity="0.4" font-size="11" font-family="sans-serif">Logo</text>
                    </svg>
                  </div>
                {% endif %}

                {% if block.settings.logo_url != blank %}
                  </a>
                {% endif %}
              </div>
          {% endcase %}
        {% endfor %}
      </div>

    </div>
  </div>
</section>

