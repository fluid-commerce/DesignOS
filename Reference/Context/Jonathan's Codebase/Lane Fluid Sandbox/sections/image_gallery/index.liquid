<!-- Image Gallery Section -->
<section class="image-gallery section {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  <div class="container">
    <div class="inner-container {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_padding_y_mobile | default: 'py-xl' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-lg' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }} {{ section.settings.container_border_radius | default: 'rounded-none' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <div class="max-w-7xl mx-auto">
        
        <!-- Header Content -->
        {% if section.settings.show_header %}
        <div class="gallery-header text-center {{ section.settings.header_margin_bottom | default: 'mb-3xl' }}">
          
          {% if section.settings.main_heading != blank %}
          <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-4xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-bold' }} {{ section.settings.heading_color | default: 'text-black' }} {{ section.settings.heading_line_height | default: 'leading-tight' }} {{ section.settings.heading_margin_bottom | default: 'mb-lg' }}">
            {{ section.settings.main_heading }}
          </h2>
          {% endif %}
          
          {% if section.settings.description != blank %}
          <div class="{{ section.settings.description_font_size | default: 'text-lg' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.description_line_height | default: 'leading-relaxed' }} {{ section.settings.description_color | default: 'text-gray-600' }} max-w-4xl mx-auto">
            {{ section.settings.description }}
          </div>
          {% endif %}
          
        </div>
        {% endif %}
        
        <!-- Gallery Grid -->
        {% if section.blocks.size > 0 %}
        <div class="gallery-grid {{ section.settings.gallery_gap | default: 'gap-md' }}">
          
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'gallery_image' %}
                <div class="gallery-item {{ block.settings.image_size | default: 'size-medium' }} {{ section.settings.image_border_radius | default: 'rounded-lg' }} overflow-hidden" {{ block.fluid_attributes }}>
                  
                  {% if block.settings.gallery_image != blank %}
                    <div class="gallery-image-wrapper">
                      <img src="{{ block.settings.gallery_image | image_url: width: 800 }}"
                           alt="{{ block.settings.image_alt | default: 'Gallery image' }}"
                           class="gallery-image w-full h-full object-cover"
                           loading="lazy">
                      
                      <!-- Optional overlay for hover effects -->
                      {% if section.settings.show_hover_overlay %}
                      <div class="gallery-overlay {{ section.settings.overlay_background_color | default: 'bg-black' }} opacity-0 hover:opacity-75 transition-opacity duration-300 absolute inset-0 flex items-center justify-center">
                        {% if block.settings.image_caption != blank %}
                        <div class="gallery-caption {{ section.settings.caption_text_color | default: 'text-white' }} {{ section.settings.caption_font_size | default: 'text-lg' }} {{ section.settings.caption_font_weight | default: 'font-semibold' }} text-center px-md">
                          {{ block.settings.image_caption }}
                        </div>
                        {% endif %}
                      </div>
                      {% endif %}
                      
                      <!-- Optional link wrapper -->
                      {% if block.settings.image_link != blank %}
                      <a href="{{ block.settings.image_link }}" 
                         class="absolute inset-0 z-10"
                         {% if block.settings.open_in_new_tab %}target="_blank" rel="noopener"{% endif %}
                         aria-label="View {{ block.settings.image_alt | default: 'gallery image' }}">
                      </a>
                      {% endif %}
                    </div>
                  {% else %}
                    <div class="gallery-image-wrapper bg-gray-200 flex items-center justify-center">
                      <img src="{{ 'placeholder-image.png' | asset_url }}"
                           alt="Gallery placeholder"
                           class="gallery-image w-full h-full object-cover opacity-50">
                    </div>
                  {% endif %}
                  
                </div>
            {% endcase %}
          {% endfor %}
          
        </div>
        {% endif %}
        
        <!-- Optional CTA Button -->
        {% if section.settings.show_cta and section.settings.cta_text != blank %}
        <div class="gallery-cta text-center {{ section.settings.cta_margin_top | default: 'mt-3xl' }}">
          <a href="{{ section.settings.cta_url | default: '#' }}" 
             class="inline-block {{ section.settings.cta_background_color | default: 'bg-black' }} {{ section.settings.cta_text_color | default: 'text-white' }} {{ section.settings.cta_font_size | default: 'text-lg' }} {{ section.settings.cta_font_weight | default: 'font-semibold' }} {{ section.settings.cta_padding | default: 'px-xl py-md' }} {{ section.settings.cta_border_radius | default: 'rounded-full' }} hover:opacity-90 transition-opacity duration-200"
             {% if section.settings.cta_open_new_tab %}target="_blank" rel="noopener"{% endif %}>
            {{ section.settings.cta_text }}
          </a>
        </div>
        {% endif %}
        
      </div>
      
    </div>
  </div>
</section>

