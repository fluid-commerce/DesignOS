<link rel="stylesheet" href="{{ 'fw_dual_quotes/styles.css' | asset_url }}">

<section class="fw-dual-quotes-section {{ section.settings.background_color }} {{ section.settings.section_padding_y_mobile }} {{ section.settings.section_padding_y_desktop }} {{ section.settings.section_border_radius }}"
  {% if section.settings.background_image != blank %}data-bg style="background-image: url('{{ section.settings.background_image | image_url }}'); background-size: cover; background-position: center;"{% endif %}>

  <div class="fw-dual-quotes-container {{ section.settings.container_background_color }} {{ section.settings.container_border_radius }} {{ section.settings.container_padding_y_mobile }} {{ section.settings.container_padding_y_desktop }} {{ section.settings.container_padding_x_mobile }} {{ section.settings.container_padding_x_desktop }}"
    {% if section.settings.container_background_image != blank %}data-bg style="background-image: url('{{ section.settings.container_background_image | image_url }}'); background-size: cover; background-position: center;"{% endif %}>

    {% if section.blocks.size > 0 %}
    <div class="fw-dual-quotes">
      {% for block in section.blocks %}
        {% if block.type == 'quote' %}
        <div class="fw-quote-card {{ block.settings.card_background_color }}" style="--card-border-color: var(--clr-{{ block.settings.border_color }});" {{ block.fluid_attributes }}>

          {% if block.settings.quote_text != blank %}
          <div class="fw-quote-text {{ block.settings.quote_font_family }} {{ block.settings.quote_font_size }} {{ block.settings.quote_font_size_desktop }} {{ block.settings.quote_font_weight }} {{ block.settings.quote_color }}">
            {{ block.settings.quote_text }}
          </div>
          {% endif %}

          {% if block.settings.attribution_text != blank %}
          <p class="fw-quote-attribution {{ block.settings.attribution_font_family }} {{ block.settings.attribution_font_size }} {{ block.settings.attribution_font_size_desktop }} {{ block.settings.attribution_font_weight }} {{ block.settings.attribution_color }}">
            {{ block.settings.attribution_text }}
          </p>
          {% endif %}

        </div>
        {% endif %}
      {% endfor %}
    </div>
    {% endif %}

  </div>
</section>

