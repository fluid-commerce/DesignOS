{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="logo-section section-t-spacing section-{{ section.id }}-padding" 
         style="background-color: {{ section.settings.background_color | default: '#ffffff' }};
                {% if section.settings.background_image != blank %}
                background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;
                {% endif %}
                position: relative;">
  
  {% if section.settings.background_image != blank %}
    <div class="logo-overlay" 
         style="background-color: {{ section.settings.overlay_color | default: '#000000' }}; 
                opacity: {{ section.settings.overlay_opacity | default: 40 | divided_by: 100.0 }}; 
                position: absolute; 
                top: 0; 
                left: 0; 
                width: 100%; 
                height: 100%; 
                z-index: 1;"></div>
  {% endif %}
  
  <div class="container" style="position: relative; z-index: 2;">
    <div class="logo-wrapper grid grid-cols-1 sm-desktop-grid-cols-2 gap-12 align-center">
      
      <!-- Heading Column -->
      <div class="logo-heading-column">
        {% if section.settings.tagline != blank %}
          <p class="logo-tagline text-sm mb-4" 
             style="color: {{ section.settings.tagline_color | default: '#6b7280' }};">
            {{ section.settings.tagline }}
          </p>
        {% endif %}
        
        {% if section.settings.heading != blank %}
          <h3 class="logo__heading text-lg font-semibold" 
              style="color: {{ section.settings.heading_color | default: '#1a1a1a' }};">
            {{ section.settings.heading }}
          </h3>
        {% endif %}
        
        {% if section.settings.description != blank %}
          <p class="logo-description text-lg mt-6" 
             style="color: {{ section.settings.description_color | default: '#6b7280' }};">
            {{ section.settings.description }}
          </p>
        {% endif %}
      </div>

      <!-- Logos Column -->
      <div class="logo-logos-column">
        <div class="logo-logos-grid grid grid-cols-2 md-tab-grid-cols-3 sm-desktop-grid-cols-5 gap-8 align-center">
          
          <!-- Logo 1 -->
          <div class="logo-item flex justify-center align-center">
            {% if section.settings.logo_1_image != blank %}
              {% if section.settings.logo_1_link != blank %}
                <a href="{{ section.settings.logo_1_link }}" class="logo-link">
              {% endif %}
              <img src="{{ section.settings.logo_1_image | image_url: width: 200 }}" 
                   alt="{{ section.settings.logo_1_alt | default: 'Company logo' }}"
                   class="logo-image">
              {% if section.settings.logo_1_link != blank %}
                </a>
              {% endif %}
            {% else %}
              <div class="logo-placeholder">
                <svg width="80" height="40" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                </svg>
                <p class="text-xs" style="margin-top: 4px; color: #9ca3af;">Logo 1</p>
              </div>
            {% endif %}
          </div>

          <!-- Logo 2 -->
          <div class="logo-item flex justify-center align-center">
            {% if section.settings.logo_2_image != blank %}
              {% if section.settings.logo_2_link != blank %}
                <a href="{{ section.settings.logo_2_link }}" class="logo-link">
              {% endif %}
              <img src="{{ section.settings.logo_2_image | image_url: width: 200 }}" 
                   alt="{{ section.settings.logo_2_alt | default: 'Company logo' }}"
                   class="logo-image">
              {% if section.settings.logo_2_link != blank %}
                </a>
              {% endif %}
            {% else %}
              <div class="logo-placeholder">
                <svg width="80" height="40" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                </svg>
                <p class="text-xs" style="margin-top: 4px; color: #9ca3af;">Logo 2</p>
              </div>
            {% endif %}
          </div>

          <!-- Logo 3 -->
          <div class="logo-item flex justify-center align-center">
            {% if section.settings.logo_3_image != blank %}
              {% if section.settings.logo_3_link != blank %}
                <a href="{{ section.settings.logo_3_link }}" class="logo-link">
              {% endif %}
              <img src="{{ section.settings.logo_3_image | image_url: width: 200 }}" 
                   alt="{{ section.settings.logo_3_alt | default: 'Company logo' }}"
                   class="logo-image">
              {% if section.settings.logo_3_link != blank %}
                </a>
              {% endif %}
            {% else %}
              <div class="logo-placeholder">
                <svg width="80" height="40" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                </svg>
                <p class="text-xs" style="margin-top: 4px; color: #9ca3af;">Logo 3</p>
              </div>
            {% endif %}
          </div>

          <!-- Logo 4 -->
          <div class="logo-item flex justify-center align-center">
            {% if section.settings.logo_4_image != blank %}
              {% if section.settings.logo_4_link != blank %}
                <a href="{{ section.settings.logo_4_link }}" class="logo-link">
              {% endif %}
              <img src="{{ section.settings.logo_4_image | image_url: width: 200 }}" 
                   alt="{{ section.settings.logo_4_alt | default: 'Company logo' }}"
                   class="logo-image">
              {% if section.settings.logo_4_link != blank %}
                </a>
              {% endif %}
            {% else %}
              <div class="logo-placeholder">
                <svg width="80" height="40" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                </svg>
                <p class="text-xs" style="margin-top: 4px; color: #9ca3af;">Logo 4</p>
              </div>
            {% endif %}
          </div>

          <!-- Logo 5 -->
          <div class="logo-item flex justify-center align-center">
            {% if section.settings.logo_5_image != blank %}
              {% if section.settings.logo_5_link != blank %}
                <a href="{{ section.settings.logo_5_link }}" class="logo-link">
              {% endif %}
              <img src="{{ section.settings.logo_5_image | image_url: width: 200 }}" 
                   alt="{{ section.settings.logo_5_alt | default: 'Company logo' }}"
                   class="logo-image">
              {% if section.settings.logo_5_link != blank %}
                </a>
              {% endif %}
            {% else %}
              <div class="logo-placeholder">
                <svg width="80" height="40" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                </svg>
                <p class="text-xs" style="margin-top: 4px; color: #9ca3af;">Logo 5</p>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.logo-section .logo-image {
  max-width: 120px;
  max-height: 60px;
  width: auto;
  height: auto;
  object-fit: contain;
  filter: {{ section.settings.logo_filter | default: 'none' }};
  transition: filter 0.3s ease;
}

.logo-section .logo-link:hover .logo-image {
  filter: none;
  opacity: 0.8;
}

.logo-section .logo-placeholder {
  width: 120px;
  height: 60px;
  background-color: #f3f4f6;
  border: 2px dashed #d1d5db;
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
}

@media (max-width: 1023px) {
  .logo-section .logo-wrapper {
    gap: 48px;
    grid-template-columns: 1fr;
  }
  
  .logo-section .logo-heading-column {
    text-align: center;
  }
  
  .logo-section .logo-logos-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (max-width: 767px) {
  .logo-section .logo-logos-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  
  .logo-section .logo-wrapper {
    gap: 32px;
  }
  
  .logo-section .logo-image {
    max-width: 100px;
    max-height: 50px;
  }
  
  .logo-section .logo-placeholder {
    width: 100px;
    height: 50px;
  }
}
</style>

{% schema %}
{
  "name": "Logo",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "info": "Optional tagline above the heading"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "Loved by thousands worldwide",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "info": "Optional description below the heading"
    },

    {
      "type": "image_picker",
      "id": "logo_1_image",
      "label": "Logo 1 - Image"
    },
    {
      "type": "text",
      "id": "logo_1_alt",
      "label": "Logo 1 - Alt Text",
      "default": "Company logo"
    },
    {
      "type": "url",
      "id": "logo_1_link",
      "label": "Logo 1 - Link",
      "info": "Optional link for the logo"
    },
    {
      "type": "image_picker",
      "id": "logo_2_image",
      "label": "Logo 2 - Image"
    },
    {
      "type": "text",
      "id": "logo_2_alt",
      "label": "Logo 2 - Alt Text",
      "default": "Company logo"
    },
    {
      "type": "url",
      "id": "logo_2_link",
      "label": "Logo 2 - Link",
      "info": "Optional link for the logo"
    },
    {
      "type": "image_picker",
      "id": "logo_3_image",
      "label": "Logo 3 - Image"
    },
    {
      "type": "text",
      "id": "logo_3_alt",
      "label": "Logo 3 - Alt Text",
      "default": "Company logo"
    },
    {
      "type": "url",
      "id": "logo_3_link",
      "label": "Logo 3 - Link",
      "info": "Optional link for the logo"
    },
    {
      "type": "image_picker",
      "id": "logo_4_image",
      "label": "Logo 4 - Image"
    },
    {
      "type": "text",
      "id": "logo_4_alt",
      "label": "Logo 4 - Alt Text",
      "default": "Company logo"
    },
    {
      "type": "url",
      "id": "logo_4_link",
      "label": "Logo 4 - Link",
      "info": "Optional link for the logo"
    },
    {
      "type": "image_picker",
      "id": "logo_5_image",
      "label": "Logo 5 - Image"
    },
    {
      "type": "text",
      "id": "logo_5_alt",
      "label": "Logo 5 - Alt Text",
      "default": "Company logo"
    },
    {
      "type": "url",
      "id": "logo_5_link",
      "label": "Logo 5 - Link",
      "info": "Optional link for the logo"
    },
    {
      "type": "select",
      "id": "logo_filter",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "grayscale(100%)",
          "label": "Grayscale"
        },
        {
          "value": "opacity(0.6)",
          "label": "Faded"
        },
        {
          "value": "grayscale(100%) opacity(0.6)",
          "label": "Grayscale + Faded"
        }
      ],
      "default": "grayscale(100%) opacity(0.6)",
      "label": "Logo Filter",
      "info": "Visual treatment for logos"
    },
    {
      "type": "color_background",
      "id": "background_color",
      "default": "#ffffff",
      "label": "Background Color"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image",
      "info": "Optional background image (will override background color)"
    },
    {
      "type": "color_background",
      "id": "overlay_color",
      "default": "#000000",
      "label": "Background Overlay Color",
      "info": "Color overlay on top of background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Background Overlay Opacity",
      "default": 40,
      "info": "0% = transparent, 100% = solid color"
    },
    {
      "type": "color_background",
      "id": "tagline_color",
      "default": "#6b7280",
      "label": "Tagline Color"
    },
    {
      "type": "color_background",
      "id": "heading_color",
      "default": "#1a1a1a",
      "label": "Heading Color"
    },
    {
      "type": "color_background",
      "id": "description_color",
      "default": "#6b7280",
      "label": "Description Color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    }
  ]
}
{% endschema %}