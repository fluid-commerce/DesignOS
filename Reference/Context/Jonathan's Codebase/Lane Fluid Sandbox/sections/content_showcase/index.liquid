<!-- Content Showcase Section -->
<section class="content-showcase {{ section.settings.background_color | default: 'bg-black' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image }}"{% endif %}>
  <div class="container">
    <div class="inner-container {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_padding_y_mobile | default: 'py-xl' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-lg' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }} {{ section.settings.container_border_radius | default: 'rounded-none' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image }}"{% endif %}>
      
      <div class="max-w-7xl mx-auto">
      
      <!-- Main Grid Layout - Matching Original Structure -->
      <div class="content-grid grid grid-cols-1 lg:grid-cols-2 gap-xl lg:gap-3xl items-start {{ section.settings.flip_layout ? 'lg:flip-layout' : '' }}">
        
        <!-- Left Side: Headline + Main Image -->
        <div class="left-content space-y-xl">
          
          <!-- Main Headline -->
          {% if section.settings.show_headline %}
          <div class="headline-wrapper">
            <h2 class="{{ section.settings.headline_font_family | default: 'font-primary' }} {{ section.settings.headline_font_size | default: 'text-4xl' }} {{ section.settings.headline_font_size_desktop | default: 'lg:text-6xl' }} {{ section.settings.headline_font_weight | default: 'font-black' }} {{ section.settings.headline_color | default: 'text-white' }} leading-tight">
              {% assign headline_text = section.settings.headline | default: "Built for the way people actually buy" %}
              {% if section.settings.show_headline_accent and section.settings.highlight_word %}
                {% assign highlight_word = section.settings.highlight_word %}
                {% if headline_text contains highlight_word %}
                  {% assign parts = headline_text | split: highlight_word %}
                  {{ parts[0] }}<span class="{{ section.settings.highlight_color | default: 'text-info' }}">{{ highlight_word }}</span>{{ parts[1] }}
                {% else %}
                  {{ headline_text }}
                {% endif %}
              {% else %}
                {{ headline_text }}
              {% endif %}
            </h2>
          </div>
          {% endif %}
          
           <!-- Main Large Image -->
           <div class="main-image-wrapper">
             {% if section.settings.main_image %}
               <img src="{{ section.settings.main_image }}"
                    alt="{{ section.settings.main_image_alt | default: 'Main content image' }}"
                    class="w-full h-auto object-cover {{ section.settings.image_border_radius | default: 'rounded-lg' }}">
             {% else %}
               <img src="{{ 'placeholder-image.png' | asset_url }}"
                    alt="{{ section.settings.main_image_alt | default: 'Main content image placeholder' }}"
                    class="w-full h-auto object-cover {{ section.settings.image_border_radius | default: 'rounded-lg' }}">
             {% endif %}
           </div>
          
        </div>
        
        <!-- Right Side: Two Small Images + Text Content -->
        <div class="right-content space-y-xl">
          
          <!-- Two Supporting Images at Top -->
          <div class="supporting-images-wrapper">
            <div class="images-grid grid grid-cols-2 gap-md">
              
               <!-- Supporting Image 1 -->
               <div class="support-image-1">
                 {% if section.settings.support_image_one %}
                   <img src="{{ section.settings.support_image_one }}"
                        alt="{{ section.settings.support_image_one_alt | default: 'Supporting image 1' }}"
                        class="w-full h-48 object-cover {{ section.settings.image_border_radius | default: 'rounded-lg' }}">
                 {% else %}
                   <img src="{{ 'placeholder-image.png' | asset_url }}"
                        alt="{{ section.settings.support_image_one_alt | default: 'Supporting image 1 placeholder' }}"
                        class="w-full h-48 object-cover {{ section.settings.image_border_radius | default: 'rounded-lg' }}">
                 {% endif %}
               </div>
              
               <!-- Supporting Image 2 -->
               <div class="support-image-2">
                 {% if section.settings.support_image_two %}
                   <img src="{{ section.settings.support_image_two }}"
                        alt="{{ section.settings.support_image_two_alt | default: 'Supporting image 2' }}"
                        class="w-full h-48 object-cover {{ section.settings.image_border_radius | default: 'rounded-lg' }}">
                 {% else %}
                   <img src="{{ 'placeholder-image.png' | asset_url }}"
                        alt="{{ section.settings.support_image_two_alt | default: 'Supporting image 2 placeholder' }}"
                        class="w-full h-48 object-cover {{ section.settings.image_border_radius | default: 'rounded-lg' }}">
                 {% endif %}
               </div>
              
            </div>
          </div>
          
          <!-- Text Content at Bottom -->
          <div class="text-content-wrapper">
            
            <!-- Subheading -->
            {% if section.settings.show_subheading %}
            <div class="subheading-wrapper mb-lg">
              <p class="{{ section.settings.subheading_font_family | default: 'font-body' }} {{ section.settings.subheading_font_size | default: 'text-xl' }} {{ section.settings.subheading_font_size_desktop | default: 'lg:text-2xl' }} {{ section.settings.subheading_font_weight | default: 'font-bold' }} {{ section.settings.subheading_color | default: 'text-white' }} leading-relaxed">
                {{ section.settings.subheading | default: "People don't just buy something the second they hear about it." }}
              </p>
            </div>
            {% endif %}
            
            <!-- Body Content - Rich Text -->
            {% if section.settings.show_body_content %}
            <div class="body-content-wrapper {{ section.settings.body_font_family | default: 'font-body' }} {{ section.settings.body_font_size | default: 'text-base' }} {{ section.settings.body_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.body_font_weight | default: 'font-normal' }} {{ section.settings.body_color | default: 'text-white' }}">
              {{ section.settings.body_content }}
            </div>
            {% endif %}
            
            <!-- Buttons -->
            {% if section.settings.show_button_one or section.settings.show_button_two %}
            <div class="buttons-wrapper flex flex-row justify-start items-center gap-md mt-xl">
              {% if section.settings.show_button_one %}
              <a href="{{ section.settings.button_one_url | default: '#' }}" 
                 class="btn btn-{{ section.settings.button_one_style | default: 'filled' }}-{{ section.settings.button_one_color | default: 'primary' }} {{ section.settings.button_one_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded' }}">
                {{ section.settings.button_one_text | default: "Learn More" }}
              </a>
              {% endif %}
              
              {% if section.settings.show_button_two %}
              <a href="{{ section.settings.button_two_url | default: '#' }}" 
                 class="btn btn-{{ section.settings.button_two_style | default: 'outline' }}-{{ section.settings.button_two_color | default: 'white' }} {{ section.settings.button_two_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded' }}">
                {{ section.settings.button_two_text | default: "Get Started" }}
              </a>
              {% endif %}
            </div>
            {% endif %}
            
          </div>
          
        </div>
        
      </div>
      
    </div>
  </div>
</section>

