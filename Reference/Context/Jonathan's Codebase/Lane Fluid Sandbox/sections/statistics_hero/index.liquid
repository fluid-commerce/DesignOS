<!-- Statistics Hero Section -->
<section class="statistics-hero {{ section.settings.background_color | default: 'bg-black' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image }}"{% endif %}>
  <div class="container">
    <div class="inner-container py-xl lg:py-3xl px-lg lg:px-xl">
      
      <div class="max-w-5xl mx-auto text-center">
        
        <!-- Main Content -->
        <div class="statistics-content space-y-3xl">
          
          <!-- Small Italic Heading -->
          {% if section.settings.show_small_heading %}
          <div class="small-heading-wrapper mb-2xl">
            <p class="{{ section.settings.small_heading_font_family | default: 'font-handwritten' }} {{ section.settings.small_heading_font_size | default: 'text-lg' }} {{ section.settings.small_heading_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.small_heading_font_weight | default: 'font-normal' }} {{ section.settings.small_heading_color | default: 'text-white' }} italic">
              {{ section.settings.small_heading | default: "OTHER PLATFORMS DON'T GET THIS:" }}
            </p>
          </div>
          {% endif %}
          
          <!-- Main Statistic + Headline -->
          {% if section.settings.show_main_statistic %}
          <div class="main-statistic-wrapper mb-2xl">
            <h2 class="{{ section.settings.main_heading_font_family | default: 'font-primary' }} {{ section.settings.main_heading_font_size | default: 'text-4xl' }} {{ section.settings.main_heading_font_size_desktop | default: 'lg:text-7xl' }} {{ section.settings.main_heading_font_weight | default: 'font-black' }} {{ section.settings.main_heading_color | default: 'text-white' }} leading-tight">
              <span class="{{ section.settings.main_stat_color | default: 'text-tertiary' }}">{{ section.settings.main_statistic | default: "93%" }}</span> {{ section.settings.main_heading | default: "of every sale happens before checkout" }}
            </h2>
          </div>
          {% endif %}
          
          <!-- Description -->
          {% if section.settings.show_description %}
          <div class="description-wrapper mb-2xl">
            <p class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-lg' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-white' }} leading-relaxed max-w-4xl mx-auto">
              {{ section.settings.description | default: "Most platforms focus only on the transaction, but that's just one moment in a much longer relationship. We-Commerce is built to support people through the entire experience—from curiosity to confidence to sharing with others." }}
            </p>
          </div>
          {% endif %}
          
          <!-- Supporting Statistics (Blocks) -->
          {% if section.blocks.size > 0 %}
          <div class="supporting-stats-wrapper">
            {% assign block_count = section.blocks.size %}
            {% assign grid_cols = 'md:grid-cols-1' %}
            {% if block_count == 2 %}
              {% assign grid_cols = 'md:grid-cols-2' %}
            {% elsif block_count >= 3 %}
              {% assign grid_cols = 'md:grid-cols-3' %}
            {% endif %}
            
            <div class="stats-grid grid grid-cols-1 {{ grid_cols }} gap-xl lg:gap-2xl">
              {% for block in section.blocks %}
                {% case block.type %}
                  {% when 'statistic' %}
                    <div class="stat-item text-center" {{ block.fluid_attributes }}>
                      <div class="stat-number {{ section.settings.stat_number_font_family | default: 'font-handwritten' }} {{ section.settings.stat_number_font_size | default: 'text-5xl lg:text-6xl' }} font-bold {{ section.settings.stat_number_color | default: 'text-tertiary' }}">
                        {{ block.settings.number | default: "0%" }}
                      </div>
                      <div class="stat-text {{ section.settings.stat_text_font_family | default: 'font-body' }} {{ section.settings.stat_text_font_size | default: 'text-base lg:text-lg' }} font-normal {{ section.settings.stat_text_color | default: 'text-white' }} mt-sm">
                        {{ block.settings.description | default: "Add your statistic description here." }}
                      </div>
                    </div>
                {% endcase %}
              {% endfor %}
            </div>
          </div>
          {% endif %}
          
        </div>
        
      </div>
      
    </div>
  </div>
</section>

