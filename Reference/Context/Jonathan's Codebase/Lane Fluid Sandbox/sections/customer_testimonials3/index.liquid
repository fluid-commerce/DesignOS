{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="testimonial3-section section-t-spacing section-{{ section.id }}-padding" 
         style="background-color: {{ section.settings.background_color | default: '#f8f9fa' }};
                {% if section.settings.background_image != blank %}
                background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;
                {% endif %}
                position: relative;
                padding-bottom: {{ section.settings.padding_top }}px;">
  
  {% if section.settings.background_image != blank %}
    <div class="testimonials3-overlay" 
         style="background-color: {{ section.settings.overlay_color | default: '#000000' }}; 
                opacity: {{ section.settings.overlay_opacity | default: 40 | divided_by: 100.0 }}; 
                position: absolute; 
                top: 0; 
                left: 0; 
                width: 100%; 
                height: 100%; 
                z-index: 1;"></div>
  {% endif %}
  
  <div class="container" style="position: relative; z-index: 2;">
    <div class="header text-center mb-16 sm-desktop-mb-20">
      <h2 class="customer_testimonials3__heading {{ section.settings.heading_size }} mb-4" 
          style="color: {{ section.settings.heading_color | default: '#1a1a1a' }};">
        {{ section.settings.heading }}
      </h2>
      <p class="text-lg sm-desktop-text-xl max-w-2xl mx-auto" 
         style="color: {{ section.settings.intro_text_color | default: '#6b7280' }};">
        {{ section.settings.intro_text }}
      </p>
    </div>
  </div>

  <!-- Edge-to-edge scrolling container -->
  <div class="testimonials3-scroll-container" style="position: relative; z-index: 2;">
    <div class="testimonials3-scroll-track">
      <!-- First set of testimonials -->
      {% for i in (1..6) limit: section.settings.testimonials_to_show %}
        {% assign testimonial_text = 'testimonial_' | append: i | append: '_text' %}
        {% assign testimonial_name = 'testimonial_' | append: i | append: '_name' %}
        {% assign testimonial_position = 'testimonial_' | append: i | append: '_position' %}
        {% assign testimonial_image = 'testimonial_' | append: i | append: '_image' %}
        
        <div class="testimonial3-card" 
             style="background-color: {{ section.settings.card_background_color | default: '#ffffff' }};">
          
          <!-- Testimonial Text -->
          <div class="testimonial-content mb-8">
            <p class="text-md" 
               style="color: {{ section.settings.testimonial_text_color | default: '#374151' }};">
              {% if section.settings[testimonial_text] != blank %}
                "{{ section.settings[testimonial_text] }}"
              {% else %}
                "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare."
              {% endif %}
            </p>
          </div>

          <!-- Author Info -->
          <div class="author-info flex align-center gap-4">
            <div class="author-avatar">
              {% if section.settings[testimonial_image] != blank %}
                <img src="{{ section.settings[testimonial_image] | image_url: width: 96 }}" 
                     alt="{{ section.settings[testimonial_name] | default: 'Customer' }}"
                     class="avatar-image">
              {% else %}
                <div class="avatar-placeholder">
                  <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                  </svg>
                </div>
              {% endif %}
            </div>
            <div class="author-details">
              {% if section.settings.show_name %}
                <p class="text-md font-semibold mb-1" style="color: {{ section.settings.author_name_color | default: '#111827' }};">
                  {% if section.settings[testimonial_name] != blank %}
                    {{ section.settings[testimonial_name] }}
                  {% else %}
                    Name Surname
                  {% endif %}
                </p>
              {% endif %}
              {% if section.settings.show_position %}
                <p class="text-sm" style="color: {{ section.settings.author_position_color | default: '#6b7280' }};">
                  {% if section.settings[testimonial_position] != blank %}
                    {{ section.settings[testimonial_position] }}
                  {% else %}
                    Position, Company name
                  {% endif %}
                </p>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}

      <!-- Duplicate set for seamless loop -->
      {% for i in (1..6) limit: section.settings.testimonials_to_show %}
        {% assign testimonial_text = 'testimonial_' | append: i | append: '_text' %}
        {% assign testimonial_name = 'testimonial_' | append: i | append: '_name' %}
        {% assign testimonial_position = 'testimonial_' | append: i | append: '_position' %}
        {% assign testimonial_image = 'testimonial_' | append: i | append: '_image' %}
        
        <div class="testimonial3-card" 
             style="background-color: {{ section.settings.card_background_color | default: '#ffffff' }};">
          
          <!-- Testimonial Text -->
          <div class="testimonial-content mb-8">
            <p class="text-md" 
               style="color: {{ section.settings.testimonial_text_color | default: '#374151' }};">
              {% if section.settings[testimonial_text] != blank %}
                "{{ section.settings[testimonial_text] }}"
              {% else %}
                "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare."
              {% endif %}
            </p>
          </div>

          <!-- Author Info -->
          <div class="author-info flex align-center gap-4">
            <div class="author-avatar">
              {% if section.settings[testimonial_image] != blank %}
                <img src="{{ section.settings[testimonial_image] | image_url: width: 96 }}" 
                     alt="{{ section.settings[testimonial_name] | default: 'Customer' }}"
                     class="avatar-image">
              {% else %}
                <div class="avatar-placeholder">
                  <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                  </svg>
                </div>
              {% endif %}
            </div>
            <div class="author-details">
              {% if section.settings.show_name %}
                <p class="text-md font-semibold mb-1" style="color: {{ section.settings.author_name_color | default: '#111827' }};">
                  {% if section.settings[testimonial_name] != blank %}
                    {{ section.settings[testimonial_name] }}
                  {% else %}
                    Name Surname
                  {% endif %}
                </p>
              {% endif %}
              {% if section.settings.show_position %}
                <p class="text-sm" style="color: {{ section.settings.author_position_color | default: '#6b7280' }};">
                  {% if section.settings[testimonial_position] != blank %}
                    {{ section.settings[testimonial_position] }}
                  {% else %}
                    Position, Company name
                  {% endif %}
                </p>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
.testimonial3-section .testimonials3-scroll-container {
  overflow: hidden;
  position: relative;
  width: 100vw;
  margin-left: calc(-50vw + 50%);
  padding: 0 20px;
}

.testimonial3-section .testimonials3-scroll-track {
  display: flex;
  gap: 32px;
  animation: testimonials-scroll 60s linear infinite;
  width: max-content;
}

.testimonial3-section .testimonials3-scroll-track:hover {
  animation-play-state: paused;
}

@keyframes testimonials-scroll {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(-50%);
  }
}

.testimonial3-section .testimonial3-card {
  flex: 0 0 400px;
  padding: 40px 32px;
  border: 1px solid #e5e7eb;
  border-radius: 8px;
  background-color: #ffffff;
  display: flex;
  flex-direction: column;
  min-height: 280px;
}

.testimonial3-section .testimonial-content {
  flex: 1;
}

.testimonial3-section .author-info {
  margin-top: auto;
}

.testimonial3-section .avatar-image {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  object-fit: cover;
}

.testimonial3-section .avatar-placeholder {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background-color: #e5e5e5;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
}

@media (max-width: 959px) {
  .testimonial3-section .testimonial3-card {
    flex: 0 0 320px;
    padding: 32px 24px;
    min-height: 260px;
  }
  
  .testimonial3-section .testimonials3-scroll-track {
    gap: 24px;
    animation-duration: 50s;
  }
  
  .testimonial3-section .testimonials3-scroll-container {
    padding: 0 15px;
  }
}

@media (max-width: 767px) {
  .testimonial3-section .testimonial3-card {
    flex: 0 0 280px;
    padding: 28px 20px;
    min-height: 240px;
  }
  
  .testimonial3-section .testimonials3-scroll-track {
    gap: 20px;
    animation-duration: 45s;
  }
  
  .testimonial3-section .testimonials3-scroll-container {
    padding: 0 10px;
  }
}
</style>

