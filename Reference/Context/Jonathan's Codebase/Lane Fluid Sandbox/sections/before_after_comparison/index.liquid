<!-- Before/After Comparison Section -->
<section class="before-after-comparison section {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  <div class="container">
    <div class="inner-container {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_padding_y_mobile | default: 'py-xl' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-lg' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }} {{ section.settings.container_border_radius | default: 'rounded-none' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Before/After Comparison Grid -->
      <div class="comparison-grid grid grid-cols-1 lg:grid-cols-2 gap-0 items-stretch">
        
        <!-- Before Section (Left) -->
        <div class="before-section {{ section.settings.before_background_color | default: 'bg-neutral-light' }} {{ section.settings.before_padding | default: 'p-xl lg:p-3xl' }} {{ section.settings.before_text_alignment | default: 'text-left' }}">
          
          <!-- Before Label -->
          {% if section.settings.show_before_label %}
          <div class="before-label {{ section.settings.before_label_margin_bottom | default: 'mb-lg' }}">
            <span class="{{ section.settings.before_label_font_size | default: 'text-sm' }} {{ section.settings.before_label_font_weight | default: 'font-medium' }} {{ section.settings.before_label_color | default: 'text-neutral-dark' }} uppercase">
              {{ section.settings.before_label | default: 'Before' }}
            </span>
          </div>
          {% endif %}
          
          <!-- Before Heading -->
          {% if section.settings.before_heading != blank %}
          <h3 class="{{ section.settings.before_heading_font_family | default: 'font-primary' }} {{ section.settings.before_heading_font_size | default: 'text-2xl' }} {{ section.settings.before_heading_font_size_desktop | default: 'lg:text-4xl' }} {{ section.settings.before_heading_font_weight | default: 'font-bold' }} {{ section.settings.before_heading_color | default: 'text-black' }} {{ section.settings.before_heading_line_height | default: 'leading-tight' }} {{ section.settings.before_heading_margin_bottom | default: 'mb-lg' }}">
            {{ section.settings.before_heading }}
          </h3>
          {% endif %}
          
          <!-- Before Description -->
          {% if section.settings.before_description != blank %}
          <div class="before-description {{ section.settings.before_description_margin_bottom | default: 'mb-xl' }}">
            <p class="{{ section.settings.before_description_font_size | default: 'text-base' }} {{ section.settings.before_description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.before_description_line_height | default: 'leading-relaxed' }} {{ section.settings.before_description_color | default: 'text-neutral-dark' }}">
              {{ section.settings.before_description }}
            </p>
          </div>
          {% endif %}
          
          <!-- Before Image/Video -->
          {% if section.settings.before_media_type == 'video' and section.settings.before_video != blank %}
          <div class="before-media-wrapper {{ section.settings.before_image_margin_top | default: 'mt-xl' }}">
            <div class="video-wrapper {{ section.settings.before_image_border_radius | default: 'rounded-lg' }} overflow-hidden">
              <video 
                class="w-full h-auto"
                {% if section.settings.before_video_autoplay %}autoplay{% endif %}
                {% if section.settings.before_video_loop %}loop{% endif %}
                {% if section.settings.before_video_muted %}muted{% endif %}
                {% if section.settings.before_video_controls %}controls{% endif %}
                {% if section.settings.before_video_poster and section.settings.before_video_poster != blank %}poster="{{ section.settings.before_video_poster | image_url }}"{% endif %}
                preload="metadata">
                <source src="{{ section.settings.before_video }}" type="video/mp4">
                Your browser does not support the video tag.
              </video>
            </div>
          </div>
          {% elsif section.settings.before_image != blank %}
          <div class="before-media-wrapper {{ section.settings.before_image_margin_top | default: 'mt-xl' }}">
            <img src="{{ section.settings.before_image | image_url: width: 600 }}"
                 alt="{{ section.settings.before_image_alt | default: 'Before image' }}"
                 class="w-full h-auto {{ section.settings.before_image_border_radius | default: 'rounded-lg' }}"
                 loading="lazy">
          </div>
          {% endif %}
          
        </div>
        
        <!-- After Section (Right) -->
        <div class="after-section {{ section.settings.after_background_color | default: 'bg-black' }} {{ section.settings.after_padding | default: 'p-xl lg:p-3xl' }} {{ section.settings.after_text_alignment | default: 'text-left' }}">
          
          <!-- After Label -->
          {% if section.settings.show_after_label %}
          <div class="after-label {{ section.settings.after_label_margin_bottom | default: 'mb-lg' }}">
            <span class="{{ section.settings.after_label_font_size | default: 'text-sm' }} {{ section.settings.after_label_font_weight | default: 'font-medium' }} {{ section.settings.after_label_color | default: 'text-white' }} uppercase">
              {{ section.settings.after_label | default: 'After' }}
            </span>
          </div>
          {% endif %}
          
          <!-- After Heading -->
          {% if section.settings.after_heading != blank %}
          <h3 class="{{ section.settings.after_heading_font_family | default: 'font-primary' }} {{ section.settings.after_heading_font_size | default: 'text-2xl' }} {{ section.settings.after_heading_font_size_desktop | default: 'lg:text-4xl' }} {{ section.settings.after_heading_font_weight | default: 'font-bold' }} {{ section.settings.after_heading_color | default: 'text-white' }} {{ section.settings.after_heading_line_height | default: 'leading-tight' }} {{ section.settings.after_heading_margin_bottom | default: 'mb-lg' }}">
            {{ section.settings.after_heading }}
          </h3>
          {% endif %}
          
          <!-- After Description -->
          {% if section.settings.after_description != blank %}
          <div class="after-description {{ section.settings.after_description_margin_bottom | default: 'mb-xl' }}">
            <p class="{{ section.settings.after_description_font_size | default: 'text-base' }} {{ section.settings.after_description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.after_description_line_height | default: 'leading-relaxed' }} {{ section.settings.after_description_color | default: 'text-white' }}">
              {{ section.settings.after_description }}
            </p>
          </div>
          {% endif %}
          
          <!-- After Image/Video -->
          {% if section.settings.after_media_type == 'video' and section.settings.after_video != blank %}
          <div class="after-media-wrapper {{ section.settings.after_image_margin_top | default: 'mt-xl' }}">
            <div class="video-wrapper {{ section.settings.after_image_border_radius | default: 'rounded-lg' }} overflow-hidden">
              <video 
                class="w-full h-auto"
                playsinline
                {% if section.settings.after_video_autoplay %}autoplay{% endif %}
                {% if section.settings.after_video_loop %}loop{% endif %}
                {% if section.settings.after_video_muted %}muted{% endif %}
                {% if section.settings.after_video_controls %}controls{% endif %}
                {% if section.settings.after_video_poster and section.settings.after_video_poster != blank %}poster="{{ section.settings.after_video_poster | image_url }}"{% endif %}
                preload="auto">
                
                <source src="{{ section.settings.after_video }}" type="video/mp4">
                Your browser does not support the video tag.
              </video>
            </div>
          </div>
          {% elsif section.settings.after_image != blank %}
          <div class="after-media-wrapper {{ section.settings.after_image_margin_top | default: 'mt-xl' }}">
            <img src="{{ section.settings.after_image | image_url: width: 600 }}"
                 alt="{{ section.settings.after_image_alt | default: 'After image' }}"
                 class="w-full h-auto {{ section.settings.after_image_border_radius | default: 'rounded-lg' }}"
                 loading="lazy">
          </div>
          {% endif %}
          
        </div>
        
      </div>
      
    </div>
  </div>
</section>

