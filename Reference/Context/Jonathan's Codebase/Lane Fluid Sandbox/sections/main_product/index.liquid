                <path d="M47.2567 1.43519C47.5317 0.78202 48.4683 0.782021 48.7433 1.43519L50.3663 5.29031C50.4823 5.56567 50.7445 5.75381 51.0454 5.77764L55.2582 6.11131C55.9719 6.16784 56.2614 7.04783 55.7175 7.50805L52.5079 10.2243C52.2786 10.4183 52.1784 10.7228 52.2485 11.0128L53.2291 15.0741C53.3952 15.7622 52.6375 16.3062 52.0264 15.9374L48.4196 13.761C48.162 13.6055 47.838 13.6055 47.5804 13.761L43.9736 15.9374C43.3625 16.3062 42.6048 15.7622 42.7709 15.0741L43.7515 11.0128C43.8216 10.7228 43.7215 10.4183 43.4922 10.2243L40.2825 7.50805C39.7386 7.04783 40.0281 6.16784 40.7418 6.11131L44.9547 5.77764C45.2556 5.75381 45.5177 5.56567 45.6337 5.29031L47.2567 1.43519Z" fill="black"/>
                <path d="M69.9056 5.48442L69.9055 5.48432L68.2825 1.6292C68.1793 1.38401 67.8208 1.38402 67.7175 1.6292L66.0945 5.48432C65.9051 5.93417 65.479 6.23769 64.9942 6.27608L60.7813 6.60975C60.5019 6.63188 60.4106 6.96145 60.6054 7.12637C60.6054 7.12637 60.6054 7.12637 60.6054 7.12637L63.8152 9.84259L63.8152 9.84263C64.1876 10.1578 64.3524 10.6548 64.2376 11.1302C64.2376 11.1302 64.2376 11.1302 64.2376 11.1302L63.2569 15.1915C63.199 15.4314 63.4698 15.6574 63.7153 15.5093L69.9056 5.48442ZM69.9056 5.48442C70.095 5.93417 70.5211 6.23769 71.0059 6.27608L75.2187 6.60975C75.4981 6.63188 75.5894 6.96145 75.3946 7.12638L72.1849 9.8426L72.1848 9.84263C71.8125 10.1578 71.6476 10.6548 71.7624 11.1302L72.7431 15.1915C72.801 15.4314 72.5302 15.6574 72.2848 15.5093C72.2847 15.5093 72.2847 15.5093 72.2847 15.5093L68.678 13.3329L69.9056 5.48442ZM67.3221 13.3329L63.7153 15.5093L68.678 13.3329C68.2615 13.0816 67.7386 13.0816 67.3221 13.3329C67.3221 13.3329 67.3221 13.3329 67.3221 13.3329Z" fill="black" stroke="black"/>
                <path fill-rule="evenodd" clip-rule="evenodd" d="M95.9144 6.55648L95.9782 6.75648C96.0307 6.90743 95.9865 7.0752 95.8665 7.18048L91.9892 10.5005L93.138 15.4765C93.1769 15.6355 93.1172 15.8025 92.9864 15.9005L92.8109 16.0205C92.7427 16.0741 92.6582 16.1023 92.5716 16.1005C92.4985 16.102 92.4266 16.0826 92.3642 16.0445L88.0002 13.3805L83.6601 16.0445C83.5977 16.0826 83.5257 16.102 83.4527 16.1005C83.3661 16.1023 83.2815 16.0741 83.2133 16.0205L83.0139 15.9005C82.8831 15.8025 82.8234 15.6355 82.8623 15.4765L84.0111 10.5005L80.1418 7.18848C80.0156 7.08382 79.9678 6.9114 80.0221 6.75648L80.1099 6.55648C80.1565 6.39842 80.2968 6.28652 80.4609 6.27648L85.5589 5.86848L87.5135 1.15648C87.5761 0.999996 87.7283 0.898266 87.8965 0.90048H88.1039C88.2705 0.896934 88.4211 0.999718 88.4788 1.15648L90.4654 5.86848L95.5634 6.27648C95.7275 6.28652 95.8677 6.39842 95.9144 6.55648ZM91.2871 13.7485L90.3936 10.0045L93.3215 7.50048L89.4841 7.19648L88.0002 3.62848V11.7405L91.2871 13.7485Z" fill="black"/>
                </g>
                <defs>
                <clipPath id="clip0_506_132013">
                <rect width="96" height="15.2002" fill="white" transform="translate(0 0.900391)"/>
                </clipPath>
                </defs>
              </svg>
              <span class="{{ section.settings.rating_font_size_mobile | default: 'text-sm' }} {{ section.settings.rating_font_size_desktop | default: 'text-base' }}" style="color: {{ section.settings.rating_text_color | default: '#6b7280' }}; font-weight: {{ section.settings.rating_font_weight | default: 400 }};">({{ 'product.stars' | t: stars: '3.5' }}) • {{ 'product.reviews' | t: reviews: '10' }}</span>
            </div>

            <p class="{{ section.settings.description_font_size_mobile | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'text-lg' }}" style="color: {{ section.settings.description_color | default: '#666666' }}; font-weight: {{ section.settings.description_font_weight | default: 400 }};">
              {{ product.feature_text }}
            </p>
            <div class="error-messages-container">
              {% if product.out_of_stock %}
                <div class="error-message {{ section.settings.error_message_font_size | default: 'text-sm' }}">
                  {{ section.settings.out_of_stock_message | default: 'This product is out of stock' }}
                </div>
              {% endif %}
            </div>
            <div class='subscribe'>
              {% if allow_subscription %}
                <div class="subscribe-item flex flex-col gap-4">
                  <div class='subscribe-option flex gap-2 align-center'>
                    {% if subscription_only %}
                      <input
                        type='radio'
                        checkbox
                        name='fluid-checkout-subscribe'
                        value='subscription'
                        id='subscribe-and-save'
                        checked=''
                      >
                    {% else %}
                      <input
                        type='radio'
                        checkbox
                        name='fluid-checkout-subscribe'
                        value='subscription'
                        id='subscribe-and-save'
                        {% if request.query_parameters.subscribe %}
                          checked
                        {% endif %}
                      >
                    {% endif %}
                    <label for='subscribe-and-save' class="flex-1 pt-1">
                      <div class='flex justify-between w-full align-center'>
                        <span>{{ 'product.subscribe' | t }}</span>
                        <p class='purchase-price {{ section.settings.price_font_size_mobile | default: 'text-2xl' }} md:{{ section.settings.price_font_size_desktop | default: 'text-3xl' }} subscription-price' style="color: {{ section.settings.price_color | default: '#000000' }}; font-weight: {{ section.settings.price_font_weight | default: 700 }};">{{ product.subscription_price }}</p>
                      </div>
                    </label>
                  </div>
                  <ul class="subscribe-features flex flex-col gap-1 pl-2">
                    {% assign saved_percentage = product.saved_percentage_on_subscription | plus: 0 %}
                      {% if saved_percentage > 1 %}
                        <li class="flex align-center gap-3">
                          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M0 12C0 5.37258 5.37258 0 12 0C18.6274 0 24 5.37258 24 12C24 18.6274 18.6274 24 12 24C5.37258 24 0 18.6274 0 12Z" fill="#DCFAE6"></path>
                            <path fill-rule="evenodd" clip-rule="evenodd" d="M17.0964 7.39016L9.93641 14.3002L8.03641 12.2702C7.68641 11.9402 7.13641 11.9202 6.73641 12.2002C6.34641 12.4902 6.23641 13.0002 6.47641 13.4102L8.72641 17.0702C8.94641 17.4102 9.32641 17.6202 9.75641 17.6202C10.1664 17.6202 10.5564 17.4102 10.7764 17.0702C11.1364 16.6002 18.0064 8.41016 18.0064 8.41016C18.9064 7.49016 17.8164 6.68016 17.0964 7.38016V7.39016Z" fill="#079455"></path>
                          </svg>
                          <span>
                            {{ 'subscribe_feature.subscribe_and_save' | t: save: product.saved_percentage_on_subscription }}
                          </span>
                        </li>
                    {% endif %}
                    <li class="flex align-center gap-3">
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M0 12C0 5.37258 5.37258 0 12 0C18.6274 0 24 5.37258 24 12C24 18.6274 18.6274 24 12 24C5.37258 24 0 18.6274 0 12Z" fill="#DCFAE6"></path>
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M17.0964 7.39016L9.93641 14.3002L8.03641 12.2702C7.68641 11.9402 7.13641 11.9202 6.73641 12.2002C6.34641 12.4902 6.23641 13.0002 6.47641 13.4102L8.72641 17.0702C8.94641 17.4102 9.32641 17.6202 9.75641 17.6202C10.1664 17.6202 10.5564 17.4102 10.7764 17.0702C11.1364 16.6002 18.0064 8.41016 18.0064 8.41016C18.9064 7.49016 17.8164 6.68016 17.0964 7.38016V7.39016Z" fill="#079455"></path>
                      </svg>
                      <span>{{'subscribe_feature.update_subscription' | t }}</span>
                    </li>
                  </ul>

                  {% if product.subscription_plans.size > 1 %}
                    <div class="subscription-plans" {% unless request.query_parameters.subscribe %}style="display: none;"{% endunless %}>
                      <div class='flex flex-col gap-2 custom-select-dropdown product-variant-item'>
                        <p class="{{ section.settings.form_label_font_size_mobile | default: 'text-base' }} md:{{ section.settings.form_label_font_size_desktop | default: 'text-lg' }}" style="color: {{ section.settings.form_label_color | default: '#374151' }}; font-weight: {{ section.settings.form_label_font_weight | default: 500 }};">Subscription Plan</p>

                        <select class='subscription-plans-dropdown option-value custom-select'>
                          {% for subscription_plan in product.subscription_plans%}
                            <option {% if subscription_plan.selected %}selected{% endif %} value='{{ subscription_plan.id }}' data-subscription-price="{{ subscription_plan.display_subscription_price }}">{{ subscription_plan.name }}</option>
                          {% endfor %}
                        </select>
                      </div>
                    </div>
                  {% endif %}
                </div>
              {% endif %}
              {% unless subscription_only %}
                <div class="one-time-purchase-section subscribe-item">
                  <div class='subscribe-option flex gap-2 align-center'>
                    <input
                      type='radio'
                      checkbox
                      name='fluid-checkout-subscribe'
                      value='regular'
                      id='one-time-purchase'
                      {% unless request.query_parameters.subscribe %}
                        checked
                      {% endunless %}
                    >
                    <label for='one-time-purchase' class="flex-1 cursor-pointer pt-1">
                      <div class='flex justify-between w-full align-center'>
                        <span>{{ 'product.one_time_purchase' | t }}</span>
                        <p class='purchase-price {{ section.settings.price_font_size_mobile | default: 'text-lg' }} md:{{ section.settings.price_font_size_desktop | default: 'text-lg' }}' style="color: {{ section.settings.price_color | default: '#000000' }}; font-weight: {{ section.settings.price_font_weight | default: 500 }};">{{ product.price }}</p>
                      </div>
                    </label>
                  </div>
                </div>
              {% endunless %}
            </div>

            {% for option in product.options_with_values %}
              <div class="product-drodpown-section flex flex-col gap-2">
                <p class="{{ section.settings.form_label_font_size_mobile | default: 'text-base' }} {{ section.settings.form_label_font_size_desktop | default: 'text-lg' }}" style="color: {{ section.settings.form_label_color | default: '#374151' }}; font-weight: {{ section.settings.form_label_font_weight | default: 500 }};">{{ option.name }}</p>
                <select name="fluid-checkout-option-{{ option.option_id }}" id="" class="custom-select variation-dropdown">
                  {% for value in option.values %}
                    <option value="{{ value.id }}" {% if value.selected %}selected{% endif %}>{{ value.name }}</option>
                  {% endfor %}
                </select>
              </div>
            {% endfor %}

            {% unless not_purchasable %}
              <div class="product-quantity-section flex flex-col gap-2">
                <p class="{{ section.settings.form_label_font_size_mobile | default: 'text-base' }} {{ section.settings.form_label_font_size_desktop | default: 'text-lg' }}" style="color: {{ section.settings.form_label_color | default: '#374151' }}; font-weight: {{ section.settings.form_label_font_weight | default: 500 }};">{{ 'product.quantity' | t }}</p>
                <div class="input-section">
                  <input type="number" value="1" {% if product.buyable_quantity %}max="{{ product.buyable_quantity }}"{% endif %} class="quantity-input-field" name="quantity"  id="fluid-checkout-quantity" min="0">
                </div>
              </div>

              <div class="btn-section flex flex-col gap-y-4">
                <button
                  class="btn btn-bg-primary w-full"
                  type="button"
                  data-fluid-add-to-cart="{{ selected_variant_id }}"
                  data-fluid-quantity="1"
                  {% if request.query_parameters.subscribe or product.subscription_only %}
                    data-fluid-subscription-plan-id="{{ product.selected_subscription_plan_id }}"
                  {% endif %}
                  >
                  {{ 'product.add_to_cart' | t }}
                </button>
                <p class="{{ section.settings.free_shipping_font_size | default: 'text-sm' }} text-center" style="color: {{ section.settings.free_shipping_text_color | default: '#6b7280' }}; font-weight: {{ section.settings.free_shipping_font_weight | default: 400 }};">{{ 'product.free_shipping' | t: amount: '$50' }}</p>
              </div>
            {% endunless %}
          </div>

          <div class="product-info-section">
            <ul>
              <li class="accordion-item">
                <div class="accordion-header active cursor-pointer flex flex-wrap align-center py-4">
                  <div class="heading">
                    <h5 class="{{ section.settings.accordion_header_font_size | default: 'text-lg' }}">{{ 'product.details' | t }}</h5>
                  </div>
                  <div class="icon flex align-center justify-center">
                    <svg width="24" height="25" viewBox="0 0 24 25" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path fill-rule="evenodd" clip-rule="evenodd" d="M11.6018 9.36784C11.8215 9.14817 12.1776 9.14817 12.3973 9.36784L18.1321 15.1027C18.3518 15.3224 18.3518 15.6785 18.1321 15.8982L17.867 16.1634C17.6473 16.383 17.2911 16.383 17.0715 16.1634L11.9995 11.0914L6.92759 16.1634C6.70791 16.383 6.35181 16.383 6.13214 16.1634L5.86694 15.8982C5.64726 15.6785 5.64726 15.3224 5.86694 15.1027L11.6018 9.36784Z" fill="black"/>
                    </svg>
                  </div><!-- .icon -->
                </div>
                <div class="accordion-content pb-5 sm-desktop-pb-6 {{ section.settings.accordion_content_font_size | default: 'text-base' }}">
                  {{ product.description }}
                </div>
              </li>
              <li class="accordion-item">
                <div class="accordion-header cursor-pointer flex flex-wrap align-center py-4">
                  <div class="heading">
                    <h5 class="{{ section.settings.accordion_header_font_size | default: 'text-lg' }}">{{ 'product.shipping' | t }}</h5>
                  </div>
                  <div class="icon flex align-center justify-center">
                    <svg width="24" height="25" viewBox="0 0 24 25" fill="none" xmlns="http://www.w3.org/2000/svg">
