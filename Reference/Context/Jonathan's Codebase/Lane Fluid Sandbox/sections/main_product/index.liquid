

{% assign not_purchasable = product.out_of_stock || product.available_for_country != true || product.active != true %}

{%- style -%}
  .product-detail-page-section-{{ section.id }} {
    background-color: {{ section.settings.section_background_color | default: '#ffffff' }};
    padding-top: {{ section.settings.padding_top_mobile | default: 24 }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile | default: 24 }}px;
  }

  @media (min-width: 768px) {
    .product-detail-page-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_desktop | default: 80 }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop | default: 80 }}px;
    }
  }

 

  .subscribe-option input[type="radio"]:checked {
    background-color: {{ section.settings.radio_button_checked_color | default: '#000000' }};
    border-color: {{ section.settings.radio_button_checked_color | default: '#000000' }} !important;
    accent-color: {{ section.settings.radio_button_checked_color | default: '#000000' }} !important;
  }

  .subscribe-option label {
    color: {{ section.settings.radio_label_color | default: '#374151' }};
    font-weight: {{ section.settings.radio_label_font_weight | default: 500 }};
  }

  /* Button styling */
  .btn.btn-bg-primary,button.btn-bg-primary.btn {
    background-color: {{ section.settings.button_background_color | default: '#000000' }} !important;
    color: {{ section.settings.button_text_color | default: '#ffffff' }} !important;
    font-weight: {{ section.settings.button_font_weight | default: 600 }} !important;
  }

  /* Breadcrumb styling */
  .breadcrumb a {
    color: {{ section.settings.breadcrumb_link_color | default: '#6b7280' }};
    font-weight: {{ section.settings.breadcrumb_font_weight | default: 400 }};
  }

  .breadcrumb .active {
    color: {{ section.settings.breadcrumb_active_color | default: '#1f2937' }};
  }

  /* Error message styling */
  .error-message {
    background-color: {{ section.settings.error_message_background_color | default: '#fee2e2' }};
    color: {{ section.settings.error_message_text_color | default: '#dc2626' }};
    font-weight: {{ section.settings.error_message_font_weight | default: 500 }};
    padding: 12px;
    border-radius: 6px;
    margin: 8px 0;
  }

  /* Input field styling */
  .custom-select, .quantity-input-field {
    background-color: {{ section.settings.input_background_color | default: '#ffffff' }};
    border-color: {{ section.settings.input_border_color | default: '#d1d5db' }};
    color: {{ section.settings.input_text_color | default: '#374151' }};
  }

  .custom-select:focus, .quantity-input-field:focus {
    border-color: {{ section.settings.input_focus_border_color | default: '#3b82f6' }};
  }

  /* Accordion styling */
  .accordion-header {
    background-color: {{ section.settings.accordion_header_background_color | default: '#f9fafb' }};
    color: {{ section.settings.accordion_header_text_color | default: '#1f2937' }};
    font-weight: {{ section.settings.accordion_header_font_weight | default: 600 }};
  }

  .accordion-content {
    background-color: {{ section.settings.accordion_content_background_color | default: '#ffffff' }};
    color: {{ section.settings.accordion_content_text_color | default: '#4b5563' }};
    font-weight: {{ section.settings.accordion_content_font_weight | default: 400 }};
  }
{%- endstyle -%}

<main class="product-detail-page-section product-detail-page-section-{{ section.id }}">
  {% if section.settings.show_breadcrumb%}
    <div class="breadcrumb">
      <div class="container">
        <ul class="flex flex-wrap align-center gap-2 {{ section.settings.breadcrumb_font_size | default: 'text-sm' }}">
          <li class="flex gap-2 align-center">
            <a href="{{ company.shop_page_url }}">{{ 'product.shop_all' | t }}</a>
            <span class="seperator">
              <svg width="6" height="8" viewBox="0 0 6 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1.47099 7.79976L5.27565 3.9951L1.47099 0.19043L0.52832 1.1331L3.39032 3.9951L0.52832 6.8571L1.47099 7.79976Z" fill="black"/>
              </svg>
            </span>
          </li>
          {% comment %} <li  class="flex gap-2 align-center">
            <a href="#">Category</a>
            <span class="seperator">
              <svg width="6" height="8" viewBox="0 0 6 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1.47099 7.79976L5.27565 3.9951L1.47099 0.19043L0.52832 1.1331L3.39032 3.9951L0.52832 6.8571L1.47099 7.79976Z" fill="black"/>
              </svg>
            </span>
          </li> {% endcomment %}
          <li>
            <a href="#" class="active font-semibold">{{ product.title }}</a>
          </li>
        </ul>
      </div>
    </div>
  {% endif%}
  <section class="product-details-section pt-6">
    <div class="container">
      <div class="grid grid-cols-1 sm-desktop-grid-cols-2 gap-x-16 gap-y-8">
        <div class="image-section sm-desktop-flex flex-wrap">
          <div class="thumbnail-section hidden sm-desktop-block">
            <div id="thumbnail-carousel" class="splide">
              <div class="splide__track">
                <ul class="splide__list splide-list">
                  {% for image in product.images %}
                    <li class="splide__slide">
                      <img src="{{ image.src }}" class="image-cover"/>
                    </li>
                  {% endfor %}
                </ul>
              </div>
            </div>
          </div><!-- thumbnail-section -->
          <div class="main-carousel-section sm-desktop-pl-4">
            <div  class="splide" id="main-carousel">
              <div class="splide__track">
                <ul class="splide__list splide-list">
                  {% for image in product.images %}
                    <li class="splide__slide">
                      <img src="{{ image.src }}" class="image-cover"/>
                    </li>
                  {% endfor %}
                </ul>
              </div>

            </div>
          </div><!-- main-carousel-section -->
        </div><!-- .image-section -->

        {% form 'product', product, class: 'product-details ', id: 'product-form' %}
          <div class="product-title {{ section.settings.product_title_font_size_mobile | default: 'text-2xl' }} {{ section.settings.product_title_font_size_desktop | default: 'text-3xl' }}" style="color: {{ section.settings.product_title_color | default: '#000000' }}; font-weight: {{ section.settings.product_title_font_weight | default: 700 }};">{{ product.title }}</div>
          <div class="description flex flex-col gap-y-6 pt-2 pb-8">
            <div class="rating-section flex flex-wrap align-center leading-none gap-2">
              <svg width="96" height="17" viewBox="0 0 96 17" fill="none" xmlns="http://www.w3.org/2000/svg">
                <g clip-path="url(#clip0_506_132013)">
                <path d="M7.25672 1.43519C7.53172 0.78202 8.46832 0.782021 8.74332 1.43519L10.3663 5.29031C10.4823 5.56567 10.7445 5.75381 11.0454 5.77764L15.2582 6.11131C15.9719 6.16784 16.2614 7.04783 15.7175 7.50805L12.5079 10.2243C12.2786 10.4183 12.1784 10.7228 12.2485 11.0128L13.2291 15.0741C13.3952 15.7622 12.6375 16.3062 12.0264 15.9374L8.41965 13.761C8.16202 13.6055 7.83802 13.6055 7.5804 13.761L3.9736 15.9374C3.3625 16.3062 2.60477 15.7622 2.77091 15.0741L3.75155 11.0128C3.82159 10.7228 3.72147 10.4183 3.49221 10.2243L0.28245 7.50805C-0.261375 7.04783 0.0280544 6.16784 0.741835 6.11131L4.9547 5.77764C5.25561 5.75381 5.51774 5.56567 5.63367 5.29031L7.25672 1.43519Z" fill="black"/>
