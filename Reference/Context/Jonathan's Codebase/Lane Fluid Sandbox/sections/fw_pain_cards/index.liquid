<link rel="stylesheet" href="{{ 'fw_pain_cards/styles.css' | asset_url }}">

<section class="fw-pain-cards-section {{ section.settings.background_color }} {{ section.settings.section_padding_y_mobile }} {{ section.settings.section_padding_y_desktop }} {{ section.settings.section_border_radius }}"
  {% if section.settings.background_image != blank %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  <div class="fw-pain-cards-container {{ section.settings.container_background_color }} {{ section.settings.container_border_radius }} {{ section.settings.container_padding_y_mobile }} {{ section.settings.container_padding_y_desktop }} {{ section.settings.container_padding_x_mobile }} {{ section.settings.container_padding_x_desktop }}"
    {% if section.settings.container_background_image != blank %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>

    {% if section.settings.eyebrow != blank or section.settings.headline != blank or section.settings.subtext != blank %}
    <div class="fw-pain-cards-header text-center">

      {% if section.settings.show_accent_bar %}
      <div class="fw-pain-cards-accent-bar mb-lg">
        {% if section.settings.accent_bar_image != blank %}
        <img src="{{ section.settings.accent_bar_image | image_url }}" alt="" class="fw-accent-bar-img" aria-hidden="true">
        {% else %}
        <div class="fw-accent-bar-fallback"></div>
        {% endif %}
      </div>
      {% endif %}

      {% if section.settings.eyebrow != blank %}
      <p class="fw-pain-cards-eyebrow {{ section.settings.eyebrow_font_family }} {{ section.settings.eyebrow_font_size }} {{ section.settings.eyebrow_font_size_desktop }} {{ section.settings.eyebrow_font_weight }} {{ section.settings.eyebrow_color }} mb-md">
        {{ section.settings.eyebrow }}
      </p>
      {% endif %}

      {% if section.settings.headline != blank %}
      <h2 class="fw-pain-cards-headline {{ section.settings.headline_font_family }} {{ section.settings.headline_font_size }} {{ section.settings.headline_font_size_desktop }} {{ section.settings.headline_font_weight }} {{ section.settings.headline_color }} mb-md">
        {{ section.settings.headline }}
      </h2>
      {% endif %}

      {% if section.settings.subtext != blank %}
      <p class="fw-pain-cards-subtext {{ section.settings.subtext_font_family }} {{ section.settings.subtext_font_size }} {{ section.settings.subtext_font_size_desktop }} {{ section.settings.subtext_font_weight }} {{ section.settings.subtext_color }} mb-2xl">
        <em>{{ section.settings.subtext }}</em>
      </p>
      {% endif %}

    </div>
    {% endif %}

    {% if section.blocks.size > 0 %}
    <div class="fw-pain-cards-grid fw-pain-cards-grid--{{ section.settings.grid_columns }}">
      {% for block in section.blocks %}
        {% if block.type == 'pain_card' %}
        <div class="fw-pain-card" {{ block.fluid_attributes }}>

          {% if block.settings.card_number != blank %}
          <span class="fw-pain-card-number">{{ block.settings.card_number }}</span>
          {% endif %}

          {% if block.settings.card_title != blank %}
          <h3 class="fw-pain-card-title {{ block.settings.card_title_font_family }} {{ block.settings.card_title_font_size }} {{ block.settings.card_title_font_size_desktop }} {{ block.settings.card_title_font_weight }} {{ block.settings.card_title_color }}">
            {{ block.settings.card_title }}
          </h3>
          {% endif %}

          {% if block.settings.card_body != blank %}
          <p class="fw-pain-card-body {{ block.settings.card_body_font_family }} {{ block.settings.card_body_font_size }} {{ block.settings.card_body_font_size_desktop }} {{ block.settings.card_body_font_weight }} {{ block.settings.card_body_color }}">
            {{ block.settings.card_body }}
          </p>
          {% endif %}

        </div>
        {% endif %}
      {% endfor %}
    </div>
    {% endif %}

    {% if section.settings.closing_headline != blank or section.settings.closing_body != blank %}
    <div class="fw-pain-cards-closing">

      {% if section.settings.closing_headline != blank %}
      <h3 class="fw-pain-cards-closing-headline {{ section.settings.closing_headline_font_family }} {{ section.settings.closing_headline_font_size }} {{ section.settings.closing_headline_font_size_desktop }} {{ section.settings.closing_headline_font_weight }} {{ section.settings.closing_headline_color }} mb-md">
        {{ section.settings.closing_headline }}
      </h3>
      {% endif %}

      {% if section.settings.closing_body != blank %}
      <p class="fw-pain-cards-closing-body {{ section.settings.closing_body_font_family }} {{ section.settings.closing_body_font_size }} {{ section.settings.closing_body_font_size_desktop }} {{ section.settings.closing_body_font_weight }} {{ section.settings.closing_body_color }}">
        {{ section.settings.closing_body }}
      </p>
      {% endif %}

    </div>
    {% endif %}

  </div>
</section>

