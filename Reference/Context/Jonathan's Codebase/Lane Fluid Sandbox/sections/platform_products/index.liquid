<!-- Platform Products Section -->
<link rel="stylesheet" href="{{ 'platform_products/styles.css' | asset_url }}">

<section class="platform-products-section {{ section.settings.background_color }} {{ section.settings.section_padding_y_mobile }} {{ section.settings.section_padding_y_desktop }}">
  <div class="container">
    
    <!-- Section Header -->
    {% if section.settings.show_header %}
    <div class="platform-header {{ section.settings.header_alignment }} mb-3xl">
      {% if section.settings.show_tagline and section.settings.tagline != blank %}
      <span class="platform-tagline {{ section.settings.tagline_font_family }} {{ section.settings.tagline_font_size }} {{ section.settings.tagline_font_size_desktop }} {{ section.settings.tagline_font_weight }} {{ section.settings.tagline_color }} mb-md block">
        {{ section.settings.tagline }}
      </span>
      {% endif %}
      
      {% if section.settings.heading != blank %}
      <h2 class="platform-heading {{ section.settings.heading_font_family }} {{ section.settings.heading_font_size }} {{ section.settings.heading_font_size_desktop }} {{ section.settings.heading_font_weight }} {{ section.settings.heading_color }} mb-lg">
        {{ section.settings.heading }}
      </h2>
      {% endif %}
      
      {% if section.settings.description != blank %}
      <p class="platform-description {{ section.settings.description_font_family }} {{ section.settings.description_font_size }} {{ section.settings.description_font_size_desktop }} {{ section.settings.description_font_weight }} {{ section.settings.description_color }} max-w-3xl {% if section.settings.header_alignment == 'text-center' %}mx-auto{% endif %}">
        {{ section.settings.description }}
      </p>
      {% endif %}
    </div>
    {% endif %}
    
    <!-- Products Grid -->
    <div class="platform-products-grid grid grid-cols-1 lg:grid-cols-3 {{ section.settings.gap }}">
      {% for block in section.blocks %}
        {% if block.type == 'product_card' %}
        <div class="platform-product-card {{ block.settings.card_background_color }} {{ section.settings.card_border_radius }} {{ section.settings.card_padding }}" {{ block.fluid_attributes }}>
          
          <!-- Product Image/Icon -->
          {% if block.settings.product_image != blank %}
          <div class="platform-product-image mb-lg">
            <img src="{{ block.settings.product_image | image_url }}" alt="{{ block.settings.title }}" class="product-img">
          </div>
          {% endif %}
          
          <!-- Product Title -->
          {% if block.settings.title != blank %}
          <h3 class="platform-product-title {{ section.settings.card_title_font_family }} {{ section.settings.card_title_font_size }} {{ section.settings.card_title_font_size_desktop }} {{ section.settings.card_title_font_weight }} {{ block.settings.title_color }} mb-md">
            {{ block.settings.title }}
          </h3>
          {% endif %}
          
          <!-- Product Description -->
          {% if block.settings.description != blank %}
          <p class="platform-product-description {{ section.settings.card_description_font_family }} {{ section.settings.card_description_font_size }} {{ section.settings.card_description_font_size_desktop }} {{ section.settings.card_description_font_weight }} {{ block.settings.description_color }}">
            {{ block.settings.description }}
          </p>
          {% endif %}
          
          <!-- Optional Link -->
          {% if block.settings.show_link and block.settings.link_url != blank %}
          <a href="{{ block.settings.link_url }}" class="platform-product-link {{ section.settings.link_color }} mt-lg inline-flex items-center gap-sm">
            {{ block.settings.link_text }}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          {% endif %}
          
          <!-- Paint Accent -->
          {% if block.settings.show_paint_accent and block.settings.paint_accent_image != blank %}
          <img src="{{ block.settings.paint_accent_image | image_url }}" alt="" class="platform-paint-accent" aria-hidden="true">
          {% endif %}
        </div>
        {% endif %}
      {% endfor %}
    </div>
    
  </div>
</section>

