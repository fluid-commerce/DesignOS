<!-- UGC Video Showcase Section -->
<section class="ugc-video-showcase {{ section.settings.section_padding_y_mobile }} {{ section.settings.section_padding_y_desktop }} {{ section.settings.section_border_radius }} {{ section.settings.background_color }}" 
         id="{{ section.id }}"
         {% if section.settings.background_image != blank %}
         style="background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');"
         {% endif %}>
  <div class="container {{ section.settings.container_background_color }} {{ section.settings.container_border_radius }} {{ section.settings.container_padding_y_mobile }} {{ section.settings.container_padding_y_desktop }} {{ section.settings.container_padding_x_mobile }} {{ section.settings.container_padding_x_desktop }}"
       {% if section.settings.container_background_image != blank %}
       style="background-image: url('{{ section.settings.container_background_image | image_url: width: 1200 }}');"
       {% endif %}>
    
    <!-- Section Header -->
    {% if section.settings.show_section_header %}
      <div class="section-header {{ section.settings.header_text_align }} {{ section.settings.heading_margin_bottom }}">
        {% if section.settings.section_heading != blank %}
          <div class="heading-wrapper {{ section.settings.heading_margin_bottom }}">
            <h2 class="section-heading {{ section.settings.heading_font_size }} {{ section.settings.heading_font_size_desktop }} {{ section.settings.heading_font_weight }} {{ section.settings.heading_line_height }} {{ section.settings.heading_text_color | default: 'text-white' }}">
              {{ section.settings.section_heading }}
            </h2>
          </div>
        {% endif %}
        
        {% if section.settings.section_description != blank %}
          <div class="description-wrapper">
            <p class="section-description {{ section.settings.description_font_size }} {{ section.settings.description_font_size_desktop }} {{ section.settings.description_line_height }} {{ section.settings.description_text_color | default: 'text-neutral-light' }}">
              {{ section.settings.section_description }}
            </p>
          </div>
        {% endif %}
      </div>
    {% endif %}
    
    <!-- Video Cards Container -->
    <div class="video-cards-wrapper {{ section.settings.cards_margin_top }}">
      
      <!-- Video Cards Grid/Slider -->
      <div class="video-cards-container" data-slider="{{ section.settings.enable_slider }}">
        <div class="video-cards-grid">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'video_card' %}
                <div class="video-card {{ section.settings.card_background_color }} {{ section.settings.card_border_radius }}" {{ block.fluid_attributes }}>
                  
                  <!-- Video Container -->
                  <div class="video-card-media {{ section.settings.video_border_radius }}">
                    {% if block.settings.video_file != blank %}
                      <!-- Video Thumbnail with Play Button -->
                      <div class="video-thumbnail-wrapper" onclick="playVideo(this, '{{ block.settings.video_file.url }}')">
                        <video class="video-thumbnail" preload="metadata" muted>
                          <source src="{{ block.settings.video_file.url }}" type="video/mp4">
                          <!-- Fallback image if video fails to load -->
                          <img src="{{ 'placeholder-image.png' | asset_url }}"
                               alt="Video thumbnail for {{ block.settings.video_title }}"
                               class="video-thumbnail"
                               loading="lazy">
                        </video>
                        
                        <!-- Play Button Overlay -->
                        <div class="play-button-overlay">
                          <div class="play-button {{ section.settings.play_button_background_color }} {{ section.settings.play_button_border_radius }}">
                            <svg class="play-icon {{ section.settings.play_button_icon_color }}" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                              <path d="M8 5v14l11-7z"/>
                            </svg>
                          </div>
                        </div>
                        
                      </div>
                      
                      <!-- Hidden Video Element (for inline playback) -->
                      <div class="video-player-wrapper" style="display: none;">
                        <video class="video-player" controls preload="metadata">
                          <source src="{{ block.settings.video_file.url }}" type="video/mp4">
                          Your browser does not support the video tag.
                        </video>
                      </div>
                    {% else %}
                      <!-- Placeholder when no video URL -->
                      <div class="video-placeholder">
                        <img src="{{ 'placeholder-image.png' | asset_url }}"
                             alt="Video placeholder"
                             class="video-thumbnail"
                             loading="lazy">
                        <div class="placeholder-text">
                          <p class="text-neutral">Add video URL to display content</p>
                        </div>
                      </div>
                    {% endif %}
                  </div>
                  
                  <!-- Card Content -->
                  <div class="video-card-content {{ section.settings.card_content_padding }}">
                    
                    <!-- Creator Info and Action Row -->
                    <div class="card-header">
                      
                      <!-- Creator Avatar -->
                      {% if block.settings.show_creator_avatar %}
                        <div class="creator-avatar {{ section.settings.avatar_border_radius }} {{ section.settings.avatar_size }}">
                          {% if block.settings.creator_avatar != blank %}
                            <img src="{{ block.settings.creator_avatar | image_url: width: 100 }}"
                                 alt="{{ block.settings.creator_name | default: 'Creator avatar' }}"
                                 class="avatar-image"
                                 loading="lazy">
                          {% else %}
                            <img src="{{ 'placeholder-image.png' | asset_url }}"
                                 alt="Creator avatar placeholder"
                                 class="avatar-image"
                                 loading="lazy">
                          {% endif %}
                        </div>
                      {% endif %}
                      
                      <!-- Video Title and Creator -->
                      <div class="video-info-wrapper">
                        {% if block.settings.video_title != blank %}
                          <h3 class="video-title {{ section.settings.title_font_size }} {{ section.settings.title_font_size_desktop }} {{ section.settings.title_font_weight }} {{ section.settings.title_line_height }} {{ block.settings.title_text_color | default: section.settings.card_text_color | default: 'text-black' }}">
                            {{ block.settings.video_title }}
                          </h3>
                        {% endif %}
                        
                        {% if block.settings.creator_name != blank %}
                          <p class="creator-name {{ section.settings.creator_font_size }} {{ section.settings.creator_font_size_desktop }} {{ block.settings.creator_text_color | default: section.settings.card_text_color | default: 'text-neutral' }}">
                            {{ block.settings.creator_name }}
                          </p>
                        {% endif %}
                      </div>
                      
                      
                    </div>
                    
                    <!-- Video Description (Optional) -->
                    {% if block.settings.video_description != blank %}
                      <div class="video-description-wrapper {{ section.settings.description_margin_top }}">
                        <p class="video-description {{ section.settings.card_description_font_size }} {{ section.settings.card_description_font_size_desktop }} {{ section.settings.card_description_line_height }} {{ block.settings.description_text_color | default: section.settings.card_text_color | default: 'text-neutral' }}">
                          {{ block.settings.video_description }}
                        </p>
                      </div>
                    {% endif %}
                    
                    
                  </div>
                </div>
            {% endcase %}
          {% endfor %}
        </div>
      </div>
      
      <!-- Navigation (for slider mode) -->
      {% if section.settings.enable_slider and section.settings.show_navigation %}
        <div class="slider-navigation {{ section.settings.navigation_margin_top }}">
          <button class="nav-button nav-prev {{ section.settings.nav_button_background_color }} {{ section.settings.nav_button_text_color }} {{ section.settings.nav_button_border_radius }}" 
                  aria-label="Previous video">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
          </button>
          <button class="nav-button nav-next {{ section.settings.nav_button_background_color }} {{ section.settings.nav_button_text_color }} {{ section.settings.nav_button_border_radius }}" 
                  aria-label="Next video">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
            </svg>
          </button>
        </div>
      {% endif %}
      
      
    </div>
  </div>
</section>

<!-- Embedded JavaScript for Slider Functionality -->
{% if section.settings.enable_slider %}
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const sliderContainer = document.querySelector('.ugc-video-showcase .video-cards-container[data-slider="true"]');
    if (!sliderContainer) return;
    
    const cardsGrid = sliderContainer.querySelector('.video-cards-grid');
    const cards = cardsGrid.querySelectorAll('.video-card');
    const prevButton = document.querySelector('.ugc-video-showcase .nav-prev');
    const nextButton = document.querySelector('.ugc-video-showcase .nav-next');
    
    if (!cards.length || !prevButton || !nextButton) return;
    
    let currentIndex = 0;
    let cardsPerView = 1;
    
    // Calculate cards per view based on screen size
    function updateCardsPerView() {
      const containerWidth = sliderContainer.offsetWidth;
      if (containerWidth >= 1200) {
        cardsPerView = Math.min(3, cards.length); // Show 3 videos on large screens
      } else if (containerWidth >= 900) {
        cardsPerView = Math.min(2, cards.length); // Show 2 videos on medium screens
      } else {
        cardsPerView = 1; // Show 1 video on mobile
      }
    }
    
    // Update slider position
    function updateSlider() {
      const cardWidth = 100 / cardsPerView;
      const maxIndex = Math.max(0, cards.length - cardsPerView);
      currentIndex = Math.min(currentIndex, maxIndex);
      
      const translateX = -(currentIndex * cardWidth);
      cardsGrid.style.transform = `translateX(${translateX}%)`;
      
      // Update button states
      prevButton.disabled = currentIndex === 0;
      nextButton.disabled = currentIndex >= maxIndex;
      
      prevButton.style.opacity = currentIndex === 0 ? '0.5' : '1';
      nextButton.style.opacity = currentIndex >= maxIndex ? '0.5' : '1';
    }
    
    // Navigation event listeners
    prevButton.addEventListener('click', function() {
      if (currentIndex > 0) {
        currentIndex--;
        updateSlider();
      }
    });
    
    nextButton.addEventListener('click', function() {
      const maxIndex = Math.max(0, cards.length - cardsPerView);
      if (currentIndex < maxIndex) {
        currentIndex++;
        updateSlider();
      }
    });
    
    // Handle window resize
    window.addEventListener('resize', function() {
      updateCardsPerView();
      updateSlider();
    });
    
    // Initialize
    updateCardsPerView();
    updateSlider();
    
    console.log('UGC video showcase slider initialized with', cards.length, 'videos');
  });
</script>
{% endif %}

<!-- Video Player JavaScript -->
<script>
  // Play video function
  function playVideo(thumbnailElement, videoUrl) {
    const videoCard = thumbnailElement.closest('.video-card');
    const thumbnailWrapper = videoCard.querySelector('.video-thumbnail-wrapper');
    const playerWrapper = videoCard.querySelector('.video-player-wrapper');
    const videoPlayer = videoCard.querySelector('.video-player');
    
    if (!playerWrapper || !videoPlayer) return;
    
    // Hide thumbnail and show video player
    thumbnailWrapper.style.display = 'none';
    playerWrapper.style.display = 'block';
    
    // Set video source if not already set
    if (!videoPlayer.src) {
      videoPlayer.src = videoUrl;
    }
    
    // Play the video
    videoPlayer.play().catch(function(error) {
      console.log('Video play failed:', error);
      // Fallback: show thumbnail again
      thumbnailWrapper.style.display = 'block';
      playerWrapper.style.display = 'none';
    });
    
    // Handle video end - show thumbnail again
    videoPlayer.addEventListener('ended', function() {
      thumbnailWrapper.style.display = 'block';
      playerWrapper.style.display = 'none';
    });
    
    // Optional: Log video play for analytics
    console.log('Video played:', videoUrl);
  }
  
</script>

