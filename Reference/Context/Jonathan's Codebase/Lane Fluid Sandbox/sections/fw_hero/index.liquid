<link rel="stylesheet" href="{{ 'fw_hero/styles.css' | asset_url }}">

<section class="fw-hero-section {{ section.settings.background_color }} {{ section.settings.section_padding_y_mobile }} {{ section.settings.section_padding_y_desktop }} {{ section.settings.section_border_radius }}"
  {% if section.settings.background_image != blank %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>

  {% if section.settings.show_ghost_text and section.settings.ghost_text_content != blank %}
  <div class="fw-hero-ghost-text font-primary" aria-hidden="true">
    {{ section.settings.ghost_text_content }}
  </div>
  {% endif %}

  {% if section.settings.show_marquee and section.settings.marquee_text != blank %}
  <div class="fw-hero-marquee" aria-hidden="true">
    <div class="fw-hero-marquee-track {{ section.settings.marquee_font_family }} {{ section.settings.marquee_font_size }} {{ section.settings.marquee_font_size_desktop }} {{ section.settings.marquee_font_weight }} {{ section.settings.marquee_color }}">
      <span>{{ section.settings.marquee_text }} &bull; {{ section.settings.marquee_text }} &bull; {{ section.settings.marquee_text }} &bull; {{ section.settings.marquee_text }} &bull; </span>
      <span>{{ section.settings.marquee_text }} &bull; {{ section.settings.marquee_text }} &bull; {{ section.settings.marquee_text }} &bull; {{ section.settings.marquee_text }} &bull; </span>
    </div>
  </div>
  {% endif %}

  <div class="fw-hero-container {{ section.settings.container_background_color }} {{ section.settings.container_border_radius }} {{ section.settings.container_padding_y_mobile }} {{ section.settings.container_padding_y_desktop }} {{ section.settings.container_padding_x_mobile }} {{ section.settings.container_padding_x_desktop }}"
    {% if section.settings.container_background_image != blank %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>

    <div class="fw-hero-content">

      {% if section.settings.eyebrow != blank %}
      <p class="fw-hero-eyebrow {{ section.settings.eyebrow_font_family }} {{ section.settings.eyebrow_font_size }} {{ section.settings.eyebrow_font_size_desktop }} {{ section.settings.eyebrow_font_weight }} {{ section.settings.eyebrow_color }}">
        {{ section.settings.eyebrow }}
      </p>
      {% endif %}

      {% if section.settings.headline != blank %}
      <div class="fw-hero-headline-wrapper">
        <h1 class="fw-hero-headline {{ section.settings.headline_font_family }} {{ section.settings.headline_font_size }} {{ section.settings.headline_font_size_desktop }} {{ section.settings.headline_font_weight }} {{ section.settings.headline_color }}">
          {{ section.settings.headline }}
        </h1>
        {% if section.settings.show_paint_stroke and section.settings.paint_stroke_image != blank %}
        <img src="{{ section.settings.paint_stroke_image | image_url }}" alt="" class="fw-hero-paint-stroke" aria-hidden="true">
        {% endif %}
      </div>
      {% endif %}

      {% if section.settings.description != blank %}
      <p class="fw-hero-description {{ section.settings.description_font_family }} {{ section.settings.description_font_size }} {{ section.settings.description_font_size_desktop }} {{ section.settings.description_font_weight }} {{ section.settings.description_color }}">
        {{ section.settings.description }}
      </p>
      {% endif %}

      <div class="fw-hero-buttons">
        {% if section.settings.show_button_one %}
        <a href="{{ section.settings.button_one_url | default: '#' }}"
           class="btn btn-{{ section.settings.button_one_style | default: 'filled' }}-{{ section.settings.button_one_color | default: 'white' }} {{ section.settings.button_one_size | default: 'btn-md' }} {{ section.settings.button_one_font_weight | default: 'font-medium' }}">
          {{ section.settings.button_one_text | default: 'Book a Demo' }}
        </a>
        {% endif %}

        {% if section.settings.show_button_two %}
        <a href="{{ section.settings.button_two_url | default: '#' }}"
           class="btn btn-{{ section.settings.button_two_style | default: 'outline' }}-{{ section.settings.button_two_color | default: 'white' }} {{ section.settings.button_two_size | default: 'btn-md' }} {{ section.settings.button_two_font_weight | default: 'font-medium' }}">
          {{ section.settings.button_two_text | default: 'Watch 2-min Overview ▶' }}
        </a>
        {% endif %}
      </div>

      {% if section.settings.small_text != blank %}
      <p class="fw-hero-small-text {{ section.settings.small_text_font_family }} {{ section.settings.small_text_font_size }} {{ section.settings.small_text_font_size_desktop }} {{ section.settings.small_text_font_weight }} {{ section.settings.small_text_color }}">
        {{ section.settings.small_text }}
      </p>
      {% endif %}

    </div>
  </div>

  {% if section.settings.decoration_image_1 != blank %}
  <img src="{{ section.settings.decoration_image_1 | image_url }}" alt="" class="fw-hero-decoration fw-hero-decoration-1" aria-hidden="true">
  {% endif %}
  {% if section.settings.decoration_image_2 != blank %}
  <img src="{{ section.settings.decoration_image_2 | image_url }}" alt="" class="fw-hero-decoration fw-hero-decoration-2" aria-hidden="true">
  {% endif %}

  {% if section.settings.show_scroll_indicator %}
  <div class="fw-hero-scroll-indicator" aria-hidden="true">
    <span class="fw-hero-scroll-indicator-line"></span>
  </div>
  {% endif %}

</section>

