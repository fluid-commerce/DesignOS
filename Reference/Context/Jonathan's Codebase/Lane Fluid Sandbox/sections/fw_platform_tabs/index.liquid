<link rel="stylesheet" href="{{ 'fw_platform_tabs/styles.css' | asset_url }}">

<section class="fw-platform-tabs-section {{ section.settings.background_color }} {{ section.settings.section_padding_y_mobile }} {{ section.settings.section_padding_y_desktop }} {{ section.settings.section_border_radius }}"
  {% if section.settings.background_image != blank %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>

  <div class="fw-platform-tabs-container {{ section.settings.container_background_color }} {{ section.settings.container_border_radius }} {{ section.settings.container_padding_y_mobile }} {{ section.settings.container_padding_y_desktop }} {{ section.settings.container_padding_x_mobile }} {{ section.settings.container_padding_x_desktop }}"
    {% if section.settings.container_background_image != blank %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>

    {% if section.settings.eyebrow != blank or section.settings.headline != blank %}
    <div class="fw-platform-tabs-header">

      {% if section.settings.eyebrow != blank %}
      <p class="fw-platform-tabs-eyebrow {{ section.settings.eyebrow_font_family }} {{ section.settings.eyebrow_font_size }} {{ section.settings.eyebrow_font_size_desktop }} {{ section.settings.eyebrow_font_weight }} {{ section.settings.eyebrow_color }}">
        {{ section.settings.eyebrow }}
      </p>
      {% endif %}

      {% if section.settings.headline != blank %}
      <h2 class="fw-platform-tabs-headline {{ section.settings.headline_font_family }} {{ section.settings.headline_font_size }} {{ section.settings.headline_font_size_desktop }} {{ section.settings.headline_font_weight }} {{ section.settings.headline_color }}">
        {{ section.settings.headline }}
      </h2>
      {% endif %}

    </div>
    {% endif %}

    {% if section.blocks.size > 0 %}
    <div class="fw-tabs-row" role="tablist">
      {% for block in section.blocks %}
      <button class="fw-tab-item{% if forloop.first %} active{% endif %}"
              role="tab"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              aria-controls="fw-tab-panel-{{ forloop.index }}"
              id="fw-tab-{{ forloop.index }}">
        {{ block.settings.tab_label | default: 'Tab' }}
      </button>
      {% endfor %}
    </div>

    {% for block in section.blocks %}
    <div class="fw-tab-content{% if forloop.first %} active{% endif %}"
         role="tabpanel"
         id="fw-tab-panel-{{ forloop.index }}"
         aria-labelledby="fw-tab-{{ forloop.index }}"
         {{ block.fluid_attributes }}>

      <div class="fw-tab-text">

        {% if block.settings.tab_title != blank %}
        <h3 class="fw-tab-title {{ block.settings.tab_title_font_family }} {{ block.settings.tab_title_font_size }} {{ block.settings.tab_title_font_size_desktop }} {{ block.settings.tab_title_font_weight }} {{ block.settings.tab_title_color }}">
          {{ block.settings.tab_title }}
        </h3>
        {% endif %}

        {% if block.settings.tab_body != blank %}
        <div class="fw-tab-body {{ block.settings.tab_body_font_family }} {{ block.settings.tab_body_font_size }} {{ block.settings.tab_body_font_size_desktop }} {{ block.settings.tab_body_font_weight }} {{ block.settings.tab_body_color }}">
          {{ block.settings.tab_body }}
        </div>
        {% endif %}

        {% if block.settings.tab_button_show %}
        <a href="{{ block.settings.tab_button_url | default: '#' }}"
           class="fw-tab-btn btn btn-{{ block.settings.tab_button_style | default: 'ghost' }}-{{ block.settings.tab_button_color | default: 'primary' }} {{ block.settings.tab_button_size | default: 'btn-md' }}">
          {{ block.settings.tab_button_text | default: 'Learn More' }}
        </a>
        {% endif %}

      </div>

      <div class="fw-tab-media">
        <div class="fw-tab-media-inner">
          {% if block.settings.tab_image != blank %}
          <img src="{{ block.settings.tab_image | image_url }}"
               alt="{{ block.settings.tab_image_alt | default: '' }}"
               loading="lazy">
          {% endif %}
          <div class="fw-tab-video-placeholder">
            <span class="fw-tab-play-btn" aria-label="Play video">
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polygon points="6,3 20,12 6,21"/></svg>
            </span>
          </div>
        </div>
      </div>

    </div>
    {% endfor %}
    {% endif %}

  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var section = document.querySelector('.fw-platform-tabs-section');
  if (!section) return;
  var tabs = section.querySelectorAll('.fw-tab-item');
  var contents = section.querySelectorAll('.fw-tab-content');
  tabs.forEach(function(tab, i) {
    tab.addEventListener('click', function() {
      tabs.forEach(function(t) {
        t.classList.remove('active');
        t.setAttribute('aria-selected', 'false');
      });
      contents.forEach(function(c) { c.classList.remove('active'); });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');
      if (contents[i]) contents[i].classList.add('active');
    });
  });
});
</script>

