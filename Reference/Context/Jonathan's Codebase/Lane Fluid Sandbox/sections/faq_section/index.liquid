<!-- FAQ Section -->
<section class="faq-section {{ section.settings.background_color | default: 'bg-neutral-light' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image }}"{% endif %}>
  <div class="container">
    <div class="inner-container {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_padding_y_mobile | default: 'py-xl' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-lg' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }} {{ section.settings.container_border_radius | default: 'rounded-none' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image }}"{% endif %}>
      
      <div class="max-w-4xl mx-auto">
        
        <!-- Main Content -->
        <div class="faq-content space-y-3xl">
          
          <!-- Main Heading -->
          {% if section.settings.show_heading %}
          <div class="heading-wrapper text-center mb-2xl">
            <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-4xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-6xl' }} {{ section.settings.heading_font_weight | default: 'font-black' }} {{ section.settings.heading_color | default: 'text-black' }} leading-tight">
              {{ section.settings.heading | default: "Questions We Get About Visual Builder" }}
            </h2>
          </div>
          {% endif %}
          
          <!-- Description -->
          {% if section.settings.show_description %}
          <div class="description-wrapper text-center mb-2xl">
            <p class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-lg' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-neutral-dark' }} leading-relaxed max-w-3xl mx-auto">
              {{ section.settings.description | default: "Find answers to the most common questions about our platform and services." }}
            </p>
          </div>
          {% endif %}
          
          <!-- FAQ Items (Blocks) -->
          {% if section.blocks.size > 0 %}
          <div class="faq-wrapper">
            <div class="faq-container" style="width: 100%; max-width: 48rem; margin: 0 auto;">
              <div class="faq-list space-y-xl">
                {% for block in section.blocks %}
                {% case block.type %}
                  {% when 'faq_item' %}
                    <div class="faq-item {{ section.settings.item_background_color | default: 'bg-white' }} {{ section.settings.item_border_radius | default: 'rounded-lg' }}" {{ block.fluid_attributes }}>
                      
                      <!-- Question (Always Visible) -->
                      <button class="faq-question w-full text-left p-lg lg:p-xl flex justify-between items-center transition-colors duration-200" 
                              onclick="toggleFAQ(this)"
                              aria-expanded="false">
                        <span class="{{ section.settings.question_font_family | default: 'font-primary' }} {{ section.settings.question_font_size | default: 'text-xl' }} {{ section.settings.question_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.question_font_weight | default: 'font-bold' }} {{ section.settings.question_color | default: 'text-black' }}">
                          {{ block.settings.question | default: "What is your question?" }}
                        </span>
                        
                        <!-- Toggle Icon -->
                        <span class="faq-icon {{ section.settings.icon_color | default: 'text-neutral' }} transition-transform duration-300">
                          <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                          </svg>
                        </span>
                      </button>
                      
                      <!-- Answer (Collapsible) -->
                      <div class="faq-answer overflow-hidden transition-all duration-300 ease-in-out max-h-0">
                        <div class="faq-answer-content px-lg lg:px-xl pb-lg lg:pb-xl pt-0">
                          <div class="{{ section.settings.answer_font_family | default: 'font-body' }} {{ section.settings.answer_font_size | default: 'text-base' }} {{ section.settings.answer_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.answer_font_weight | default: 'font-normal' }} {{ section.settings.answer_color | default: 'text-neutral-dark' }} leading-relaxed">
                            {{ block.settings.answer | default: "Add your answer here. You can include multiple paragraphs and detailed explanations." }}
                          </div>
                        </div>
                      </div>
                      
                    </div>
                {% endcase %}
                {% endfor %}
              </div>
            </div>
          </div>
          {% endif %}
          
        </div>
        
      </div>
      
    </div>
  </div>
</section>

<script>
// FAQ Toggle Functionality with Smooth Animation
function toggleFAQ(button) {
  const faqItem = button.closest('.faq-item');
  const answer = faqItem.querySelector('.faq-answer');
  const icon = button.querySelector('.faq-icon');
  const isExpanded = button.getAttribute('aria-expanded') === 'true';
  
  // Close all other FAQ items
  const allFAQs = document.querySelectorAll('.faq-item');
  allFAQs.forEach(item => {
    if (item !== faqItem) {
      const otherButton = item.querySelector('.faq-question');
      const otherAnswer = item.querySelector('.faq-answer');
      const otherIcon = item.querySelector('.faq-icon');
      
      otherButton.setAttribute('aria-expanded', 'false');
      otherAnswer.style.maxHeight = '0';
      otherIcon.style.transform = 'rotate(0deg)';
    }
  });
  
  // Toggle current FAQ
  if (isExpanded) {
    // Close current FAQ
    button.setAttribute('aria-expanded', 'false');
    answer.style.maxHeight = '0';
    icon.style.transform = 'rotate(0deg)';
  } else {
    // Open current FAQ
    button.setAttribute('aria-expanded', 'true');
    answer.style.maxHeight = answer.scrollHeight + 'px';
    icon.style.transform = 'rotate(180deg)';
  }
}

// Initialize FAQ on page load
document.addEventListener('DOMContentLoaded', function() {
  // Ensure all FAQs start closed
  const allAnswers = document.querySelectorAll('.faq-answer');
  allAnswers.forEach(answer => {
    answer.style.maxHeight = '0';
  });
});
</script>

