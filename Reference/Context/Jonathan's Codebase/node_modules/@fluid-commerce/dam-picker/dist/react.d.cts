import { DamPickerConfig, DamPickerCallbacks, SelectedAsset, DamPickerError, DamPickerFilters } from './index.cjs';
export { AssetMetadata, AssetType, DamPicker, DamPickerErrorCode } from './index.cjs';

/**
 * React hook for using the DamPicker
 *
 * @example
 * ```tsx
 * function ImageSelector() {
 *   const { open } = useDamPicker({ token: 'your-token' });
 *
 *   return (
 *     <button onClick={() => open({
 *       onSelect: (asset) => console.log(asset.url)
 *     })}>
 *       Choose Image
 *     </button>
 *   );
 * }
 * ```
 */
declare function useDamPicker(config: DamPickerConfig): {
    open: (callbacks: Partial<DamPickerCallbacks> & {
        onSelect: (asset: SelectedAsset) => void;
    }) => void;
    close: () => void;
    isOpen: boolean;
};

interface DamPickerModalProps {
    /** Whether the picker modal is open */
    isOpen: boolean;
    /** Fluid API token */
    token: string;
    /** Called when user selects an asset */
    onSelect: (asset: SelectedAsset) => void;
    /** Called when user cancels/closes the picker */
    onCancel?: () => void;
    /** Called when an error occurs */
    onError?: (error: DamPickerError) => void;
    /** Called when the picker is ready */
    onReady?: () => void;
    /** Override the picker app URL (for local development) */
    baseUrl?: string;
    /** Z-index for the modal overlay */
    zIndex?: number;
    /** Filter options */
    filters?: DamPickerFilters;
}
/**
 * React component for the DamPicker modal (controlled mode)
 *
 * @example
 * ```tsx
 * function ImageSelector() {
 *   const [isOpen, setIsOpen] = useState(false);
 *
 *   return (
 *     <>
 *       <button onClick={() => setIsOpen(true)}>Choose Image</button>
 *       <DamPickerModal
 *         isOpen={isOpen}
 *         token="your-token"
 *         onSelect={(asset) => {
 *           console.log(asset.url);
 *           setIsOpen(false);
 *         }}
 *         onCancel={() => setIsOpen(false)}
 *       />
 *     </>
 *   );
 * }
 * ```
 */
declare function DamPickerModal({ isOpen, token, onSelect, onCancel, onError, onReady, baseUrl, zIndex, filters, }: DamPickerModalProps): null;

export { DamPickerCallbacks, DamPickerConfig, DamPickerError, DamPickerFilters, DamPickerModal, type DamPickerModalProps, SelectedAsset, useDamPicker };
