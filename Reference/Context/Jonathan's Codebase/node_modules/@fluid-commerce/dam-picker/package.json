{
  "name": "@fluid-commerce/dam-picker",
  "version": "0.1.0",
  "description": "Embeddable DAM file picker for Fluid Commerce applications",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist .turbo"
  },
  "keywords": [
    "fluid",
    "dam",
    "file-picker",
    "asset-management",
    "digital-assets"
  ],
  "author": "Fluid Commerce",
  "license": "MIT",
  "homepage": "https://github.com/fluid-commerce/fluid-dam-picker",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fluid-commerce/fluid-dam-picker.git",
    "directory": "packages/sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
