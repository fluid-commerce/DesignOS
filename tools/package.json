{
  "name": "fluid-tools",
  "version": "0.1.0",
  "private": true,
  "description": "CLI tools for Fluid DesignOS — validators, importers, scaffolders. Tests use node:test.",
  "scripts": {
    "test": "node -e \"const{globSync}=require('node:fs'),{spawnSync}=require('node:child_process');const files=globSync('__tests__/**/*.test.cjs');const r=spawnSync(process.execPath,['--test',...files],{stdio:'inherit'});process.exit(r.status??1);\""
  },
  "dependencies": {
    "parse5": "^8.0.1",
    "picocolors": "^1.1.1",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  }
}
